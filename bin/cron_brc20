#!/usr/bin/env bash
set -e

# Kill switch (par défaut ON)
if [[ "${BRC20_ENABLED:-1}" != "1" ]]; then
  echo "[cron_brc20] disabled (BRC20_ENABLED=${BRC20_ENABLED})"
  exit 0
fi

cd /home/victor/bitcoin_monitor

export RBENV_ROOT="$HOME/.rbenv"
export PATH="$RBENV_ROOT/bin:$PATH"
eval "$(rbenv init - bash)"

bundle exec rails brc20:scan_new_blocks
