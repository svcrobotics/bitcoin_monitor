<%
  direction_label = {
    "bullish" => "haussier",
    "bearish" => "baissier",
    "neutral" => "neutre"
  }

  direction_class = {
    "bullish" => "text-emerald-300",
    "bearish" => "text-rose-300",
    "neutral" => "text-slate-300"
  }

  indicator_rows = [
    {
      name: "FED",
      description: "Taux directeurs américains",
      signal: @fed_signal,
      success_rate: @fed_success_rate,
      last_predictions: @fed_predictions,
      source: "Macro",
      note: "Signal lent, utile pour comprendre le contexte monétaire."
    },
    {
      name: "Dollar",
      description: "Indice du dollar américain",
      signal: @dxy_signal,
      success_rate: @dxy_success_rate,
      last_predictions: @dxy_predictions,
      source: "Macro",
      note: "Quand le dollar monte, Bitcoin est souvent sous pression."
    },
    {
      name: "Flux exchanges",
      description: "Entrées / sorties BTC des exchanges",
      signal: @exchange_signal,
      success_rate: @exchange_success_rate,
      last_predictions: @exchange_predictions,
      source: "On-chain",
      note: "Encore bruité seul, mais utile pour mesurer la pression vendeuse."
    }
  ]

  all_predictions =
    (@fed_predictions + @dxy_predictions + @exchange_predictions)
      .sort_by(&:predicted_on)
      .reverse
      .first(18)
%>

<div class="min-h-screen bg-slate-950 text-slate-100">
  <div class="mx-auto max-w-7xl px-6 py-10">

    <div>
      <div class="inline-flex rounded-full border border-cyan-500/20 bg-cyan-500/10 px-3 py-1 text-xs font-medium text-cyan-300">
        Intelligence de marché
      </div>

      <h1 class="mt-4 text-4xl font-semibold text-white">
        Les signaux macro et on-chain influencent-ils Bitcoin ?
      </h1>

      <p class="mt-4 max-w-4xl text-sm leading-6 text-slate-400">
        Tansa teste une idée simple : certains indicateurs comme la FED, le dollar ou les flux vers les exchanges
        peuvent-ils aider à comprendre si Bitcoin a plus de chances de monter ou de baisser ?
        Chaque signal est enregistré, puis vérifié avec le prix réel du BTC.
      </p>
    </div>

    <div class="mt-8 rounded-3xl border border-slate-800 bg-slate-900/60 p-8">
      <div class="text-xs uppercase tracking-[0.2em] text-slate-500">
        Lecture actuelle
      </div>

      <h2 class="mt-3 text-2xl font-semibold text-white">
        Biais actuel : prudent
      </h2>

      <p class="mt-4 max-w-4xl text-sm leading-6 text-slate-400">
        La FED est neutre, le dollar se renforce et les flux exchanges indiquent une pression vendeuse potentielle.
        Le signal global reste donc prudent pour Bitcoin. Cette lecture n’est pas une prédiction certaine :
        elle sert uniquement d’aide à la décision.
      </p>
    </div>

    <div class="mt-8 rounded-3xl border border-slate-800 bg-slate-900/60 overflow-hidden">
      <div class="border-b border-slate-800 px-8 py-5">
        <div class="text-xs uppercase tracking-[0.2em] text-slate-500">
          Tableau de bord des indicateurs
        </div>

        <h2 class="mt-2 text-2xl font-semibold text-white">
          Quels signaux semblent les plus utiles ?
        </h2>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full">
          <thead class="border-b border-slate-800 bg-slate-950/40">
            <tr>
              <th class="px-8 py-4 text-left text-xs uppercase tracking-[0.2em] text-slate-500">Indicateur</th>
              <th class="px-8 py-4 text-left text-xs uppercase tracking-[0.2em] text-slate-500">Signal actuel</th>
              <th class="px-8 py-4 text-left text-xs uppercase tracking-[0.2em] text-slate-500">Dernière valeur</th>
              <th class="px-8 py-4 text-left text-xs uppercase tracking-[0.2em] text-slate-500">Réussite</th>
              <th class="px-8 py-4 text-left text-xs uppercase tracking-[0.2em] text-slate-500">Lecture</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-slate-800">
            <% indicator_rows.each do |row| %>
              <% signal = row[:signal] %>
              <% dir = signal&.direction %>

              <tr class="hover:bg-slate-800/40">
                <td class="px-8 py-5">
                  <div class="text-sm font-semibold text-white"><%= row[:name] %></div>
                  <div class="mt-1 text-xs text-slate-500"><%= row[:description] %></div>
                </td>

                <td class="px-8 py-5">
                  <div class="text-sm font-semibold uppercase <%= direction_class[dir] || 'text-slate-300' %>">
                    <%= direction_label[dir] || "—" %>
                  </div>

                  <div class="mt-1 text-xs text-slate-500">
                    observé le <%= signal&.observed_on || "—" %>
                  </div>
                </td>

                <td class="px-8 py-5 text-sm text-slate-300">
                  <% if row[:name] == "Flux exchanges" %>
                    netflow :
                    <%= number_with_delimiter(signal&.metadata&.dig("netflow_btc").to_f.round(2), delimiter: " ") if signal.present? %>
                    BTC
                  <% else %>
                    <%= signal&.metadata&.dig("latest_value") || "—" %>
                  <% end %>
                </td>

                <td class="px-8 py-5">
                  <div class="text-2xl font-semibold text-white">
                    <%= row[:success_rate] %>%
                  </div>

                  <div class="mt-1 text-xs text-slate-500">
                    backtest actuel
                  </div>
                </td>

                <td class="px-8 py-5 max-w-sm text-sm leading-6 text-slate-400">
                  <%= row[:note] %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-8 grid gap-6 md:grid-cols-3">
      <div class="rounded-3xl border border-slate-800 bg-slate-900/60 p-6">
        <div class="text-lg font-semibold text-white">1. On observe</div>
        <p class="mt-3 text-sm leading-6 text-slate-400">
          Tansa récupère les données FED, dollar et flux exchanges.
        </p>
      </div>

      <div class="rounded-3xl border border-slate-800 bg-slate-900/60 p-6">
        <div class="text-lg font-semibold text-white">2. On teste</div>
        <p class="mt-3 text-sm leading-6 text-slate-400">
          Chaque indicateur produit un biais simple : haussier, baissier ou neutre.
        </p>
      </div>

      <div class="rounded-3xl border border-slate-800 bg-slate-900/60 p-6">
        <div class="text-lg font-semibold text-white">3. On vérifie</div>
        <p class="mt-3 text-sm leading-6 text-slate-400">
          Le système compare ensuite la prédiction avec le mouvement réel du BTC.
        </p>
      </div>
    </div>

    <div class="mt-8 rounded-3xl border border-slate-800 bg-slate-900/60 overflow-hidden">

      <div class="border-b border-slate-800 px-8 py-5">
        <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">

          <div>
            <div class="text-xs uppercase tracking-[0.2em] text-slate-500">
              Historique vérifié
            </div>

            <h2 class="mt-2 text-2xl font-semibold text-white">
              Historique des prédictions
            </h2>

            <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-400">
              Chaque signal est enregistré puis comparé à l’évolution réelle du prix du Bitcoin.
              Le système mesure ensuite si la lecture était correcte ou non.
            </p>
          </div>

          <%
            filters = [
              ["all", "Tous"],
              ["fed", "FED"],
              ["dollar", "Dollar"],
              ["exchange", "Flux exchanges"]
            ]
          %>

          <div class="flex flex-wrap gap-2">
            <% filters.each do |key, label| %>
              <% active = @selected_indicator == key %>

              <%= link_to label,
                market_signals_path(indicator: key),
                class: [
                  "rounded-full border px-4 py-2 text-xs font-semibold transition",
                  active ?
                    "border-cyan-500/30 bg-cyan-500/10 text-cyan-300" :
                    "border-slate-700 bg-slate-950 text-slate-400 hover:text-white"
                ].join(" ")
              %>
            <% end %>
          </div>

        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full">

          <thead class="border-b border-slate-800 bg-slate-950/40">
            <tr>
              <th class="px-8 py-4 text-left text-xs uppercase tracking-[0.2em] text-slate-500">
                Indicateur
              </th>

              <th class="px-8 py-4 text-left text-xs uppercase tracking-[0.2em] text-slate-500">
                Période
              </th>

              <th class="px-8 py-4 text-left text-xs uppercase tracking-[0.2em] text-slate-500">
                Signal
              </th>

              <th class="px-8 py-4 text-left text-xs uppercase tracking-[0.2em] text-slate-500">
                BTC
              </th>

              <th class="px-8 py-4 text-left text-xs uppercase tracking-[0.2em] text-slate-500">
                Résultat
              </th>
            </tr>
          </thead>

          <tbody class="divide-y divide-slate-800">

            <% @history_predictions.each do |prediction| %>

              <% result_ok = prediction.result == "success" %>
              <% dir = prediction.direction %>

              <% label =
                case prediction.indicator
                when "FEDFUNDS"
                  "FED"
                when "DTWEXBGS"
                  "Dollar"
                when "EXCHANGE_CORE_FLOW"
                  "Flux exchanges"
                else
                  prediction.indicator
                end
              %>

              <% indicator_badge =
                case prediction.indicator
                when "FEDFUNDS"
                  "border-slate-700 bg-slate-950 text-slate-300"
                when "DTWEXBGS"
                  "border-cyan-500/20 bg-cyan-500/10 text-cyan-300"
                when "EXCHANGE_CORE_FLOW"
                  "border-orange-500/20 bg-orange-500/10 text-orange-300"
                else
                  "border-slate-700 bg-slate-950 text-slate-300"
                end
              %>

              <tr class="transition hover:bg-slate-800/40">

                <td class="px-8 py-5">
                  <div class="flex items-center gap-3">
                    <span class="rounded-full border px-3 py-1 text-xs font-semibold uppercase <%= indicator_badge %>">
                      <%= label %>
                    </span>
                  </div>
                </td>

                <td class="px-8 py-5 text-sm text-slate-300">
                  <div>
                    <%= prediction.predicted_on %>
                  </div>

                  <div class="mt-1 text-xs text-slate-500">
                    vérifié le <%= prediction.target_on %>
                  </div>
                </td>

                <td class="px-8 py-5">
                  <div class="text-sm font-semibold uppercase <%= direction_class[dir] || 'text-slate-300' %>">
                    <%= direction_label[dir] || "—" %>
                  </div>

                  <% if prediction.confidence.present? %>
                    <div class="mt-1 text-xs text-slate-500">
                      confiance <%= prediction.confidence %>%
                    </div>
                  <% end %>
                </td>

                <td class="px-8 py-5">
                  <div class="text-sm font-semibold <%= prediction.performance_pct.to_f >= 0 ? 'text-emerald-300' : 'text-rose-300' %>">
                    <%= prediction.performance_pct.to_f.round(2) %>%
                  </div>

                  <div class="mt-1 text-xs text-slate-500">
                    évolution BTC
                  </div>
                </td>

                <td class="px-8 py-5">
                  <span class="rounded-full border px-3 py-1 text-xs font-semibold uppercase <%= result_ok ? 'border-emerald-500/20 bg-emerald-500/10 text-emerald-300' : 'border-rose-500/20 bg-rose-500/10 text-rose-300' %>">
                    <%= result_ok ? "réussi" : "échoué" %>
                  </span>
                </td>

              </tr>

            <% end %>

          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>