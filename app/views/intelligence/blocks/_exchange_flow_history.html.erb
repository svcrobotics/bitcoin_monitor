<% history = Array(local_assigns.fetch(:history, [])) %>

<% if history.any? %>
  <section class="rounded-2xl border border-white/10 bg-white/[0.03] p-5">
    <div class="mb-4">
      <div class="text-xs font-semibold uppercase tracking-[0.18em] text-cyan-300">
        Preuve · Historique
      </div>

      <h3 class="mt-1 text-lg font-semibold text-white">
        Netflow exchange-like récent
      </h3>

      <p class="mt-1 text-xs text-slate-500">
        Les jours récents permettent de vérifier si le signal est isolé ou persistant.
      </p>
    </div>

    <div class="space-y-3">
      <% history.each do |row| %>
        <% netflow = row[:netflow_btc].to_f %>
        <% positive = netflow.positive? %>
        <% negative = netflow.negative? %>

        <div class="rounded-xl border border-white/10 bg-black/20 p-4">
          <div class="flex items-center justify-between gap-4">
            <div>
              <div class="text-sm font-medium text-slate-200">
                <%= l(row[:day], format: :long) rescue row[:day] %>
              </div>

              <div class="mt-1 text-xs text-slate-500">
                <%= number_with_delimiter(row[:events_count].to_i) %> événements
              </div>
            </div>

            <div class="text-right">
              <div class="font-mono text-sm <%= positive ? "text-amber-300" : negative ? "text-emerald-300" : "text-slate-300" %>">
                <%= positive ? "▲" : negative ? "▼" : "≈" %>
                <%= number_with_precision(netflow.abs, precision: 2, delimiter: " ") %> BTC
              </div>

              <div class="mt-1 text-xs text-slate-500">
                <%= row[:signal].to_s.humanize %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </section>
<% end %>
