<% layer1 ||= {} %>

<div class="rounded-2xl border border-white/10 bg-gray-950/70 p-5">
  <div class="text-xs font-semibold uppercase tracking-wide text-gray-500">
    Layer 1
  </div>

  <h3 class="mt-1 text-lg font-semibold text-gray-100">
    Synchronisation blockchain
  </h3>

  <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-3">
    <div class="rounded-xl border border-white/10 bg-black/20 p-4">
      <div class="text-xs text-gray-500">Best height</div>
      <div class="mt-1 font-mono text-lg text-gray-100">
        <%= number_with_delimiter(layer1[:best_height].to_i) %>
      </div>
    </div>

    <div class="rounded-xl border border-white/10 bg-black/20 p-4">
      <div class="text-xs text-gray-500">Processed</div>
      <div class="mt-1 font-mono text-lg text-gray-100">
        <%= number_with_delimiter(layer1[:last_processed_height].to_i) %>
      </div>
    </div>

    <div class="rounded-xl border border-white/10 bg-black/20 p-4">
      <div class="text-xs text-gray-500">Lag</div>
      <div class="mt-1 font-mono text-lg <%= layer1[:lag].to_i.positive? ? "text-amber-300" : "text-emerald-300" %>">
        <%= layer1[:lag].to_i %> blocs
      </div>
    </div>
  </div>
</div>