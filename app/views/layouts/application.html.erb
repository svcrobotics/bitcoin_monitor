<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Tansa" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen overflow-hidden bg-[#050711] text-slate-100 antialiased">
    <% if notice.present? || alert.present? %>
      <div class="fixed left-1/2 top-4 z-50 w-[calc(100%-2rem)] max-w-xl -translate-x-1/2 space-y-2">
        <% if notice.present? %>
          <div class="rounded-xl border border-violet-400/30 bg-[#080a16]/90 px-4 py-2 text-sm text-violet-100 shadow-2xl backdrop-blur-xl">
            <%= notice %>
          </div>
        <% end %>

        <% if alert.present? %>
          <div class="rounded-xl border border-rose-400/30 bg-[#080a16]/90 px-4 py-2 text-sm text-rose-100 shadow-2xl backdrop-blur-xl">
            <%= alert %>
          </div>
        <% end %>
      </div>
    <% end %>

    <main class="h-screen overflow-y-auto">
      <%= yield %>
    </main>
  </body>
</html>
