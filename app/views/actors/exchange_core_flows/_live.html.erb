<%= turbo_frame_tag "exchange_core_today_live" do %>
  <% today = today || {} %>

  <% net = today[:netflow_btc].to_d %>
  <% inflow = today[:inflow_btc].to_d %>
  <% outflow = today[:outflow_btc].to_d %>

  <% dir =
    if net.positive?
      :up
    elsif net.negative?
      :down
    else
      :flat
    end
  %>

  <% net_icon = dir == :up ? "▲" : dir == :down ? "▼" : "≈" %>
  <% net_cls = dir == :up ? "text-amber-300" : dir == :down ? "text-emerald-300" : "text-gray-300" %>

  <section class="mb-6 rounded-2xl border border-gray-800 bg-gray-950/40 p-6 sm:p-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <div class="flex flex-wrap items-center gap-3">
          <h1 class="text-xl font-semibold text-gray-100 sm:text-2xl">
            Exchange Core Flow
          </h1>

          <!-- Live badge -->
          <div class="hidden md:flex items-center gap-1 rounded-md border border-cyan-500/20 bg-cyan-500/10 px-1.5 py-0.5">
            <span class="h-1.5 w-1.5 rounded-full bg-cyan-400 animate-pulse"></span>

            <span class="text-[10px] font-semibold uppercase tracking-[0.14em] text-cyan-300">
              Live
            </span>
          </div>
        </div>

        <p class="mt-2 max-w-3xl text-sm leading-relaxed text-gray-400">
          Flux exchange-like du jour en cours, calculés uniquement depuis les acteurs
          <code>exchange_like</code> validés par Actor Profiles.
          Source événementielle :
          <code>actor_profile_exchange_like</code>.
          Ce bloc se met à jour automatiquement sans recharger la page.
        </p>
      </div>

      <div class="text-xs text-gray-500">
        Mis à jour :
        <span class="font-mono text-gray-300">
          <%= today[:updated_at] ? l(today[:updated_at], format: "%H:%M:%S") : "—" %>
        </span>
      </div>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-4">
      <div class="rounded-xl border border-gray-800 bg-black/20 p-4">
        <div class="text-xs text-gray-500">Inflow aujourd’hui</div>
        <div class="mt-2 text-xl font-semibold text-gray-100">
          <span class="font-mono"><%= number_with_precision(inflow, precision: 2, delimiter: " ") %></span>
          <span class="text-gray-400">BTC</span>
        </div>
      </div>

      <div class="rounded-xl border border-gray-800 bg-black/20 p-4">
        <div class="text-xs text-gray-500">Outflow aujourd’hui</div>
        <div class="mt-2 text-xl font-semibold text-gray-100">
          <span class="font-mono"><%= number_with_precision(outflow, precision: 2, delimiter: " ") %></span>
          <span class="text-gray-400">BTC</span>
        </div>
      </div>

      <div class="rounded-xl border border-gray-800 bg-black/20 p-4">
        <div class="text-xs text-gray-500">Net aujourd’hui</div>
        <div class="mt-2 text-xl font-semibold <%= net_cls %>">
          <%= net_icon %>
          <span class="font-mono"><%= number_with_precision(net.abs, precision: 2, delimiter: " ") %></span>
          <span class="text-gray-400">BTC</span>
        </div>
      </div>

      <div class="rounded-xl border border-gray-800 bg-black/20 p-4">
        <div class="text-xs text-gray-500">Événements live</div>
        <div class="mt-2 text-xl font-semibold text-gray-100">
          <span class="font-mono"><%= number_with_delimiter(today[:events_count].to_i) %></span>
        </div>
      </div>
    </div>

    <div class="mt-5 rounded-xl border border-gray-800 bg-black/20 p-4">
      <div class="text-xs text-gray-500">Lecture actuelle</div>
      <p class="mt-2 text-sm leading-relaxed text-gray-300">
        <%= today[:interpretation] %>
      </p>
    </div>
    <div class="mt-5 rounded-xl border border-gray-800 bg-black/20 p-4">
      <div class="text-xs text-gray-500">Lecture actuelle</div>
      <p class="mt-2 text-sm leading-relaxed text-gray-300">
        <%= today[:interpretation] %>
      </p>

      <p class="mt-3 text-[11px] text-gray-600">
        source=actor_profile_exchange_like · acteurs validés par ActorProfile
      </p>
    </div>
  </section>
<% end %>