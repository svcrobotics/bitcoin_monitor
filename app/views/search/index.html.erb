<div class="min-h-screen bg-slate-950 px-4 py-8 text-slate-100 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-5xl">

    <header class="mb-8">
      <div class="text-xs font-semibold uppercase tracking-[0.25em] text-cyan-300">
        Bitcoin Monitor Search
      </div>

      <h1 class="mt-3 text-4xl font-bold tracking-tight text-white">
        Recherche globale
      </h1>

      <p class="mt-3 text-slate-400">
        Elasticsearch unifié : modules, clusters, signaux, alertes et données on-chain.
      </p>
    </header>

    <section class="mb-8 rounded-3xl border border-slate-700/70 bg-slate-900/80 p-6">
      <form action="<%= search_path %>" method="get">
        <div class="flex flex-col gap-3 md:flex-row">
          <input
            type="text"
            name="q"
            value="<%= @q %>"
            placeholder="Recherche..."
            class="w-full rounded-2xl border border-slate-700 bg-slate-950/70 px-5 py-4 text-white placeholder-slate-600 outline-none focus:border-cyan-400/60"
          >

          <button
            type="submit"
            class="rounded-2xl border border-cyan-400/40 bg-cyan-500/10 px-6 py-4 text-sm font-bold text-cyan-100 hover:bg-cyan-500/20">
            Rechercher
          </button>
        </div>
      </form>
    </section>

    <% if @results.present? %>
      <div class="mb-4 text-sm text-slate-500">
        <%= @results.size %> résultat(s)
      </div>

      <div class="space-y-3">
        <% @results.each do |result| %>

          <%= link_to result[:route],
            class: "block rounded-2xl border border-slate-700/70 bg-slate-900/70 p-5 transition hover:border-cyan-400/40 hover:bg-slate-800/70" do %>

            <div class="flex items-start justify-between gap-4">

              <div class="min-w-0">
                <div class="text-lg font-semibold text-white">
                  <%= result[:title] %>
                </div>

                <% if result[:subtitle].present? %>
                  <div class="mt-1 text-sm text-slate-400">
                    <%= result[:subtitle] %>
                  </div>
                <% end %>

                <div class="mt-3 text-xs uppercase tracking-wide text-cyan-300">
                  <%= result[:type] %>
                </div>
              </div>

              <div class="text-slate-600">
                →
              </div>

            </div>

          <% end %>

        <% end %>
      </div>

    <% elsif @q.present? %>

      <div class="rounded-2xl border border-slate-700/70 bg-slate-900/60 p-6 text-slate-400">
        Aucun résultat pour :
        <span class="font-semibold text-white"><%= @q %></span>
      </div>

    <% end %>

  </div>
</div>
