<section class="rounded-2xl border border-slate-800 bg-slate-950 p-5 text-slate-100">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="text-xs uppercase tracking-wide text-slate-500">ETF candidates</p>
      <h2 class="mt-1 text-xl font-semibold">Clusters détectés par Tansa</h2>
      <p class="mt-2 text-sm text-slate-400">
        Détection interne basée sur les données on-chain. Ces clusters sont des candidats ETF, pas des identifications confirmées.
      </p>
    </div>

    <div class="rounded-full bg-emerald-500/10 px-3 py-1 text-xs font-semibold text-emerald-300">
      <%= data[:count].to_i %> candidats
    </div>
  </div>

  <div class="mt-5 grid grid-cols-2 gap-3 md:grid-cols-3">
    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
      <p class="text-xs uppercase tracking-wide text-slate-500">Candidats</p>
      <p class="mt-2 text-2xl font-bold"><%= data[:count].to_i %></p>
    </div>

    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
      <p class="text-xs uppercase tracking-wide text-slate-500">Balance cumulée</p>
      <p class="mt-2 text-2xl font-bold">
        <%= number_with_delimiter(data[:total_balance_btc].to_d.round(2)) %> BTC
      </p>
    </div>

    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
      <p class="text-xs uppercase tracking-wide text-slate-500">Source</p>
      <p class="mt-2 text-sm font-semibold text-slate-300">Tansa interne</p>
    </div>
  </div>

  <%
    unavailable_label = "indisponible"
    numeric_or_unavailable = lambda do |value|
      value.nil? ? unavailable_label : number_with_delimiter(value.to_d.round(2))
    end
  %>

  <div class="mt-6 overflow-hidden rounded-xl border border-slate-800">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-900 text-xs uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-4 py-3">Cluster</th>
          <th class="px-4 py-3">Score ETF</th>
          <th class="px-4 py-3">Balance</th>
          <th class="px-4 py-3">Reçu</th>
          <th class="px-4 py-3">Envoyé</th>
          <th class="px-4 py-3">Tx</th>
          <th class="px-4 py-3">Classification</th>
        </tr>
      </thead>

      <tbody class="divide-y divide-slate-800 bg-slate-950">
        <% Array(data[:candidates]).each do |candidate| %>
          <tr>
            <td class="px-4 py-3 font-mono text-slate-300"><%= candidate[:cluster_id] %></td>
            <td class="px-4 py-3 text-emerald-300"><%= candidate[:etf_score].nil? ? unavailable_label : candidate[:etf_score].to_i %></td>
            <td class="px-4 py-3"><%= numeric_or_unavailable.call(candidate[:balance_btc]) %></td>
            <td class="px-4 py-3"><%= numeric_or_unavailable.call(candidate[:total_received_btc]) %></td>
            <td class="px-4 py-3"><%= numeric_or_unavailable.call(candidate[:total_sent_btc]) %></td>
            <td class="px-4 py-3"><%= number_with_delimiter(candidate[:tx_count].to_i) %></td>
            <td class="px-4 py-3 text-slate-400"><%= candidate[:classification] || "—" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
