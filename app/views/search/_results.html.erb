<% if q.present? && results.present? %>

  <div class="mt-3 overflow-hidden rounded-2xl border border-slate-700/70 bg-slate-900 shadow-2xl shadow-black/30">

    <% results.each do |result| %>

      <%= link_to result[:route],
        class: "block border-b border-slate-800 px-5 py-4 transition hover:bg-slate-800/80 last:border-b-0" do %>

        <div class="flex items-center justify-between gap-4">

          <div class="min-w-0">
            <div class="truncate text-sm font-semibold text-white">
              <%= result[:title] %>
            </div>

            <% if result[:subtitle].present? %>
              <div class="mt-1 truncate text-xs text-slate-400">
                <%= result[:subtitle] %>
              </div>
            <% end %>
          </div>

          <div class="text-xs uppercase tracking-wide text-cyan-300">
            <%= result[:type] %>
          </div>

        </div>

      <% end %>

    <% end %>

  </div>

<% end %>
