<div class="max-w-7xl mx-auto px-6 py-8">

  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-100">
      Actor Labels
    </h1>

    <p class="mt-2 text-gray-400">
      Probable economic actors inferred from Cluster.
    </p>
  </div>

  <div class="overflow-hidden rounded-xl border border-gray-800 bg-gray-900">
    <table class="min-w-full divide-y divide-gray-800">

      <thead class="bg-gray-950">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-400 uppercase">
            Cluster
          </th>

          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-400 uppercase">
            Label
          </th>

          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-400 uppercase">
            Confidence
          </th>

          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-400 uppercase">
            Source
          </th>

          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-400 uppercase">
            Metadata
          </th>
        </tr>
      </thead>

      <tbody class="divide-y divide-gray-800">
        <% @actor_labels.each do |actor| %>
          <tr class="hover:bg-gray-800/50">

            <td class="px-4 py-3 text-sm text-gray-200">
              <%= actor.cluster_id %>
            </td>

            <td class="px-4 py-3">
              <span class="inline-flex rounded-full px-2 py-1 text-xs font-semibold
                <%=
                  case actor.label
                  when "exchange_like"
                    "bg-blue-500/10 text-blue-300"
                  when "whale_like"
                    "bg-purple-500/10 text-purple-300"
                  when "service_like"
                    "bg-emerald-500/10 text-emerald-300"
                  else
                    "bg-gray-500/10 text-gray-300"
                  end
                %>">
                <%= actor.label %>
              </span>
            </td>

            <td class="px-4 py-3 text-sm text-gray-200">
              <%= actor.confidence %>
            </td>

            <td class="px-4 py-3 text-sm text-gray-400">
              <%= actor.source %>
            </td>

            <td class="px-4 py-3 text-xs text-gray-500">
              <%= actor.metadata.to_json %>
            </td>

          </tr>
        <% end %>
      </tbody>

    </table>
  </div>
</div>
