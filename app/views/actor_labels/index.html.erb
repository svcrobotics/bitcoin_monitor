<div class="max-w-7xl mx-auto px-6 py-8">
  <div class="mb-8 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <p class="text-xs uppercase tracking-wide text-gray-500">Actor Graph</p>

      <h1 class="mt-1 text-3xl font-bold text-gray-100">
        Actor Labels
      </h1>

      <p class="mt-2 max-w-3xl text-sm text-gray-400">
        Couche d’interprétation construite depuis les profils de clusters.
        Chaque ligne représente un acteur économique probable détecté par Cluster.
      </p>
    </div>

    <div class="rounded-2xl border border-gray-800 bg-gray-900/60 px-4 py-3">
      <p class="text-xs uppercase tracking-wide text-gray-500">Displayed</p>
      <p class="mt-1 text-2xl font-semibold text-gray-100">
        <%= @actor_labels.size %>
      </p>
    </div>
  </div>

  <div class="mb-6 grid grid-cols-1 gap-4 sm:grid-cols-3">
    <% counts = @actor_labels.group_by(&:label).transform_values(&:count) %>

    <% [
      ["exchange_like", "Exchange-like", "bg-blue-500/10 text-blue-300 border-blue-500/20"],
      ["whale_like", "Whale-like", "bg-purple-500/10 text-purple-300 border-purple-500/20"],
      ["service_like", "Service-like", "bg-emerald-500/10 text-emerald-300 border-emerald-500/20"]
    ].each do |label, title, color_class| %>
      <div class="rounded-2xl border border-gray-800 bg-gray-900/60 p-4">
        <div class="flex items-center justify-between gap-3">
          <span class="inline-flex rounded-full border px-2 py-1 text-xs font-semibold <%= color_class %>">
            <%= title %>
          </span>

          <span class="text-2xl font-bold text-gray-100">
            <%= counts[label] || 0 %>
          </span>
        </div>

        <p class="mt-3 text-xs text-gray-500">
          Acteurs probables classés <%= label %>.
        </p>
      </div>
    <% end %>
  </div>

  <div class="overflow-hidden rounded-2xl border border-gray-800 bg-gray-900/70 shadow-xl">
    <div class="border-b border-gray-800 px-5 py-4">
      <h2 class="text-sm font-semibold text-gray-200">
        Interesting actors
      </h2>
      <p class="mt-1 text-xs text-gray-500">
        Labels non-retail triés par confiance décroissante.
      </p>
    </div>

    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-800">
        <thead class="bg-gray-950/70">
          <tr>
            <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">
              Cluster
            </th>
            <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">
              Label
            </th>
            <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">
              Confidence
            </th>
            <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">
              Source
            </th>
            <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">
              Metadata
            </th>
          </tr>
        </thead>

        <tbody class="divide-y divide-gray-800">
          <% @actor_labels.each do |actor| %>
            <tr class="hover:bg-white/[0.03] transition">
              <td class="px-5 py-4 text-sm font-semibold text-gray-100">
                #<%= actor.cluster_id %>
              </td>

              <td class="px-5 py-4">
                <% label_class =
                  case actor.label
                  when "exchange_like"
                    "bg-blue-500/10 text-blue-300 border-blue-500/20"
                  when "whale_like"
                    "bg-purple-500/10 text-purple-300 border-purple-500/20"
                  when "service_like"
                    "bg-emerald-500/10 text-emerald-300 border-emerald-500/20"
                  else
                    "bg-gray-500/10 text-gray-300 border-gray-500/20"
                  end
                %>

                <span class="inline-flex rounded-full border px-2.5 py-1 text-xs font-semibold <%= label_class %>">
                  <%= actor.label %>
                </span>
              </td>

              <td class="px-5 py-4">
                <div class="flex items-center gap-3">
                  <div class="h-2 w-24 overflow-hidden rounded-full bg-gray-800">
                    <div
                      class="h-full rounded-full bg-gray-300"
                      style="width: <%= actor.confidence %>%"
                    ></div>
                  </div>

                  <span class="text-sm font-semibold text-gray-200">
                    <%= actor.confidence %>
                  </span>
                </div>
              </td>

              <td class="px-5 py-4 text-sm text-gray-400">
                <%= actor.source %>
              </td>

              <td class="px-5 py-4 text-xs text-gray-500">
                <code class="rounded-lg bg-black/30 px-2 py-1">
                  <%= actor.metadata.to_json %>
                </code>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>