<%
  snapshot ||= {}

  pipeline_snapshot =
    System::PipelineController.snapshot

  cluster_decision =
    System::PipelineController.decision(
      :cluster,
      current_snapshot:
        pipeline_snapshot
    )

  dashboard =
    Clusters::DashboardSnapshot.call(
      snapshot: snapshot,
      decision: cluster_decision
    )
%>

<%= render(
      "questions/answers/cluster_pipeline",
      dashboard: dashboard
    ) %>
