<%
  raw_snapshot =
    snapshot || {}

  source =
    (
      raw_snapshot[:source] ||
      raw_snapshot["source"]
    ).to_s

  overview =
    if source ==
       "layer1_overview_snapshot"
      raw_snapshot
    else
      Layer1::OverviewSnapshot.call(
        realtime: raw_snapshot
      )
    end

  dashboard =
    Layer1::DashboardSnapshot.call(
      snapshot: overview
    )
%>

<%= render(
      "questions/answers/layer1_catchup_indicators",
      overview: overview
    ) %>

<%= render(
      "questions/answers/layer1_pipeline",
      dashboard: dashboard
    ) %>
