<%
  service ||= {}

  cases =
    Array(
      service[:cases] ||
      service["cases"]
    )

  analyzed =
    (
      service[:analyzed] ||
      service["analyzed"]
    ).to_i

  confirmed =
    (
      service[:confirmed] ||
      service["confirmed"]
    ).to_i

  not_confirmed =
    (
      service[:not_confirmed] ||
      service["not_confirmed"]
    ).to_i

  labels_published =
    (
      service[:labels_published] ||
      service["labels_published"]
    ).to_i

  status =
    (
      service[:status] ||
      service["status"] ||
      "unavailable"
    ).to_s
%>

<section class="rounded-3xl border border-cyan-400/20 bg-cyan-400/[0.035] p-5">
  <header class="flex flex-col justify-between gap-4 lg:flex-row lg:items-start">
    <div class="max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-300">
        Heavy Service
      </p>

      <h3 class="mt-2 text-lg font-semibold text-white">
        Résolution des infrastructures de service
      </h3>

      <p class="mt-2 text-sm leading-6 text-slate-400">
        Heavy Service mesure la continuité opérationnelle, les flux
        bidirectionnels et la distribution externe des candidats service.
      </p>
    </div>

    <div class="flex flex-wrap gap-2">
      <span class="rounded-full border border-cyan-300/25 bg-cyan-300/10 px-3 py-1 text-xs font-semibold text-cyan-200">
        <%= status.upcase %>
      </span>

      <span class="rounded-full border border-violet-300/25 bg-violet-300/10 px-3 py-1 text-xs font-semibold text-violet-200">
        MODE SHADOW
      </span>
    </div>
  </header>

  <div class="mt-5 grid gap-3 md:grid-cols-3">
    <div class="rounded-2xl border border-white/10 bg-black/20 p-4">
      <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">
        Entrée
      </div>

      <div class="mt-2 font-mono text-sm text-white">
        service_like_candidate_inputs
      </div>

      <p class="mt-2 text-xs leading-5 text-slate-500">
        Candidats sélectionnés par ActorBehavior et les règles strictes.
      </p>
    </div>

    <div class="rounded-2xl border border-violet-400/20 bg-violet-400/[0.04] p-4">
      <div class="text-xs font-semibold uppercase tracking-wide text-violet-300/70">
        Calcul
      </div>

      <div class="mt-2 text-sm font-semibold text-white">
        <%= analyzed %> analyses certifiées
      </div>

      <p class="mt-2 text-xs leading-5 text-slate-500">
        Continuité, récurrence, bidirectionnalité et largeur externe.
      </p>
    </div>

    <div class="rounded-2xl border border-amber-400/20 bg-amber-400/[0.04] p-4">
      <div class="text-xs font-semibold uppercase tracking-wide text-amber-300/70">
        Sortie
      </div>

      <div class="mt-2 text-sm font-semibold text-white">
        Décision Heavy shadow
      </div>

      <p class="mt-2 text-xs leading-5 text-slate-500">
        <%= labels_published %> label publié. Résolution finale non raccordée.
      </p>
    </div>
  </div>

  <div class="mt-4 grid grid-cols-3 gap-3">
    <div class="rounded-xl bg-black/20 p-3 text-center">
      <div class="text-xs text-slate-500">Analysés</div>
      <div class="mt-1 text-xl font-semibold text-white">
        <%= analyzed %>
      </div>
    </div>

    <div class="rounded-xl bg-emerald-400/[0.05] p-3 text-center">
      <div class="text-xs text-emerald-300/70">Confirmés</div>
      <div class="mt-1 text-xl font-semibold text-emerald-300">
        <%= confirmed %>
      </div>
    </div>

    <div class="rounded-xl bg-amber-400/[0.05] p-3 text-center">
      <div class="text-xs text-amber-300/70">Non confirmés</div>
      <div class="mt-1 text-xl font-semibold text-amber-300">
        <%= not_confirmed %>
      </div>
    </div>
  </div>

  <div class="mt-4 rounded-2xl border border-amber-400/20 bg-amber-400/[0.04] p-4 text-sm leading-6 text-slate-400">
    <span class="font-semibold text-amber-200">
      État actuel :
    </span>
    les preuves Heavy Service sont certifiées et disponibles pour calibration,
    mais elles ne participent pas encore à la classification finale
    ActorLabels et ne publient aucun label.
  </div>

  <details class="mt-4 rounded-2xl border border-white/10 bg-black/20">
    <summary class="cursor-pointer select-none px-4 py-3 text-sm font-semibold text-slate-300">
      Voir les <%= cases.size %> analyses Heavy Service
    </summary>

    <div class="space-y-3 border-t border-white/10 p-4">
      <% cases.each do |item| %>
        <%
          hard_gates =
            (
              item[:hard_gates] ||
              item["hard_gates"] ||
              {}
            ).to_h

          cluster_id =
            item[:cluster_id] ||
            item["cluster_id"]

          decision =
            (
              item[:decision] ||
              item["decision"] ||
              "unknown"
            ).to_s

          score =
            item[:score] ||
            item["score"]

          external_clusters =
            item[:external_clusters] ||
            item["external_clusters"]

          external_addresses =
            item[:external_addresses] ||
            item["external_addresses"]

          complete_output_evidence =
            hard_gates[:complete_output_evidence] ||
            hard_gates["complete_output_evidence"]
        %>

        <article class="rounded-xl border border-white/10 bg-white/[0.025] p-4">
          <div class="flex flex-col justify-between gap-3 md:flex-row md:items-start">
            <div>
              <div class="font-semibold <%= decision == "confirmed" ? "text-emerald-200" : "text-amber-200" %>">
                <%= decision == "confirmed" ? "Infrastructure service confirmée" : "Infrastructure service non confirmée" %>
              </div>

              <div class="mt-1 font-mono text-xs text-slate-400">
                cluster <%= cluster_id || "—" %>
              </div>
            </div>

            <div class="md:text-right">
              <div class="text-xs text-slate-500">
                Score service
              </div>

              <div class="mt-1 text-xl font-semibold text-white">
                <%= score.to_i %> / 100
              </div>
            </div>
          </div>

          <dl class="mt-3 grid grid-cols-2 gap-2 text-xs md:grid-cols-3">
            <div class="rounded-lg bg-black/20 p-2">
              <dt class="text-slate-500">Preuve de sortie</dt>
              <dd class="mt-1 font-semibold <%= complete_output_evidence ? "text-emerald-300" : "text-amber-300" %>">
                <%= complete_output_evidence ? "complète" : "incomplète" %>
              </dd>
            </div>

            <div class="rounded-lg bg-black/20 p-2">
              <dt class="text-slate-500">Clusters externes</dt>
              <dd class="mt-1 font-semibold text-white">
                <%= number_with_delimiter(external_clusters.to_i) %>
              </dd>
            </div>

            <div class="rounded-lg bg-black/20 p-2">
              <dt class="text-slate-500">Adresses externes</dt>
              <dd class="mt-1 font-semibold text-white">
                <%= number_with_delimiter(external_addresses.to_i) %>
              </dd>
            </div>
          </dl>
        </article>
      <% end %>
    </div>
  </details>
</section>
