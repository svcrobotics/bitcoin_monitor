<%
  raw_overview = (overview || {}).with_indifferent_access
  realtime = (raw_overview[:realtime] || {}).with_indifferent_access
  sync = (realtime[:sync] || {}).with_indifferent_access
  pace = (raw_overview[:pace] || {}).with_indifferent_access
  network = (pace[:network] || {}).with_indifferent_access
  certification = (pace[:certification] || {}).with_indifferent_access
  processing = (pace[:processing] || {}).with_indifferent_access
  comparison = (pace[:comparison] || {}).with_indifferent_access

  lag = comparison[:current_lag] || realtime[:lag] || sync[:lag]
  progress = Layer1::CatchupProgressSnapshot.call(current_lag: lag).with_indifferent_access
  downstream = progress[:phase].to_s == "downstream_catchup"

  processed_height = realtime[:processed_height] || sync[:processed_height] || sync[:continuous_tip]
  core_height = realtime[:best_height] || sync[:best_height]
  core_height = processed_height.to_i + lag.to_i if core_height.blank? && processed_height.present? && lag.present?

  network_seconds = network[:median_interval_seconds]
  effective_seconds = certification[:median_10_seconds] || comparison[:effective_interval_seconds] || certification[:median_30_seconds]
  internal_seconds = processing[:median_10_seconds] || comparison[:internal_processing_seconds] || processing[:median_30_seconds]
  waiting_seconds = comparison[:scheduler_overhead_seconds]

  format_duration = lambda do |seconds|
    if seconds.blank?
      "—"
    else
      total = seconds.to_f.round
      hours = total / 3600
      minutes = (total % 3600) / 60
      remaining = total % 60
      hours.positive? ? "#{hours} h #{minutes.to_s.rjust(2, "0")} min" :
        minutes.positive? ? "#{minutes} min #{remaining.to_s.rjust(2, "0")} s" :
        "#{remaining} s"
    end
  end

  status = progress[:status].to_s
  verdict_label = {
    "catching_up" => "LAYER1 RATTRAPE",
    "falling_behind" => "LAYER1 PREND DU RETARD",
    "stable" => "LAYER1 STAGNE",
    "target_reached" => "OBJECTIF ATTEINT",
    "downstream_catchup" => "MODULES AVAL ACTIFS",
    "measuring" => "MESURE EN COURS"
  }.fetch(status, "MESURE INDISPONIBLE")

  verdict_classes =
    case status
    when "catching_up", "target_reached"
      "border-emerald-500/40 bg-emerald-500/10 text-emerald-200"
    when "falling_behind"
      "border-rose-500/40 bg-rose-500/10 text-rose-200"
    when "downstream_catchup"
      "border-cyan-500/40 bg-cyan-500/10 text-cyan-200"
    when "stable", "measuring"
      "border-amber-500/40 bg-amber-500/10 text-amber-200"
    else
      "border-slate-700 bg-slate-900 text-slate-300"
    end

  phase_progress = progress[:progress_blocks].to_i
  phase_progress_label =
    if downstream
      phase_progress.positive? ? "+#{phase_progress} bloc(s)" : "0 bloc"
    elsif phase_progress.positive?
      "-#{phase_progress} bloc(s)"
    elsif progress[:lag_change].to_i.positive?
      "+#{progress[:lag_change].to_i} bloc(s)"
    else
      "0 bloc"
    end

  observed_rate = progress[:observed_change_per_hour]
  observed_rate_label =
    if downstream
      "augmentation volontaire du lag"
    elsif progress[:estimation_ready] != true
      "échantillon insuffisant"
    elsif observed_rate.blank?
      "—"
    elsif observed_rate.to_f.negative?
      "-#{number_with_precision(observed_rate.to_f.abs, precision: 2)} bloc/h"
    elsif observed_rate.to_f.positive?
      "+#{number_with_precision(observed_rate.to_f, precision: 2)} bloc/h"
    else
      "0 bloc/h"
    end

  estimate_label =
    case status
    when "target_reached"
      "objectif atteint"
    when "catching_up"
      if progress[:estimation_ready] != true
        "tendance favorable · estimation prématurée"
      elsif progress[:estimated_catchup_at].present?
        distance_of_time_in_words(Time.current, progress[:estimated_catchup_at])
      else
        "—"
      end
    when "stable"
      "impossible à estimer"
    when "falling_behind"
      "impossible au rythme actuel"
    when "measuring"
      "mesure en cours"
    else
      "—"
    end

  heading = downstream ? "Travail des modules aval" : "Progression réellement observée"
  description = downstream ?
    "Layer1 est volontairement arrêté. Le lag augmente jusqu’au seuil de reprise pendant que les modules aval travaillent." :
    "Le verdict dépend uniquement de la variation réelle du lag depuis le début de la phase. Les cadences servent à expliquer le résultat."

  target_title = downstream ? "Reprise Layer1 au lag #{progress[:target_lag]}" : "Objectif lag #{progress[:target_lag]}"
  target_value = downstream ?
    (progress[:blocks_to_target].to_i.zero? ? "reprise imminente" : "#{progress[:blocks_to_target]} bloc(s) avant reprise") :
    estimate_label
  target_detail = downstream ? "seuil haut de l’hystérésis" : "#{progress[:blocks_to_target]} bloc(s) restant(s)"
%>

<section class="mb-5 rounded-lg border border-slate-700 bg-slate-950/90 p-4 md:p-5" data-layer1-catchup-indicators>
  <div class="flex flex-col gap-3 border-b border-slate-800 pb-4 md:flex-row md:items-start md:justify-between">
    <div>
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-slate-500">Pilotage du rattrapage</p>
      <h2 class="mt-2 text-lg font-semibold text-white"><%= heading %></h2>
      <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-400"><%= description %></p>
    </div>
    <div class="rounded-md border px-3 py-2 text-center font-mono text-xs font-semibold uppercase tracking-wide <%= verdict_classes %>"><%= verdict_label %></div>
  </div>

  <div class="mt-4 grid gap-3 sm:grid-cols-2 xl:grid-cols-6">
    <div class="rounded-md border border-slate-800 bg-slate-900/70 p-3">
      <p class="font-mono text-[11px] uppercase tracking-wide text-slate-500">Lag à l’entrée</p>
      <p class="mt-1 font-mono text-xl font-semibold text-white"><%= progress[:baseline_lag].present? ? "#{progress[:baseline_lag]} blocs" : "—" %></p>
      <p class="mt-1 text-xs text-slate-500">phase depuis <%= format_duration.call(progress[:elapsed_seconds]) %></p>
    </div>

    <div class="rounded-md border border-slate-800 bg-slate-900/70 p-3">
      <p class="font-mono text-[11px] uppercase tracking-wide text-slate-500">Lag actuel</p>
      <p class="mt-1 font-mono text-xl font-semibold text-white"><%= progress[:current_lag].present? ? "#{progress[:current_lag]} blocs" : "—" %></p>
      <p class="mt-1 text-xs text-slate-500">cycle <%= progress[:stop_lag] %> ↔ <%= progress[:start_lag] %></p>
    </div>

    <div class="rounded-md border border-slate-800 bg-slate-900/70 p-3">
      <p class="font-mono text-[11px] uppercase tracking-wide text-slate-500">Progression de la phase</p>
      <p class="mt-1 font-mono text-lg font-semibold text-slate-100"><%= phase_progress_label %></p>
      <p class="mt-1 text-xs text-slate-500"><%= observed_rate_label %></p>
    </div>

    <div class="rounded-md border border-slate-800 bg-slate-900/70 p-3">
      <p class="font-mono text-[11px] uppercase tracking-wide text-slate-500">Bitcoin Core</p>
      <p class="mt-1 font-mono text-lg font-semibold text-cyan-200"><%= format_duration.call(network_seconds) %></p>
      <p class="mt-1 text-xs text-slate-500">cadence médiane</p>
    </div>

    <div class="rounded-md border border-slate-800 bg-slate-900/70 p-3">
      <p class="font-mono text-[11px] uppercase tracking-wide text-slate-500"><%= downstream ? "Dernière cadence Layer1" : "Layer1 effectif" %></p>
      <p class="mt-1 font-mono text-lg font-semibold text-emerald-200"><%= format_duration.call(effective_seconds) %></p>
      <p class="mt-1 text-xs text-slate-500">
        <% if downstream %>
          historique · Layer1 arrêté
        <% else %>
          traitement <%= format_duration.call(internal_seconds) %> · attente <%= format_duration.call(waiting_seconds) %>
        <% end %>
      </p>
    </div>

    <div class="rounded-md border border-slate-800 bg-slate-900/70 p-3">
      <p class="font-mono text-[11px] uppercase tracking-wide text-slate-500"><%= target_title %></p>
      <p class="mt-1 font-mono text-sm font-semibold text-slate-100"><%= target_value %></p>
      <p class="mt-1 text-xs text-slate-500"><%= target_detail %></p>
    </div>
  </div>

  <div class="mt-3 rounded-md border border-slate-800 bg-slate-900/50 px-3 py-2">
    <p class="font-mono text-xs text-slate-400">
      Core <%= core_height || "—" %> · Layer1 <%= processed_height || "—" %> · bloc en cours <%= processing[:current_height] || "—" %>
      <% if downstream %>
        · projection de rattrapage masquée pendant la pause
      <% else %>
        · projection par cadences : <%= comparison[:backlog_change_per_hour].present? ? "#{comparison[:backlog_change_per_hour]} bloc/h" : "—" %> (information secondaire)
      <% end %>
    </p>
  </div>
</section>
