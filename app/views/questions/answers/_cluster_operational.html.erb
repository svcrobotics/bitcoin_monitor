<%
  read_value = lambda do |hash, key|
    next nil unless hash.respond_to?(:[])

    hash[key] || hash[key.to_s]
  end

  sync = read_value.call(snapshot, :sync) || {}
  activity = read_value.call(snapshot, :activity) || {}
  automation = read_value.call(snapshot, :automation) || {}

  layer1_tip = read_value.call(sync, :layer1_tip).to_i
  cluster_tip = read_value.call(sync, :cluster_tip).to_i
  lag = read_value.call(sync, :scanner_lag).to_i

  pipeline_state =
    read_value.call(activity, :pipeline_state).to_s

  current_height =
    read_value.call(activity, :current_height)

  worker_present =
    read_value.call(automation, :process_present) == true

  busy_workers =
    read_value.call(automation, :busy_workers).to_i

  queue_size =
    read_value.call(automation, :queue_size).to_i

  recent_checkpoints =
    Array(
      read_value.call(
        snapshot,
        :recent_checkpoints
      )
    )

  coverage =
    read_value.call(
      snapshot,
      :coverage
    ) || {}

  coverage_complete =
    read_value.call(
      coverage,
      :complete
    ) == true

  coverage_status =
    read_value.call(
      coverage,
      :status
    ).to_s

  missing_addresses =
    read_value.call(
      coverage,
      :missing_addresses
    )

  unclustered_addresses =
    read_value.call(
      coverage,
      :unclustered_addresses
    )

  invalid_cluster_refs =
    read_value.call(
      coverage,
      :invalid_cluster_refs
    )

  coverage_counts_available =
    !missing_addresses.nil? &&
    !unclustered_addresses.nil? &&
    !invalid_cluster_refs.nil?

  coverage_label =
    if coverage_complete
      "complète et à jour"
    elsif coverage_status == "incomplete"
      "rattrapage en cours"
    else
      "vérification en attente"
    end

  coverage_card_classes =
    if coverage_complete
      "border-emerald-400/20 bg-emerald-400/[0.06]"
    elsif coverage_status == "incomplete"
      "border-amber-400/20 bg-amber-400/[0.06]"
    else
      "border-white/10 bg-white/[0.03]"
    end

  coverage_text_class =
    if coverage_complete
      "text-emerald-300"
    elsif coverage_status == "incomplete"
      "text-amber-300"
    else
      "text-slate-300"
    end

  active = pipeline_state == "active"

  state_label =
    case pipeline_state
    when "active"
      "rattrapage actif"
    when "queued"
      "travail planifié"
    when "idle_synced"
      "synchronisé"
    when "worker_missing"
      "worker absent"
    else
      "déclenchement attendu"
    end

  state_summary =
    if active
      "Cluster traite actuellement les blocs déjà certifiés par Layer1."
    elsif pipeline_state == "idle_synced"
      "Cluster est synchronisé avec le dernier bloc certifié par Layer1."
    elsif pipeline_state == "queued"
      "Un traitement Cluster est en attente dans la queue."
    else
      "Cluster présente un retard, mais aucun traitement actif n’est observé."
    end

  action_label =
    if active
      "laisser le rattrapage progresser"
    elsif pipeline_state == "idle_synced"
      "aucune action"
    else
      "vérifier l’automatisation Cluster"
    end
%>

<div class="space-y-6">
  <div>
    <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">
      Cluster
    </div>

    <h2 class="mt-2 text-2xl font-semibold text-white">
      État du clustering
    </h2>

    <p class="mt-2 text-sm leading-6 text-slate-300">
      <%= state_summary %>
    </p>
  </div>

  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
      <div class="text-xs uppercase tracking-wide text-slate-500">
        État
      </div>
      <div class="mt-2 font-semibold text-white">
        <%= state_label %>
      </div>
    </div>

    <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
      <div class="text-xs uppercase tracking-wide text-slate-500">
        Données strictes
      </div>
      <div class="mt-2 font-semibold text-white">
        checkpoint <%= number_with_delimiter(cluster_tip, delimiter: " ") %> certifié
      </div>
    </div>

    <div class="rounded-2xl border p-4 <%= coverage_card_classes %>">
      <div class="text-xs uppercase tracking-wide text-slate-500">
        Couverture globale
      </div>

      <div class="mt-2 font-semibold <%= coverage_text_class %>">
        <%= coverage_label %>
      </div>

      <% if coverage_counts_available %>
        <div class="mt-2 text-xs leading-5 text-slate-400">
          <%= number_with_delimiter(
            missing_addresses.to_i,
            delimiter: " "
          ) %>
          adresse(s) manquante(s)
          ·
          <%= number_with_delimiter(
            unclustered_addresses.to_i,
            delimiter: " "
          ) %>
          sans cluster
          ·
          <%= number_with_delimiter(
            invalid_cluster_refs.to_i,
            delimiter: " "
          ) %>
          référence(s) invalide(s)
        </div>
      <% end %>
    </div>

    <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
      <div class="text-xs uppercase tracking-wide text-slate-500">
        Retard
      </div>
      <div class="mt-2 text-xl font-semibold text-white">
        <%= number_with_delimiter(lag, delimiter: " ") %> blocs
      </div>
    </div>

    <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
      <div class="text-xs uppercase tracking-wide text-slate-500">
        Audit détaillé
      </div>
      <div class="mt-2 font-semibold text-slate-300">
        non chargé dans cette vue
      </div>
    </div>

    <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
      <div class="text-xs uppercase tracking-wide text-slate-500">
        Action
      </div>
      <div class="mt-2 font-semibold text-white">
        <%= action_label %>
      </div>
    </div>
  </div>

  <div class="rounded-2xl border border-white/10 bg-white/[0.025] p-5">
    <p class="text-sm leading-6 text-slate-300">
      Le clustering multi-input traite uniquement les blocs déjà certifiés
      par Layer1. La couverture globale et l’audit étendu sont volontairement
      séparés de cette réponse opérationnelle afin de conserver une réponse
      immédiate.
    </p>
  </div>

  <% if recent_checkpoints.any? %>
    <div>
      <div class="text-sm font-semibold text-white">
        Vitesse récente
      </div>

      <div class="mt-3 space-y-2">
        <% recent_checkpoints.each do |checkpoint| %>
          <%
            height =
              read_value.call(
                checkpoint,
                :height
              ).to_i

            duration_ms =
              read_value.call(
                checkpoint,
                :duration_ms
              ).to_i

            duration_minutes =
              duration_ms.positive? ?
                (duration_ms / 60_000.0).round(1) :
                nil
          %>

          <div class="flex items-center justify-between rounded-xl border border-white/5 px-4 py-2">
            <span class="font-mono text-sm text-slate-300">
              <%= number_with_delimiter(height, delimiter: " ") %>
            </span>

            <span class="text-sm text-slate-400">
              <%= duration_minutes ? "#{duration_minutes} min" : "durée indisponible" %>
            </span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <details class="rounded-2xl border border-white/10 bg-white/[0.025]">
    <summary class="cursor-pointer px-5 py-4 text-sm font-semibold text-slate-200">
      Voir les détails techniques
    </summary>

    <div class="grid gap-3 border-t border-white/10 px-5 py-4 sm:grid-cols-2">
      <div>
        <div class="text-xs text-slate-500">Layer1 certifié</div>
        <div class="mt-1 font-mono text-slate-200">
          <%= number_with_delimiter(layer1_tip, delimiter: " ") %>
        </div>
      </div>

      <div>
        <div class="text-xs text-slate-500">Bloc Cluster certifié</div>
        <div class="mt-1 font-mono text-slate-200">
          <%= number_with_delimiter(cluster_tip, delimiter: " ") %>
        </div>
      </div>

      <div>
        <div class="text-xs text-slate-500">Bloc en cours</div>
        <div class="mt-1 font-mono text-slate-200">
          <%= current_height ? number_with_delimiter(current_height, delimiter: " ") : "aucun" %>
        </div>
      </div>

      <div>
        <div class="text-xs text-slate-500">Worker</div>
        <div class="mt-1 text-slate-200">
          <% if worker_present && busy_workers.positive? %>
            actif
          <% elsif worker_present %>
            disponible
          <% else %>
            absent
          <% end %>
        </div>
      </div>

      <div>
        <div class="text-xs text-slate-500">Workers occupés</div>
        <div class="mt-1 font-mono text-slate-200">
          <%= busy_workers %>
        </div>
      </div>

      <div>
        <div class="text-xs text-slate-500">Queue</div>
        <div class="mt-1 font-mono text-slate-200">
          <%= queue_size %>
        </div>
      </div>
    </div>
  </details>
</div>
