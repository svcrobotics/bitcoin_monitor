<%
  heavy ||= {}

  cases =
    Array(
      heavy[:cases] ||
      heavy["cases"]
    )

  analyzed =
    (
      heavy[:analyzed] ||
      heavy["analyzed"]
    ).to_i

  confirmed =
    (
      heavy[:candidates] ||
      heavy["candidates"]
    ).to_i

  rejected =
    (
      heavy[:rejected] ||
      heavy["rejected"]
    ).to_i

  published =
    (
      heavy[:labels_published] ||
      heavy["labels_published"]
    ).to_i

  status =
    (
      heavy[:status] ||
      heavy["status"] ||
      "unavailable"
    ).to_s
%>

<section class="rounded-3xl border border-cyan-400/20 bg-cyan-400/[0.035] p-5">
  <header class="flex flex-col justify-between gap-4 lg:flex-row lg:items-start">
    <div class="max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-300">
        Heavy Exchange
      </p>

      <h3 class="mt-2 text-lg font-semibold text-white">
        Résolution des infrastructures d’exchange
      </h3>

      <p class="mt-2 text-sm leading-6 text-slate-400">
        Heavy Exchange approfondit les candidats issus des règles strictes
        en recherchant une chaîne collecte → sweep concentré → distribution.
      </p>
    </div>

    <span class="w-fit rounded-full border border-cyan-300/25 bg-cyan-300/10 px-3 py-1 text-xs font-semibold text-cyan-200">
      <%= status.upcase %>
    </span>
  </header>

  <div class="mt-5 grid gap-3 md:grid-cols-3">
    <div class="rounded-2xl border border-white/10 bg-black/20 p-4">
      <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">
        Entrée
      </div>

      <div class="mt-2 font-mono text-sm text-white">
        candidats exchange
      </div>

      <p class="mt-2 text-xs leading-5 text-slate-500">
        Signaux stricts produits par ActorLabels.
      </p>
    </div>

    <div class="rounded-2xl border border-violet-400/20 bg-violet-400/[0.04] p-4">
      <div class="text-xs font-semibold uppercase tracking-wide text-violet-300/70">
        Calcul
      </div>

      <div class="mt-2 text-sm font-semibold text-white">
        <%= number_with_delimiter(analyzed) %> analyses Heavy
      </div>

      <p class="mt-2 text-xs leading-5 text-slate-500">
        Dépôts, sweep, consolidation et distribution externe.
      </p>
    </div>

    <div class="rounded-2xl border border-emerald-400/20 bg-emerald-400/[0.04] p-4">
      <div class="text-xs font-semibold uppercase tracking-wide text-emerald-300/70">
        Sortie
      </div>

      <div class="mt-2 font-mono text-sm text-white">
        exchange_infrastructure_candidate
      </div>

      <p class="mt-2 text-xs leading-5 text-slate-500">
        <%= published %> label(s) publié(s) pour les modules aval.
      </p>
    </div>
  </div>

  <div class="mt-4 grid grid-cols-3 gap-3">
    <div class="rounded-xl bg-black/20 p-3 text-center">
      <div class="text-xs text-slate-500">Analysés</div>
      <div class="mt-1 text-xl font-semibold text-white">
        <%= analyzed %>
      </div>
    </div>

    <div class="rounded-xl bg-emerald-400/[0.05] p-3 text-center">
      <div class="text-xs text-emerald-300/70">Confirmés</div>
      <div class="mt-1 text-xl font-semibold text-emerald-300">
        <%= confirmed %>
      </div>
    </div>

    <div class="rounded-xl bg-amber-400/[0.05] p-3 text-center">
      <div class="text-xs text-amber-300/70">Non confirmés</div>
      <div class="mt-1 text-xl font-semibold text-amber-300">
        <%= rejected %>
      </div>
    </div>
  </div>

  <details class="mt-4 rounded-2xl border border-white/10 bg-black/20">
    <summary class="cursor-pointer select-none px-4 py-3 text-sm font-semibold text-slate-300">
      Voir les <%= cases.size %> analyses Heavy Exchange
    </summary>

    <div class="space-y-3 border-t border-white/10 p-4">
      <% cases.each do |item| %>
        <%
          candidate =
            item[:candidate] == true ||
            item["candidate"] == true

          source_cluster =
            item[:source_cluster_id] ||
            item["source_cluster_id"]

          downstream_cluster =
            item[:downstream_cluster_id] ||
            item["downstream_cluster_id"]

          confidence =
            item[:confidence] ||
            item["confidence"]

          sweep_share =
            item[:sweep_share_percent] ||
            item["sweep_share_percent"]

          infrastructure_score =
            item[:infrastructure_score] ||
            item["infrastructure_score"]

          external_clusters =
            item[:external_clusters] ||
            item["external_clusters"]

          label_published =
            item[:label_published] == true ||
            item["label_published"] == true
        %>

        <article class="rounded-xl border border-white/10 bg-white/[0.025] p-4">
          <div class="flex flex-col justify-between gap-3 md:flex-row md:items-start">
            <div>
              <div class="font-semibold <%= candidate ? "text-emerald-200" : "text-amber-200" %>">
                <%= candidate ? "Infrastructure exchange confirmée" : "Infrastructure exchange non confirmée" %>
              </div>

              <div class="mt-1 font-mono text-xs text-slate-400">
                cluster <%= source_cluster || "—" %>
                →
                <%= downstream_cluster || "—" %>
              </div>
            </div>

            <span class="w-fit rounded-full border border-white/10 px-2.5 py-1 text-[10px] font-semibold text-slate-300">
              <%= label_published ? "LABEL PUBLIÉ" : "AUCUN LABEL" %>
            </span>
          </div>

          <dl class="mt-3 grid grid-cols-2 gap-2 text-xs md:grid-cols-4">
            <div class="rounded-lg bg-black/20 p-2">
              <dt class="text-slate-500">Confiance</dt>
              <dd class="mt-1 font-semibold text-white">
                <%= confidence.to_i %> %
              </dd>
            </div>

            <div class="rounded-lg bg-black/20 p-2">
              <dt class="text-slate-500">Sweep principal</dt>
              <dd class="mt-1 font-semibold text-white">
                <%= sweep_share.present? ? "#{number_with_precision(sweep_share, precision: 2)} %" : "—" %>
              </dd>
            </div>

            <div class="rounded-lg bg-black/20 p-2">
              <dt class="text-slate-500">Score infrastructure</dt>
              <dd class="mt-1 font-semibold text-white">
                <%= infrastructure_score.to_i %> / 100
              </dd>
            </div>

            <div class="rounded-lg bg-black/20 p-2">
              <dt class="text-slate-500">Clusters externes</dt>
              <dd class="mt-1 font-semibold text-white">
                <%= number_with_delimiter(external_clusters.to_i) %>
              </dd>
            </div>
          </dl>
        </article>
      <% end %>
    </div>
  </details>
</section>
