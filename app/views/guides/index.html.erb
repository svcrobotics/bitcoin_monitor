<% content_for :title, "Guides" %>

<div class="min-h-screen bg-gray-950 text-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <header class="mb-8">
      <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-white">
            Guides
          </h1>
          <p class="mt-2 text-sm sm:text-base text-gray-400 max-w-3xl">
            Documentation fonctionnelle et technique des modules de Bitcoin Monitor.
          </p>
        </div>

        <div class="text-xs text-gray-500">
          <span class="text-gray-300 font-medium"><%= @guides.size %></span> guide(s)
        </div>
      </div>
    </header>

    <% featured_guides = @guides.select { |g| g.respond_to?(:featured?) && g.featured? } %>
    <% other_guides = @guides - featured_guides %>

    <% if featured_guides.any? %>
      <section class="mb-10">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500">
            Modules clés
          </h2>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
          <% featured_guides.each do |guide| %>
            <%= link_to guide_path(guide),
                class: "group block rounded-2xl border border-gray-800 bg-gray-900/95 p-5 hover:border-purple-500/40 hover:bg-gray-900 transition" do %>

              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                  <div class="flex flex-wrap items-center gap-2 mb-3">
                    <% if guide.category.present? %>
                      <span class="inline-flex items-center rounded-full border border-gray-700 bg-gray-800 px-2.5 py-1 text-[11px] font-medium text-gray-300">
                        <%= guide.category %>
                      </span>
                    <% end %>

                    <% if guide.app_area.present? %>
                      <span class="inline-flex items-center rounded-full border border-purple-500/20 bg-purple-500/10 px-2.5 py-1 text-[11px] font-medium text-purple-300">
                        <%= guide.app_area %>
                      </span>
                    <% end %>
                  </div>

                  <h3 class="text-lg font-semibold text-white group-hover:text-purple-300 transition">
                    <%= guide.title %>
                  </h3>

                  <% if guide.excerpt.present? %>
                    <p class="mt-2 text-sm text-gray-400 leading-relaxed line-clamp-3">
                      <%= guide.excerpt %>
                    </p>
                  <% end %>
                </div>

                <div class="shrink-0 text-gray-600 group-hover:text-purple-300 transition">
                  →
                </div>
              </div>

              <div class="mt-4 flex items-center justify-between text-xs text-gray-500">
                <span><%= guide.slug %></span>
                <span>
                  <%= guide.updated_at.present? ? l(guide.updated_at, format: :short) : "—" %>
                </span>
              </div>
            <% end %>
          <% end %>
        </div>
      </section>
    <% end %>

    <section>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500">
          Tous les guides
        </h2>
      </div>

      <% if @guides.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
          <% @guides.each do |guide| %>
            <%= link_to guide_path(guide),
                class: "group block rounded-2xl border border-gray-800 bg-gray-900/95 p-5 hover:border-gray-700 hover:bg-gray-900 transition" do %>

              <div class="flex flex-wrap items-center gap-2 mb-3">
                <% if guide.category.present? %>
                  <span class="inline-flex items-center rounded-full border border-gray-700 bg-gray-800 px-2 py-0.5 text-[11px] font-medium text-gray-300">
                    <%= guide.category %>
                  </span>
                <% end %>

                <% if guide.app_area.present? %>
                  <span class="inline-flex items-center rounded-full border border-gray-700 bg-gray-800 px-2 py-0.5 text-[11px] font-medium text-gray-400">
                    <%= guide.app_area %>
                  </span>
                <% end %>

                <% if guide.respond_to?(:featured?) && guide.featured? %>
                  <span class="inline-flex items-center rounded-full border border-amber-500/20 bg-amber-500/10 px-2 py-0.5 text-[11px] font-medium text-amber-300">
                    Featured
                  </span>
                <% end %>
              </div>

              <h3 class="text-base font-semibold text-white group-hover:text-purple-300 transition">
                <%= guide.title %>
              </h3>

              <% if guide.excerpt.present? %>
                <p class="mt-2 text-sm text-gray-400 leading-relaxed line-clamp-3">
                  <%= guide.excerpt %>
                </p>
              <% else %>
                <p class="mt-2 text-sm text-gray-500">
                  Aucun résumé disponible.
                </p>
              <% end %>

              <div class="mt-4 flex items-center justify-between text-xs text-gray-500">
                <span class="truncate pr-3"><%= guide.slug %></span>
                <span class="shrink-0">→</span>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="rounded-2xl border border-gray-800 bg-gray-900/95 p-6 text-sm text-gray-400">
          Aucun guide publié pour le moment.
        </div>
      <% end %>
    </section>
  </div>
</div>