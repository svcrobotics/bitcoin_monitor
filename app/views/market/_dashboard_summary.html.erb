<%# app/views/.../_market_synthese.html.erb (exemple) %>
<section class="mt-6 bg-gray-900/40 border border-gray-800 rounded-2xl p-5 sm:p-6">
  <div class="flex items-start justify-between gap-3 mb-4">
    <div class="min-w-0">
      <h2 class="text-lg sm:text-xl font-semibold text-gray-100">
        <%= t("dashboard.market_summary.title") %>
      </h2>
      <p class="text-xs sm:text-sm text-gray-500 mt-1">
        <%= t("dashboard.market_summary.subtitle") %>
      </p>
    </div>

    <div class="shrink-0">
      <%= link_to "#{t("dashboard.market_summary.view")} →",
      (respond_to?(:market_price_path) ? market_price_path : "/market/price"),
      class: "text-xs font-semibold text-gray-300 hover:text-gray-100 transition" %>
    </div>
  </div>

  <%# ===================== SNAPSHOT / INDICATEURS ===================== %>
  <%= render "shared/market_snapshot", snapshot: snapshot if snapshot.present? %>

  <%#= render "market/one_liner", one_liner: one_liner if one_liner.present? %>

  <%= render "market/period_metrics",
        perf_pct: perf_pct,
        high: high,
        low: low,
        pos_pct: pos_pct,
        max_drawdown_pct: max_drawdown_pct,
        vol_label: vol_label,
        vol_pct: vol_pct %>

  <%= render "market/ma200",
        ma200: ma200,
        ma_badge: ma_badge,
        px_vs_ma200_pct: px_vs_ma200_pct,
        px_now: px_now %>

  <%# ===================== VERDICT (TRADER) ===================== %>
  <%= render "market/alignment",
        alignment: alignment,
        sell_verdict: sell_verdict %>

  <%# ===================== ALERTES TRADER ===================== %>
  <% if trader_alerts.present? %>
    <div class="mt-6">
      <%= render "market/trader_alerts",
            trader_alerts: trader_alerts,
            range: range,
            alerts_mode: alerts_mode,
            perf_pct: perf_pct,
            pos_pct: pos_pct,
            vol_pct: vol_pct,
            max_drawdown_pct: max_drawdown_pct,
            alignment: alignment %>
    </div>
  <% end %>
</section>
