<%# locals: alignment:, sell_verdict: (optionnel) %>
<% return unless alignment.present? %>

<% days = alignment.respond_to?(:days) ? alignment.days : nil %>
<% return unless days.present? %>

<section class="mt-4 bg-gray-800/80 border border-gray-700 rounded-2xl p-4 sm:p-5 shadow-xl">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
    <div class="min-w-0">
      <h2 class="text-lg font-semibold text-gray-100">Alignement Prix / Exchanges</h2>
      <p class="text-sm text-gray-400">
        Lecture sur <span class="font-mono"><%= days %>j</span> • flux nets vers exchanges (à recouper avec zones de prix)
      </p>
    </div>

    <% if alignment.respond_to?(:badge_cls) && alignment.respond_to?(:label) %>
      <span class="text-xs px-3 py-1 rounded-full border <%= alignment.badge_cls %>">
        <%= alignment.label %>
      </span>
    <% end %>
  </div>

  <!-- Metrics -->
  <div class="mt-4 grid grid-cols-1 sm:grid-cols-3 gap-3">
    <div class="bg-gray-900/60 border border-gray-700 rounded-xl p-3">
      <div class="text-xs text-gray-400">Net flow exchanges</div>
      <div class="text-lg font-semibold <%= alignment.flow_net_btc.to_f > 0 ? "text-rose-300" : (alignment.flow_net_btc.to_f < 0 ? "text-emerald-300" : "text-gray-200") %>">
        <%= alignment.flow_net_btc.to_f.positive? ? "+" : "" %>
        <%= number_with_precision(alignment.flow_net_btc, precision: 0, delimiter: " ") %> BTC
      </div>
      <div class="text-[11px] text-gray-500 mt-1">
        net = inflow − outflow • net &gt; 0 = pression vendeuse potentielle
      </div>
    </div>

    <div class="bg-gray-900/60 border border-gray-700 rounded-xl p-3">
      <div class="text-xs text-gray-400">Inflow</div>
      <div class="text-lg font-semibold text-gray-200">
        <span class="font-mono"><%= number_with_precision(alignment.flow_inflow_btc, precision: 0, delimiter: " ") %></span> BTC
      </div>
      <div class="text-[11px] text-gray-500 mt-1">
        dépôts vers exchanges (intention possible de vendre)
      </div>
    </div>

    <div class="bg-gray-900/60 border border-gray-700 rounded-xl p-3">
      <div class="text-xs text-gray-400">Outflow</div>
      <div class="text-lg font-semibold text-gray-200">
        <span class="font-mono"><%= number_with_precision(alignment.flow_outflow_btc, precision: 0, delimiter: " ") %></span> BTC
      </div>
      <div class="text-[11px] text-gray-500 mt-1">
        retraits des exchanges (réduction possible de pression vendeuse)
      </div>
    </div>
  </div>

  <% if alignment.respond_to?(:hint) && alignment.hint.present? %>
    <p class="mt-3 text-sm text-gray-200">
      <span class="text-gray-400">Lecture :</span>
      <%= alignment.hint %>
    </p>
  <% end %>

  <% if sell_verdict.present? %>
    <div class="mt-4 bg-gray-900/60 border border-gray-700 rounded-xl p-4">
      <div class="flex items-center justify-between gap-3">
        <div>
          <p class="text-xs uppercase tracking-wide text-gray-400">Ventes : confirmation</p>
          <p class="text-sm text-gray-200 mt-1"><%= sell_verdict[2] %></p>
        </div>
        <span class="text-xs px-3 py-1 rounded-full border <%= sell_verdict[1] %>">
          <%= sell_verdict[0] %>
        </span>
      </div>

      <p class="text-[11px] text-gray-500 mt-2">
        Inflow = intention • confirmation = réaction du prix après dépôts nets.
      </p>
    </div>
  <% end %>
</section>
