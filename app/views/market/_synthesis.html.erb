<%# app/views/market/_synthesis.html.erb %>
<%# locals: synthesis: %>
<% return unless synthesis.present? %>

<section class="mt-4 bg-indigo-900/20 border border-indigo-800 rounded-2xl p-4 sm:p-5">
  <div class="flex items-start justify-between gap-3">
    <div>
      <h3 class="text-sm sm:text-base font-semibold text-gray-100">
        <%= synthesis.title %> (<%= synthesis.window_days %>j)
      </h3>
      <p class="mt-1 text-xs sm:text-sm text-gray-400">
        Lecture macro issue des indicateurs ci-dessus.
        <span class="text-gray-500">Aucune prédiction.</span>
      </p>
    </div>

    <span class="text-xs px-3 py-1 rounded-full border <%= synthesis.badge_cls %>">
      Régime de marché
    </span>
  </div>

  <p class="mt-3 text-sm text-gray-200 leading-relaxed">
    <%= synthesis.summary %>
  </p>

  <p class="mt-2 text-[11px] text-gray-500">
    Cette synthèse décrit un <span class="font-semibold text-gray-400">régime de marché</span>,
    pas une opportunité d’achat ou de vente.
  </p>
</section>
