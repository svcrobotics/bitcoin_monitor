<% simple = respond_to?(:simple_mode?) && simple_mode? %>

<section class="mt-6 bg-gray-900/40 border border-gray-800 rounded-2xl p-5 sm:p-6">

  <%= render "market/header",
        range: @range,
        alerts_mode: @alerts_mode,
        trader_alerts: @trader_alerts,
        journal_body_all: @journal_body_all %>

  <div class="mt-4">
    <%= render "market/range_selector", range: @range, alerts_mode: @alerts_mode %>
  </div>

  <div class="mt-4">
    <%= render "market/pressure_index", pressure: @pressure_index %>
    <%= render "market/maturity_index", maturity: @maturity_index %>
    <%= render "market/absorption_index", absorption: @absorption_index %>
    <%= render "market/synthesis", synthesis: @market_synthesis %>
  </div>

  <%# ===================== MODE SIMPLE : DÉCISION D'ABORD ===================== %>
  <% if simple %>
    <div class="mt-4">
      <%= render "market/one_liner", one_liner: @one_liner %>
    </div>

    <div class="mt-4">
      <%= render "market/alignment", alignment: @alignment, sell_verdict: @sell_verdict %>
    </div>

    <p class="mt-3 text-xs text-gray-500 leading-relaxed">
      Pour <span class="text-gray-300 font-semibold">où</span> agir (achat/vente),
      regarde surtout les <span class="text-gray-200 font-semibold">Zones de prix</span> sur le dashboard.
    </p>
  <% end %>

  <%# ===================== GRAPH ===================== %>
  <div class="mt-5">
    <%= render "market/price_chart", price_series: @price_series %>
  </div>

  <%# ===================== CONTEXTE (SNAPSHOT) ===================== %>
  <% if @snapshot.present? %>
    <% if simple %>
      <details class="group mt-5">
        <summary class="cursor-pointer select-none text-xs font-semibold text-gray-300 hover:text-gray-100 inline-flex items-center gap-2">
          <span>Contexte marché</span>
          <span class="text-gray-500 group-open:hidden">▸</span>
          <span class="text-gray-500 hidden group-open:inline">▾</span>
        </summary>

        <div class="mt-3">
          <%= render "shared/market_snapshot", snapshot: @snapshot %>
        </div>
      </details>
    <% else %>
      <div class="mt-6">
        <%= render "shared/market_snapshot", snapshot: @snapshot %>
      </div>
    <% end %>
  <% end %>

  <%# ===================== MODE TRADER : ONE-LINER APRÈS LE GRAPH ===================== %>
  <% unless simple %>
    <div class="mt-4">
      <%= render "market/one_liner", one_liner: @one_liner %>
    </div>
  <% end %>

  <div class="mt-4">
    <%= render "market/period_metrics",
          perf_pct: @perf_pct,
          high: @high,
          low: @low,
          pos_pct: @pos_pct,
          max_drawdown_pct: @max_drawdown_pct,
          vol_label: @vol_label,
          vol_pct: @vol_pct %>
  </div>

  <div class="mt-4">
    <%= render "market/ma200",
          ma200: @ma200,
          ma_badge: @ma_badge,
          px_vs_ma200_pct: @px_vs_ma200_pct,
          px_now: @px_now %>
  </div>

  <%# ===================== ALIGNMENT (TRADER) ===================== %>
  <% unless simple %>
    <div class="mt-4">
      <%= render "market/alignment", alignment: @alignment, sell_verdict: @sell_verdict %>
    </div>
  <% end %>

  <%# ===================== ALERTS : DÉTAILS (SIMPLE) / PLEIN (TRADER) ===================== %>
  <% if @trader_alerts.present? %>
    <% if simple %>
      <div class="mt-6">
        <details class="group">
          <summary class="cursor-pointer select-none text-xs font-semibold text-gray-300 hover:text-gray-100 inline-flex items-center gap-2">
            <span>Signaux avancés</span>
            <span class="text-gray-500 group-open:hidden">▸</span>
            <span class="text-gray-500 hidden group-open:inline">▾</span>
          </summary>

          <div class="mt-3">
            <%= render "market/trader_alerts",
                  trader_alerts: @trader_alerts,
                  range: @range,
                  alerts_mode: @alerts_mode,
                  perf_pct: @perf_pct,
                  pos_pct: @pos_pct,
                  vol_pct: @vol_pct,
                  max_drawdown_pct: @max_drawdown_pct,
                  alignment: @alignment %>
          </div>
        </details>
      </div>
    <% else %>
      <div class="mt-6">
        <%= render "market/trader_alerts",
              trader_alerts: @trader_alerts,
              range: @range,
              alerts_mode: @alerts_mode,
              perf_pct: @perf_pct,
              pos_pct: @pos_pct,
              vol_pct: @vol_pct,
              max_drawdown_pct: @max_drawdown_pct,
              alignment: @alignment %>
      </div>
    <% end %>
  <% end %>

</section>
