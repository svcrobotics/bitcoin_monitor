<%# app/views/market/_range_selector.html.erb %>
<%# locals: range:, alerts_mode: %>

<div class="mt-4 flex flex-wrap gap-2">
  <% { "7d" => "7 jours", "30d" => "30 jours", "1y" => "1 an" }.each do |key, label| %>
    <% active = (range.to_s == key) %>

    <% merged_params = request.query_parameters.merge("range" => key) %>
    <%# garde alerts_mode si présent, sinon ne force rien %>
    <% if local_assigns[:alerts_mode].present? %>
      <% merged_params["alerts_mode"] = alerts_mode %>
    <% else %>
      <% merged_params.delete("alerts_mode") %>
    <% end %>

    <%= link_to label,
                url_for(merged_params),
                class: "px-3 py-1.5 rounded-xl border text-sm transition " +
                       (active ? "bg-indigo-500/15 border-indigo-500/50 text-indigo-200"
                               : "bg-gray-900/60 border-gray-700 text-gray-300 hover:bg-gray-800") %>
  <% end %>
</div>
