<%= turbo_frame_tag "layer1_audit_panel" do %>
  <% last_audit ||= nil %>
  <% last_audits = Array(last_audits) %>
  <% checks = last_audit&.checks || {} %>
  <% total = checks.size %>
  <% ok = checks.count { |_name, result| result["passed"] } %>
  <% compliance = total.zero? ? 0 : ((ok.to_f / total) * 100).round %>

  <section class="mt-8 rounded-2xl border border-slate-800 bg-slate-950 p-6 text-slate-100">
    <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
      <div>
        <p class="text-sm font-semibold text-blue-400">Preuve Layer1</p>

        <h2 class="mt-1 text-2xl font-bold text-white">
          Bitcoin Core ↔ Tansa
        </h2>

        <p class="mt-2 max-w-3xl text-sm text-slate-400">
          Les données affichées par Tansa sont comparées directement à Bitcoin Core,
          la source de vérité du réseau Bitcoin.
        </p>
      </div>

      <%= button_to "Vérifier maintenant",
        system_layer1_audit_run_path,
        method: :post,
        data: { turbo_stream: true },
        class: "rounded-xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-500" %>
    </div>

    <% if last_audit %>
      <div class="mt-6 grid gap-3 md:grid-cols-4">
        <div class="rounded-xl border border-slate-800 bg-slate-900 p-4">
          <p class="text-xs uppercase tracking-wide text-slate-500">
            Bloc audité
          </p>
          <p class="mt-2 text-3xl font-bold text-white">
            <%= last_audit.audited_height %>
          </p>
        </div>

        <div class="rounded-xl border border-slate-800 bg-slate-900 p-4">
          <p class="text-xs uppercase tracking-wide text-slate-500">
            Conformité
          </p>
          <p class="mt-2 text-3xl font-bold text-emerald-400">
            <%= compliance %>%
          </p>
        </div>

        <div class="rounded-xl border border-slate-800 bg-slate-900 p-4">
          <p class="text-xs uppercase tracking-wide text-slate-500">
            Contrôles
          </p>
          <p class="mt-2 text-3xl font-bold text-white">
            <%= ok %>/<%= total %>
          </p>
        </div>

        <div class="rounded-xl border border-slate-800 bg-slate-900 p-4">
          <p class="text-xs uppercase tracking-wide text-slate-500">
            Dernière vérification
          </p>
          <p class="mt-2 text-lg font-bold text-white">
            <%= last_audit.created_at.strftime("%d/%m %H:%M") %>
          </p>
        </div>
      </div>

      <div class="mt-6 rounded-xl border <%= compliance == 100 ? 'border-emerald-500/20 bg-emerald-500/5' : 'border-red-500/20 bg-red-500/5' %> p-4">
        <% if compliance == 100 %>
          <p class="text-sm text-emerald-300">
            ✓ Les données affichées par Tansa sont actuellement conformes à Bitcoin Core.
            Aucune divergence n'a été détectée lors du dernier audit.
          </p>
        <% else %>
          <p class="text-sm text-red-300">
            ⚠ Une divergence a été détectée entre Bitcoin Core et les données stockées par Tansa.
          </p>
        <% end %>
      </div>

      <% mapping = {
        "tx_count_matches" => "Transactions",
        "block_exists_in_db" => "Bloc",
        "block_hash_matches" => "Hash",
        "outputs_count_matches" => "Outputs",
        "outputs_value_matches" => "Valeur BTC"
      } %>

      <div class="mt-6 overflow-hidden rounded-xl border border-slate-800">
        <table class="w-full text-sm">
          <thead class="bg-slate-900 text-slate-400">
            <tr>
              <th class="px-4 py-3 text-left">Contrôle</th>
              <th class="px-4 py-3 text-left">Bitcoin Core</th>
              <th class="px-4 py-3 text-left">Tansa</th>
              <th class="px-4 py-3 text-left">Validation</th>
            </tr>
          </thead>

          <tbody>
            <% checks.each do |name, result| %>
              <% passed = result["passed"] %>

              <tr class="border-t border-slate-800">
                <td class="px-4 py-3 font-medium text-white">
                  <%= mapping[name] || name.humanize %>
                </td>

                <td class="px-4 py-3 font-mono text-xs text-slate-300">
                  <%= result["bitcoin_core"] || "—" %>
                </td>

                <td class="px-4 py-3 font-mono text-xs text-slate-300">
                  <%= result["postgresql"] || "—" %>
                </td>

                <td class="px-4 py-3">
                  <% if passed %>
                    <span class="inline-flex rounded-full bg-emerald-500/10 px-3 py-1 text-xs font-semibold text-emerald-300 ring-1 ring-emerald-500/30">
                      Conforme
                    </span>
                  <% else %>
                    <span class="inline-flex rounded-full bg-red-500/10 px-3 py-1 text-xs font-semibold text-red-300 ring-1 ring-red-500/30">
                      Divergence
                    </span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="mt-6 rounded-xl border border-yellow-900/40 bg-yellow-950/20 p-4">
        <p class="text-sm text-yellow-200">
          Aucun audit disponible. Lancez une vérification pour comparer Bitcoin Core et Tansa.
        </p>
      </div>
    <% end %>
  </section>
<% end %>