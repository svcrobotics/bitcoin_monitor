  <!-- Jobs -->
  <section class="<%= section_class %>">
    <div class="mb-5">
      <div class="<%= label_class %>">Cron supervision</div>
      <h2 class="mt-1 text-xl font-semibold text-gray-100">Jobs détaillés</h2>
      <p class="mt-2 <%= muted_class %>">
        Vue compacte des exécutions, retards, durées, heartbeat et état opérationnel.
      </p>
    </div>

    <div class="rounded-xl border border-white/10 overflow-hidden">
      <table class="w-full table-fixed text-xs">
        <thead class="bg-black/20 text-gray-400">
          <tr class="text-left">
            <th class="py-3 px-3 w-[18%]">Job</th>
            <th class="py-3 px-3 w-[8%]">Cat.</th>
            <th class="py-3 px-3 w-[8%]">Cron</th>
            <th class="py-3 px-3 w-[8%]">Statut</th>
            <th class="py-3 px-3 w-[16%]">Exécution</th>
            <th class="py-3 px-3 w-[12%]">Durées</th>
            <th class="py-3 px-3 w-[10%]">Retard</th>
            <th class="py-3 px-3 w-[10%]">Runtime</th>
            <th class="py-3 px-3 w-[5%]">Lock</th>
            <th class="py-3 px-3 w-[5%]">Exit</th>
          </tr>
        </thead>

        <tbody class="text-gray-300">
          <% @job_health.each do |job| %>
            <tr class="border-t border-white/5 align-top hover:bg-white/5 transition">
              <td class="py-3 px-3">
                <div class="font-medium text-gray-100 truncate"><%= job[:label] || job[:name] %></div>
                <div class="mt-1 font-mono text-[10px] text-gray-500 truncate"><%= job[:name] %></div>

                <% if job[:command].present? %>
                  <div class="mt-1 font-mono text-[10px] text-gray-600 truncate"><%= job[:command] %></div>
                <% end %>

                <div class="mt-2 flex flex-wrap gap-1">
                  <% if job[:critical] %>
                    <span class="inline-flex rounded-full px-2 py-0.5 text-[10px] text-amber-300 bg-amber-500/10 border border-amber-500/20">
                      critical
                    </span>
                  <% end %>

                  <% unless job[:active] %>
                    <span class="inline-flex rounded-full px-2 py-0.5 text-[10px] text-gray-400 bg-gray-500/10 border border-gray-500/20">
                      disabled
                    </span>
                  <% end %>
                </div>
              </td>

              <td class="py-3 px-3">
                <div class="truncate"><%= job[:category] || "—" %></div>
                <div class="mt-1 text-[10px] text-gray-500 font-mono"><%= job[:last_triggered_by] || "—" %></div>
              </td>

              <td class="py-3 px-3 font-mono text-[10px] break-words">
                <%= job[:cron] || "—" %>
              </td>

              <td class="py-3 px-3">
                <span class="inline-flex items-center rounded-full px-2.5 py-1 text-[10px] font-semibold <%= status_badge_class(job[:status]) %>">
                  <%= job[:status].to_s.upcase %>
                </span>

                <div class="mt-2 space-y-1 text-[10px]">
                  <div class="text-emerald-300 truncate">ok: <%= safe_time(job[:last_ok_at]) %></div>
                  <div class="text-rose-300 truncate">fail: <%= safe_time(job[:last_fail_at]) %></div>
                  <div class="text-orange-300 truncate">skip: <%= safe_time(job[:last_skipped_at]) %></div>
                </div>
              </td>

              <td class="py-3 px-3 font-mono text-[10px]">
                <div class="truncate text-gray-200">start: <%= safe_time(job[:last_run_at]) %></div>
                <div class="truncate text-gray-400 mt-1">end: <%= safe_time(job[:last_finish_at]) %></div>
                <div class="truncate text-gray-500 mt-1">hb: <%= safe_seconds(job[:heartbeat_age_seconds]) %></div>
              </td>

              <td class="py-3 px-3 font-mono text-[10px]">
                <div class="truncate text-gray-200">last: <%= safe_duration_ms(job[:last_duration_ms]) %></div>
                <div class="truncate text-gray-400 mt-1">avg10: <%= safe_duration_ms(job[:avg_duration_ms]) %></div>
                <div class="truncate text-gray-500 mt-1">max10: <%= safe_duration_ms(job[:max_duration_ms]) %></div>
              </td>

              <td class="py-3 px-3 font-mono text-[10px]">
                <div class="<%= job[:delay_seconds].to_i > 0 ? "text-amber-300" : "text-gray-200" %>">
                  delay: <%= safe_seconds(job[:delay_seconds]) %>
                </div>
                <div class="mt-1 text-gray-400">
                  missed: <%= job[:missed_runs] || 0 %>
                </div>
                <div class="mt-1 <%= job[:capacity_status] == "over" ? "text-rose-300" : job[:capacity_status] == "tight" ? "text-amber-300" : "text-emerald-300" %>">
                  capacity: <%= job[:capacity_status] || "unknown" %>
                </div>
                <div class="mt-1 text-orange-300">
                  skips10: <%= job[:skips_in_last_10] || 0 %>
                </div>
              </td>

              <td class="py-3 px-3 font-mono text-[10px]">
                <div class="text-sky-300 truncate">
                  <%= safe_seconds(job[:current_runtime_seconds]) %>
                </div>

                <% if job[:progress_pct].present? || job[:progress_label].present? %>
                  <% pct = [[job[:progress_pct].to_f, 0].max, 100].min %>

                  <div class="mt-2">
                    <% if job[:progress_pct].present? %>
                      <div class="flex items-center justify-between mb-1">
                        <span class="text-gray-500">progress</span>
                        <span class="text-gray-300"><%= pct.round(1) %>%</span>
                      </div>

                      <div class="h-1.5 rounded-full bg-white/10 overflow-hidden">
                        <div
                          class="h-full bg-sky-400 rounded-full"
                          style="width: <%= pct %>%">
                        </div>
                      </div>
                    <% end %>

                    <% if job[:progress_label].present? %>
                      <div class="mt-1 text-[10px] text-gray-500 truncate">
                        <%= job[:progress_label] %>
                      </div>
                    <% end %>
                  </div>
                <% elsif job[:status].to_s.in?(%w[running stuck long_running]) %>
                  <div class="mt-2 text-[10px] text-gray-500 leading-4">
                    progression non exposée
                  </div>
                <% end %>
              </td>

              <td class="py-3 px-3 text-[10px]">
                <span class="<%= job[:lock_present] ? "text-amber-300" : "text-gray-500" %>">
                  <%= job[:lock_present] ? "yes" : "no" %>
                </span>
              </td>

              <td class="py-3 px-3 font-mono text-[10px]">
                <%= job[:last_exit_code].nil? ? "—" : job[:last_exit_code] %>
              </td>
            </tr>

            <% if job[:last_error].present? %>
              <tr class="border-t border-white/5">
                <td colspan="10" class="px-3 pb-4">
                  <div class="rounded-lg border border-rose-500/20 bg-black/30 p-3 text-[10px] text-rose-200 whitespace-pre-wrap break-words">
                    <%= job[:last_error] %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% end %>

          <% if @job_health.blank? %>
            <tr>
              <td colspan="10" class="py-6 px-4 text-sm text-gray-500">Aucune donnée job disponible.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <!-- Scanners -->
  <section class="<%= section_class %>">
    <div class="mb-5">
      <div class="<%= label_class %>">Scanner cursors</div>
      <h2 class="mt-1 text-xl font-semibold text-gray-100">État des scanners</h2>
      <p class="mt-2 <%= muted_class %>">
        Dernier bloc scanné, best block, lag et date de mise à jour.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <% (@scanner_status || {}).each do |key, s| %>
        <% scanner_status = (s[:status] || :warn).to_s %>
        <div class="<%= panel_class %>">
          <div class="flex items-start justify-between gap-3">
            <div>
              <div class="text-base font-semibold text-gray-100"><%= s[:label] || key %></div>
            </div>
            <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(scanner_status) %>">
              <%= scanner_status.upcase %>
            </span>
          </div>

          <% if s[:error].present? %>
            <pre class="mt-4 text-xs text-rose-200 whitespace-pre-wrap"><%= s[:error] %></pre>
          <% else %>
            <div class="mt-4 space-y-2 text-sm">
              <div class="flex items-center justify-between">
                <span class="text-gray-500">Last scanned</span>
                <span class="font-mono text-gray-200"><%= s[:last_blockheight] || "—" %></span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-gray-500">Best block</span>
                <span class="font-mono text-gray-200"><%= s[:best_height] || "—" %></span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-gray-500">Lag</span>
                <span class="font-mono <%= s[:lag].to_i > 12 ? "text-rose-300" : "text-gray-200" %>"><%= s[:lag] || "—" %></span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-gray-500">Updated</span>
                <span class="font-mono text-gray-200"><%= safe_time(s[:updated_at]) %></span>
              </div>
              <% if s[:last_blockhash].present? %>
                <div>
                  <div class="text-gray-500 mb-1">Hash</div>
                  <div class="font-mono text-xs text-gray-400 break-all"><%= s[:last_blockhash] %></div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>

      <% if @scanner_status.blank? %>
        <div class="text-sm text-gray-500">Aucun scanner disponible.</div>
      <% end %>
    </div>
  </section>

  <!-- Tables -->
  <section class="<%= section_class %>">
    <div class="mb-5">
      <div class="<%= label_class %>">Data freshness</div>
      <h2 class="mt-1 text-xl font-semibold text-gray-100">État des tables</h2>
      <p class="mt-2 <%= muted_class %>">
        Volume, fraîcheur, âge des données et retard éventuel par rapport aux attentes.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 2xl:grid-cols-3 gap-4">
      <% (@tables || {}).each do |name, table| %>
        <%
          raw_last = table[:last_at] || table[:last_day]

          last_time =
            case raw_last
            when Time, ActiveSupport::TimeWithZone, DateTime then raw_last
            when Date then raw_last.in_time_zone
            when String
              begin
                Time.zone.parse(raw_last)
              rescue
                nil
              end
            else
              nil
            end

          table_status = (table[:status] || :warn).to_s
          daily_table  = table[:min_day].present?

          age_h =
            if table.key?(:age_h)
              table[:age_h].to_f
            elsif last_time
              ((Time.current - last_time) / 3600.0)
            end

          last_day =
            if daily_table
              last_time&.to_date
            end

          expected_day =
            if daily_table
              begin
                table[:min_day].to_date
              rescue
                nil
              end
            end
        %>

        <div class="<%= panel_class %>">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <div class="text-sm font-semibold text-gray-100 break-words"><%= name %></div>
            </div>

            <span class="shrink-0 inline-flex items-center rounded-full px-2.5 py-1 text-[11px] font-semibold <%= status_badge_class(table_status) %>">
              <%= table_status.upcase %>
            </span>
          </div>

          <div class="mt-4 grid grid-cols-2 gap-x-4 gap-y-2 text-xs">
            <div class="text-gray-500">Count</div>
            <div class="text-right font-mono text-gray-200 truncate"><%= table[:count] || "—" %></div>

            <div class="text-gray-500">Last</div>
            <div class="text-right font-mono text-gray-200 break-words">
              <% if last_time %>
                <%= daily_table ? last_time.to_date.strftime("%Y-%m-%d") : last_time.strftime("%Y-%m-%d %H:%M") %>
              <% else %>
                —
              <% end %>
            </div>

            <% if daily_table %>
              <div class="text-gray-500">Attendu</div>
              <div class="text-right font-mono text-gray-200">
                <%= expected_day ? expected_day.strftime("%Y-%m-%d") : "—" %>
              </div>

              <div class="text-gray-500">Dernier jour</div>
              <div class="text-right font-mono text-gray-200">
                <%= last_day ? last_day.strftime("%Y-%m-%d") : "—" %>
              </div>

              <div class="text-gray-500">Retard</div>
              <div class="text-right font-mono <%= expected_day && last_day && last_day < expected_day ? "text-rose-300" : "text-gray-200" %>">
                <% if expected_day && last_day && last_day < expected_day %>
                  <%= (expected_day - last_day).to_i %>j
                <% else %>
                  0j
                <% end %>
              </div>
            <% else %>
              <div class="text-gray-500">Âge</div>
              <div class="text-right font-mono text-gray-200">
                <%= age_h ? "#{age_h.round(1)}h" : "—" %>
              </div>

              <div class="text-gray-500">SLA</div>
              <div class="text-right font-mono text-gray-200">
                <%= table[:sla_h].present? ? "#{table[:sla_h]}h" : "—" %>
              </div>
            <% end %>
          </div>

          <% if table[:hint].present? %>
            <div class="mt-4 border-t border-white/5 pt-3 text-xs text-gray-400 leading-5">
              <%= table[:hint] %>
            </div>
          <% end %>
        </div>
      <% end %>

      <% if @tables.blank? %>
        <div class="text-sm text-gray-500">Aucune métrique de table disponible.</div>
      <% end %>
    </div>
  </section>

  <!-- QA -->
  <section class="<%= section_class %>">
    <div class="flex items-center justify-between gap-4">
      <div>
        <div class="<%= label_class %>">Quality assurance</div>
        <h2 class="mt-1 text-xl font-semibold text-gray-100">QA / Tests</h2>
        <p class="mt-2 <%= muted_class %>">
          Accès à la page de validation et aux contrôles de non-régression.
        </p>
      </div>

      <%= link_to "Ouvrir QA / Tests",
          system_tests_path,
          class: "inline-flex items-center rounded-xl border border-violet-500/20 bg-violet-500/10 px-4 py-2 text-sm font-medium text-violet-300 hover:bg-violet-500/15 transition" %>
    </div>
  </section>

  <!-- Recent JobRuns -->
  <section class="<%= section_class %>">
    <div class="mb-5">
      <div class="<%= label_class %>">Recent execution log</div>
      <h2 class="mt-1 text-xl font-semibold text-gray-100">Dernières exécutions</h2>
      <p class="mt-2 <%= muted_class %>">
        Historique récent des `JobRun`, utile pour comprendre la chronologie effective des opérations.
      </p>
    </div>

    <div class="overflow-x-auto rounded-xl border border-white/10">
      <table class="min-w-full text-sm">
        <thead class="bg-black/20 text-gray-400">
          <tr class="text-left">
            <th class="py-3 px-4">Job</th>
            <th class="py-3 px-4">Statut</th>
            <th class="py-3 px-4">Début</th>
            <th class="py-3 px-4">Fin</th>
            <th class="py-3 px-4">Durée</th>
            <th class="py-3 px-4">Exit</th>
            <th class="py-3 px-4">Erreur</th>
          </tr>
        </thead>

        <tbody class="text-gray-300">
          <% @jobs.first(30).each do |jr| %>
            <tr class="border-t border-white/5 align-top hover:bg-white/5 transition">
              <td class="py-3 px-4">
                <div class="font-mono text-xs text-gray-200"><%= jr.name %></div>
              </td>
              <td class="py-3 px-4">
                <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(jr.status) %>">
                  <%= jr.status.to_s.upcase %>
                </span>
              </td>
              <td class="py-3 px-4 font-mono text-xs"><%= safe_time(jr.started_at || jr.created_at) %></td>
              <td class="py-3 px-4 font-mono text-xs"><%= safe_time(jr.finished_at) %></td>
              <td class="py-3 px-4 font-mono text-xs"><%= safe_duration_ms(jr.duration_ms) %></td>
              <td class="py-3 px-4 font-mono text-xs"><%= jr.exit_code.nil? ? "—" : jr.exit_code %></td>
              <td class="py-3 px-4 text-xs text-gray-400">
                <%= jr.error.to_s.first(220).presence || "—" %>
              </td>
            </tr>
          <% end %>

          <% if @jobs.blank? %>
            <tr>
              <td colspan="7" class="py-6 px-4 text-sm text-gray-500">Aucun JobRun récent disponible.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>