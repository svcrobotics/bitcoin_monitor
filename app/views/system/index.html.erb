        <div class="mt-3 space-y-2 text-sm">
          <div class="flex justify-between">
            <span class="text-gray-500">Fast path</span>
            <span class="font-mono text-gray-200">
              <%= ENV.fetch("LAYER1_FAST_PATH", "true") == "true" ? "enabled" : "disabled" %>
            </span>
          </div>

          <div class="flex justify-between">
            <span class="text-gray-500">Process queue</span>
            <span class="font-mono <%= layer1[:process_queue_size].to_i > 0 ? "text-amber-300" : "text-gray-200" %>">
              <%= layer1[:process_queue_size] || 0 %>
            </span>
          </div>
        </div>

        <p class="mt-3 <%= muted_class %>">
          Layer 1 rapide ; spent state et flows sont résolus en asynchrone.
        </p>
      </div>
