<!-- app/views/system/index.html.erb -->
<% @checks ||= {} %>
<% @recovery ||= {} %>
<% @anomalies ||= [] %>
<% @snapshot ||= {} %>
<% @recovery_snapshot ||= {} %>
<% @cluster_pipeline_status ||= {} %>
<% @actor_labels_status ||= {} %>
<% @actor_profiles_runtime ||= {} %>
<% @realtime ||= {} %>
<% @recent_blocks ||= [] %>

<% layer1 = @recovery_snapshot[:layer1] || {} %>
<% layer1_counts = layer1[:status_counts] || {} %>
<% layer1_redis = layer1[:redis_buffers] || {} %>
<% cluster_batch = @cluster_pipeline_status[:batch] || {} %>
<% cluster_realtime = @cluster_pipeline_status[:realtime] || {} %>
<% actor_labels = @actor_labels_status || {} %>
<% actor_profiles_runtime = @actor_profiles_runtime || {} %>
<% actor_profile_queues = actor_profiles_runtime[:queues] || {} %>

<%
  section_class = "rounded-2xl border border-white/10 bg-white/5 p-5 shadow-sm"
  panel_class   = "rounded-xl border border-white/10 bg-black/20 p-4"
  label_class   = "text-[11px] uppercase tracking-[0.14em] text-gray-500"
  muted_class   = "text-sm text-gray-400"

  bitcoind = @checks[:bitcoind] || {}
  blockchain = @checks[:bitcoind_activity] || {}
  disks = @checks[:disks] || {}
  disk_cards = [disks[:bitcoind], disks[:data], disks[:system]].compact

  exchange_like_count = actor_labels[:exchange_like].to_i
  whale_like_count = actor_labels[:whale_like].to_i
  etf_candidate_count = actor_labels[:etf_candidate].to_i
  service_like_count = actor_labels[:service_like].to_i
  retail_like_count = actor_labels[:retail_like].to_i
  unknown_count = actor_labels[:unknown].to_i
  total_labels = actor_labels[:total].to_i

  actor_profile_count = actor_profiles_runtime[:profiles_count].to_i

  cluster_input_count = defined?(ClusterInput) ? (ClusterInput.count rescue 0) : 0
  cluster_input_max_id = defined?(ClusterInput) ? (ClusterInput.maximum(:id) rescue nil) : nil
  cluster_input_max_height = defined?(ClusterInput) ? (ClusterInput.maximum(:block_height) rescue nil) : nil
  cluster_input_max_spent_height = defined?(ClusterInput) ? (ClusterInput.maximum(:spent_block_height) rescue nil) : nil

  utxo_output_count = defined?(UtxoOutput) ? (UtxoOutput.count rescue 0) : 0
  utxo_output_min_height = defined?(UtxoOutput) ? (UtxoOutput.minimum(:block_height) rescue nil) : nil
  utxo_output_max_height = defined?(UtxoOutput) ? (UtxoOutput.maximum(:block_height) rescue nil) : nil
  utxo_output_last_at = defined?(UtxoOutput) ? (UtxoOutput.maximum(:created_at) rescue nil) : nil

  tx_output_count = defined?(TxOutput) ? (TxOutput.count rescue 0) : 0
  tx_output_max_height = defined?(TxOutput) ? (TxOutput.maximum(:block_height) rescue nil) : nil

  latest_exchange_flow_height = defined?(ExchangeCoreFlowEvent) ? (ExchangeCoreFlowEvent.maximum(:block_height) rescue nil) : nil

  layer1_best_height = layer1[:best_height] || layer1[:highest_buffered_height] || blockchain[:blocks]
  layer1_processed_height = layer1[:last_processed_height]
  layer1_lag = layer1[:lag].to_i
  redis_outputs = layer1_redis[:outputs_buffer].to_i
  redis_spent = layer1_redis[:spent_outputs_buffer].to_i
  redis_total = redis_outputs + redis_spent

  utxo_coverage_state =
    if utxo_output_count.zero?
      "critical"
    elsif utxo_output_max_height.to_i < layer1_processed_height.to_i
      "warning"
    else
      "ok"
    end

  cluster_transition_state =
    if cluster_input_count.zero?
      "warning"
    elsif cluster_input_max_spent_height.to_i < utxo_output_min_height.to_i
      "warning"
    else
      "ok"
    end

  global_state =
    if @recovery[:critical_problems_count].to_i > 0
      "critical"
    elsif @anomalies.any? || layer1_lag.positive? || redis_outputs > 500_000
      "warning"
    else
      "ok"
    end

  def status_badge_class(status)
    case status.to_s
    when "ok", "ready", "healthy", "fresh"
      "text-emerald-300 bg-emerald-500/10 border border-emerald-500/20"
    when "running", "processing", "active"
      "text-sky-300 bg-sky-500/10 border border-sky-500/20"
    when "warning", "late", "delayed", "skipped", "waiting"
      "text-amber-300 bg-amber-500/10 border border-amber-500/20"
    when "stuck", "failing", "fail", "failed", "stale", "critical", "never_ran"
      "text-rose-300 bg-rose-500/10 border border-rose-500/20"
    else
      "text-gray-300 bg-gray-500/10 border border-gray-500/20"
    end
  end

  def safe_time(value)
    return "—" if value.blank?
    value.respond_to?(:strftime) ? value.strftime("%Y-%m-%d %H:%M:%S") : value.to_s
  rescue
    value.to_s
  end

  def safe_seconds(value)
    return "—" if value.blank?
    total_seconds = value.to_i
    minutes = total_seconds / 60
    seconds = total_seconds % 60
    minutes.positive? ? "#{minutes}m #{seconds}s" : "#{seconds}s"
  rescue
    "—"
  end

  def yes_no_badge(value)
    value ? "OK" : "FAIL"
  end
%>

<div class="w-full max-w-none mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">
  <section class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <div class="<%= label_class %>">Operations dashboard</div>
      <h1 class="mt-2 text-3xl font-bold text-gray-100">System</h1>
      <p class="mt-2 max-w-4xl <%= muted_class %>">
        Cockpit Tansa : Bitcoin Core → UTXO Outputs → Cluster Inputs → Cluster → Actor Profiles → Actor Labels → Layer 2.
      </p>
    </div>

    <div class="flex flex-col items-start gap-2 lg:items-end">
      <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold <%= status_badge_class(global_state) %>">
        <%= global_state.upcase %>
      </span>
      <div class="text-xs text-gray-500 font-mono">
        snapshot:
        <span class="text-gray-300"><%= safe_time(@snapshot[:generated_at] || Time.current) %></span>
      </div>
    </div>
  </section>

  <section class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-6">
    <div class="<%= section_class %>">
      <div class="<%= label_class %>">Global status</div>
      <div class="mt-3 text-2xl font-bold <%= global_state == "ok" ? "text-emerald-300" : global_state == "warning" ? "text-amber-300" : "text-rose-300" %>">
        <%= global_state.upcase %>
      </div>
      <div class="mt-2 text-xs text-gray-500">santé générale</div>
    </div>

    <div class="<%= section_class %>">
      <div class="<%= label_class %>">Layer 1 lag</div>
      <div class="mt-3 text-2xl font-bold <%= layer1_lag > 0 ? "text-amber-300" : "text-emerald-300" %>">
        <%= layer1_lag %>
      </div>
      <div class="mt-2 text-xs text-gray-500">blocs de retard</div>
    </div>

    <div class="<%= section_class %>">
      <div class="<%= label_class %>">Redis outputs</div>
      <div class="mt-3 text-2xl font-bold <%= redis_outputs.positive? ? "text-amber-300" : "text-emerald-300" %>">
        <%= number_with_delimiter(redis_outputs) %>
      </div>
      <div class="mt-2 text-xs text-gray-500">buffer à flusher</div>
    </div>

    <div class="<%= section_class %>">
      <div class="<%= label_class %>">UTXO outputs</div>
      <div class="mt-3 text-2xl font-bold text-cyan-300">
        <%= number_with_delimiter(utxo_output_count) %>
      </div>
      <div class="mt-2 text-xs text-gray-500">max height <%= utxo_output_max_height || "—" %></div>
    </div>

    <div class="<%= section_class %>">
      <div class="<%= label_class %>">Cluster inputs</div>
      <div class="mt-3 text-2xl font-bold text-purple-300">
        <%= number_with_delimiter(cluster_input_count) %>
      </div>
      <div class="mt-2 text-xs text-gray-500">max spent <%= cluster_input_max_spent_height || "—" %></div>
    </div>

    <div class="<%= section_class %>">
      <div class="<%= label_class %>">Validated actors</div>
      <div class="mt-3 text-2xl font-bold text-emerald-300">
        <%= number_with_delimiter(exchange_like_count + whale_like_count + etf_candidate_count) %>
      </div>
      <div class="mt-2 text-xs text-gray-500">exchange · whale · ETF</div>
    </div>
  </section>

  <%= render "system/layer1/block_chain_stream", blocks: @recent_blocks %>

  <section class="<%= section_class %>">
    <div class="mb-5">
      <div class="<%= label_class %>">Canonical architecture</div>
      <h2 class="mt-1 text-xl font-semibold text-gray-100">UTXO Outputs → Cluster Inputs → Cluster → Actor Profiles → Actor Labels → Layer 2</h2>
      <p class="mt-2 <%= muted_class %>">
        <span class="font-mono text-cyan-300">utxo_outputs</span> est la table vivante des UTXO disponibles.
        <span class="font-mono text-cyan-300">cluster_inputs</span> est la table analytique des outputs dépensés utilisée par Cluster et Actor Profiles.
        <span class="font-mono text-gray-500">tx_outputs</span> reste une source historique de transition, mais n’est plus dans le chemin critique.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-4 xl:grid-cols-6">
      <% [
        ["1", "UTXO Outputs", "État vivant des UTXO", "utxo_outputs", utxo_coverage_state],
        ["2", "Cluster Inputs", "Spends enrichis pour clustering", "cluster_inputs", cluster_transition_state],
        ["3", "Cluster", "Regroupement d’adresses", "address graph", @cluster_pipeline_status[:status].presence || "unknown"],
        ["4", "Actor Profiles", "Scores et comportements", "profiles", actor_profile_count.positive? ? "ok" : "warning"],
        ["5", "Actor Labels", "exchange_like, whale_like, etf_candidate", "labels", total_labels.positive? ? "ok" : "warning"],
        ["6", "Layer 2", "Flows, alerts, signals", "business intelligence", (exchange_like_count + whale_like_count + etf_candidate_count).positive? ? "ok" : "waiting"]
      ].each do |step, title, body, purpose, status| %>
        <div class="rounded-2xl border border-white/10 bg-slate-950/50 p-4">
          <div class="flex items-center justify-between gap-3">
            <div class="flex items-center gap-3">
              <div class="flex h-8 w-8 items-center justify-center rounded-full bg-cyan-500/10 text-sm font-bold text-cyan-300"><%= step %></div>
              <div class="text-base font-semibold text-gray-100"><%= title %></div>
            </div>
            <span class="rounded-full px-2 py-1 text-[10px] font-semibold <%= status_badge_class(status) %>"><%= status.to_s.upcase %></span>
          </div>
          <p class="mt-3 text-sm text-gray-300"><%= body %></p>
          <p class="mt-2 text-xs text-gray-500"><%= purpose %></p>
        </div>
      <% end %>
    </div>
  </section>

  <section class="<%= section_class %>">
    <div class="mb-5 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <div class="<%= label_class %>">Infrastructure</div>
        <h2 class="mt-1 text-xl font-semibold text-gray-100">Bitcoin Core, RPC, ZMQ et stockage</h2>
      </div>
      <%= link_to "Ouvrir Recovery center",
          system_recovery_path,
          class: "inline-flex items-center rounded-xl border border-sky-500/20 bg-sky-500/10 px-4 py-2 text-sm font-medium text-sky-300 hover:bg-sky-500/15 transition" %>
    </div>

    <div class="grid grid-cols-1 gap-5 xl:grid-cols-3">
      <div class="xl:col-span-2 rounded-xl border border-white/10 bg-black/20 p-4">
        <div class="mb-4">
          <div class="<%= label_class %>">Core blockchain</div>
          <h3 class="mt-1 text-lg font-semibold text-gray-100">Bitcoin Core / RPC</h3>
        </div>

        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
          <div class="rounded-xl border border-white/10 bg-gray-950/60 p-4">
            <div class="flex items-start justify-between gap-3">
              <div>
                <div class="<%= label_class %>">Service</div>
                <div class="mt-1 text-base font-semibold text-gray-100">Bitcoind RPC</div>
              </div>
              <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(bitcoind[:ok] ? "ok" : "fail") %>">
                <%= yes_no_badge(bitcoind[:ok]) %>
              </span>
            </div>

            <div class="mt-4 space-y-2 text-sm">
              <div class="flex justify-between"><span class="text-gray-500">Blocks</span><span class="font-mono text-gray-200"><%= bitcoind[:blocks] || "—" %></span></div>
              <div class="flex justify-between"><span class="text-gray-500">Progress</span><span class="font-mono text-gray-200"><%= bitcoind[:progress_pct] || "—" %>%</span></div>
            </div>
          </div>

          <div class="rounded-xl border border-white/10 bg-gray-950/60 p-4">
            <div class="flex items-start justify-between gap-3">
              <div>
                <div class="<%= label_class %>">Network</div>
                <div class="mt-1 text-base font-semibold text-gray-100">Blockchain sync</div>
              </div>
              <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(blockchain[:ok] ? "ok" : "fail") %>">
                <%= yes_no_badge(blockchain[:ok]) %>
              </span>
            </div>

            <div class="mt-4 space-y-2 text-sm">
              <div class="flex justify-between"><span class="text-gray-500">Blocks</span><span class="font-mono text-gray-200"><%= blockchain[:blocks] || "—" %></span></div>
              <div class="flex justify-between"><span class="text-gray-500">Headers</span><span class="font-mono text-gray-200"><%= blockchain[:headers] || "—" %></span></div>
              <div class="flex justify-between"><span class="text-gray-500">Node lag</span><span class="font-mono <%= blockchain[:lag].to_i > 0 ? "text-amber-300" : "text-emerald-300" %>"><%= blockchain[:lag] || 0 %></span></div>
            </div>
          </div>
        </div>
      </div>

      <div class="rounded-xl border border-white/10 bg-black/20 p-4">
        <%= turbo_stream_from "bitcoin_blocks" %>

        <div class="mb-4">
          <div class="<%= label_class %>">Realtime ingestion</div>
          <h3 class="mt-1 text-lg font-semibold text-gray-100">ZMQ watcher / processor</h3>
        </div>

        <div class="space-y-3">
          <% { "Watcher" => (@realtime[:watcher] || {}), "Processor" => (@realtime[:processor] || {}) }.each do |name, state| %>
            <% status = (state[:status] || :missing).to_s %>
            <div class="rounded-xl border border-white/10 bg-gray-950/60 p-4">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <div class="<%= label_class %>"><%= name %></div>
                  <div class="mt-1 text-base font-semibold text-gray-100"><%= name == "Watcher" ? "Block detector" : "Layer 1 processor" %></div>
                </div>
                <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(status) %>"><%= status.upcase %></span>
              </div>

              <div class="mt-4 space-y-2 text-sm">
                <div class="flex justify-between"><span class="text-gray-500">Last height</span><span class="font-mono text-gray-200"><%= state[:last_blockheight] || "—" %></span></div>
                <div class="flex justify-between"><span class="text-gray-500">Age</span><span class="font-mono text-gray-200"><%= safe_seconds(state[:age_seconds]) %></span></div>
                <div class="pt-2 border-t border-white/5">
                  <div class="text-gray-500 text-xs mb-1">Updated</div>
                  <div class="font-mono text-xs text-gray-300 truncate"><%= safe_time(state[:updated_at]) %></div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <% if disk_cards.any? %>
      <div class="mt-5 rounded-xl border border-white/10 bg-black/20 p-4">
        <div class="mb-4">
          <div class="<%= label_class %>">Storage</div>
          <h3 class="mt-1 text-lg font-semibold text-gray-100">Disques et volumes</h3>
        </div>

        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
          <% disk_cards.each do |disk| %>
            <% disk_state = (disk[:status] || "warn").to_s %>
            <% used_pct = [[disk[:used_pct].to_f, 0].max, 100].min if disk[:used_pct].present? %>

            <div class="rounded-xl border border-white/10 bg-gray-950/60 p-4">
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                  <div class="<%= label_class %>">Disque</div>
                  <div class="mt-1 truncate text-base font-semibold text-gray-100"><%= disk[:label] || "Storage" %></div>
                </div>
                <span class="shrink-0 inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(disk_state) %>"><%= disk_state.upcase %></span>
              </div>

              <div class="mt-4 space-y-2 text-sm">
                <div>
                  <div class="text-gray-500 mb-1">Path</div>
                  <div class="font-mono text-xs text-gray-300 truncate"><%= disk[:path] || "—" %></div>
                </div>

                <% if disk[:mount].present? %>
                  <div>
                    <div class="text-gray-500 mb-1">Mount</div>
                    <div class="font-mono text-xs text-gray-300 truncate"><%= disk[:mount] %></div>
                  </div>
                <% end %>

                <div class="flex justify-between">
                  <span class="text-gray-500">Utilisation</span>
                  <span class="font-mono <%= disk[:used_pct].to_i >= 90 ? "text-rose-300" : disk[:used_pct].to_i >= 80 ? "text-amber-300" : "text-gray-200" %>">
                    <%= disk[:used_pct] ? "#{disk[:used_pct]}%" : "—" %>
                  </span>
                </div>

                <% if disk[:used_pct].present? %>
                  <div class="h-1.5 overflow-hidden rounded-full bg-white/10">
                    <div class="h-full rounded-full <%= used_pct >= 90 ? "bg-rose-400" : used_pct >= 80 ? "bg-amber-400" : "bg-emerald-400" %>" style="width: <%= used_pct %>%"></div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </section>

  <section class="<%= section_class %>">
    <% processed_height = layer1_processed_height.to_i %>
    <% cluster_spent_height = cluster_input_max_spent_height.to_i %>
    <% flow_height = latest_exchange_flow_height.to_i %>
    <% cluster_lag = processed_height.positive? && cluster_spent_height.positive? ? [processed_height - cluster_spent_height, 0].max : nil %>
    <% flow_lag = processed_height.positive? && flow_height.positive? ? [processed_height - flow_height, 0].max : nil %>
    <% async_lag = [cluster_lag.to_i, flow_lag.to_i].max %>
    <% layer1_state =
      if layer1_counts["failed"].to_i > 0
        "failed"
      elsif layer1_lag.positive? || redis_outputs > 500_000 || redis_spent > 50_000
        "warning"
      elsif redis_outputs.positive? || redis_spent.positive?
        "active"
      else
        "ok"
      end
    %>

    <div class="mb-5 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <div class="<%= label_class %>">Layer 1</div>
        <h2 class="mt-1 text-xl font-semibold text-gray-100">Canonical UTXO pipeline</h2>
        <p class="mt-2 <%= muted_class %>">
          Ingestion des blocs, extraction des outputs, maintien de <span class="font-mono text-cyan-300">utxo_outputs</span>, résolution des spends et alimentation de <span class="font-mono text-cyan-300">cluster_inputs</span>.
        </p>
      </div>
      <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold <%= status_badge_class(layer1_state) %>"><%= layer1_state.upcase %></span>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-6">
      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Best height</div>
        <div class="mt-3 text-3xl font-bold text-gray-100"><%= layer1_best_height || "—" %></div>
        <div class="mt-3 space-y-2 text-sm">
          <div class="flex justify-between"><span class="text-gray-500">Processed</span><span class="font-mono text-gray-200"><%= layer1_processed_height || "—" %></span></div>
          <div class="flex justify-between"><span class="text-gray-500">Lag</span><span class="font-mono <%= layer1_lag.positive? ? "text-amber-300" : "text-emerald-300" %>"><%= layer1_lag %></span></div>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Redis buffers</div>
        <div class="mt-3 text-3xl font-bold <%= redis_total.positive? ? "text-amber-300" : "text-emerald-300" %>">
          <%= number_with_delimiter(redis_total) %>
        </div>
        <div class="mt-3 space-y-2 text-sm">
          <div class="flex justify-between"><span class="text-gray-500">Outputs</span><span class="font-mono text-gray-200"><%= number_with_delimiter(redis_outputs) %></span></div>
          <div class="flex justify-between"><span class="text-gray-500">Spent</span><span class="font-mono text-gray-200"><%= number_with_delimiter(redis_spent) %></span></div>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">UTXO outputs</div>
        <div class="mt-3 text-3xl font-bold text-cyan-300"><%= number_with_delimiter(utxo_output_count) %></div>
        <div class="mt-3 space-y-2 text-sm">
          <div class="flex justify-between"><span class="text-gray-500">Min</span><span class="font-mono text-gray-200"><%= utxo_output_min_height || "—" %></span></div>
          <div class="flex justify-between"><span class="text-gray-500">Max</span><span class="font-mono text-gray-200"><%= utxo_output_max_height || "—" %></span></div>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Cluster inputs</div>
        <div class="mt-3 text-3xl font-bold text-purple-300"><%= number_with_delimiter(cluster_input_count) %></div>
        <div class="mt-3 space-y-2 text-sm">
          <div class="flex justify-between"><span class="text-gray-500">Max height</span><span class="font-mono text-gray-200"><%= cluster_input_max_height || "—" %></span></div>
          <div class="flex justify-between"><span class="text-gray-500">Max spent</span><span class="font-mono text-gray-200"><%= cluster_input_max_spent_height || "—" %></span></div>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Async cluster lag</div>
        <div class="mt-3 text-3xl font-bold <%= cluster_lag.to_i > 100 ? "text-amber-300" : "text-emerald-300" %>"><%= cluster_lag || "—" %></div>
        <p class="mt-3 <%= muted_class %>">processed - cluster max spent</p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">tx_outputs legacy</div>
        <div class="mt-3 text-3xl font-bold text-gray-400"><%= number_with_delimiter(tx_output_count) %></div>
        <p class="mt-3 <%= muted_class %>">historique transition · max <%= tx_output_max_height || "—" %></p>
      </div>
    </div>
  </section>

  <section class="<%= section_class %>">
    <div class="mb-5 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <div class="<%= label_class %>">Cluster</div>
        <h2 class="mt-1 text-xl font-semibold text-gray-100">Address graph & entities</h2>
        <p class="mt-2 <%= muted_class %>">
          Cluster consomme exclusivement <span class="font-mono text-cyan-300">cluster_inputs</span>. Les lectures directes de <span class="font-mono text-gray-500">tx_outputs</span> doivent rester réservées au backfill ou à l’historique.
        </p>
      </div>
      <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold <%= status_badge_class(@cluster_pipeline_status[:status]) %>">
        <%= @cluster_pipeline_status[:status].to_s.upcase.presence || "UNKNOWN" %>
      </span>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-5">
      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Batch scanner</div>
        <div class="mt-3 text-3xl font-bold text-gray-100"><%= cluster_batch[:scanner_height] || "—" %></div>
        <p class="mt-2 <%= muted_class %>">lag <%= cluster_batch[:lag] || "—" %> blocs</p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Realtime stream</div>
        <div class="mt-3 text-3xl font-bold text-gray-100"><%= cluster_realtime[:scanner_height] || "—" %></div>
        <p class="mt-2 <%= muted_class %>">lag <%= cluster_realtime[:lag] || "—" %> blocs</p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Dirty clusters</div>
        <div class="mt-3 text-3xl font-bold <%= @cluster_pipeline_status[:dirty_queue_size].to_i > 0 ? "text-amber-300" : "text-emerald-300" %>">
          <%= @cluster_pipeline_status[:dirty_queue_size] || 0 %>
        </div>
        <p class="mt-2 <%= muted_class %>">queue technique interne</p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Profiles</div>
        <div class="mt-3 text-3xl font-bold text-gray-100"><%= @cluster_pipeline_status[:profiles_count] || 0 %></div>
        <p class="mt-2 <%= muted_class %>">profils cluster batch</p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Signals</div>
        <div class="mt-3 text-3xl font-bold text-gray-100"><%= @cluster_pipeline_status[:signals_count] || 0 %></div>
        <p class="mt-2 <%= muted_class %>">événements analytiques</p>
      </div>
    </div>
  </section>

  <section class="<%= section_class %>">
    <% actor_profile_status = actor_profiles_runtime[:status] || "unknown" %>

    <div class="mb-5 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <div class="<%= label_class %>">Actor Profiles</div>
        <h2 class="mt-1 text-xl font-semibold text-gray-100">Behavioral runtime</h2>
        <p class="mt-2 <%= muted_class %>">
          Les profils consomment <span class="font-mono text-cyan-300">cluster_inputs</span> pour construire les comportements d’acteurs.
        </p>
      </div>

      <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold <%= status_badge_class(actor_profile_status) %>">
        <%= actor_profile_status.to_s.upcase %>
      </span>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-6">
      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Profiles</div>
        <div class="mt-3 text-3xl font-bold text-cyan-300"><%= number_with_delimiter(actor_profiles_runtime[:profiles_count].to_i) %></div>
        <p class="mt-2 <%= muted_class %>">profils comportementaux</p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Unprocessed deltas</div>
        <div class="mt-3 text-3xl font-bold <%= actor_profiles_runtime[:deltas_unprocessed].to_i.positive? ? "text-amber-300" : "text-emerald-300" %>">
          <%= number_with_delimiter(actor_profiles_runtime[:deltas_unprocessed].to_i) %>
        </div>
        <p class="mt-2 <%= muted_class %>">événements à appliquer</p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Dirty Redis</div>
        <div class="mt-3 text-3xl font-bold <%= actor_profiles_runtime[:dirty_clusters].to_i.positive? ? "text-sky-300" : "text-emerald-300" %>">
          <%= number_with_delimiter(actor_profiles_runtime[:dirty_clusters].to_i) %>
        </div>
        <p class="mt-2 <%= muted_class %>">clusters à dispatcher</p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Queue light</div>
        <div class="mt-3 text-3xl font-bold text-gray-100"><%= number_with_delimiter(actor_profile_queues[:light].to_i) %></div>
        <p class="mt-2 <%= muted_class %>">p3_actor_profile_light</p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Queue heavy</div>
        <div class="mt-3 text-3xl font-bold <%= actor_profile_queues[:heavy].to_i.positive? ? "text-amber-300" : "text-emerald-300" %>">
          <%= number_with_delimiter(actor_profile_queues[:heavy].to_i) %>
        </div>
        <p class="mt-2 <%= muted_class %>">gros clusters</p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">15 min activity</div>
        <div class="mt-3 text-3xl font-bold text-purple-300"><%= number_with_delimiter(actor_profiles_runtime[:processed_deltas_15m].to_i) %></div>
        <p class="mt-2 <%= muted_class %>">
          processed / <%= number_with_delimiter(actor_profiles_runtime[:recent_deltas_15m].to_i) %> created
        </p>
      </div>
    </div>
  </section>

  <section class="<%= section_class %>">
    <% coverage_count = exchange_like_count + whale_like_count + etf_candidate_count + service_like_count + retail_like_count + unknown_count %>
    <% coverage_pct = total_labels.positive? ? ((coverage_count.to_f / total_labels) * 100).round(1) : 0 %>
    <% actor_label_state =
      if total_labels.zero?
        "warning"
      elsif exchange_like_count.zero? && whale_like_count.zero? && etf_candidate_count.zero? && service_like_count.zero?
        "warning"
      else
        "ok"
      end
    %>

    <div class="mb-5 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <div class="<%= label_class %>">Actor Labels</div>
        <h2 class="mt-1 text-xl font-semibold text-gray-100">Validated economic classifications</h2>
        <p class="mt-2 <%= muted_class %>">
          Labels validés issus uniquement des Actor Profiles.
        </p>
      </div>

      <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold <%= status_badge_class(actor_label_state) %>">
        <%= actor_label_state.upcase %>
      </span>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-6">
      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Total labels</div>
        <div class="mt-3 text-3xl font-bold text-gray-100"><%= number_with_delimiter(total_labels) %></div>
        <p class="mt-2 <%= muted_class %>">source actor_profile</p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Exchange-like</div>
        <div class="mt-3 text-3xl font-bold text-blue-300"><%= number_with_delimiter(exchange_like_count) %></div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Whale-like</div>
        <div class="mt-3 text-3xl font-bold text-purple-300"><%= number_with_delimiter(whale_like_count) %></div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">ETF candidates</div>
        <div class="mt-3 text-3xl font-bold text-emerald-300"><%= number_with_delimiter(etf_candidate_count) %></div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Service-like</div>
        <div class="mt-3 text-3xl font-bold text-cyan-300"><%= number_with_delimiter(service_like_count) %></div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Retail / Unknown</div>
        <div class="mt-3 text-3xl font-bold text-gray-100"><%= number_with_delimiter(retail_like_count + unknown_count) %></div>
        <p class="mt-2 <%= muted_class %>">retail: <%= number_with_delimiter(retail_like_count) %> · unknown: <%= number_with_delimiter(unknown_count) %></p>
      </div>
    </div>

    <div class="mt-5 rounded-2xl border border-slate-800 bg-slate-950/40 p-4">
      <div class="<%= label_class %>">Diagnostic Actor Labels</div>
      <p class="mt-2 text-sm leading-relaxed text-slate-300">
        <% if total_labels.zero? %>
          Aucun label issu d’Actor Profiles n’est disponible.
        <% elsif exchange_like_count.zero? && whale_like_count.zero? && etf_candidate_count.zero? %>
          Les Actor Profiles génèrent des labels, mais aucun acteur exchange/whale/ETF n’est encore disponible.
        <% else %>
          Actor Labels est opérationnel depuis la source <span class="font-mono text-cyan-300">actor_profile</span>.
        <% end %>
      </p>

      <div class="mt-4 h-1.5 overflow-hidden rounded-full bg-white/10">
        <div
          class="h-full rounded-full <%= coverage_pct >= 95 ? "bg-emerald-400" : coverage_pct >= 50 ? "bg-amber-400" : "bg-rose-400" %>"
          style="width: <%= [[coverage_pct, 0].max, 100].min %>%">
        </div>
      </div>

      <div class="mt-2 flex items-center justify-between text-xs text-gray-500">
        <span>Distribution coverage</span>
        <span class="font-mono text-gray-300"><%= coverage_pct %>%</span>
      </div>
    </div>
  </section>

  <section class="<%= section_class %>">
    <div class="mb-5">
      <div class="<%= label_class %>">Layer 2</div>
      <h2 class="mt-1 text-xl font-semibold text-gray-100">Business intelligence modules</h2>
      <p class="mt-2 <%= muted_class %>">
        Les modules Layer 2 consomment Actor Labels et produisent une lecture métier.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-5 xl:grid-cols-3">
      <div class="rounded-2xl border border-blue-500/10 bg-blue-500/[0.03] p-5">
        <% exchange_flow_lag = latest_exchange_flow_height.present? && layer1_best_height.to_i.positive? ? [layer1_best_height.to_i - latest_exchange_flow_height.to_i, 0].max : nil %>
        <% exchange_flow_state = exchange_like_count.zero? ? "waiting" : exchange_flow_lag.to_i > 6 ? "warning" : "ok" %>

        <div class="flex items-start justify-between gap-4">
          <div>
            <div class="<%= label_class %>">Exchange Flow</div>
            <h3 class="mt-1 text-lg font-semibold text-gray-100">Exchange pressure</h3>
          </div>
          <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(exchange_flow_state) %>"><%= exchange_flow_state.upcase %></span>
        </div>

        <div class="mt-4 space-y-2 text-sm">
          <div class="flex justify-between"><span class="text-gray-500">Exchange labels</span><span class="font-mono text-gray-200"><%= number_with_delimiter(exchange_like_count) %></span></div>
          <div class="flex justify-between"><span class="text-gray-500">Latest flow height</span><span class="font-mono text-gray-200"><%= latest_exchange_flow_height || "—" %></span></div>
          <div class="flex justify-between"><span class="text-gray-500">Lag</span><span class="font-mono text-gray-200"><%= exchange_flow_lag || "—" %></span></div>
        </div>
      </div>

      <div class="rounded-2xl border border-purple-500/10 bg-purple-500/[0.03] p-5">
        <div class="<%= label_class %>">Whales</div>
        <h3 class="mt-1 text-lg font-semibold text-gray-100">Whale-like actors</h3>
        <div class="mt-4 text-3xl font-bold text-purple-300"><%= number_with_delimiter(whale_like_count) %></div>
        <p class="mt-2 <%= muted_class %>">classification depuis Actor Profiles</p>
      </div>

      <div class="rounded-2xl border border-emerald-500/10 bg-emerald-500/[0.03] p-5">
        <div class="<%= label_class %>">ETF / Institutional</div>
        <h3 class="mt-1 text-lg font-semibold text-gray-100">ETF candidates actors</h3>
        <div class="mt-4 text-3xl font-bold text-emerald-300"><%= number_with_delimiter(etf_candidate_count) %></div>
        <p class="mt-2 <%= muted_class %>">classification depuis Actor Profiles</p>
      </div>
    </div>
  </section>
</div>