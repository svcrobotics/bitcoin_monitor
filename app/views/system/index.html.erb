<!-- app/views/system/index.html.erb -->
<% @checks          ||= {} %>
<% @summary         ||= {} %>
<% @recovery        ||= {} %>
<% @anomalies       ||= [] %>
<% @job_health      ||= [] %>
<% @exchange_like_status ||= {} %>
<% @btc_status ||= {} %>
<% @snapshot        ||= {} %>
<% @sidekiq_status ||= {} %>
<% @cluster_pipeline_status ||= {} %>
<% @realtime ||= {} %>
<% @recovery_snapshot ||= {} %>
<% @recent_blocks ||= [] %>

<% layer1 = @recovery_snapshot[:layer1] || {} %>
<% layer1_counts = layer1[:status_counts] || {} %>
<% layer1_redis = layer1[:redis_buffers] || {} %>
<% cluster_batch = @cluster_pipeline_status[:batch] || {} %>
<% cluster_realtime = @cluster_pipeline_status[:realtime] || {} %>

<%
  section_class = "rounded-2xl border border-white/10 bg-white/5 p-5"
  panel_class   = "rounded-xl border border-white/10 bg-black/20 p-4"
  label_class   = "text-[11px] uppercase tracking-[0.14em] text-gray-500"
  muted_class   = "text-sm text-gray-400"

  bitcoind = @checks[:bitcoind] || {}
  blockchain = @checks[:bitcoind_activity] || {}
  disks = @checks[:disks] || {}
  disk_cards = [disks[:bitcoind], disks[:data], disks[:system]].compact

  latest_whale =
    begin
      defined?(WhaleAlert) ? WhaleAlert.order(block_height: :desc, updated_at: :desc).first : nil
    rescue
      nil
    end

  whale_count =
    begin
      defined?(WhaleAlert) ? WhaleAlert.count : 0
    rescue
      0
    end

  latest_flow =
    begin
      defined?(ExchangeFlowDay) ? ExchangeFlowDay.order(day: :desc).first : nil
    rescue
      nil
    end

  flow_detail =
    begin
      if defined?(ExchangeFlowDayDetail) && latest_flow.present?
        ExchangeFlowDayDetail.find_by(day: latest_flow.day)
      end
    rescue
      nil
    end

  global_state =
    if @recovery[:critical_problems_count].to_i > 0
      "critical"
    elsif @anomalies.any?
      "warning"
    else
      "ok"
    end

  def status_badge_class(status)
    case status.to_s
    when "ok", "ready", "healthy", "fresh"
      "text-emerald-300 bg-emerald-500/10 border border-emerald-500/20"
    when "running", "processing"
      "text-sky-300 bg-sky-500/10 border border-sky-500/20"
    when "warning", "late", "delayed", "skipped"
      "text-amber-300 bg-amber-500/10 border border-amber-500/20"
    when "stuck", "failing", "fail", "failed", "stale", "critical", "never_ran"
      "text-rose-300 bg-rose-500/10 border border-rose-500/20"
    else
      "text-gray-300 bg-gray-500/10 border border-gray-500/20"
    end
  end

  def safe_time(value)
    return "—" if value.blank?

    if respond_to?(:fmt_time)
      fmt_time(value)
    else
      value.respond_to?(:strftime) ? value.strftime("%Y-%m-%d %H:%M:%S") : value.to_s
    end
  rescue
    value.to_s
  end

  def safe_duration_ms(value)
    return "—" if value.blank?

    if respond_to?(:fmt_duration_ms)
      fmt_duration_ms(value)
    else
      total_seconds = (value.to_f / 1000.0).round
      minutes = total_seconds / 60
      seconds = total_seconds % 60
      minutes.positive? ? "#{minutes}m #{seconds}s" : "#{seconds}s"
    end
  end

  def safe_seconds(value)
    return "—" if value.blank?

    if respond_to?(:fmt_seconds)
      fmt_seconds(value)
    else
      total_seconds = value.to_i
      minutes = total_seconds / 60
      seconds = total_seconds % 60
      minutes.positive? ? "#{minutes}m #{seconds}s" : "#{seconds}s"
    end
  end

  def yes_no_badge(value)
    value ? "OK" : "FAIL"
  end

  def fmt_btc(value)
    return "—" if value.blank?

    "#{value.to_d.round(4).to_s('F')} BTC"
  rescue
    value.to_s
  end
%>

<div class="w-full max-w-none mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">
  <!-- Header -->
  <section class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4">
    <div>
      <div class="<%= label_class %>">Operations dashboard</div>
      <h1 class="mt-2 text-3xl font-bold text-gray-100">System</h1>
      <p class="mt-2 <%= muted_class %>">
        Cockpit opérationnel : infrastructure, Layer 1, modules analytiques Layer 2, BTC market data, Sidekiq et recovery.
      </p>
    </div>

    <div class="flex flex-col items-start lg:items-end gap-2">
      <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold <%= status_badge_class(global_state) %>">
        <%= global_state.upcase %>
      </span>

      <div class="text-xs text-gray-500 font-mono">
        snapshot:
        <span class="text-gray-300"><%= safe_time(@snapshot[:generated_at] || Time.current) %></span>
      </div>
    </div>
  </section>

  <!-- KPI -->
  <section class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-6 gap-4">
    <div class="<%= section_class %>">
      <div class="<%= label_class %>">Global status</div>
      <div class="mt-3 text-2xl font-bold <%= global_state == "ok" ? "text-emerald-300" : global_state == "warning" ? "text-amber-300" : "text-rose-300" %>">
        <%= global_state.upcase %>
      </div>
    </div>

    <div class="<%= section_class %>">
      <div class="<%= label_class %>">Layer 1 lag</div>
      <div class="mt-3 text-2xl font-bold <%= layer1[:lag].to_i > 0 ? "text-amber-300" : "text-emerald-300" %>">
        <%= layer1[:lag] || 0 %>
      </div>
    </div>

    <div class="<%= section_class %>">
      <div class="<%= label_class %>">Cluster realtime lag</div>
      <div class="mt-3 text-2xl font-bold <%= cluster_realtime[:lag].to_i > 24 ? "text-rose-300" : cluster_realtime[:lag].to_i > 6 ? "text-amber-300" : "text-emerald-300" %>">
        <%= cluster_realtime[:lag] || 0 %>
      </div>
      <div class="mt-2 text-xs text-gray-500">
        batch lag: <span class="font-mono text-gray-300"><%= cluster_batch[:lag] || "—" %></span>
      </div>
    </div>

    <div class="<%= section_class %>">
      <div class="<%= label_class %>">Dirty clusters</div>
      <div class="mt-3 text-2xl font-bold <%= @cluster_pipeline_status[:dirty_queue_size].to_i > 0 ? "text-amber-300" : "text-emerald-300" %>">
        <%= @cluster_pipeline_status[:dirty_queue_size] || 0 %>
      </div>
    </div>

    <div class="<%= section_class %>">
      <div class="<%= label_class %>">Jobs en anomalie</div>
      <div class="mt-3 text-2xl font-bold text-amber-300">
        <%= (@summary[:late_jobs_count] || 0).to_i + (@summary[:failing_jobs_count] || 0).to_i %>
      </div>
    </div>

    <div class="<%= section_class %>">
      <div class="<%= label_class %>">Whale alerts</div>
      <div class="mt-3 text-2xl font-bold text-gray-100">
        <%= whale_count %>
      </div>
    </div>
  </section>

  <%= render "system/layer1/block_chain_stream", blocks: @recent_blocks %>

  <!-- Recovery summary -->
  <section class="<%= section_class %>">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
      <div>
        <div class="<%= label_class %>">Recovery</div>
        <h2 class="mt-1 text-xl font-semibold text-gray-100">Recovery readiness</h2>
        <p class="mt-2 <%= muted_class %>">
          Résumé de la capacité du système à reprendre après panne, redémarrage ou retard Layer 1.
        </p>
      </div>

      <div class="flex flex-col items-start lg:items-end gap-3">
        <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold <%= status_badge_class(@recovery[:recovery_needed] ? "critical" : "ok") %>">
          <%= @recovery[:recovery_needed] ? "RECOVERY NEEDED" : "READY" %>
        </span>

        <%= link_to "Ouvrir Recovery center",
            system_recovery_path,
            class: "inline-flex items-center rounded-xl border border-sky-500/20 bg-sky-500/10 px-4 py-2 text-sm font-medium text-sky-300 hover:bg-sky-500/15 transition" %>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mt-5">
      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Bitcoind RPC</div>
        <div class="mt-3">
          <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold <%= status_badge_class(bitcoind[:ok] ? "ok" : "fail") %>">
            <%= yes_no_badge(bitcoind[:ok]) %>
          </span>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Problèmes critiques</div>
        <div class="mt-3 text-2xl font-bold text-gray-100">
          <%= @recovery[:critical_problems_count] || 0 %>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Layer 1 processed</div>
        <div class="mt-3 text-2xl font-bold text-gray-100">
          <%= layer1[:last_processed_height] || "—" %>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Recovery order</div>
        <div class="mt-3 text-sm text-gray-300 leading-6">
          <%= (@recovery[:restart_order] || []).presence&.join(" → ") || "—" %>
        </div>
      </div>
    </div>
  </section>

  <!-- Infrastructure -->
  <section class="<%= section_class %>">
    <div class="mb-5">
      <div class="<%= label_class %>">Infrastructure</div>
      <h2 class="mt-1 text-xl font-semibold text-gray-100">Bitcoind, stockage et realtime</h2>
      <p class="mt-2 <%= muted_class %>">
        État des dépendances techniques de base : Bitcoin Core, synchronisation réseau, disques et ingestion temps réel.
      </p>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-5">
      <!-- Core blockchain -->
      <div class="xl:col-span-2 rounded-xl border border-white/10 bg-black/20 p-4">
        <div class="mb-4">
          <div class="<%= label_class %>">Core blockchain</div>
          <h3 class="mt-1 text-lg font-semibold text-gray-100">Bitcoin Core / RPC</h3>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <!-- Bitcoind RPC -->
          <div class="rounded-xl border border-white/10 bg-gray-950/60 p-4">
            <div class="flex items-start justify-between gap-3">
              <div>
                <div class="<%= label_class %>">Service</div>
                <div class="mt-1 text-base font-semibold text-gray-100">Bitcoind RPC</div>
              </div>

              <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(bitcoind[:ok] ? "ok" : "fail") %>">
                <%= yes_no_badge(bitcoind[:ok]) %>
              </span>
            </div>

            <div class="mt-4 space-y-2 text-sm">
              <div class="flex items-center justify-between gap-4">
                <span class="text-gray-500">Blocks</span>
                <span class="font-mono text-gray-200"><%= bitcoind[:blocks] || "—" %></span>
              </div>

              <div class="flex items-center justify-between gap-4">
                <span class="text-gray-500">Progress</span>
                <span class="font-mono text-gray-200"><%= bitcoind[:progress_pct] || "—" %>%</span>
              </div>
            </div>
          </div>

          <!-- Blockchain network -->
          <div class="rounded-xl border border-white/10 bg-gray-950/60 p-4">
            <div class="flex items-start justify-between gap-3">
              <div>
                <div class="<%= label_class %>">Network</div>
                <div class="mt-1 text-base font-semibold text-gray-100">Blockchain sync</div>
              </div>

              <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(blockchain[:ok] ? "ok" : "fail") %>">
                <%= yes_no_badge(blockchain[:ok]) %>
              </span>
            </div>

            <div class="mt-4 space-y-2 text-sm">
              <div class="flex items-center justify-between gap-4">
                <span class="text-gray-500">Blocks</span>
                <span class="font-mono text-gray-200"><%= blockchain[:blocks] || "—" %></span>
              </div>

              <div class="flex items-center justify-between gap-4">
                <span class="text-gray-500">Headers</span>
                <span class="font-mono text-gray-200"><%= blockchain[:headers] || "—" %></span>
              </div>

              <div class="flex items-center justify-between gap-4">
                <span class="text-gray-500">Node lag</span>
                <span class="font-mono <%= blockchain[:lag].to_i > 0 ? "text-amber-300" : "text-emerald-300" %>">
                  <%= blockchain[:lag] || 0 %>
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Realtime ingestion -->
      <div class="rounded-xl border border-white/10 bg-black/20 p-4">
        <%= turbo_stream_from "bitcoin_blocks" %>

        <div class="mb-4">
          <div class="<%= label_class %>">Realtime ingestion</div>
          <h3 class="mt-1 text-lg font-semibold text-gray-100">ZMQ watcher / processor</h3>
        </div>

        <div class="space-y-3">
          <% { "Watcher" => (@realtime[:watcher] || {}), "Processor" => (@realtime[:processor] || {}) }.each do |name, state| %>
            <% status = (state[:status] || :missing).to_s %>

            <div class="rounded-xl border border-white/10 bg-gray-950/60 p-4">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <div class="<%= label_class %>"><%= name %></div>
                  <div class="mt-1 text-base font-semibold text-gray-100">
                    <%= name == "Watcher" ? "Block detector" : "Layer 1 processor" %>
                  </div>
                </div>

                <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(status) %>">
                  <%= status.upcase %>
                </span>
              </div>

              <div class="mt-4 space-y-2 text-sm">
                <div class="flex items-center justify-between gap-4">
                  <span class="text-gray-500">Last height</span>
                  <span class="font-mono text-gray-200"><%= state[:last_blockheight] || "—" %></span>
                </div>

                <div class="flex items-center justify-between gap-4">
                  <span class="text-gray-500">Age</span>
                  <span class="font-mono <%= state[:age_seconds].to_i > 1200 ? "text-amber-300" : "text-gray-200" %>">
                    <%= safe_seconds(state[:age_seconds]) %>
                  </span>
                </div>

                <div class="pt-2 border-t border-white/5">
                  <div class="text-gray-500 text-xs mb-1">Updated</div>
                  <div class="font-mono text-xs text-gray-300 truncate">
                    <%= safe_time(state[:updated_at]) %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Storage -->
    <% if disk_cards.any? %>
      <div class="mt-5 rounded-xl border border-white/10 bg-black/20 p-4">
        <div class="mb-4">
          <div class="<%= label_class %>">Storage</div>
          <h3 class="mt-1 text-lg font-semibold text-gray-100">Disques et volumes</h3>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
          <% disk_cards.each do |disk| %>
            <% disk_state = (disk[:status] || "warn").to_s %>

            <div class="rounded-xl border border-white/10 bg-gray-950/60 p-4">
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                  <div class="<%= label_class %>">Disque</div>
                  <div class="mt-1 text-base font-semibold text-gray-100 truncate">
                    <%= disk[:label] || "Storage" %>
                  </div>
                </div>

                <span class="shrink-0 inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(disk_state) %>">
                  <%= disk_state.upcase %>
                </span>
              </div>

              <div class="mt-4 space-y-2 text-sm">
                <div>
                  <div class="text-gray-500 mb-1">Path</div>
                  <div class="font-mono text-xs text-gray-300 truncate">
                    <%= disk[:path] || "—" %>
                  </div>
                </div>

                <% if disk[:mount].present? %>
                  <div>
                    <div class="text-gray-500 mb-1">Mount</div>
                    <div class="font-mono text-xs text-gray-300 truncate">
                      <%= disk[:mount] %>
                    </div>
                  </div>
                <% end %>

                <div class="flex items-center justify-between gap-4">
                  <span class="text-gray-500">Utilisation</span>
                  <span class="font-mono <%= disk[:used_pct].to_i >= 90 ? "text-rose-300" : disk[:used_pct].to_i >= 80 ? "text-amber-300" : "text-gray-200" %>">
                    <%= disk[:used_pct] ? "#{disk[:used_pct]}%" : "—" %>
                  </span>
                </div>

                <% if disk[:used_pct].present? %>
                  <% used_pct = [[disk[:used_pct].to_f, 0].max, 100].min %>

                  <div class="h-1.5 rounded-full bg-white/10 overflow-hidden">
                    <div
                      class="h-full rounded-full <%= used_pct >= 90 ? "bg-rose-400" : used_pct >= 80 ? "bg-amber-400" : "bg-emerald-400" %>"
                      style="width: <%= used_pct %>%">
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </section>

  <!-- Layer 1 -->
  <section class="<%= section_class %>">
    <% layer1_state =
      if layer1_counts["failed"].to_i > 0
        "failed"
      elsif layer1[:lag].to_i > 0 || layer1_counts["processing"].to_i > 0 || layer1_counts["enqueued"].to_i > 0
        "running"
      else
        "ok"
      end
    %>

    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-5">
      <div>
        <div class="<%= label_class %>">Layer 1</div>
        <h2 class="mt-1 text-xl font-semibold text-gray-100">Blockchain Data Engine</h2>
        <p class="mt-2 <%= muted_class %>">
          Source officielle blockchain : ingestion des blocs, extraction UTXO, spent state, buffers Redis et flush PostgreSQL.
        </p>
      </div>

      <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold <%= status_badge_class(layer1_state) %>">
        <%= layer1_state.upcase %>
      </span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-5 gap-4">
      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Best height</div>
        <div class="mt-3 text-3xl font-bold text-gray-100"><%= layer1[:best_height] || "—" %></div>
        <div class="mt-3 space-y-2 text-sm">
          <div class="flex justify-between">
            <span class="text-gray-500">Buffered</span>
            <span class="font-mono text-gray-200"><%= layer1[:highest_buffered_height] || "—" %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Processed</span>
            <span class="font-mono text-gray-200"><%= layer1[:last_processed_height] || "—" %></span>
          </div>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Lag</div>
        <div class="mt-3 text-3xl font-bold <%= layer1[:lag].to_i > 0 ? "text-amber-300" : "text-emerald-300" %>">
          <%= layer1[:lag] || 0 %>
        </div>
        <div class="mt-3 space-y-2 text-sm">
          <div class="flex justify-between">
            <span class="text-gray-500">Speed</span>
            <span class="font-mono text-gray-200"><%= layer1[:recovery_speed] || "—" %> bloc/min</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">ETA</span>
            <span class="font-mono text-gray-200"><%= layer1[:eta_minutes] ? "#{layer1[:eta_minutes]} min" : "—" %></span>
          </div>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Block states</div>
        <div class="mt-3 grid grid-cols-2 gap-2 text-sm">
          <div class="flex justify-between gap-3">
            <span class="text-gray-500">Pending</span>
            <span class="font-mono text-gray-200"><%= layer1_counts["pending"].to_i %></span>
          </div>
          <div class="flex justify-between gap-3">
            <span class="text-gray-500">Enqueued</span>
            <span class="font-mono text-amber-300"><%= layer1_counts["enqueued"].to_i %></span>
          </div>
          <div class="flex justify-between gap-3">
            <span class="text-gray-500">Processing</span>
            <span class="font-mono text-sky-300"><%= layer1_counts["processing"].to_i %></span>
          </div>
          <div class="flex justify-between gap-3">
            <span class="text-gray-500">Failed</span>
            <span class="font-mono text-rose-300"><%= layer1_counts["failed"].to_i %></span>
          </div>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Redis buffers</div>
        <div class="mt-3 text-3xl font-bold <%= (layer1_redis[:outputs_buffer].to_i + layer1_redis[:spent_outputs_buffer].to_i) > 0 ? "text-amber-300" : "text-emerald-300" %>">
          <%= layer1_redis[:outputs_buffer].to_i + layer1_redis[:spent_outputs_buffer].to_i %>
        </div>
        <div class="mt-3 space-y-2 text-sm">
          <div class="flex justify-between">
            <span class="text-gray-500">Outputs</span>
            <span class="font-mono text-gray-200"><%= layer1_redis[:outputs_buffer] || 0 %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Spent</span>
            <span class="font-mono text-gray-200"><%= layer1_redis[:spent_outputs_buffer] || 0 %></span>
          </div>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Process queue</div>
        <div class="mt-3 text-3xl font-bold <%= layer1[:process_queue_size].to_i > 0 ? "text-amber-300" : "text-emerald-300" %>">
          <%= layer1[:process_queue_size] || 0 %>
        </div>
        <p class="mt-3 <%= muted_class %>">
          Jobs Layer 1 en attente dans Sidekiq.
        </p>
      </div>
    </div>
  </section>

  <!-- Sidekiq -->
  <section class="<%= section_class %>">
    <div class="mb-5">
      <div class="<%= label_class %>">Async processing</div>
      <h2 class="mt-1 text-xl font-semibold text-gray-100">Sidekiq / Redis</h2>
      <p class="mt-2 <%= muted_class %>">
        Supervision des workers asynchrones et des backlogs.
      </p>
    </div>

    <% if @sidekiq_status[:error].present? %>
      <div class="rounded-xl border border-rose-500/20 bg-rose-500/5 p-4 text-sm text-rose-200">
        <%= @sidekiq_status[:error] %>
      </div>
    <% else %>
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
        <div class="<%= panel_class %>">
          <div class="flex items-start justify-between gap-3">
            <div>
              <div class="<%= label_class %>">Status</div>
              <div class="mt-1 text-lg font-semibold text-gray-100">Sidekiq</div>
            </div>

            <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(@sidekiq_status[:status]) %>">
              <%= @sidekiq_status[:status].to_s.upcase.presence || "UNKNOWN" %>
            </span>
          </div>

          <div class="mt-4 space-y-2 text-sm">
            <div class="flex justify-between">
              <span class="text-gray-500">Processes</span>
              <span class="font-mono text-gray-200"><%= @sidekiq_status[:processes_size] || 0 %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-500">Busy</span>
              <span class="font-mono text-gray-200"><%= @sidekiq_status[:busy] || 0 %> / <%= @sidekiq_status[:concurrency] || 0 %></span>
            </div>
          </div>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Queue</div>
          <div class="mt-4 space-y-2 text-sm">
            <div class="flex justify-between">
              <span class="text-gray-500">Default queue</span>
              <span class="font-mono text-gray-200"><%= @sidekiq_status[:queue_size] || 0 %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-500">Latency</span>
              <span class="font-mono text-gray-200"><%= @sidekiq_status[:latency] || 0 %>s</span>
            </div>
          </div>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Reliability</div>
          <div class="mt-4 space-y-2 text-sm">
            <div class="flex justify-between">
              <span class="text-gray-500">Processed</span>
              <span class="font-mono text-gray-200"><%= @sidekiq_status[:processed] || 0 %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-500">Failed</span>
              <span class="font-mono text-rose-300"><%= @sidekiq_status[:failed] || 0 %></span>
            </div>
          </div>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Backlog</div>
          <div class="mt-4 space-y-2 text-sm">
            <div class="flex justify-between">
              <span class="text-gray-500">Scheduled</span>
              <span class="font-mono text-gray-200"><%= @sidekiq_status[:scheduled_size] || 0 %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-500">Retry</span>
              <span class="font-mono text-amber-300"><%= @sidekiq_status[:retry_size] || 0 %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-500">Dead</span>
              <span class="font-mono text-rose-300"><%= @sidekiq_status[:dead_size] || 0 %></span>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </section>

  <!-- Layer 2 Modules -->
  <section class="<%= section_class %>">
    <div class="mb-5">
      <div class="<%= label_class %>">Layer 2 modules</div>
      <h2 class="mt-1 text-xl font-semibold text-gray-100">Analytical pipelines</h2>
      <p class="mt-2 <%= muted_class %>">
        Modules analytiques consommateurs du Layer 1 : cluster, exchange-like, whales, inflow/outflow. BTC reste un module marché indépendant.
      </p>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-2 2xl:grid-cols-5 gap-4">
      <!-- Cluster -->
      <div class="<%= panel_class %>">
        <div class="flex items-start justify-between gap-3">
          <div>
            <div class="<%= label_class %>">Cluster</div>
            <div class="mt-1 text-lg font-semibold text-gray-100">Graph intelligence</div>
          </div>

          <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(@cluster_pipeline_status[:status]) %>">
            <%= @cluster_pipeline_status[:status].to_s.upcase.presence || "UNKNOWN" %>
          </span>
        </div>

        <% if @cluster_pipeline_status[:error].present? %>
          <pre class="mt-4 text-xs text-rose-200 whitespace-pre-wrap"><%= @cluster_pipeline_status[:error] %></pre>
        <% else %>
          <div class="mt-4 space-y-3 text-sm">
            <div class="rounded-lg border border-white/10 bg-black/20 p-3 space-y-2">
              <div class="text-xs font-semibold uppercase tracking-wide text-gray-500">Batch scanner</div>

              <div class="flex justify-between">
                <span class="text-gray-500">Cursor</span>
                <span class="font-mono text-gray-200"><%= cluster_batch[:scanner_height] || "—" %></span>
              </div>

              <div class="flex justify-between">
                <span class="text-gray-500">Lag</span>
                <span class="font-mono <%= cluster_batch[:lag].to_i > 72 ? "text-rose-300" : cluster_batch[:lag].to_i > 24 ? "text-amber-300" : "text-emerald-300" %>">
                  <%= cluster_batch[:lag] || "—" %>
                </span>
              </div>

              <div class="flex justify-between">
                <span class="text-gray-500">Updated</span>
                <span class="font-mono text-[10px] text-gray-400"><%= safe_time(cluster_batch[:updated_at]) %></span>
              </div>
            </div>

            <div class="rounded-lg border border-white/10 bg-black/20 p-3 space-y-2">
              <div class="text-xs font-semibold uppercase tracking-wide text-gray-500">Realtime stream</div>

              <div class="flex justify-between">
                <span class="text-gray-500">Cursor</span>
                <span class="font-mono text-gray-200"><%= cluster_realtime[:scanner_height] || "—" %></span>
              </div>

              <div class="flex justify-between">
                <span class="text-gray-500">Lag</span>
                <span class="font-mono <%= cluster_realtime[:lag].to_i > 24 ? "text-rose-300" : cluster_realtime[:lag].to_i > 6 ? "text-amber-300" : "text-emerald-300" %>">
                  <%= cluster_realtime[:lag] || "—" %>
                </span>
              </div>

              <div class="flex justify-between">
                <span class="text-gray-500">Updated</span>
                <span class="font-mono text-[10px] text-gray-400"><%= safe_time(cluster_realtime[:updated_at]) %></span>
              </div>
            </div>

            <div class="pt-2 border-t border-white/10 space-y-2">
              <div class="flex justify-between">
                <span class="text-gray-500">Refresh queue</span>
                <span class="font-mono <%= @cluster_pipeline_status[:refresh_queue].to_i > 0 ? "text-amber-300" : "text-emerald-300" %>">
                  <%= @cluster_pipeline_status[:refresh_queue] || 0 %>
                </span>
              </div>

              <div class="flex justify-between">
                <span class="text-gray-500">Dirty clusters</span>
                <span class="font-mono <%= @cluster_pipeline_status[:dirty_queue_size].to_i > 0 ? "text-amber-300" : "text-emerald-300" %>">
                  <%= @cluster_pipeline_status[:dirty_queue_size] || 0 %>
                </span>
              </div>

              <div class="flex justify-between">
                <span class="text-gray-500">Profiles</span>
                <span class="font-mono text-gray-200"><%= @cluster_pipeline_status[:profiles_count] || 0 %></span>
              </div>

              <div class="flex justify-between">
                <span class="text-gray-500">Signals</span>
                <span class="font-mono text-gray-200"><%= @cluster_pipeline_status[:signals_count] || 0 %></span>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Exchange-like -->
      <div class="<%= panel_class %>">
        <% builder = @exchange_like_status[:builder] || {} %>
        <% scanner = @exchange_like_status[:scanner] || {} %>
        <% metrics = @exchange_like_status[:metrics] || {} %>

        <div class="flex items-start justify-between gap-3">
          <div>
            <div class="<%= label_class %>">Exchange-like</div>
            <div class="mt-1 text-lg font-semibold text-gray-100">Address intelligence</div>
          </div>

          <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(scanner[:status] || builder[:status]) %>">
            <%= (scanner[:status] || builder[:status] || "unknown").to_s.upcase %>
          </span>
        </div>

        <% if @exchange_like_status[:error].present? %>
          <pre class="mt-4 text-xs text-rose-200 whitespace-pre-wrap"><%= @exchange_like_status[:error] %></pre>
        <% else %>
          <div class="mt-4 space-y-2 text-sm">
            <div class="flex justify-between">
              <span class="text-gray-500">Builder cursor</span>
              <span class="font-mono text-gray-200"><%= builder[:last_blockheight] || "—" %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-500">Observed cursor</span>
              <span class="font-mono text-gray-200"><%= scanner[:last_blockheight] || "—" %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-500">Addresses</span>
              <span class="font-mono text-gray-200"><%= metrics[:addresses_total] || 0 %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-500">Observed UTXO</span>
              <span class="font-mono text-gray-200"><%= metrics[:observed_total] || 0 %></span>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Inflow / Outflow -->
      <div class="<%= panel_class %>">
        <% flow_status = latest_flow.present? ? "ok" : "unknown" %>

        <div class="flex items-start justify-between gap-3">
          <div>
            <div class="<%= label_class %>">Inflow / Outflow</div>
            <div class="mt-1 text-lg font-semibold text-gray-100">Exchange flows</div>
          </div>

          <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(flow_status) %>">
            <%= flow_status.upcase %>
          </span>
        </div>

        <div class="mt-4 space-y-2 text-sm">
          <div class="flex justify-between">
            <span class="text-gray-500">Last day</span>
            <span class="font-mono text-gray-200"><%= latest_flow&.day || "—" %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Inflow</span>
            <span class="font-mono text-gray-200"><%= fmt_btc(latest_flow&.inflow_btc) %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Outflow</span>
            <span class="font-mono text-gray-200"><%= fmt_btc(latest_flow&.outflow_btc) %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Netflow</span>
            <span class="font-mono <%= latest_flow&.netflow_btc.to_d.positive? ? "text-emerald-300" : "text-rose-300" rescue "text-gray-200" %>">
              <%= fmt_btc(latest_flow&.netflow_btc) %>
            </span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Deposits</span>
            <span class="font-mono text-gray-200"><%= flow_detail&.deposit_count || "—" %></span>
          </div>
        </div>
      </div>

      <!-- Whale -->
      <div class="<%= panel_class %>">
        <% whale_status = latest_whale.present? ? "ok" : "unknown" %>

        <div class="flex items-start justify-between gap-3">
          <div>
            <div class="<%= label_class %>">Whale</div>
            <div class="mt-1 text-lg font-semibold text-gray-100">Large transfers</div>
          </div>

          <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(whale_status) %>">
            <%= whale_status.upcase %>
          </span>
        </div>

        <div class="mt-4 space-y-2 text-sm">
          <div class="flex justify-between">
            <span class="text-gray-500">Total alerts</span>
            <span class="font-mono text-gray-200"><%= whale_count %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Last height</span>
            <span class="font-mono text-gray-200"><%= latest_whale&.block_height || "—" %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Last total out</span>
            <span class="font-mono text-gray-200"><%= fmt_btc(latest_whale&.total_out_btc) %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Tier</span>
            <span class="font-mono text-gray-200"><%= latest_whale&.tier || "—" %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Source</span>
            <span class="font-mono text-gray-200"><%= latest_whale&.meta&.dig("source") || "legacy/layer1" rescue "—" %></span>
          </div>
        </div>
      </div>

      <!-- BTC -->
      <div class="<%= panel_class %>">
        <% daily = @btc_status[:daily] || {} %>
        <% intraday_5m = @btc_status[:intraday_5m] || {} %>
        <% intraday_1h = @btc_status[:intraday_1h] || {} %>

        <div class="flex items-start justify-between gap-3">
          <div>
            <div class="<%= label_class %>">BTC</div>
            <div class="mt-1 text-lg font-semibold text-gray-100">Market data</div>
          </div>

          <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(daily[:status]) %>">
            <%= daily[:status].to_s.upcase.presence || "UNKNOWN" %>
          </span>
        </div>

        <% if @btc_status[:error].present? %>
          <pre class="mt-4 text-xs text-rose-200 whitespace-pre-wrap"><%= @btc_status[:error] %></pre>
        <% else %>
          <div class="mt-4 space-y-2 text-sm">
            <div class="flex justify-between">
              <span class="text-gray-500">Daily last day</span>
              <span class="font-mono text-gray-200"><%= daily[:last_day] || "—" %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-500">Close USD</span>
              <span class="font-mono text-gray-200"><%= daily[:close_usd] ? daily[:close_usd].to_f.round(2) : "—" %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-500">Candles 5m</span>
              <span class="font-mono text-gray-200"><%= intraday_5m[:candles_count] || 0 %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-500">Candles 1h</span>
              <span class="font-mono text-gray-200"><%= intraday_1h[:candles_count] || 0 %></span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <!-- Anomalies -->
  <section class="<%= section_class %>">
    <div class="mb-5">
      <div class="<%= label_class %>">Exceptions</div>
      <h2 class="mt-1 text-xl font-semibold text-gray-100">Anomalies à traiter</h2>
      <p class="mt-2 <%= muted_class %>">
        Liste courte des jobs nécessitant une attention immédiate.
      </p>
    </div>

    <% if @anomalies.any? %>
      <div class="space-y-3">
        <% @anomalies.first(8).each do |job| %>
          <div class="rounded-xl border border-amber-500/20 bg-amber-500/5 p-4">
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0">
                <div class="text-sm font-semibold text-gray-100"><%= job[:label] || job[:name] %></div>
                <div class="mt-1 text-xs text-gray-400">
                  <span class="font-mono">status=<%= job[:status] %></span>
                  <span class="mx-2 text-gray-600">•</span>
                  <span class="font-mono">delay=<%= safe_seconds(job[:delay_seconds]) %></span>
                  <span class="mx-2 text-gray-600">•</span>
                  <span class="font-mono">missed=<%= job[:missed_runs] || 0 %></span>
                </div>
              </div>

              <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(job[:status]) %>">
                <%= job[:status].to_s.upcase %>
              </span>
            </div>

            <% if job[:last_error].present? %>
              <pre class="mt-4 rounded-lg border border-rose-500/20 bg-black/30 p-3 text-xs text-rose-200 whitespace-pre-wrap overflow-x-auto"><%= job[:last_error] %></pre>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-xl border border-emerald-500/20 bg-emerald-500/5 p-4 text-sm text-emerald-300">
        Aucune anomalie détectée.
      </div>
    <% end %>
  </section>

  <!-- Critical jobs -->
  <section class="<%= section_class %>">
    <div class="mb-5">
      <div class="<%= label_class %>">Cron supervision</div>
      <h2 class="mt-1 text-xl font-semibold text-gray-100">Jobs critiques</h2>
      <p class="mt-2 <%= muted_class %>">
        Vue compacte des jobs critiques, retards, durées, heartbeat et état opérationnel.
      </p>
    </div>

    <% critical_jobs = (@job_health || []).select { |job| job[:critical] || job[:status].to_s.in?(%w[failing fail failed stuck late long_running never_ran]) } %>

    <div class="rounded-xl border border-white/10 overflow-hidden">
      <table class="w-full table-fixed text-xs">
        <thead class="bg-black/20 text-gray-400">
          <tr class="text-left">
            <th class="py-3 px-3 w-[28%]">Job</th>
            <th class="py-3 px-3 w-[12%]">Statut</th>
            <th class="py-3 px-3 w-[16%]">Exécution</th>
            <th class="py-3 px-3 w-[14%]">Durée</th>
            <th class="py-3 px-3 w-[14%]">Retard</th>
            <th class="py-3 px-3 w-[16%]">Progression</th>
          </tr>
        </thead>

        <tbody class="text-gray-300">
          <% critical_jobs.first(20).each do |job| %>
            <tr class="border-t border-white/5 align-top hover:bg-white/5 transition">
              <td class="py-3 px-3">
                <div class="font-medium text-gray-100 truncate"><%= job[:label] || job[:name] %></div>
                <div class="mt-1 font-mono text-[10px] text-gray-500 truncate"><%= job[:name] %></div>
              </td>

              <td class="py-3 px-3">
                <span class="inline-flex items-center rounded-full px-2.5 py-1 text-[10px] font-semibold <%= status_badge_class(job[:status]) %>">
                  <%= job[:status].to_s.upcase %>
                </span>
              </td>

              <td class="py-3 px-3 font-mono text-[10px]">
                <div class="truncate text-gray-200">start: <%= safe_time(job[:last_run_at]) %></div>
                <div class="truncate text-gray-400 mt-1">end: <%= safe_time(job[:last_finish_at]) %></div>
                <div class="truncate text-gray-500 mt-1">hb: <%= safe_seconds(job[:heartbeat_age_seconds]) %></div>
              </td>

              <td class="py-3 px-3 font-mono text-[10px]">
                <div class="truncate text-gray-200">last: <%= safe_duration_ms(job[:last_duration_ms]) %></div>
                <div class="truncate text-gray-400 mt-1">avg10: <%= safe_duration_ms(job[:avg_duration_ms]) %></div>
              </td>

              <td class="py-3 px-3 font-mono text-[10px]">
                <div class="<%= job[:delay_seconds].to_i > 0 ? "text-amber-300" : "text-gray-200" %>">
                  delay: <%= safe_seconds(job[:delay_seconds]) %>
                </div>
                <div class="mt-1 text-gray-400">
                  missed: <%= job[:missed_runs] || 0 %>
                </div>
              </td>

              <td class="py-3 px-3 font-mono text-[10px]">
                <% if job[:progress_pct].present? || job[:progress_label].present? %>
                  <% pct = [[job[:progress_pct].to_f, 0].max, 100].min %>

                  <% if job[:progress_pct].present? %>
                    <div class="flex items-center justify-between mb-1">
                      <span class="text-gray-500">progress</span>
                      <span class="text-gray-300"><%= pct.round(1) %>%</span>
                    </div>

                    <div class="h-1.5 rounded-full bg-white/10 overflow-hidden">
                      <div class="h-full bg-sky-400 rounded-full" style="width: <%= pct %>%"></div>
                    </div>
                  <% end %>

                  <% if job[:progress_label].present? %>
                    <div class="mt-1 text-[10px] text-gray-500 truncate">
                      <%= job[:progress_label] %>
                    </div>
                  <% end %>
                <% else %>
                  <span class="text-gray-500">—</span>
                <% end %>
              </td>
            </tr>

            <% if job[:last_error].present? %>
              <tr class="border-t border-white/5">
                <td colspan="6" class="px-3 pb-4">
                  <div class="rounded-lg border border-rose-500/20 bg-black/30 p-3 text-[10px] text-rose-200 whitespace-pre-wrap break-words">
                    <%= job[:last_error] %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% end %>

          <% if critical_jobs.blank? %>
            <tr>
              <td colspan="6" class="py-6 px-4 text-sm text-emerald-300">
                Aucun job critique en anomalie.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>