<!-- app/views/system/index.html.erb -->
<% @checks          ||= {} %>
<% @summary         ||= {} %>
<% @recovery        ||= {} %>
<% @anomalies       ||= [] %>
<% @job_health      ||= [] %>
<% @scanner_status  ||= {} %>
<% @exchange_like_status ||= {} %>
<% @btc_status ||= {} %>
<% @tables          ||= {} %>
<% @jobs            ||= [] %>
<% @snapshot        ||= {} %>
<% @sidekiq_status ||= {} %>
<% @cluster_pipeline_status ||= {} %>
<% @realtime ||= {} %>

<%
  section_class = "rounded-2xl border border-white/10 bg-white/5 p-5"
  panel_class   = "rounded-xl border border-white/10 bg-black/20 p-4"
  label_class   = "text-[11px] uppercase tracking-[0.14em] text-gray-500"
  muted_class   = "text-sm text-gray-400"
  mono_class    = "font-mono text-xs"

  global_state =
    if @recovery[:critical_problems_count].to_i > 0
      "critical"
    elsif @anomalies.any?
      "warning"
    else
      "ok"
    end

  def status_badge_class(status)
    case status.to_s
    when "skipped"
      "text-orange-300 bg-orange-500/10 border border-orange-500/20"
    when "stuck"
      "text-rose-200 bg-rose-500/20 border border-rose-500/30"
    when "ok"
      "text-emerald-300 bg-emerald-500/10 border border-emerald-500/20"
    when "running"
      "text-sky-300 bg-sky-500/10 border border-sky-500/20"
    when "warning", "late"
      "text-amber-300 bg-amber-500/10 border border-amber-500/20"
    when "failing", "fail", "long_running", "never_ran", "stale"
      "text-rose-300 bg-rose-500/10 border border-rose-500/20"
    when "disabled"
      "text-gray-300 bg-gray-500/10 border border-gray-500/20"
    else
      "text-gray-300 bg-gray-500/10 border border-gray-500/20"
    end
  end

  def global_badge_class(state)
    case state.to_s
    when "ok"
      "text-emerald-300 bg-emerald-500/10 border border-emerald-500/20"
    when "warning"
      "text-amber-300 bg-amber-500/10 border border-amber-500/20"
    else
      "text-rose-300 bg-rose-500/10 border border-rose-500/20"
    end
  end

  def yes_no_badge(value)
    value ? "OK" : "FAIL"
  end

  def yes_no_badge_class(value)
    value ? "text-emerald-300 bg-emerald-500/10 border border-emerald-500/20" :
            "text-rose-300 bg-rose-500/10 border border-rose-500/20"
  end

  def safe_time(value)
    return "—" if value.blank?
    if respond_to?(:fmt_time)
      fmt_time(value)
    else
      value.respond_to?(:strftime) ? value.strftime("%Y-%m-%d %H:%M:%S") : value.to_s
    end
  rescue
    value.to_s
  end

  def safe_duration_ms(value)
    return "—" if value.blank?
    if respond_to?(:fmt_duration_ms)
      fmt_duration_ms(value)
    else
      total_seconds = (value.to_f / 1000.0).round
      minutes = total_seconds / 60
      seconds = total_seconds % 60
      minutes.positive? ? "#{minutes}m #{seconds}s" : "#{seconds}s"
    end
  end

  def safe_seconds(value)
    return "—" if value.blank?
    if respond_to?(:fmt_seconds)
      fmt_seconds(value)
    else
      total_seconds = value.to_i
      minutes = total_seconds / 60
      seconds = total_seconds % 60
      minutes.positive? ? "#{minutes}m #{seconds}s" : "#{seconds}s"
    end
  end

  bitcoind = @checks[:bitcoind] || {}
  blockchain = @checks[:bitcoind_activity] || {}
  disks = @checks[:disks] || {}
  disk_cards = [disks[:bitcoind], disks[:data], disks[:system]].compact
%>

<div class="w-full max-w-none mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">
  <!-- Header -->
  <section class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4">
    <div>
      <div class="<%= label_class %>">Operations dashboard</div>
      <h1 class="mt-2 text-3xl font-bold text-gray-100">System</h1>
      <p class="mt-2 <%= muted_class %>">
        Supervision opérationnelle de l’infrastructure, des jobs cron, des scanners et de la fraîcheur des données.
      </p>
    </div>

    <div class="flex flex-col items-start lg:items-end gap-2">
      <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold <%= global_badge_class(global_state) %>">
        <%= global_state.upcase %>
      </span>
      <div class="text-xs text-gray-500 font-mono">
        snapshot:
        <span class="text-gray-300"><%= safe_time(@snapshot[:generated_at] || Time.current) %></span>
      </div>
    </div>
  </section>

  <!-- KPI -->
  <section class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-6 gap-4">
    <div class="<%= section_class %>">
      <div class="<%= label_class %>">Global status</div>
      <div class="mt-3 text-2xl font-bold <%= global_state == "ok" ? "text-emerald-300" : global_state == "warning" ? "text-amber-300" : "text-rose-300" %>">
        <%= global_state.upcase %>
      </div>
    </div>

    <div class="<%= section_class %>">
      <div class="<%= label_class %>">Jobs actifs</div>
      <div class="mt-3 text-2xl font-bold text-gray-100"><%= @summary[:active_jobs_count] || 0 %></div>
    </div>

    <div class="<%= section_class %>">
      <div class="<%= label_class %>">Jobs critiques</div>
      <div class="mt-3 text-2xl font-bold text-gray-100"><%= @summary[:critical_jobs_count] || 0 %></div>
    </div>

    <div class="<%= section_class %>">
      <div class="<%= label_class %>">En retard</div>
      <div class="mt-3 text-2xl font-bold text-amber-300"><%= @summary[:late_jobs_count] || 0 %></div>
    </div>

    <div class="<%= section_class %>">
      <div class="<%= label_class %>">Running / longs</div>
      <div class="mt-3 text-2xl font-bold text-sky-300">
        <%= (@summary[:running_jobs_count] || 0) + (@summary[:long_running_jobs_count] || 0) %>
      </div>
    </div>

    <div class="<%= section_class %>">
      <div class="<%= label_class %>">En échec</div>
      <div class="mt-3 text-2xl font-bold text-rose-300"><%= @summary[:failing_jobs_count] || 0 %></div>
    </div>
  </section>

  <!-- Recovery -->
  <section class="<%= section_class %>">
    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4">
      <div>
        <div class="<%= label_class %>">Recovery</div>

        <h2 class="mt-1 text-xl font-semibold text-gray-100">
          Recovery readiness
        </h2>

        <p class="mt-2 <%= muted_class %>">
          État synthétique de la capacité du système à reprendre automatiquement
          après panne, redémarrage serveur, coupure électrique ou interruption prolongée.
        </p>
      </div>

      <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold <%= @recovery[:recovery_needed] ? "text-rose-300 bg-rose-500/10 border border-rose-500/20" : "text-emerald-300 bg-emerald-500/10 border border-emerald-500/20" %>">
        <%= @recovery[:recovery_needed] ? "RECOVERY NEEDED" : "READY" %>
      </span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-5">
      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Bitcoind RPC</div>

        <div class="mt-3">
          <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold <%= yes_no_badge_class(bitcoind[:ok]) %>">
            <%= yes_no_badge(bitcoind[:ok]) %>
          </span>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Problèmes critiques</div>

        <div class="mt-3 text-2xl font-bold text-gray-100">
          <%= @recovery[:critical_problems_count] || 0 %>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">
          Ordre de récupération des données
        </div>

        <div class="mt-3 text-sm text-gray-300 leading-6">
          <%= (@recovery[:restart_order] || []).presence&.join(" → ") || "—" %>
        </div>
      </div>
    </div>

    <% if (@recovery[:critical_problems] || []).any? %>
      <div class="mt-5 rounded-xl border border-rose-500/20 bg-rose-500/5 p-4">
        <div class="text-sm font-semibold text-rose-200">
          Problèmes critiques détectés
        </div>

        <div class="mt-3 grid grid-cols-1 md:grid-cols-2 gap-3">
          <% @recovery[:critical_problems].each do |problem| %>
            <div class="rounded-lg bg-black/20 border border-white/10 px-3 py-2">
              <div class="text-sm text-gray-100">
                <%= problem[:name] %>
              </div>

              <div class="text-xs text-rose-300 mt-1">
                <%= problem[:status] %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </section>

  <!-- Infrastructure -->
  <section class="<%= section_class %>">
    <div class="mb-5">
      <div class="<%= label_class %>">Infrastructure</div>
      <h2 class="mt-1 text-xl font-semibold text-gray-100">Bitcoind, blockchain et stockage</h2>
      <p class="mt-2 <%= muted_class %>">
        Vue rapide de la connectivité RPC, de la progression blockchain et de l’occupation disque.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
      <div class="<%= panel_class %>">
        <div class="flex items-start justify-between gap-3">
          <div>
            <div class="<%= label_class %>">Service</div>
            <div class="mt-1 text-lg font-semibold text-gray-100">Bitcoind RPC</div>
          </div>
          <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= yes_no_badge_class(bitcoind[:ok]) %>">
            <%= yes_no_badge(bitcoind[:ok]) %>
          </span>
        </div>

        <% if bitcoind[:ok] %>
          <div class="mt-4 space-y-2 text-sm">
            <div class="flex items-center justify-between">
              <span class="text-gray-500">Blocks</span>
              <span class="font-mono text-gray-200"><%= bitcoind[:blocks] || "—" %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-gray-500">Progress</span>
              <span class="font-mono text-gray-200"><%= bitcoind[:progress_pct] || "—" %>%</span>
            </div>
          </div>
        <% else %>
          <pre class="mt-4 text-xs text-rose-200 whitespace-pre-wrap"><%= bitcoind[:error].presence || "Erreur RPC non disponible." %></pre>
        <% end %>
      </div>

      <div class="<%= panel_class %>">
        <div class="flex items-start justify-between gap-3">
          <div>
            <div class="<%= label_class %>">Réseau</div>
            <div class="mt-1 text-lg font-semibold text-gray-100">Blockchain</div>
          </div>
          <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= yes_no_badge_class(blockchain[:ok]) %>">
            <%= yes_no_badge(blockchain[:ok]) %>
          </span>
        </div>

        <% if blockchain[:ok] %>
          <div class="mt-4 space-y-2 text-sm">
            <div class="flex items-center justify-between">
              <span class="text-gray-500">Blocks</span>
              <span class="font-mono text-gray-200"><%= blockchain[:blocks] || "—" %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-gray-500">Headers</span>
              <span class="font-mono text-gray-200"><%= blockchain[:headers] || "—" %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-gray-500">Lag</span>
              <span class="font-mono <%= blockchain[:lag].to_i > 0 ? "text-amber-300" : "text-gray-200" %>"><%= blockchain[:lag] || "—" %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-gray-500">Progress</span>
              <span class="font-mono text-gray-200"><%= blockchain[:progress_pct] || "—" %>%</span>
            </div>
          </div>
        <% else %>
          <pre class="mt-4 text-xs text-rose-200 whitespace-pre-wrap"><%= blockchain[:error].presence || "Erreur blockchain non disponible." %></pre>
        <% end %>
      </div>

      <% disk_cards.each do |disk| %>
        <% disk_state = (disk[:status] || "warn").to_s %>
        <div class="<%= panel_class %>">
          <div class="flex items-start justify-between gap-3">
            <div>
              <div class="<%= label_class %>">Disque</div>
              <div class="mt-1 text-lg font-semibold text-gray-100"><%= disk[:label] || "Storage" %></div>
            </div>
            <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(disk_state) %>">
              <%= disk_state.upcase %>
            </span>
          </div>

          <div class="mt-4 space-y-2 text-sm">
            <div class="flex items-center justify-between">
              <span class="text-gray-500">Path</span>
              <span class="font-mono text-gray-200"><%= disk[:path] || "—" %></span>
            </div>
            <% if disk[:mount].present? %>
              <div class="flex items-center justify-between">
                <span class="text-gray-500">Mount</span>
                <span class="font-mono text-gray-200"><%= disk[:mount] %></span>
              </div>
            <% end %>
            <div class="flex items-center justify-between">
              <span class="text-gray-500">Utilisation</span>
              <span class="font-mono text-gray-200"><%= disk[:used_pct] ? "#{disk[:used_pct]}%" : "—" %></span>
            </div>
          </div>

          <% if disk[:raw].present? %>
            <pre class="mt-4 text-xs text-gray-400 whitespace-pre-wrap leading-5"><%= disk[:raw] %></pre>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>

  <!-- Realtime -->
  <section class="<%= section_class %>">
    <div class="mb-5">
      <div class="<%= label_class %>">Realtime</div>
      <h2 class="mt-1 text-xl font-semibold text-gray-100">Realtime block stream</h2>
      <p class="mt-2 <%= muted_class %>">
        Surveillance des nouveaux blocs Bitcoin et traitement incrémental du module Cluster.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <% { "Watcher" => (@realtime[:watcher] || {}), "Processor" => (@realtime[:processor] || {}) }.each do |name, state| %>
        <% status = (state[:status] || :missing).to_s %>

        <div class="<%= panel_class %>">
          <div class="flex items-start justify-between gap-3">
            <div>
              <div class="<%= label_class %>"><%= name %></div>
              <div class="mt-1 text-lg font-semibold text-gray-100">
                <%= name == "Watcher" ? "Block detector" : "Block processor" %>
              </div>
            </div>

            <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(status) %>">
              <%= status.upcase %>
            </span>
          </div>

          <div class="mt-4 space-y-2 text-sm">
            <div class="flex items-center justify-between">
              <span class="text-gray-500">Last height</span>
              <span class="font-mono text-gray-200"><%= state[:last_blockheight] || "—" %></span>
            </div>

            <div class="flex items-center justify-between">
              <span class="text-gray-500">Updated</span>
              <span class="font-mono text-gray-200"><%= safe_time(state[:updated_at]) %></span>
            </div>

            <div class="flex items-center justify-between">
              <span class="text-gray-500">Age</span>
              <span class="font-mono <%= state[:age_seconds].to_i > 1200 ? "text-amber-300" : "text-gray-200" %>">
                <%= safe_seconds(state[:age_seconds]) %>
              </span>
            </div>

            <div>
              <div class="text-gray-500 mb-1">Hash</div>
              <div class="font-mono text-xs text-gray-400 break-all">
                <%= state[:last_blockhash] || "—" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <!-- Sidekiq -->
  <section class="<%= section_class %>">
    <div class="mb-5">
      <div class="<%= label_class %>">Async processing</div>
      <h2 class="mt-1 text-xl font-semibold text-gray-100">Sidekiq / Redis</h2>
      <p class="mt-2 <%= muted_class %>">
        Supervision des workers asynchrones utilisés notamment par le refresh des clusters.
      </p>
    </div>

    <% if @sidekiq_status[:error].present? %>
      <div class="rounded-xl border border-rose-500/20 bg-rose-500/5 p-4 text-sm text-rose-200">
        <%= @sidekiq_status[:error] %>
      </div>
    <% else %>
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
        <div class="<%= panel_class %>">
          <div class="flex items-start justify-between gap-3">
            <div>
              <div class="<%= label_class %>">Status</div>
              <div class="mt-1 text-lg font-semibold text-gray-100">Sidekiq</div>
            </div>
            <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(@sidekiq_status[:status]) %>">
              <%= @sidekiq_status[:status].to_s.upcase %>
            </span>
          </div>

          <div class="mt-4 space-y-2 text-sm">
            <div class="flex items-center justify-between">
              <span class="text-gray-500">Processes</span>
              <span class="font-mono text-gray-200"><%= @sidekiq_status[:processes_size] || 0 %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-gray-500">Busy</span>
              <span class="font-mono text-gray-200"><%= @sidekiq_status[:busy] || 0 %> / <%= @sidekiq_status[:concurrency] || 0 %></span>
            </div>
          </div>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Queue</div>
          <div class="mt-4 space-y-2 text-sm">
            <div class="flex items-center justify-between">
              <span class="text-gray-500">Default queue</span>
              <span class="font-mono text-gray-200"><%= @sidekiq_status[:queue_size] || 0 %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-gray-500">Latency</span>
              <span class="font-mono text-gray-200"><%= @sidekiq_status[:latency] || 0 %>s</span>
            </div>
          </div>

          <% if (@sidekiq_status[:jobs_by_class] || {}).any? %>
            <div class="mt-4 border-t border-white/5 pt-3">
              <div class="text-xs text-gray-500 mb-2">Jobs en attente</div>

              <div class="space-y-1">
                <% @sidekiq_status[:jobs_by_class].each do |klass, count| %>
                  <div class="flex items-center justify-between gap-3 text-xs">
                    <span class="font-mono text-gray-400 truncate"><%= klass %></span>
                    <span class="font-mono text-gray-200"><%= count %></span>
                  </div>
                <% end %>
              </div>
            </div>
          <% else %>
            <div class="mt-4 border-t border-white/5 pt-3 text-xs text-emerald-300">
              Aucun job en attente.
            </div>
          <% end %>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Reliability</div>
          <div class="mt-4 space-y-2 text-sm">
            <div class="flex items-center justify-between">
              <span class="text-gray-500">Processed</span>
              <span class="font-mono text-gray-200"><%= @sidekiq_status[:processed] || 0 %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-gray-500">Failed</span>
              <span class="font-mono text-rose-300"><%= @sidekiq_status[:failed] || 0 %></span>
            </div>
          </div>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Backlog</div>
          <div class="mt-4 space-y-2 text-sm">
            <div class="flex items-center justify-between">
              <span class="text-gray-500">Scheduled</span>
              <span class="font-mono text-gray-200"><%= @sidekiq_status[:scheduled_size] || 0 %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-gray-500">Retry</span>
              <span class="font-mono text-amber-300"><%= @sidekiq_status[:retry_size] || 0 %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-gray-500">Dead</span>
              <span class="font-mono text-rose-300"><%= @sidekiq_status[:dead_size] || 0 %></span>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </section>

  <!-- Cluster pipeline -->
  <section class="<%= section_class %>">
    <div class="mb-5">
      <div class="<%= label_class %>">Cluster intelligence</div>
      <h2 class="mt-1 text-xl font-semibold text-gray-100">Cluster pipeline</h2>

      <p class="mt-2 <%= muted_class %>">
        Supervision complète du pipeline cluster : scan blockchain, refresh async, profils, métriques et signaux.
      </p>
    </div>

    <% if @cluster_pipeline_status[:error].present? %>
      <div class="rounded-xl border border-rose-500/20 bg-rose-500/5 p-4 text-sm text-rose-200">
        <%= @cluster_pipeline_status[:error] %>
      </div>
    <% else %>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">

        <div class="<%= panel_class %>">
          <div class="flex items-start justify-between gap-3">
            <div>
              <div class="<%= label_class %>">Scanner</div>
              <div class="mt-1 text-lg font-semibold text-gray-100">
                Cluster scan
              </div>
            </div>

            <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(@cluster_pipeline_status[:status]) %>">
              <%= @cluster_pipeline_status[:status].to_s.upcase %>
            </span>
          </div>

          <div class="mt-4 space-y-2 text-sm">
            <div class="flex items-center justify-between">
              <span class="text-gray-500">Last scanned</span>
              <span class="font-mono text-gray-200">
                <%= @cluster_pipeline_status[:scanner_height] || "—" %>
              </span>
            </div>

            <div class="flex items-center justify-between">
              <span class="text-gray-500">Best block</span>
              <span class="font-mono text-gray-200">
                <%= @cluster_pipeline_status[:best_height] || "—" %>
              </span>
            </div>

            <div class="flex items-center justify-between">
              <span class="text-gray-500">Lag</span>

              <span class="font-mono <%= @cluster_pipeline_status[:lag].to_i > 12 ? "text-rose-300" : "text-gray-200" %>">
                <%= @cluster_pipeline_status[:lag] || "—" %>
              </span>
            </div>
          </div>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Async refresh</div>

          <div class="mt-4 space-y-2 text-sm">

            <div class="flex items-center justify-between">
              <span class="text-gray-500">Refresh queue</span>

              <span class="font-mono <%= @cluster_pipeline_status[:refresh_queue].to_i > 0 ? "text-amber-300" : "text-emerald-300" %>">
