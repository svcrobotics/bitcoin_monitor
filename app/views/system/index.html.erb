  <!-- Cluster / Actor Graph -->
  <section class="<%= section_class %>">
    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-5">
      <div>
        <div class="<%= label_class %>">Actor Graph</div>
        <h2 class="mt-1 text-xl font-semibold text-gray-100">Cluster Engine</h2>
        <p class="mt-2 <%= muted_class %>">
          Couche intermédiaire entre Layer 1 et les modules analytiques : clusters, liens d’adresses,
          profils économiques et dirty refresh.
        </p>
      </div>

      <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold <%= status_badge_class(@cluster_pipeline_status[:status]) %>">
        <%= @cluster_pipeline_status[:status].to_s.upcase.presence || "UNKNOWN" %>
      </span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-5 gap-4">
      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Batch scanner</div>
        <div class="mt-3 text-3xl font-bold text-gray-100">
          <%= cluster_batch[:scanner_height] || "—" %>
        </div>
        <p class="mt-2 <%= muted_class %>">
          lag <%= cluster_batch[:lag] || "—" %> blocs
        </p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Realtime stream</div>
        <div class="mt-3 text-3xl font-bold text-gray-100">
          <%= cluster_realtime[:scanner_height] || "—" %>
        </div>
        <p class="mt-2 <%= muted_class %>">
          lag <%= cluster_realtime[:lag] || "—" %> blocs
        </p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Dirty clusters</div>
        <div class="mt-3 text-3xl font-bold <%= @cluster_pipeline_status[:dirty_queue_size].to_i > 0 ? "text-amber-300" : "text-emerald-300" %>">
          <%= @cluster_pipeline_status[:dirty_queue_size] || 0 %>
        </div>
        <p class="mt-2 <%= muted_class %>">
          refresh queue <%= @cluster_pipeline_status[:refresh_queue] || 0 %>
        </p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Profiles</div>
        <div class="mt-3 text-3xl font-bold text-gray-100">
          <%= @cluster_pipeline_status[:profiles_count] || 0 %>
        </div>
        <p class="mt-2 <%= muted_class %>">
          profils de clusters
        </p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Signals</div>
        <div class="mt-3 text-3xl font-bold text-gray-100">
          <%= @cluster_pipeline_status[:signals_count] || 0 %>
        </div>
        <p class="mt-2 <%= muted_class %>">
          événements analytiques
        </p>
      </div>
    </div>
  </section>

  <!-- Actor Labels -->
  <section class="<%= section_class %>">
    <%
      actor_labels = @actor_labels_status || {}

      total_labels = actor_labels[:total].to_i
      displayed_labels = actor_labels[:displayed].presence || actor_labels[:displayed_count].presence || 100

      exchange_like_count = actor_labels[:exchange_like].to_i
      whale_like_count = actor_labels[:whale_like].to_i
      service_like_count = actor_labels[:service_like].to_i
      retail_like_count = actor_labels[:retail_like].to_i
      unknown_count = actor_labels[:unknown].to_i

      last_updated_at = actor_labels[:last_updated_at]

      coverage_count = exchange_like_count + whale_like_count + service_like_count + retail_like_count + unknown_count
      coverage_pct = total_labels.positive? ? ((coverage_count.to_f / total_labels) * 100).round(1) : 0

      actor_label_state =
        if total_labels.zero?
          "warning"
        elsif exchange_like_count.zero? && whale_like_count.zero? && service_like_count.zero?
          "warning"
        else
          "ok"
        end
    %>

    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <div class="<%= label_class %>">Actor Graph</div>
        <h2 class="mt-1 text-xl font-semibold text-gray-100">Actor Labels</h2>
        <p class="mt-2 <%= muted_class %>">
          Couche de classification économique : transforme les profils de clusters en acteurs exploitables
          par les modules exchange-like, whales, flows et analytics.
        </p>
      </div>

      <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold <%= status_badge_class(actor_label_state) %>">
        <%= actor_label_state.upcase %>
      </span>
    </div>

    <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-6">
      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Total labels</div>
        <div class="mt-3 text-3xl font-bold text-gray-100">
          <%= number_with_delimiter(total_labels) %>
        </div>
        <p class="mt-2 <%= muted_class %>">
          réalité en base
        </p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Displayed</div>
        <div class="mt-3 text-3xl font-bold text-gray-100">
          <%= number_with_delimiter(displayed_labels) %>
        </div>
        <p class="mt-2 <%= muted_class %>">
          lignes affichées dans la vue
        </p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Exchange-like</div>
        <div class="mt-3 text-3xl font-bold text-blue-300">
          <%= number_with_delimiter(exchange_like_count) %>
        </div>
        <p class="mt-2 <%= muted_class %>">
          acteurs probables exchanges
        </p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Whale-like</div>
        <div class="mt-3 text-3xl font-bold text-purple-300">
          <%= number_with_delimiter(whale_like_count) %>
        </div>
        <p class="mt-2 <%= muted_class %>">
          grands détenteurs probables
        </p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Service-like</div>
        <div class="mt-3 text-3xl font-bold text-emerald-300">
          <%= number_with_delimiter(service_like_count) %>
        </div>
        <p class="mt-2 <%= muted_class %>">
          services / infrastructures
        </p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Retail / Unknown</div>
        <div class="mt-3 text-3xl font-bold text-gray-100">
          <%= number_with_delimiter(retail_like_count + unknown_count) %>
        </div>
        <p class="mt-2 <%= muted_class %>">
          retail: <%= number_with_delimiter(retail_like_count) %> · unknown: <%= number_with_delimiter(unknown_count) %>
        </p>
      </div>
    </div>

    <div class="mt-5 rounded-2xl border border-slate-800 bg-slate-950/40 p-4">
      <div class="<%= label_class %>">Diagnostic Actor Labels</div>

      <p class="mt-2 text-sm leading-relaxed text-slate-300">
        <% if total_labels.zero? %>
          Aucun label économique n’est disponible. Les modules Layer 2 ne peuvent pas encore s’appuyer sur l’Actor Graph.
        <% elsif displayed_labels.to_i < total_labels %>
          Actor Labels est opérationnel. La page affiche
          <span class="font-mono text-gray-100"><%= number_with_delimiter(displayed_labels) %></span>
          lignes sur
          <span class="font-mono text-gray-100"><%= number_with_delimiter(total_labels) %></span>
          labels réels en base. La distribution affichée ici correspond à la totalité des labels, pas seulement aux lignes visibles.
        <% elsif exchange_like_count.zero? %>
          Les labels existent, mais aucun acteur exchange-like n’est identifié. Les flows exchange risquent d’être incomplets.
        <% elsif whale_like_count.zero? %>
          Les labels sont actifs. Les exchanges sont disponibles, mais la détection whale-like doit encore monter en couverture.
        <% else %>
          Actor Labels est opérationnel. Les modules Layer 2 peuvent consommer les classifications économiques issues du Cluster Engine.
        <% end %>
      </p>

      <div class="mt-4 h-1.5 overflow-hidden rounded-full bg-white/10">
        <div
          class="h-full rounded-full <%= coverage_pct >= 95 ? "bg-emerald-400" : coverage_pct >= 50 ? "bg-amber-400" : "bg-rose-400" %>"
          style="width: <%= [[coverage_pct, 0].max, 100].min %>%">
        </div>
      </div>

      <div class="mt-2 flex items-center justify-between text-xs text-gray-500">
        <span>Distribution coverage</span>
        <span class="font-mono text-gray-300"><%= coverage_pct %>%</span>
      </div>
    </div>

    <div class="mt-5 flex flex-col gap-3 border-t border-white/10 pt-4 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-xs text-gray-500">
        Last update:
        <span class="font-mono text-gray-300">
          <%= last_updated_at || "—" %>
        </span>
      </p>

      <%= link_to "Open Actor Labels", actor_labels_path,
        class: "inline-flex items-center rounded-xl border border-blue-500/20 bg-blue-500/10 px-3 py-2 text-xs font-semibold text-blue-300 hover:bg-blue-500/15 transition" %>
    </div>
  </section>
  
  <!-- Exchange Core Flow -->
  <section class="<%= section_class %>">
    <%
      flow_today = Dashboard::ExchangeCoreNetflowToday.call rescue {}

      inflow_btc = flow_today[:inflow_btc].to_d
      outflow_btc = flow_today[:outflow_btc].to_d
      netflow_btc = flow_today[:netflow_btc].to_d

      events_count = flow_today[:events_count].to_i
      signal = flow_today[:signal].presence || "Unknown"

      exchange_like_count =
        (@actor_labels_status || {})[:exchange_like].to_i

      last_flow_height =
        ExchangeCoreFlowEvent.maximum(:block_height)

      best_height =
        @layer1_status[:best_height].to_i rescue 0

      flow_lag =
        if last_flow_height.present?
          [best_height - last_flow_height.to_i, 0].max
        else
          nil
        end

      flow_state =
        if exchange_like_count.zero?
          "warning"
        elsif flow_lag.to_i > 6
          "warning"
        else
          "ok"
        end
    %>

    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <div class="<%= label_class %>">Layer 2 consumer</div>

        <h2 class="mt-1 text-xl font-semibold text-gray-100">
          Exchange Core Flow
        </h2>

        <p class="mt-2 <%= muted_class %>">
          Module Layer 2 consommateur des Actor Labels. Analyse les flux entrants et sortants des acteurs exchange_like afin de mesurer la pression acheteuse/vendeuse du marché.
        </p>
      </div>

      <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold <%= status_badge_class(flow_state) %>">
        <%= flow_state.upcase %>
      </span>
    </div>

    <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-6">
      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Source</div>

        <div class="mt-3 text-3xl font-bold text-blue-300">
          Actor Graph
        </div>

        <p class="mt-2 <%= muted_class %>">
          exchange_like labels
        </p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Exchange actors</div>

        <div class="mt-3 text-3xl font-bold text-gray-100">
          <%= number_with_delimiter(exchange_like_count) %>
        </div>

        <p class="mt-2 <%= muted_class %>">
          acteurs exchange_like actifs
        </p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Today inflow</div>

        <div class="mt-3 text-3xl font-bold text-rose-300">
          <%= fmt_btc(inflow_btc) %>
        </div>

        <p class="mt-2 <%= muted_class %>">
          BTC entrants vers exchanges
        </p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Today outflow</div>

        <div class="mt-3 text-3xl font-bold text-emerald-300">
          <%= fmt_btc(outflow_btc) %>
        </div>

        <p class="mt-2 <%= muted_class %>">
          BTC sortants des exchanges
        </p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Netflow</div>

        <div class="mt-3 text-3xl font-bold <%= netflow_btc.positive? ? "text-rose-300" : "text-emerald-300" %>">
          <%= fmt_btc(netflow_btc) %>
        </div>

        <p class="mt-2 <%= muted_class %>">
          <%= signal %>
        </p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Events today</div>

        <div class="mt-3 text-3xl font-bold text-gray-100">
          <%= number_with_delimiter(events_count) %>
        </div>

        <p class="mt-2 <%= muted_class %>">
          événements exchange détectés
        </p>
      </div>
    </div>

    <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-3">
      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Last processed block</div>

        <div class="mt-3 text-3xl font-bold text-gray-100">
          <%= last_flow_height || "—" %>
        </div>

        <p class="mt-2 <%= muted_class %>">
          dernière hauteur traitée
        </p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Flow lag</div>

        <div class="mt-3 text-3xl font-bold <%= flow_lag.to_i > 0 ? "text-amber-300" : "text-emerald-300" %>">
          <%= flow_lag || 0 %>
        </div>

        <p class="mt-2 <%= muted_class %>">
          retard sur Layer 1
        </p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Updated at</div>

        <div class="mt-2 text-sm text-gray-300">
          <%= flow_today[:updated_at] || "—" %>
        </div>
      </div>
    </div>

    <div class="mt-5 rounded-2xl border border-slate-800 bg-slate-950/40 p-4">
      <div class="<%= label_class %>">
        Diagnostic Exchange Core Flow
      </div>

      <p class="mt-2 text-sm leading-relaxed text-slate-300">
        <% if exchange_like_count.zero? %>
          Aucun acteur exchange_like n’est disponible dans Actor Labels. Exchange Core Flow ne peut pas encore produire des flux fiables.
        <% elsif flow_lag.to_i > 6 %>
          Exchange Core Flow présente un retard de <%= flow_lag %> bloc(s) par rapport au Layer 1. Les métriques de netflow peuvent être temporairement incomplètes.
        <% elsif netflow_btc.positive? %>
          Les entrées vers exchanges dominent actuellement les sorties. Le module détecte une pression vendeuse nette sur les acteurs exchange_like.
        <% else %>
          Les sorties des exchanges dominent actuellement les entrées. Le module détecte une pression acheteuse ou accumulation probable.
        <% end %>
      </p>
    </div>
  </section>

  <!-- Sidekiq summary -->
  <section class="<%= section_class %>">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <div class="<%= label_class %>">Async processing</div>
        <h2 class="mt-1 text-xl font-semibold text-gray-100">Sidekiq / Redis</h2>
        <p class="mt-2 <%= muted_class %>">
          Résumé runtime. Le détail des queues, backlogs et workers est disponible dans la page Sidekiq.
        </p>
      </div>

      <%= link_to "Ouvrir Sidekiq runtime",
        system_sidekiq_path,
        class: "inline-flex items-center rounded-xl border border-sky-500/20 bg-sky-500/10 px-4 py-2 text-sm font-medium text-sky-300 hover:bg-sky-500/15 transition" %>
    </div>

    <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-4">
      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Status</div>
        <div class="mt-3 text-2xl font-bold text-gray-100">
          <%= @sidekiq_status[:status].to_s.upcase.presence || "UNKNOWN" %>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Busy</div>
        <div class="mt-3 text-2xl font-bold text-gray-100">
          <%= @sidekiq_status[:busy] || 0 %> / <%= @sidekiq_status[:concurrency] || 0 %>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Retry</div>
        <div class="mt-3 text-2xl font-bold <%= @sidekiq_status[:retry_size].to_i > 0 ? "text-amber-300" : "text-emerald-300" %>">
          <%= @sidekiq_status[:retry_size] || 0 %>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Dead</div>
        <div class="mt-3 text-2xl font-bold <%= @sidekiq_status[:dead_size].to_i > 0 ? "text-rose-300" : "text-emerald-300" %>">
          <%= @sidekiq_status[:dead_size] || 0 %>
        </div>
      </div>
    </div>
  </section>

  <!-- Anomalies -->
  <section class="<%= section_class %>">
    <div class="mb-5">
      <div class="<%= label_class %>">Exceptions</div>
      <h2 class="mt-1 text-xl font-semibold text-gray-100">Anomalies à traiter</h2>
      <p class="mt-2 <%= muted_class %>">
        Liste courte des jobs nécessitant une attention immédiate.
      </p>
    </div>

    <% if @anomalies.any? %>
      <div class="space-y-3">
        <% @anomalies.first(8).each do |job| %>
          <div class="rounded-xl border border-amber-500/20 bg-amber-500/5 p-4">
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0">
                <div class="text-sm font-semibold text-gray-100"><%= job[:label] || job[:name] %></div>
                <div class="mt-1 text-xs text-gray-400">
                  <span class="font-mono">status=<%= job[:status] %></span>
                  <span class="mx-2 text-gray-600">•</span>
                  <span class="font-mono">delay=<%= safe_seconds(job[:delay_seconds]) %></span>
                  <span class="mx-2 text-gray-600">•</span>
                  <span class="font-mono">missed=<%= job[:missed_runs] || 0 %></span>
                </div>
              </div>

              <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(job[:status]) %>">
                <%= job[:status].to_s.upcase %>
              </span>
            </div>

            <% if job[:last_error].present? %>
              <pre class="mt-4 rounded-lg border border-rose-500/20 bg-black/30 p-3 text-xs text-rose-200 whitespace-pre-wrap overflow-x-auto"><%= job[:last_error] %></pre>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-xl border border-emerald-500/20 bg-emerald-500/5 p-4 text-sm text-emerald-300">
        Aucune anomalie détectée.
      </div>
    <% end %>
  </section>

  <!-- Critical jobs -->
  <section class="<%= section_class %>">
    <div class="mb-5">
      <div class="<%= label_class %>">Cron supervision</div>
      <h2 class="mt-1 text-xl font-semibold text-gray-100">Jobs critiques</h2>
      <p class="mt-2 <%= muted_class %>">
        Vue compacte des jobs critiques, retards, durées, heartbeat et état opérationnel.
      </p>
    </div>

    <% critical_jobs = (@job_health || []).select { |job| job[:critical] || job[:status].to_s.in?(%w[failing fail failed stuck late long_running never_ran]) } %>

    <div class="rounded-xl border border-white/10 overflow-hidden">
      <table class="w-full table-fixed text-xs">
        <thead class="bg-black/20 text-gray-400">
          <tr class="text-left">
            <th class="py-3 px-3 w-[28%]">Job</th>
            <th class="py-3 px-3 w-[12%]">Statut</th>
            <th class="py-3 px-3 w-[16%]">Exécution</th>
            <th class="py-3 px-3 w-[14%]">Durée</th>
            <th class="py-3 px-3 w-[14%]">Retard</th>
            <th class="py-3 px-3 w-[16%]">Progression</th>
          </tr>
        </thead>

        <tbody class="text-gray-300">
          <% critical_jobs.first(20).each do |job| %>
            <tr class="border-t border-white/5 align-top hover:bg-white/5 transition">
              <td class="py-3 px-3">
                <div class="font-medium text-gray-100 truncate"><%= job[:label] || job[:name] %></div>
                <div class="mt-1 font-mono text-[10px] text-gray-500 truncate"><%= job[:name] %></div>
              </td>

              <td class="py-3 px-3">
                <span class="inline-flex items-center rounded-full px-2.5 py-1 text-[10px] font-semibold <%= status_badge_class(job[:status]) %>">
                  <%= job[:status].to_s.upcase %>
                </span>
              </td>

              <td class="py-3 px-3 font-mono text-[10px]">
                <div class="truncate text-gray-200">start: <%= safe_time(job[:last_run_at]) %></div>
                <div class="truncate text-gray-400 mt-1">end: <%= safe_time(job[:last_finish_at]) %></div>
                <div class="truncate text-gray-500 mt-1">hb: <%= safe_seconds(job[:heartbeat_age_seconds]) %></div>
              </td>

              <td class="py-3 px-3 font-mono text-[10px]">
                <div class="truncate text-gray-200">last: <%= safe_duration_ms(job[:last_duration_ms]) %></div>
                <div class="truncate text-gray-400 mt-1">avg10: <%= safe_duration_ms(job[:avg_duration_ms]) %></div>
              </td>

              <td class="py-3 px-3 font-mono text-[10px]">
                <div class="<%= job[:delay_seconds].to_i > 0 ? "text-amber-300" : "text-gray-200" %>">
                  delay: <%= safe_seconds(job[:delay_seconds]) %>
                </div>
                <div class="mt-1 text-gray-400">
                  missed: <%= job[:missed_runs] || 0 %>
                </div>
              </td>

              <td class="py-3 px-3 font-mono text-[10px]">
                <% if job[:progress_pct].present? || job[:progress_label].present? %>
                  <% pct = [[job[:progress_pct].to_f, 0].max, 100].min %>

                  <% if job[:progress_pct].present? %>
                    <div class="flex items-center justify-between mb-1">
                      <span class="text-gray-500">progress</span>
                      <span class="text-gray-300"><%= pct.round(1) %>%</span>
                    </div>

                    <div class="h-1.5 rounded-full bg-white/10 overflow-hidden">
                      <div class="h-full bg-sky-400 rounded-full" style="width: <%= pct %>%"></div>
                    </div>
                  <% end %>

                  <% if job[:progress_label].present? %>
                    <div class="mt-1 text-[10px] text-gray-500 truncate">
                      <%= job[:progress_label] %>
                    </div>
                  <% end %>
                <% else %>
                  <span class="text-gray-500">—</span>
                <% end %>
              </td>
            </tr>

            <% if job[:last_error].present? %>
              <tr class="border-t border-white/5">
                <td colspan="6" class="px-3 pb-4">
                  <div class="rounded-lg border border-rose-500/20 bg-black/30 p-3 text-[10px] text-rose-200 whitespace-pre-wrap break-words">
                    <%= job[:last_error] %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% end %>

          <% if critical_jobs.blank? %>
            <tr>
              <td colspan="6" class="py-6 px-4 text-sm text-emerald-300">
                Aucun job critique en anomalie.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>