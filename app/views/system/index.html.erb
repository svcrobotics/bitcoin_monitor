<!-- app/views/system/index.html.erb -->
<% @checks ||= {} %>
<% @summary ||= {} %>
<% @recovery ||= {} %>
<% @anomalies ||= [] %>
<% @job_health ||= [] %>
<% @exchange_like_status ||= {} %>
<% @btc_status ||= {} %>
<% @snapshot ||= {} %>
<% @sidekiq_status ||= {} %>
<% @cluster_pipeline_status ||= {} %>
<% @realtime ||= {} %>
<% @recovery_snapshot ||= {} %>
<% @recent_blocks ||= [] %>
<% @actor_labels_status ||= {} %>
<% @actor_intelligence ||= {} %>

<% layer1 = @recovery_snapshot[:layer1] || {} %>
<% layer1_counts = layer1[:status_counts] || {} %>
<% layer1_redis = layer1[:redis_buffers] || {} %>
<% cluster_batch = @cluster_pipeline_status[:batch] || {} %>
<% cluster_realtime = @cluster_pipeline_status[:realtime] || {} %>

<%
  section_class = "rounded-2xl border border-white/10 bg-white/5 p-5 shadow-sm"
  panel_class   = "rounded-xl border border-white/10 bg-black/20 p-4"
  label_class   = "text-[11px] uppercase tracking-[0.14em] text-gray-500"
  muted_class   = "text-sm text-gray-400"

  bitcoind = @checks[:bitcoind] || {}
  blockchain = @checks[:bitcoind_activity] || {}
  disks = @checks[:disks] || {}
  disk_cards = [disks[:bitcoind], disks[:data], disks[:system]].compact

  actor_labels = @actor_labels_status || {}

  exchange_like_count = actor_labels[:exchange_like].to_i
  whale_like_count = actor_labels[:whale_like].to_i
  etf_like_count = actor_labels[:etf_like].to_i
  service_like_count = actor_labels[:service_like].to_i
  retail_like_count = actor_labels[:retail_like].to_i
  unknown_count = actor_labels[:unknown].to_i
  total_labels = actor_labels[:total].to_i

  actor_profile_count = begin
    defined?(ActorProfile) ? ActorProfile.count : 0
  rescue
    0
  end

  address_flow_stat_count = begin
    defined?(AddressFlowStat) ? AddressFlowStat.count : 0
  rescue
    0
  end

  latest_whale_flow = begin
    defined?(WhaleCoreFlowDay) ? WhaleCoreFlowDay.order(day: :desc).first : nil
  rescue
    nil
  end

  latest_exchange_flow_height = begin
    defined?(ExchangeCoreFlowEvent) ? ExchangeCoreFlowEvent.maximum(:block_height) : nil
  rescue
    nil
  end

  global_state =
    if @recovery[:critical_problems_count].to_i > 0
      "critical"
    elsif @anomalies.any?
      "warning"
    else
      "ok"
    end

  def status_badge_class(status)
    case status.to_s
    when "ok", "ready", "healthy", "fresh"
      "text-emerald-300 bg-emerald-500/10 border border-emerald-500/20"
    when "running", "processing", "active"
      "text-sky-300 bg-sky-500/10 border border-sky-500/20"
    when "warning", "late", "delayed", "skipped", "waiting"
      "text-amber-300 bg-amber-500/10 border border-amber-500/20"
    when "stuck", "failing", "fail", "failed", "stale", "critical", "never_ran"
      "text-rose-300 bg-rose-500/10 border border-rose-500/20"
    else
      "text-gray-300 bg-gray-500/10 border border-gray-500/20"
    end
  end

  def safe_time(value)
    return "—" if value.blank?

    if respond_to?(:fmt_time)
      fmt_time(value)
    else
      value.respond_to?(:strftime) ? value.strftime("%Y-%m-%d %H:%M:%S") : value.to_s
    end
  rescue
    value.to_s
  end

  def safe_seconds(value)
    return "—" if value.blank?

    if respond_to?(:fmt_seconds)
      fmt_seconds(value)
    else
      total_seconds = value.to_i
      minutes = total_seconds / 60
      seconds = total_seconds % 60
      minutes.positive? ? "#{minutes}m #{seconds}s" : "#{seconds}s"
    end
  end

  def yes_no_badge(value)
    value ? "OK" : "FAIL"
  end

  def fmt_btc(value)
    return "—" if value.blank?

    "#{value.to_d.round(4).to_s('F')} BTC"
  rescue
    value.to_s
  end

  def compact_btc(value)
    return "—" if value.blank?

    value.to_d.round(2).to_s("F")
  rescue
    value.to_s
  end
%>

<div class="w-full max-w-none mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">
  <!-- Header -->
  <section class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <div class="<%= label_class %>">Operations dashboard</div>
      <h1 class="mt-2 text-3xl font-bold text-gray-100">System</h1>
      <p class="mt-2 max-w-4xl <%= muted_class %>">
        Cockpit Tansa : lecture simple de la chaîne réelle Bitcoin Core → Layer 1 → Cluster → Actor Profiles → Actor Labels → Layer 2.
        Les états expérimentaux restent internes ; cette page affiche uniquement les couches canoniques et les sorties métier.
      </p>
    </div>

    <div class="flex flex-col items-start gap-2 lg:items-end">
      <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold <%= status_badge_class(global_state) %>">
        <%= global_state.upcase %>
      </span>
      <div class="text-xs text-gray-500 font-mono">
        snapshot:
        <span class="text-gray-300"><%= safe_time(@snapshot[:generated_at] || Time.current) %></span>
      </div>
    </div>
  </section>

  <!-- Top KPIs -->
  <section class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-6">
    <div class="<%= section_class %>">
      <div class="<%= label_class %>">Global status</div>
      <div class="mt-3 text-2xl font-bold <%= global_state == "ok" ? "text-emerald-300" : global_state == "warning" ? "text-amber-300" : "text-rose-300" %>">
        <%= global_state.upcase %>
      </div>
      <div class="mt-2 text-xs text-gray-500">santé générale</div>
    </div>

    <div class="<%= section_class %>">
      <div class="<%= label_class %>">Layer 1 lag</div>
      <div class="mt-3 text-2xl font-bold <%= layer1[:lag].to_i > 0 ? "text-amber-300" : "text-emerald-300" %>">
        <%= layer1[:lag] || 0 %>
      </div>
      <div class="mt-2 text-xs text-gray-500">blocs de retard</div>
    </div>

    <div class="<%= section_class %>">
      <div class="<%= label_class %>">Cluster lag</div>
      <div class="mt-3 text-2xl font-bold <%= cluster_realtime[:lag].to_i > 24 ? "text-rose-300" : cluster_realtime[:lag].to_i > 6 ? "text-amber-300" : "text-emerald-300" %>">
        <%= cluster_realtime[:lag] || 0 %>
      </div>
      <div class="mt-2 text-xs text-gray-500">
        batch: <span class="font-mono text-gray-300"><%= cluster_batch[:lag] || "—" %></span>
      </div>
    </div>

    <div class="<%= section_class %>">
      <div class="<%= label_class %>">Actor profiles</div>
      <div class="mt-3 text-2xl font-bold text-cyan-300">
        <%= number_with_delimiter(actor_profile_count) %>
      </div>
      <div class="mt-2 text-xs text-gray-500">profils comportementaux</div>
    </div>

    <div class="<%= section_class %>">
      <div class="<%= label_class %>">Validated actors</div>
      <div class="mt-3 text-2xl font-bold text-purple-300">
        <%= number_with_delimiter(exchange_like_count + whale_like_count + etf_like_count) %>
      </div>
      <div class="mt-2 text-xs text-gray-500">exchange · whale · ETF</div>
    </div>

    <div class="<%= section_class %>">
      <div class="<%= label_class %>">Whale netflow</div>
      <div class="mt-3 text-2xl font-bold <%= latest_whale_flow&.netflow_btc.to_f >= 0 ? 'text-emerald-300' : 'text-rose-300' %>">
        <%= latest_whale_flow ? "#{latest_whale_flow.netflow_btc.to_f.round(0)} BTC" : "—" %>
      </div>
      <div class="mt-2 text-xs text-gray-500"><%= latest_whale_flow&.day || "no data" %></div>
    </div>
  </section>

  <%= render "system/layer1/block_chain_stream", blocks: @recent_blocks %>

  <!-- Canonical pipeline -->
  <section class="<%= section_class %>">
    <div class="mb-5">
      <div class="<%= label_class %>">Canonical architecture</div>
      <h2 class="mt-1 text-xl font-semibold text-gray-100">Layer 1 → Cluster → Actor Profiles → Actor Labels → Layer 2</h2>
      <p class="mt-2 <%= muted_class %>">
        Cette carte montre la colonne vertébrale officielle. Les modules métier ne devinent pas les acteurs directement : ils consomment les labels validés.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-4 xl:grid-cols-5">
      <% [
        ["1", "Layer 1", "Blocs, transactions, outputs, spends", "Vérité blockchain canonique", layer1[:lag].to_i.zero? ? "ok" : "running"],
        ["2", "Cluster", "Adresses regroupées en entités probables", "Structure technique", @cluster_pipeline_status[:status].presence || "unknown"],
        ["3", "Actor Profiles", "Volumes, activité, net BTC, scores", "Comportement économique", actor_profile_count.positive? ? "ok" : "warning"],
        ["4", "Actor Labels", "exchange_like, whale_like, etf_like", "Classification exploitable", total_labels.positive? ? "ok" : "warning"],
        ["5", "Layer 2", "Flows, alerts, signals, intelligence", "Lecture métier", (exchange_like_count + whale_like_count + etf_like_count).positive? ? "ok" : "waiting"]
      ].each do |step, title, body, purpose, status| %>
        <div class="rounded-2xl border border-white/10 bg-slate-950/50 p-4">
          <div class="flex items-center justify-between gap-3">
            <div class="flex items-center gap-3">
              <div class="flex h-8 w-8 items-center justify-center rounded-full bg-cyan-500/10 text-sm font-bold text-cyan-300"><%= step %></div>
              <div class="text-base font-semibold text-gray-100"><%= title %></div>
            </div>
            <span class="rounded-full px-2 py-1 text-[10px] font-semibold <%= status_badge_class(status) %>"><%= status.to_s.upcase %></span>
          </div>
          <p class="mt-3 text-sm text-gray-300"><%= body %></p>
          <p class="mt-2 text-xs text-gray-500"><%= purpose %></p>
        </div>
      <% end %>
    </div>
  </section>

  <!-- Infrastructure -->
  <section class="<%= section_class %>">
    <div class="mb-5 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <div class="<%= label_class %>">Infrastructure</div>
        <h2 class="mt-1 text-xl font-semibold text-gray-100">Bitcoin Core, RPC, ZMQ et stockage</h2>
        <p class="mt-2 <%= muted_class %>">
          Les dépendances de base doivent être saines avant de juger les couches analytiques.
        </p>
      </div>
      <%= link_to "Ouvrir Recovery center",
          system_recovery_path,
          class: "inline-flex items-center rounded-xl border border-sky-500/20 bg-sky-500/10 px-4 py-2 text-sm font-medium text-sky-300 hover:bg-sky-500/15 transition" %>
    </div>

    <div class="grid grid-cols-1 gap-5 xl:grid-cols-3">
      <div class="xl:col-span-2 rounded-xl border border-white/10 bg-black/20 p-4">
        <div class="mb-4">
          <div class="<%= label_class %>">Core blockchain</div>
          <h3 class="mt-1 text-lg font-semibold text-gray-100">Bitcoin Core / RPC</h3>
        </div>

        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
          <div class="rounded-xl border border-white/10 bg-gray-950/60 p-4">
            <div class="flex items-start justify-between gap-3">
              <div>
                <div class="<%= label_class %>">Service</div>
                <div class="mt-1 text-base font-semibold text-gray-100">Bitcoind RPC</div>
              </div>
              <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(bitcoind[:ok] ? "ok" : "fail") %>">
                <%= yes_no_badge(bitcoind[:ok]) %>
              </span>
            </div>

            <div class="mt-4 space-y-2 text-sm">
              <div class="flex items-center justify-between gap-4"><span class="text-gray-500">Blocks</span><span class="font-mono text-gray-200"><%= bitcoind[:blocks] || "—" %></span></div>
              <div class="flex items-center justify-between gap-4"><span class="text-gray-500">Progress</span><span class="font-mono text-gray-200"><%= bitcoind[:progress_pct] || "—" %>%</span></div>
            </div>
          </div>

          <div class="rounded-xl border border-white/10 bg-gray-950/60 p-4">
            <div class="flex items-start justify-between gap-3">
              <div>
                <div class="<%= label_class %>">Network</div>
                <div class="mt-1 text-base font-semibold text-gray-100">Blockchain sync</div>
              </div>
              <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(blockchain[:ok] ? "ok" : "fail") %>">
                <%= yes_no_badge(blockchain[:ok]) %>
              </span>
            </div>

            <div class="mt-4 space-y-2 text-sm">
              <div class="flex items-center justify-between gap-4"><span class="text-gray-500">Blocks</span><span class="font-mono text-gray-200"><%= blockchain[:blocks] || "—" %></span></div>
              <div class="flex items-center justify-between gap-4"><span class="text-gray-500">Headers</span><span class="font-mono text-gray-200"><%= blockchain[:headers] || "—" %></span></div>
              <div class="flex items-center justify-between gap-4"><span class="text-gray-500">Node lag</span><span class="font-mono <%= blockchain[:lag].to_i > 0 ? "text-amber-300" : "text-emerald-300" %>"><%= blockchain[:lag] || 0 %></span></div>
            </div>
          </div>
        </div>
      </div>

      <div class="rounded-xl border border-white/10 bg-black/20 p-4">
        <%= turbo_stream_from "bitcoin_blocks" %>

        <div class="mb-4">
          <div class="<%= label_class %>">Realtime ingestion</div>
          <h3 class="mt-1 text-lg font-semibold text-gray-100">ZMQ watcher / processor</h3>
        </div>

        <div class="space-y-3">
          <% { "Watcher" => (@realtime[:watcher] || {}), "Processor" => (@realtime[:processor] || {}) }.each do |name, state| %>
            <% status = (state[:status] || :missing).to_s %>

            <div class="rounded-xl border border-white/10 bg-gray-950/60 p-4">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <div class="<%= label_class %>"><%= name %></div>
                  <div class="mt-1 text-base font-semibold text-gray-100"><%= name == "Watcher" ? "Block detector" : "Layer 1 processor" %></div>
                </div>
                <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(status) %>"><%= status.upcase %></span>
              </div>

              <div class="mt-4 space-y-2 text-sm">
                <div class="flex items-center justify-between gap-4"><span class="text-gray-500">Last height</span><span class="font-mono text-gray-200"><%= state[:last_blockheight] || "—" %></span></div>
                <div class="flex items-center justify-between gap-4"><span class="text-gray-500">Age</span><span class="font-mono <%= state[:age_seconds].to_i > 1200 ? "text-amber-300" : "text-gray-200" %>"><%= safe_seconds(state[:age_seconds]) %></span></div>
                <div class="pt-2 border-t border-white/5">
                  <div class="text-gray-500 text-xs mb-1">Updated</div>
                  <div class="font-mono text-xs text-gray-300 truncate"><%= safe_time(state[:updated_at]) %></div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <% if disk_cards.any? %>
      <div class="mt-5 rounded-xl border border-white/10 bg-black/20 p-4">
        <div class="mb-4">
          <div class="<%= label_class %>">Storage</div>
          <h3 class="mt-1 text-lg font-semibold text-gray-100">Disques et volumes</h3>
        </div>

        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
          <% disk_cards.each do |disk| %>
            <% disk_state = (disk[:status] || "warn").to_s %>
            <% used_pct = [[disk[:used_pct].to_f, 0].max, 100].min if disk[:used_pct].present? %>

            <div class="rounded-xl border border-white/10 bg-gray-950/60 p-4">
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                  <div class="<%= label_class %>">Disque</div>
                  <div class="mt-1 truncate text-base font-semibold text-gray-100"><%= disk[:label] || "Storage" %></div>
                </div>
                <span class="shrink-0 inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(disk_state) %>"><%= disk_state.upcase %></span>
              </div>

              <div class="mt-4 space-y-2 text-sm">
                <div>
                  <div class="text-gray-500 mb-1">Path</div>
                  <div class="font-mono text-xs text-gray-300 truncate"><%= disk[:path] || "—" %></div>
                </div>

                <% if disk[:mount].present? %>
                  <div>
                    <div class="text-gray-500 mb-1">Mount</div>
                    <div class="font-mono text-xs text-gray-300 truncate"><%= disk[:mount] %></div>
                  </div>
                <% end %>

                <div class="flex items-center justify-between gap-4">
                  <span class="text-gray-500">Utilisation</span>
                  <span class="font-mono <%= disk[:used_pct].to_i >= 90 ? "text-rose-300" : disk[:used_pct].to_i >= 80 ? "text-amber-300" : "text-gray-200" %>">
                    <%= disk[:used_pct] ? "#{disk[:used_pct]}%" : "—" %>
                  </span>
                </div>

                <% if disk[:used_pct].present? %>
                  <div class="h-1.5 overflow-hidden rounded-full bg-white/10">
                    <div class="h-full rounded-full <%= used_pct >= 90 ? "bg-rose-400" : used_pct >= 80 ? "bg-amber-400" : "bg-emerald-400" %>" style="width: <%= used_pct %>%"></div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </section>

  <!-- Layer 1 -->
  <section class="<%= section_class %>">
    <% processed_height = layer1[:last_processed_height].to_i %>
    <% spent_height = layer1[:spent_max_height].to_i %>
    <% flow_height = layer1[:exchange_flow_max_height].to_i %>
    <% spent_lag = processed_height.positive? && spent_height.positive? ? [processed_height - spent_height, 0].max : nil %>
    <% flow_lag = processed_height.positive? && flow_height.positive? ? [processed_height - flow_height, 0].max : nil %>
    <% async_lag = [spent_lag.to_i, flow_lag.to_i].max %>
    <% layer1_state =
      if layer1_counts["failed"].to_i > 0
        "failed"
      elsif layer1[:lag].to_i > 0 || layer1_counts["processing"].to_i > 0 || layer1_counts["enqueued"].to_i > 0 || async_lag > 5
        "running"
      else
        "ok"
      end
    %>

    <div class="mb-5 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <div class="<%= label_class %>">Layer 1</div>
        <h2 class="mt-1 text-xl font-semibold text-gray-100">Canonical blockchain data</h2>
        <p class="mt-2 <%= muted_class %>">
          Ingestion des blocs, extraction des outputs, résolution des spends et flush PostgreSQL. C’est la source de vérité pour toutes les couches suivantes.
        </p>
      </div>
      <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold <%= status_badge_class(layer1_state) %>"><%= layer1_state.upcase %></span>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-6">
      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Best height</div>
        <div class="mt-3 text-3xl font-bold text-gray-100"><%= layer1[:best_height] || "—" %></div>
        <div class="mt-3 space-y-2 text-sm">
          <div class="flex justify-between"><span class="text-gray-500">Buffered</span><span class="font-mono text-gray-200"><%= layer1[:highest_buffered_height] || "—" %></span></div>
          <div class="flex justify-between"><span class="text-gray-500">Processed</span><span class="font-mono text-gray-200"><%= layer1[:last_processed_height] || "—" %></span></div>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Lag</div>
        <div class="mt-3 text-3xl font-bold <%= layer1[:lag].to_i > 0 ? "text-amber-300" : "text-emerald-300" %>"><%= layer1[:lag] || 0 %></div>
        <div class="mt-3 space-y-2 text-sm">
          <div class="flex justify-between"><span class="text-gray-500">Speed</span><span class="font-mono text-gray-200"><%= layer1[:recovery_speed] || "—" %> bloc/min</span></div>
          <div class="flex justify-between"><span class="text-gray-500">ETA</span><span class="font-mono text-gray-200"><%= layer1[:eta_minutes] ? "#{layer1[:eta_minutes]} min" : "—" %></span></div>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Async state</div>
        <div class="mt-3 text-3xl font-bold <%= async_lag > 5 ? "text-amber-300" : "text-emerald-300" %>"><%= async_lag %></div>
        <div class="mt-3 space-y-2 text-sm">
          <div class="flex justify-between"><span class="text-gray-500">Spent max</span><span class="font-mono text-gray-200"><%= spent_height.positive? ? spent_height : "—" %></span></div>
          <div class="flex justify-between"><span class="text-gray-500">Flow max</span><span class="font-mono text-gray-200"><%= flow_height.positive? ? flow_height : "—" %></span></div>
          <div class="flex justify-between"><span class="text-gray-500">Spent lag</span><span class="font-mono <%= spent_lag.to_i > 5 ? "text-amber-300" : "text-gray-200" %>"><%= spent_lag.nil? ? "—" : spent_lag %></span></div>
          <div class="flex justify-between"><span class="text-gray-500">Flow lag</span><span class="font-mono <%= flow_lag.to_i > 5 ? "text-amber-300" : "text-gray-200" %>"><%= flow_lag.nil? ? "—" : flow_lag %></span></div>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Block states</div>
        <div class="mt-3 grid grid-cols-2 gap-2 text-sm">
          <div class="flex justify-between gap-3"><span class="text-gray-500">Pending</span><span class="font-mono text-gray-200"><%= layer1_counts["pending"].to_i %></span></div>
          <div class="flex justify-between gap-3"><span class="text-gray-500">Enqueued</span><span class="font-mono text-amber-300"><%= layer1_counts["enqueued"].to_i %></span></div>
          <div class="flex justify-between gap-3"><span class="text-gray-500">Processing</span><span class="font-mono text-sky-300"><%= layer1_counts["processing"].to_i %></span></div>
          <div class="flex justify-between gap-3"><span class="text-gray-500">Failed</span><span class="font-mono text-rose-300"><%= layer1_counts["failed"].to_i %></span></div>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Redis buffers</div>
        <div class="mt-3 text-3xl font-bold <%= (layer1_redis[:outputs_buffer].to_i + layer1_redis[:spent_outputs_buffer].to_i) > 0 ? "text-amber-300" : "text-emerald-300" %>">
          <%= layer1_redis[:outputs_buffer].to_i + layer1_redis[:spent_outputs_buffer].to_i %>
        </div>
        <div class="mt-3 space-y-2 text-sm">
          <div class="flex justify-between"><span class="text-gray-500">Outputs</span><span class="font-mono text-gray-200"><%= layer1_redis[:outputs_buffer] || 0 %></span></div>
          <div class="flex justify-between"><span class="text-gray-500">Spent</span><span class="font-mono text-gray-200"><%= layer1_redis[:spent_outputs_buffer] || 0 %></span></div>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">AddressFlowStats</div>
        <div class="mt-3 text-3xl font-bold text-cyan-300"><%= number_with_delimiter(address_flow_stat_count) %></div>
        <p class="mt-3 <%= muted_class %>">agrégats live par adresse</p>
      </div>
    </div>
  </section>

  <!-- Cluster -->
  <section class="<%= section_class %>">
    <div class="mb-5 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <div class="<%= label_class %>">Cluster</div>
        <h2 class="mt-1 text-xl font-semibold text-gray-100">Address graph & entities</h2>
        <p class="mt-2 <%= muted_class %>">
          Regroupe les adresses en entités probables. Cette couche ne produit pas encore de lecture métier finale ; elle prépare la structure utilisée par Actor Profiles.
        </p>
      </div>
      <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold <%= status_badge_class(@cluster_pipeline_status[:status]) %>">
        <%= @cluster_pipeline_status[:status].to_s.upcase.presence || "UNKNOWN" %>
      </span>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-5">
      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Batch scanner</div>
        <div class="mt-3 text-3xl font-bold text-gray-100"><%= cluster_batch[:scanner_height] || "—" %></div>
        <p class="mt-2 <%= muted_class %>">lag <%= cluster_batch[:lag] || "—" %> blocs</p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Realtime stream</div>
        <div class="mt-3 text-3xl font-bold text-gray-100"><%= cluster_realtime[:scanner_height] || "—" %></div>
        <p class="mt-2 <%= muted_class %>">lag <%= cluster_realtime[:lag] || "—" %> blocs</p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Dirty clusters</div>
        <div class="mt-3 text-3xl font-bold <%= @cluster_pipeline_status[:dirty_queue_size].to_i > 0 ? "text-amber-300" : "text-emerald-300" %>">
          <%= @cluster_pipeline_status[:dirty_queue_size] || 0 %>
        </div>
        <p class="mt-2 <%= muted_class %>">queue technique interne</p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Cluster profiles</div>
        <div class="mt-3 text-3xl font-bold text-gray-100"><%= @cluster_pipeline_status[:profiles_count] || 0 %></div>
        <p class="mt-2 <%= muted_class %>">profils cluster batch</p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Signals</div>
        <div class="mt-3 text-3xl font-bold text-gray-100"><%= @cluster_pipeline_status[:signals_count] || 0 %></div>
        <p class="mt-2 <%= muted_class %>">événements analytiques</p>
      </div>
    </div>
  </section>

  <!-- Actor Profiles -->
  <section class="<%= section_class %>">
    <% actor_profiles_runtime = @actor_profiles_runtime || {} %>
    <% actor_profile_queues = actor_profiles_runtime[:queues] || {} %>
    <% actor_profile_status = actor_profiles_runtime[:status] || "unknown" %>

    <div class="mb-5 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <div class="<%= label_class %>">Actor Profiles</div>
        <h2 class="mt-1 text-xl font-semibold text-gray-100">Behavioral runtime</h2>
        <p class="mt-2 <%= muted_class %>">
          Suit en temps réel le moteur incrémental : deltas produits par Layer 1, clusters dirty Redis,
          files Sidekiq light/heavy et derniers profils comportementaux mis à jour.
        </p>
      </div>

      <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold <%= status_badge_class(actor_profile_status) %>">
        <%= actor_profile_status.to_s.upcase %>
      </span>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-6">
      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Profiles</div>
        <div class="mt-3 text-3xl font-bold text-cyan-300">
          <%= number_with_delimiter(actor_profiles_runtime[:profiles_count].to_i) %>
        </div>
        <p class="mt-2 <%= muted_class %>">profils comportementaux</p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Unprocessed deltas</div>
        <div class="mt-3 text-3xl font-bold <%= actor_profiles_runtime[:deltas_unprocessed].to_i.positive? ? "text-amber-300" : "text-emerald-300" %>">
          <%= number_with_delimiter(actor_profiles_runtime[:deltas_unprocessed].to_i) %>
        </div>
        <p class="mt-2 <%= muted_class %>">événements à appliquer</p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Dirty Redis</div>
        <div class="mt-3 text-3xl font-bold <%= actor_profiles_runtime[:dirty_clusters].to_i.positive? ? "text-sky-300" : "text-emerald-300" %>">
          <%= number_with_delimiter(actor_profiles_runtime[:dirty_clusters].to_i) %>
        </div>
        <p class="mt-2 <%= muted_class %>">clusters à dispatcher</p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Queue light</div>
        <div class="mt-3 text-3xl font-bold text-gray-100">
          <%= number_with_delimiter(actor_profile_queues[:light].to_i) %>
        </div>
        <p class="mt-2 <%= muted_class %>">p3_actor_profile_light</p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Queue heavy</div>
        <div class="mt-3 text-3xl font-bold <%= actor_profile_queues[:heavy].to_i.positive? ? "text-amber-300" : "text-emerald-300" %>">
          <%= number_with_delimiter(actor_profile_queues[:heavy].to_i) %>
        </div>
        <p class="mt-2 <%= muted_class %>">gros clusters</p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">15 min activity</div>
        <div class="mt-3 text-3xl font-bold text-purple-300">
          <%= number_with_delimiter(actor_profiles_runtime[:processed_deltas_15m].to_i) %>
        </div>
        <p class="mt-2 <%= muted_class %>">
          processed / <%= number_with_delimiter(actor_profiles_runtime[:recent_deltas_15m].to_i) %> created
        </p>
      </div>
    </div>

    <div class="mt-5 rounded-2xl border border-white/10 bg-slate-950/40 p-4">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <div class="<%= label_class %>">Recent Actor Profiles</div>
          <h3 class="mt-1 text-lg font-semibold text-gray-100">Derniers profils mis à jour</h3>
        </div>
      </div>

      <div class="mt-4 overflow-hidden rounded-xl border border-white/10">
        <table class="min-w-full divide-y divide-white/10 text-sm">
          <thead class="bg-white/5">
            <tr class="text-left text-xs uppercase tracking-wide text-gray-400">
              <th class="px-4 py-3">Profile</th>
              <th class="px-4 py-3">Cluster</th>
              <th class="px-4 py-3">Classification</th>
              <th class="px-4 py-3">Priority</th>
              <th class="px-4 py-3">Height</th>
              <th class="px-4 py-3">Updated</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-white/5 bg-slate-950/30">
            <% Array(actor_profiles_runtime[:recent_profiles]).each do |profile| %>
              <tr>
                <td class="px-4 py-3 font-mono text-xs text-gray-300"><%= profile[:id] %></td>
                <td class="px-4 py-3 font-mono text-xs text-gray-300"><%= profile[:cluster_id] %></td>
                <td class="px-4 py-3">
                  <span class="inline-flex rounded-full bg-cyan-500/10 px-2 py-1 text-xs font-semibold text-cyan-300">
                    <%= profile[:classification] || "unknown" %>
                  </span>
                </td>
                <td class="px-4 py-3 font-mono text-xs text-gray-300"><%= profile[:priority] || "—" %></td>
                <td class="px-4 py-3 font-mono text-xs text-gray-300"><%= profile[:last_computed_height] || "—" %></td>
                <td class="px-4 py-3 font-mono text-xs text-gray-400"><%= safe_time(profile[:updated_at]) %></td>
              </tr>
            <% end %>

            <% if Array(actor_profiles_runtime[:recent_profiles]).empty? %>
              <tr>
                <td colspan="6" class="px-4 py-6 text-center text-sm text-gray-500">
                  Aucun profil récent.
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Actor Labels -->
  <section class="<%= section_class %>">
    <%
      actor_labels = @actor_labels_status || {}

      total_labels       = actor_labels[:total].to_i
      exchange_like_count = actor_labels[:exchange_like].to_i
      whale_like_count    = actor_labels[:whale_like].to_i
      etf_like_count      = actor_labels[:etf_like].to_i
      service_like_count  = actor_labels[:service_like].to_i
      retail_like_count   = actor_labels[:retail_like].to_i
      unknown_count       = actor_labels[:unknown].to_i

      displayed_labels = total_labels
      last_updated_at = actor_labels[:last_updated_at]

      coverage_count =
        exchange_like_count +
        whale_like_count +
        etf_like_count +
        service_like_count +
        retail_like_count +
        unknown_count

      coverage_pct =
        total_labels.positive? ?
          ((coverage_count.to_f / total_labels) * 100).round(1) :
          0

      actor_label_state =
        if total_labels.zero?
          "warning"
        elsif exchange_like_count.zero? &&
              whale_like_count.zero? &&
              etf_like_count.zero? &&
              service_like_count.zero?
          "warning"
        else
          "ok"
        end
    %>

    <div class="mb-5 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <div class="<%= label_class %>">Actor Labels</div>

        <h2 class="mt-1 text-xl font-semibold text-gray-100">
          Validated economic classifications
        </h2>

        <p class="mt-2 <%= muted_class %>">
          Labels validés issus uniquement des Actor Profiles.
          Cette vue ne mélange plus les anciennes sources
          cluster_profile, actor_metric ou actor_score.
        </p>
      </div>

      <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold <%= status_badge_class(actor_label_state) %>">
        <%= actor_label_state.upcase %>
      </span>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-6">
      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Total labels</div>
        <div class="mt-3 text-3xl font-bold text-gray-100">
          <%= number_with_delimiter(total_labels) %>
        </div>
        <p class="mt-2 <%= muted_class %>">
          source actor_profile uniquement
        </p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Exchange-like</div>
        <div class="mt-3 text-3xl font-bold text-blue-300">
          <%= number_with_delimiter(exchange_like_count) %>
        </div>
        <p class="mt-2 <%= muted_class %>">
          validés par ActorProfile
        </p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Whale-like</div>
        <div class="mt-3 text-3xl font-bold text-purple-300">
          <%= number_with_delimiter(whale_like_count) %>
        </div>
        <p class="mt-2 <%= muted_class %>">
          comportement accumulation
        </p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">ETF-like</div>
        <div class="mt-3 text-3xl font-bold text-emerald-300">
          <%= number_with_delimiter(etf_like_count) %>
        </div>
        <p class="mt-2 <%= muted_class %>">
          institutionnels détectés
        </p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Service-like</div>
        <div class="mt-3 text-3xl font-bold text-cyan-300">
          <%= number_with_delimiter(service_like_count) %>
        </div>
        <p class="mt-2 <%= muted_class %>">
          acteurs techniques
        </p>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Retail / Unknown</div>
        <div class="mt-3 text-3xl font-bold text-gray-100">
          <%= number_with_delimiter(retail_like_count + unknown_count) %>
        </div>
        <p class="mt-2 <%= muted_class %>">
          retail: <%= number_with_delimiter(retail_like_count) %>
          · unknown: <%= number_with_delimiter(unknown_count) %>
        </p>
      </div>
    </div>

    <div class="mt-5 rounded-2xl border border-slate-800 bg-slate-950/40 p-4">
      <div class="<%= label_class %>">Diagnostic Actor Labels</div>

      <p class="mt-2 text-sm leading-relaxed text-slate-300">
        <% if total_labels.zero? %>
          Aucun label issu d’Actor Profiles n’est disponible.
          Les modules Layer 2 ne doivent pas encore consommer cette source.
        <% elsif exchange_like_count.zero? &&
                whale_like_count.zero? &&
                etf_like_count.zero? %>
          Les Actor Profiles génèrent des labels,
          mais aucun acteur exchange/whale/ETF n’est encore disponible.
        <% else %>
          Actor Labels est opérationnel depuis la source
          <span class="font-mono text-cyan-300">actor_profile</span>.
        <% end %>
      </p>

      <div class="mt-4 h-1.5 overflow-hidden rounded-full bg-white/10">
        <div
          class="h-full rounded-full <%= coverage_pct >= 95 ? "bg-emerald-400" : coverage_pct >= 50 ? "bg-amber-400" : "bg-rose-400" %>"
          style="width: <%= [[coverage_pct, 0].max, 100].min %>%">
        </div>
      </div>

      <div class="mt-2 flex items-center justify-between text-xs text-gray-500">
        <span>Distribution coverage</span>
        <span class="font-mono text-gray-300">
          <%= coverage_pct %>%
        </span>
      </div>
    </div>

    <div class="mt-5 flex flex-col gap-3 border-t border-white/10 pt-4 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-xs text-gray-500">
        Source:
        <span class="font-mono text-cyan-300">
          <%= actor_labels[:source] || "actor_profile" %>
        </span>

        · Last update:
        <span class="font-mono text-gray-300">
          <%= safe_time(last_updated_at) %>
        </span>

        · Displayed:
        <span class="font-mono text-gray-300">
          <%= number_with_delimiter(displayed_labels) %>
        </span>
      </p>

      <%= link_to "Open Actor Labels",
        actor_labels_path,
        class: "inline-flex items-center rounded-xl border border-blue-500/20 bg-blue-500/10 px-3 py-2 text-xs font-semibold text-blue-300 hover:bg-blue-500/15 transition" %>
    </div>
  </section>

  <!-- Layer 2 Analytics -->
  <section class="<%= section_class %>">
    <div class="mb-5">
      <div class="<%= label_class %>">Layer 2</div>
      <h2 class="mt-1 text-xl font-semibold text-gray-100">Business intelligence modules</h2>
      <p class="mt-2 <%= muted_class %>">
        Les modules Layer 2 ne redétectent pas les acteurs. Ils consomment Actor Labels et produisent une lecture métier : pression exchange,
        comportement whale, accumulation ETF et futurs signaux/alertes.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-5 xl:grid-cols-3">
      <!-- Exchange Flow -->
      <div class="rounded-2xl border border-blue-500/10 bg-blue-500/[0.03] p-5">
        <%
          flow_today = Dashboard::ExchangeCoreNetflowToday.call rescue {}
          exchange_inflow_btc = flow_today[:inflow_btc].to_d
          exchange_outflow_btc = flow_today[:outflow_btc].to_d
          exchange_netflow_btc = flow_today[:netflow_btc].to_d
          exchange_events_count = flow_today[:events_count].to_i
          exchange_signal = flow_today[:signal].presence || "Unknown"
          best_height = layer1[:best_height].to_i
          exchange_flow_lag = latest_exchange_flow_height.present? && best_height.positive? ? [best_height - latest_exchange_flow_height.to_i, 0].max : nil
          exchange_flow_state = exchange_like_count.zero? ? "waiting" : exchange_flow_lag.to_i > 6 ? "warning" : "ok"
        %>

        <div class="flex items-start justify-between gap-4">
          <div>
            <div class="<%= label_class %>">Exchange Flow</div>
            <h3 class="mt-1 text-lg font-semibold text-gray-100">Exchange pressure</h3>
          </div>
          <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(exchange_flow_state) %>"><%= exchange_flow_state.upcase %></span>
        </div>

        <p class="mt-3 text-sm text-gray-400">
          Consomme <span class="font-mono text-blue-300">exchange_like</span> pour mesurer inflow, outflow et netflow des exchanges.
        </p>

        <div class="mt-5 grid grid-cols-2 gap-3">
          <div class="rounded-xl border border-white/10 bg-black/20 p-3">
            <div class="<%= label_class %>">Actors</div>
            <div class="mt-2 text-2xl font-bold text-blue-300"><%= number_with_delimiter(exchange_like_count) %></div>
          </div>
          <div class="rounded-xl border border-white/10 bg-black/20 p-3">
            <div class="<%= label_class %>">Events today</div>
            <div class="mt-2 text-2xl font-bold text-gray-100"><%= number_with_delimiter(exchange_events_count) %></div>
          </div>
          <div class="rounded-xl border border-white/10 bg-black/20 p-3">
            <div class="<%= label_class %>">Inflow</div>
            <div class="mt-2 text-xl font-bold text-rose-300"><%= fmt_btc(exchange_inflow_btc) %></div>
          </div>
          <div class="rounded-xl border border-white/10 bg-black/20 p-3">
            <div class="<%= label_class %>">Outflow</div>
            <div class="mt-2 text-xl font-bold text-emerald-300"><%= fmt_btc(exchange_outflow_btc) %></div>
          </div>
        </div>

        <div class="mt-4 rounded-xl border border-white/10 bg-black/20 p-3">
          <div class="flex items-center justify-between gap-3">
            <span class="text-sm text-gray-500">Netflow</span>
            <span class="font-mono text-lg font-bold <%= exchange_netflow_btc.positive? ? "text-rose-300" : "text-emerald-300" %>"><%= fmt_btc(exchange_netflow_btc) %></span>
          </div>
          <p class="mt-2 text-xs text-gray-500"><%= exchange_signal %> · lag <%= exchange_flow_lag || 0 %> bloc(s)</p>
        </div>
      </div>

      <!-- Whale Flow -->
      <div class="rounded-2xl border border-purple-500/10 bg-purple-500/[0.03] p-5">
        <%
          whale_today = begin
            defined?(WhaleCoreFlowDay) ? WhaleCoreFlowDay.order(day: :desc).first : nil
          rescue
            nil
          end
          whale_inflow_btc = whale_today&.inflow_btc.to_d
          whale_outflow_btc = whale_today&.outflow_btc.to_d
          whale_netflow_btc = whale_today&.netflow_btc.to_d
          whale_flow_state = whale_like_count.positive? ? "ok" : "waiting"
          whale_signal =
            if whale_netflow_btc.positive?
              "Accumulation"
            elsif whale_netflow_btc.negative?
              "Distribution"
            else
              "Neutral"
            end
        %>

        <div class="flex items-start justify-between gap-4">
          <div>
            <div class="<%= label_class %>">Whale Flow</div>
            <h3 class="mt-1 text-lg font-semibold text-gray-100">Large holder behavior</h3>
          </div>
          <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(whale_flow_state) %>"><%= whale_flow_state.upcase %></span>
        </div>

        <p class="mt-3 text-sm text-gray-400">
          Consomme uniquement <span class="font-mono text-purple-300">whale_like</span> pour suivre accumulation et distribution des grands acteurs validés.
        </p>

        <div class="mt-5 grid grid-cols-2 gap-3">
          <div class="rounded-xl border border-white/10 bg-black/20 p-3">
            <div class="<%= label_class %>">Actors</div>
            <div class="mt-2 text-2xl font-bold text-purple-300"><%= number_with_delimiter(whale_like_count) %></div>
          </div>
          <div class="rounded-xl border border-white/10 bg-black/20 p-3">
            <div class="<%= label_class %>">Signal</div>
            <div class="mt-2 text-2xl font-bold text-gray-100"><%= whale_signal %></div>
          </div>
          <div class="rounded-xl border border-white/10 bg-black/20 p-3">
            <div class="<%= label_class %>">Inflow</div>
            <div class="mt-2 text-xl font-bold text-rose-300"><%= fmt_btc(whale_inflow_btc) %></div>
          </div>
          <div class="rounded-xl border border-white/10 bg-black/20 p-3">
            <div class="<%= label_class %>">Outflow</div>
            <div class="mt-2 text-xl font-bold text-emerald-300"><%= fmt_btc(whale_outflow_btc) %></div>
          </div>
        </div>

        <div class="mt-4 rounded-xl border border-white/10 bg-black/20 p-3">
          <div class="flex items-center justify-between gap-3">
            <span class="text-sm text-gray-500">Netflow</span>
            <span class="font-mono text-lg font-bold <%= whale_netflow_btc.positive? ? "text-emerald-300" : whale_netflow_btc.negative? ? "text-rose-300" : "text-gray-300" %>"><%= fmt_btc(whale_netflow_btc) %></span>
          </div>
          <p class="mt-2 text-xs text-gray-500"><%= whale_today&.day || "no daily flow yet" %></p>
        </div>
      </div>

      <!-- ETF Flow -->
      <div class="rounded-2xl border border-emerald-500/10 bg-emerald-500/[0.03] p-5">
        <% etf_flow_state = etf_like_count.positive? ? "ok" : "waiting" %>

        <div class="flex items-start justify-between gap-4">
          <div>
            <div class="<%= label_class %>">ETF Flow</div>
            <h3 class="mt-1 text-lg font-semibold text-gray-100">Institutional accumulation</h3>
          </div>
          <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= status_badge_class(etf_flow_state) %>"><%= etf_flow_state.upcase %></span>
        </div>

        <p class="mt-3 text-sm text-gray-400">
          Consomme <span class="font-mono text-emerald-300">etf_like</span>. Tant qu’aucun ETF validé n’existe, le module reste en attente proprement.
        </p>

        <div class="mt-5 grid grid-cols-2 gap-3">
          <div class="rounded-xl border border-white/10 bg-black/20 p-3">
            <div class="<%= label_class %>">ETF-like</div>
            <div class="mt-2 text-2xl font-bold text-emerald-300"><%= number_with_delimiter(etf_like_count) %></div>
          </div>
          <div class="rounded-xl border border-white/10 bg-black/20 p-3">
            <div class="<%= label_class %>">Status</div>
            <div class="mt-2 text-2xl font-bold text-cyan-300"><%= etf_like_count.positive? ? "READY" : "WAITING" %></div>
          </div>
          <div class="rounded-xl border border-white/10 bg-black/20 p-3">
            <div class="<%= label_class %>">Input</div>
            <div class="mt-2 text-xl font-bold text-gray-100">Actor Labels</div>
          </div>
          <div class="rounded-xl border border-white/10 bg-black/20 p-3">
            <div class="<%= label_class %>">Output</div>
            <div class="mt-2 text-xl font-bold text-gray-100">ETF signal</div>
          </div>
        </div>

        <div class="mt-4 rounded-xl border border-white/10 bg-black/20 p-3">
          <div class="text-sm text-gray-300">
            <% if etf_like_count.positive? %>
              Des acteurs ETF-like validés sont disponibles. ETF Flow peut produire une lecture dédiée.
            <% else %>
              Aucun acteur ETF-like validé pour le moment. Le module attend davantage de données avant activation.
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Recovery summary -->
  <section class="<%= section_class %>">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <div class="<%= label_class %>">Recovery</div>
        <h2 class="mt-1 text-xl font-semibold text-gray-100">Operational recovery</h2>
        <p class="mt-2 <%= muted_class %>">
          Résumé rapide de la capacité du système à reprendre après panne, redémarrage ou retard Layer 1.
        </p>
      </div>

      <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold <%= status_badge_class(@recovery[:recovery_needed] ? "critical" : "ok") %>">
        <%= @recovery[:recovery_needed] ? "RECOVERY NEEDED" : "READY" %>
      </span>
    </div>

    <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-4">
      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Bitcoind RPC</div>
        <div class="mt-3">
          <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold <%= status_badge_class(bitcoind[:ok] ? "ok" : "fail") %>">
            <%= yes_no_badge(bitcoind[:ok]) %>
          </span>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Critical problems</div>
        <div class="mt-3 text-2xl font-bold text-gray-100"><%= @recovery[:critical_problems_count] || 0 %></div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Layer 1 processed</div>
        <div class="mt-3 text-2xl font-bold text-gray-100"><%= layer1[:last_processed_height] || "—" %></div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Recovery order</div>
        <div class="mt-3 text-sm leading-6 text-gray-300"><%= (@recovery[:restart_order] || []).presence&.join(" → ") || "—" %></div>
      </div>
    </div>
  </section>
</div>
