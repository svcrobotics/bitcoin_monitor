<div
  data-controller="block-chain-stream"
  class="rounded-2xl border border-white/10 bg-black/20 p-5 overflow-hidden"
>
  <div class="flex items-center justify-between gap-4 mb-5">
    <div>
      <div class="text-[11px] uppercase tracking-[0.14em] text-gray-500">
        Layer 1 live stream
      </div>

      <h2 class="mt-1 text-xl font-semibold text-gray-100">
        Chaîne de blocs récente
      </h2>

      <p class="mt-2 text-sm text-gray-400">
        Visualisation des derniers blocs ingérés : hauteur, statut, transactions et intervalle entre deux blocs.
      </p>
    </div>
  </div>

  <div class="relative">
    <div class="absolute left-0 right-0 top-1/2 h-px bg-sky-500/20"></div>

    <div class="flex gap-5 overflow-x-auto pb-3 scroll-smooth">
      <% blocks = Array(local_assigns[:blocks]) %>

      <% blocks.each_with_index do |block, index| %>
        <% previous_block = blocks[index + 1] %>

        <% delta_seconds =
          if block.block_time.present? && previous_block&.block_time.present?
            (block.block_time.to_time - previous_block.block_time.to_time).to_i.abs
          end
        %>

        <% rhythm =
          if delta_seconds.blank?
            "—"
          elsif delta_seconds < 300
            "rapide"
          elsif delta_seconds > 900
            "lent"
          else
            "normal"
          end
        %>

        <% rhythm_class =
          case rhythm
          when "rapide"
            "text-sky-300"
          when "lent"
            "text-amber-300"
          when "normal"
            "text-emerald-300"
          else
            "text-gray-400"
          end
        %>

        <% status = block.status.to_s %>

        <% badge_class =
          case status
          when "processed"
            "text-emerald-300 bg-emerald-500/10 border-emerald-500/20"
          when "processing"
            "text-sky-300 bg-sky-500/10 border-sky-500/20"
          when "enqueued", "pending"
            "text-amber-300 bg-amber-500/10 border-amber-500/20"
          when "failed"
            "text-rose-300 bg-rose-500/10 border-rose-500/20"
          else
            "text-gray-300 bg-gray-500/10 border-gray-500/20"
          end
        %>

        <div
          data-block-chain-stream-target="block"
          class="relative shrink-0 w-48 rounded-xl border border-white/10 bg-gray-950/90 p-4 shadow-lg transition duration-500 hover:-translate-y-1 hover:border-sky-500/30"
        >
          <div class="absolute -left-5 top-1/2 h-px w-5 bg-sky-500/30"></div>
          <div class="absolute -right-5 top-1/2 h-px w-5 bg-sky-500/30"></div>

          <div class="flex items-start justify-between gap-3">
            <div>
              <div class="text-[10px] uppercase tracking-wide text-gray-500">
                Block
              </div>

              <div class="mt-1 font-mono text-lg font-bold text-gray-100">
                <%= block.height %>
              </div>
            </div>

            <span class="rounded-full border px-2 py-0.5 text-[10px] font-semibold <%= badge_class %>">
              <%= status.upcase %>
            </span>
          </div>

          <div class="mt-4 space-y-2 text-xs">
            <div class="flex justify-between gap-3">
              <span class="text-gray-500">Tx</span>
              <span class="font-mono text-gray-200"><%= block.tx_count || "—" %></span>
            </div>

            <div class="flex justify-between gap-3">
              <span class="text-gray-500">Intervalle</span>
              <span class="font-mono <%= rhythm_class %>">
                <%= delta_seconds ? "#{(delta_seconds / 60.0).round(1)} min" : "—" %>
              </span>
            </div>

            <div class="flex justify-between gap-3">
              <span class="text-gray-500">Rythme</span>
              <span class="font-mono <%= rhythm_class %>">
                <%= rhythm %>
              </span>
            </div>

            <div class="pt-2 border-t border-white/5">
              <div class="text-gray-500 mb-1">Hash</div>
              <div class="font-mono text-[10px] text-gray-400 truncate">
                <%= block.block_hash %>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <% if blocks.blank? %>
        <div class="text-sm text-gray-500">
          Aucun bloc récent disponible.
        </div>
      <% end %>
    </div>
  </div>
</div>