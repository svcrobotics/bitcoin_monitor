<% snapshot = @recovery_snapshot || {} %>
<% state = @recovery_state || snapshot[:state] || {} %>
<% layer1 = snapshot[:layer1] || {} %>
<% redis_buffers = layer1[:redis_buffers] || {} %>
<% status_counts = layer1[:status_counts] || {} %>

<%
  section_class = "rounded-2xl border border-white/10 bg-gray-950/70 p-5 shadow-sm"
  panel_class = "rounded-xl border border-white/10 bg-black/20 p-4"
  label_class = "text-xs font-semibold uppercase tracking-wide text-gray-500"
  muted_class = "text-sm text-gray-400"

  status_classes = lambda do |status|
    case status.to_s
    when "ok", "healthy", "processed"
      "border-emerald-500/20 bg-emerald-500/10 text-emerald-300"
    when "critical", "stalled", "fail", "failed"
      "border-rose-500/20 bg-rose-500/10 text-rose-300"
    else
      "border-amber-500/20 bg-amber-500/10 text-amber-300"
    end
  end

  ms_to_label = lambda do |ms|
    value = ms.to_i

    if value <= 0
      "—"
    elsif value < 1_000
      "#{value} ms"
    elsif value < 60_000
      "#{(value / 1_000.0).round(1)} s"
    else
      "#{(value / 60_000.0).round(1)} min"
    end
  end

  seconds_to_label = lambda do |seconds|
    value = seconds.to_i

    if value <= 0
      "—"
    elsif value < 60
      "#{value}s"
    elsif value < 3_600
      "#{(value / 60.0).round(1)} min"
    else
      "#{(value / 3_600.0).round(1)} h"
    end
  end

  progress_pct = lambda do |pipe|
    best = pipe[:best_height].to_i
    last = pipe[:last_height].to_i

    best <= 0 ? 100 : [[(last.to_f / best * 100).round(2), 100].min, 0].max
  end

  lag_label = lambda do |lag_value|
    lag_value.to_i <= 0 ? "À jour" : "#{lag_value.to_i} blocs de retard"
  end

  lag = layer1[:lag].to_i
  eta = layer1[:eta_minutes]
  speed = layer1[:recovery_speed]

  layer1_state =
    if status_counts["failed"].to_i > 0
      "critical"
    elsif lag > 0 || status_counts["processing"].to_i > 0 || status_counts["enqueued"].to_i > 0
      "recovering"
    else
      "healthy"
    end

  bottleneck =
    if layer1[:current_processing_blocks].present?
      "Traitement Layer 1 actif : #{layer1[:current_processing_blocks].size} bloc(s) en cours."
    elsif lag > 0
      "Recovery en attente : #{lag} blocs à rattraper."
    else
      "Layer 1 synchronisé."
    end
%>

<div class="mx-auto max-w-7xl px-6 py-8 text-gray-100">
  <div class="mb-8 rounded-3xl border border-gray-800 bg-gradient-to-br from-gray-900 to-gray-950 p-6">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <p class="text-sm uppercase tracking-wide text-gray-500">System recovery</p>
        <h1 class="mt-2 text-3xl font-bold">Recovery control center</h1>

        <p class="mt-2 max-w-3xl text-gray-400">
          Suivi du rattrapage blockchain, des jobs Sidekiq, des buffers Redis et des blocs lents.
        </p>

        <div class="mt-5 rounded-2xl border border-gray-800 bg-gray-950/70 p-4">
          <div class="text-sm uppercase tracking-wide text-gray-500">Diagnostic principal</div>
          <div class="mt-1 text-lg font-semibold"><%= bottleneck %></div>
          <div class="mt-2 text-sm text-gray-400">
            Layer 1 lag : <%= lag %> blocs ·
            vitesse : <%= speed || "—" %> bloc/min ·
            ETA : <%= eta ? "#{eta} min" : "—" %>
          </div>
        </div>
      </div>

      <div class="min-w-56 rounded-2xl border <%= status_classes.call(layer1_state) %> px-5 py-4 text-right">
        <div class="text-sm opacity-80">État Layer 1</div>
        <div class="mt-1 text-3xl font-bold"><%= layer1_state.upcase %></div>
        <div class="mt-2 text-xs opacity-70">
          generated_at: <%= snapshot[:generated_at] || "—" %>
        </div>
      </div>
    </div>
  </div>

  <% if snapshot[:error].present? %>
    <div class="rounded-2xl border border-rose-500/30 bg-rose-500/10 p-4 text-rose-200">
      <%= snapshot[:error] %>
    </div>
  <% else %>

    <section class="<%= section_class %>">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
        <div>
          <div class="<%= label_class %>">Layer 1</div>
          <h2 class="mt-1 text-xl font-semibold">Blockchain recovery</h2>
          <p class="mt-2 <%= muted_class %>">
            État réel du rattrapage : buffer, processing, métriques par bloc et backlog Redis.
          </p>
        </div>

        <span class="inline-flex items-center rounded-full border px-3 py-1 text-sm font-semibold <%= status_classes.call(layer1_state) %>">
          <%= layer1_state.upcase %>
        </span>
      </div>

      <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-4">
        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Best height</div>
          <div class="mt-3 text-3xl font-bold"><%= layer1[:best_height] || "—" %></div>
          <p class="mt-2 <%= muted_class %>">
            buffered <%= layer1[:highest_buffered_height] || "—" %>
          </p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Last processed</div>
          <div class="mt-3 text-3xl font-bold"><%= layer1[:last_processed_height] || "—" %></div>
          <p class="mt-2 <%= muted_class %>">
            lag <%= layer1[:lag] || "—" %> blocs
          </p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Recovery speed</div>
          <div class="mt-3 text-3xl font-bold"><%= layer1[:recovery_speed] || "—" %></div>
          <p class="mt-2 <%= muted_class %>">blocs/min sur 30 minutes</p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">ETA</div>
          <div class="mt-3 text-3xl font-bold"><%= layer1[:eta_minutes] ? "#{layer1[:eta_minutes]}m" : "—" %></div>
          <p class="mt-2 <%= muted_class %>">estimation recovery</p>
        </div>
      </div>

      <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-5">
        <% ["pending", "enqueued", "processing", "processed", "failed"].each do |status| %>
          <div class="<%= panel_class %>">
            <div class="<%= label_class %>"><%= status %></div>
            <div class="mt-3 text-2xl font-bold"><%= status_counts[status].to_i %></div>
          </div>
        <% end %>
      </div>

      <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-3">
        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Process queue</div>
          <div class="mt-3 text-3xl font-bold"><%= layer1[:process_queue_size] || 0 %></div>
          <p class="mt-2 <%= muted_class %>">jobs BlockProcessJob en attente</p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Outputs Redis</div>
          <div class="mt-3 text-3xl font-bold"><%= redis_buffers[:outputs_buffer] || 0 %></div>
          <p class="mt-2 <%= muted_class %>">blockchain:outputs:buffer</p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Spent outputs Redis</div>
          <div class="mt-3 text-3xl font-bold"><%= redis_buffers[:spent_outputs_buffer] || 0 %></div>
          <p class="mt-2 <%= muted_class %>">blockchain:spent_outputs:buffer</p>
        </div>
      </div>
    </section>

    <section class="<%= section_class %> mt-8">
      <div class="<%= label_class %>">Processing blocks</div>
      <h2 class="mt-1 text-xl font-semibold">Blocs en cours</h2>

      <div class="mt-4 overflow-x-auto rounded-2xl border border-gray-800">
        <table class="w-full text-left text-sm">
          <thead class="bg-gray-900 text-gray-400">
            <tr>
              <th class="px-4 py-3">Height</th>
              <th class="px-4 py-3">Age</th>
              <th class="px-4 py-3">Heartbeat</th>
              <th class="px-4 py-3">RPC</th>
              <th class="px-4 py-3">Parse</th>
              <th class="px-4 py-3">Flush</th>
              <th class="px-4 py-3">Attempts</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-gray-800 bg-gray-950">
            <% if layer1[:current_processing_blocks].blank? %>
              <tr>
                <td colspan="7" class="px-4 py-4 text-gray-500">Aucun bloc en processing.</td>
              </tr>
            <% else %>
              <% layer1[:current_processing_blocks].to_a.each do |b| %>
                <tr>
                  <td class="px-4 py-3 font-semibold"><%= b[:height] %></td>
                  <td class="px-4 py-3"><%= seconds_to_label.call(b[:age_seconds]) %></td>
                  <td class="px-4 py-3"><%= seconds_to_label.call(b[:heartbeat_age_seconds]) %></td>
                  <td class="px-4 py-3"><%= ms_to_label.call(b[:rpc_duration_ms]) %></td>
                  <td class="px-4 py-3 text-amber-300"><%= ms_to_label.call(b[:parse_duration_ms]) %></td>
                  <td class="px-4 py-3"><%= ms_to_label.call(b[:flush_duration_ms]) %></td>
                  <td class="px-4 py-3"><%= b[:attempts] || 0 %></td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="<%= section_class %> mt-8">
      <div class="<%= label_class %>">Recent blocks</div>
      <h2 class="mt-1 text-xl font-semibold">Derniers blocs Layer 1 traités</h2>

      <p class="mt-2 <%= muted_class %>">
        Les derniers blocs processed/failed, dans l’ordre décroissant de hauteur. Par défaut : 25 blocs.
      </p>

      <div class="mt-4 overflow-x-auto rounded-2xl border border-gray-800">
        <table class="w-full text-left text-sm">
          <thead class="bg-gray-900 text-gray-400">
            <tr>
              <th class="px-4 py-3">Height</th>
              <th class="px-4 py-3">Status</th>
              <th class="px-4 py-3">Total</th>
              <th class="px-4 py-3">RPC</th>
              <th class="px-4 py-3">Parse</th>
              <th class="px-4 py-3">Flush</th>
              <th class="px-4 py-3">Attempts</th>
              <th class="px-4 py-3">Finished at</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-gray-800 bg-gray-950">
            <% if layer1[:recent_blocks].blank? %>
              <tr>
                <td colspan="8" class="px-4 py-4 text-gray-500">
                  Aucun bloc récent disponible.
                </td>
              </tr>
            <% else %>
              <% layer1[:recent_blocks].to_a.each do |b| %>
                <tr>
                  <td class="px-4 py-3 font-semibold"><%= b[:height] %></td>

                  <td class="px-4 py-3">
                    <span class="rounded-full border px-2 py-1 text-xs font-semibold <%= status_classes.call(b[:status]) %>">
                      <%= b[:status].to_s.upcase %>
                    </span>
                  </td>

                  <td class="px-4 py-3"><%= ms_to_label.call(b[:duration_ms]) %></td>
                  <td class="px-4 py-3"><%= ms_to_label.call(b[:rpc_duration_ms]) %></td>
                  <td class="px-4 py-3 text-amber-300"><%= ms_to_label.call(b[:parse_duration_ms]) %></td>
                  <td class="px-4 py-3"><%= ms_to_label.call(b[:flush_duration_ms]) %></td>
                  <td class="px-4 py-3"><%= b[:attempts] || 0 %></td>

                  <td class="px-4 py-3 text-gray-400">
                    <%= b[:processed_at] || b[:failed_at] || "—" %>
                  </td>
                </tr>

                <% if b[:status].to_s == "failed" && (b[:error_class].present? || b[:error_message].present?) %>
                  <tr>
                    <td colspan="8" class="bg-rose-950/20 px-4 py-3 text-xs text-rose-300">
                      <%= truncate("#{b[:error_class]} #{b[:error_message]}", length: 220) %>
                    </td>
                  </tr>
                <% end %>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <% if layer1[:recent_failed_blocks].present? %>
      <section class="<%= section_class %> mt-8">
        <div class="<%= label_class %>">Failed blocks</div>
        <h2 class="mt-1 text-xl font-semibold">Blocs Layer 1 en erreur</h2>

        <div class="mt-4 overflow-x-auto rounded-2xl border border-gray-800">
          <table class="w-full text-left text-sm">
            <thead class="bg-gray-900 text-gray-400">
              <tr>
                <th class="px-4 py-3">Height</th>
                <th class="px-4 py-3">Attempts</th>
                <th class="px-4 py-3">Failed at</th>
                <th class="px-4 py-3">Error</th>
              </tr>
            </thead>

            <tbody class="divide-y divide-gray-800 bg-gray-950">
              <% layer1[:recent_failed_blocks].to_a.each do |b| %>
                <tr>
                  <td class="px-4 py-3 font-semibold"><%= b[:height] %></td>
                  <td class="px-4 py-3"><%= b[:attempts] || 0 %></td>
                  <td class="px-4 py-3"><%= b[:failed_at] || "—" %></td>
                  <td class="px-4 py-3 text-rose-300">
                    <%= truncate("#{b[:error_class]} #{b[:error_message]}", length: 160) %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </section>
    <% end %>

    <div class="mt-10 flex items-center justify-between">
      <h2 class="text-xl font-semibold">Pipelines de recovery</h2>
      <div class="text-sm text-gray-500">Progression par curseur</div>
    </div>

    <div class="mt-4 grid grid-cols-1 gap-4 lg:grid-cols-2">
      <% snapshot[:pipelines].to_h.each do |_key, pipe| %>
        <% pct = progress_pct.call(pipe) %>

        <div class="rounded-2xl border border-gray-800 bg-gray-900 p-5">
          <div class="flex items-center justify-between gap-4">
            <div>
              <div class="text-sm text-gray-400"><%= pipe[:priority] %></div>
              <div class="text-lg font-semibold"><%= pipe[:label] %></div>

              <% if pipe[:lag].present? %>
                <div class="mt-1 text-sm text-gray-500"><%= lag_label.call(pipe[:lag]) %></div>
              <% end %>
            </div>

            <span class="rounded-full border px-3 py-1 text-sm font-semibold <%= status_classes.call(pipe[:status]) %>">
              <%= pipe[:status].to_s.upcase %>
            </span>
          </div>

          <% if pipe[:lag].present? %>
            <div class="mt-5">
              <div class="mb-2 flex items-center justify-between text-xs text-gray-500">
                <span><%= pipe[:last_height] %></span>
                <span><%= pct %>%</span>
                <span><%= pipe[:best_height] %></span>
              </div>

              <div class="h-2 overflow-hidden rounded-full bg-gray-800">
                <div
                  class="h-full rounded-full <%= pipe[:status].to_s == "critical" ? "bg-rose-400" : pipe[:status].to_s == "ok" ? "bg-emerald-400" : "bg-amber-400" %>"
                  style="width: <%= pct %>%">
                </div>
              </div>

              <div class="mt-4 grid grid-cols-3 gap-3 text-sm">
                <div class="rounded-xl bg-gray-950 p-3">
                  <div class="text-gray-500">Last</div>
                  <div class="font-semibold"><%= pipe[:last_height] %></div>
                </div>

                <div class="rounded-xl bg-gray-950 p-3">
                  <div class="text-gray-500">Best</div>
                  <div class="font-semibold"><%= pipe[:best_height] %></div>
                </div>

                <div class="rounded-xl bg-gray-950 p-3">
                  <div class="text-gray-500">Lag</div>
                  <div class="font-semibold"><%= pipe[:lag] %></div>
                </div>
              </div>
            </div>
          <% end %>

          <% if pipe[:tables].present? %>
            <div class="mt-5 space-y-2">
              <% pipe[:tables].to_a.each do |t| %>
                <div class="flex items-center justify-between rounded-xl bg-gray-950 px-3 py-2 text-sm">
                  <span class="text-gray-300"><%= t[:name] %></span>
                  <span class="<%= t[:status] == "ok" ? "text-emerald-300" : t[:status] == "critical" ? "text-rose-300" : "text-amber-300" %>">
                    <%= t[:last_day] || "missing" %>
                  </span>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <h2 class="mt-10 text-xl font-semibold">Queues Sidekiq</h2>

    <div class="mt-4 overflow-hidden rounded-2xl border border-gray-800">
      <table class="w-full text-left text-sm">
        <thead class="bg-gray-900 text-gray-400">
          <tr>
            <th class="px-4 py-3">Queue</th>
            <th class="px-4 py-3">Size</th>
            <th class="px-4 py-3">Latency</th>
            <th class="px-4 py-3">État</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-gray-800 bg-gray-950">
          <% snapshot[:queues].to_a.each do |q| %>
            <% busy = q[:size].to_i > 0 || q[:latency].to_f > 30 %>

            <tr>
              <td class="px-4 py-3 font-medium"><%= q[:name] %></td>
              <td class="px-4 py-3"><%= q[:size] %></td>
              <td class="px-4 py-3"><%= q[:latency] %>s</td>
              <td class="px-4 py-3">
                <span class="rounded-full border px-2 py-1 text-xs font-semibold <%= busy ? "border-amber-500/20 bg-amber-500/10 text-amber-300" : "border-emerald-500/20 bg-emerald-500/10 text-emerald-300" %>">
                  <%= busy ? "BACKLOG" : "CLEAR" %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="mt-10 grid grid-cols-1 gap-6 lg:grid-cols-2">
      <div>
        <h2 class="text-xl font-semibold">Workers actifs</h2>

        <div class="mt-4 space-y-2">
          <% if snapshot[:workers].blank? %>
            <div class="rounded-2xl border border-gray-800 bg-gray-900 p-4 text-gray-400">
              Aucun worker actif.
            </div>
          <% else %>
            <% snapshot[:workers].to_a.each do |w| %>
              <div class="rounded-2xl border border-gray-800 bg-gray-900 p-4">
                <div class="font-semibold"><%= w[:job_class] %></div>
                <div class="mt-1 text-sm text-gray-400">
                  queue=<%= w[:queue] %> · run_at=<%= w[:run_at] %>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>

      <div>
        <h2 class="text-xl font-semibold">Locks</h2>

        <div class="mt-4 space-y-2">
          <% snapshot[:locks].to_a.each do |lock| %>
            <%
              age = lock[:age_seconds].to_i

              relevant_lag =
                case lock[:name]
                when "realtime_processing_lock"
                  state[:realtime_lag].to_i
                when "exchange_observed_scan_lock"
                  state[:exchange_lag].to_i
                when "recovery_orchestrator_lock"
                  [state[:realtime_lag].to_i, state[:exchange_lag].to_i, state[:cluster_lag].to_i].max
                else
                  0
                end

              lock_state =
                if age <= 300
                  :active
                elsif relevant_lag <= 5
                  :idle
                elsif age <= 1800
                  :waiting
                else
                  :stale
                end

              lock_classes =
                case lock_state
                when :active
                  "border-emerald-500/20 bg-emerald-500/10 text-emerald-300"
                when :idle
                  "border-sky-500/20 bg-sky-500/10 text-sky-300"
                when :waiting
                  "border-amber-500/20 bg-amber-500/10 text-amber-300"
                else
                  "border-rose-500/20 bg-rose-500/10 text-rose-300"
                end

              lock_label =
                case lock_state
                when :active
                  "ACTIVE"
                when :idle
                  "IDLE"
                when :waiting
                  "WAITING"
                else
                  "STALE"
                end
            %>

            <div class="rounded-2xl border border-gray-800 bg-gray-900 p-4">
              <div class="flex items-center justify-between">
                <div class="font-semibold"><%= lock[:name] %></div>
                <span class="rounded-full border px-2 py-1 text-xs font-semibold <%= lock_classes %>">
                  <%= lock_label %>
                </span>
              </div>

              <div class="mt-2 text-sm text-gray-400">
                updated_at: <%= lock[:updated_at] || "missing" %><br>
                age: <%= lock[:age_seconds] || "—" %>s<br>
                lag lié: <%= relevant_lag %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <h2 class="mt-10 text-xl font-semibold">Dernières exécutions recovery</h2>

    <div class="mt-4 overflow-x-auto rounded-2xl border border-gray-800">
      <table class="w-full text-left text-sm">
        <thead class="bg-gray-900 text-gray-400">
          <tr>
            <th class="px-4 py-3">Job</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Start</th>
            <th class="px-4 py-3">Durée</th>
            <th class="px-4 py-3">Progress</th>
            <th class="px-4 py-3">Erreur</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-gray-800 bg-gray-950">
          <% snapshot[:recent_job_runs].to_a.each do |jr| %>
            <tr class="align-top">
              <td class="px-4 py-3 font-medium"><%= jr[:name] %></td>

              <td class="px-4 py-3">
                <span class="rounded-full border px-2 py-1 text-xs font-semibold <%= status_classes.call(jr[:status]) %>">
                  <%= jr[:status].to_s.upcase %>
                </span>
              </td>

              <td class="px-4 py-3 text-gray-300"><%= jr[:started_at] %></td>

              <td class="px-4 py-3">
                <%= jr[:duration_seconds] || "—" %>s
              </td>

              <td class="px-4 py-3">
                <% if jr[:progress_pct].present? || jr[:progress_label].present? || jr[:progress_meta].present? %>
                  <% pct = [[jr[:progress_pct].to_f, 0].max, 100].min %>

                  <div class="min-w-44">
                    <% if jr[:progress_pct].present? %>
                      <div class="mb-1 flex justify-between text-xs text-gray-500">
                        <span>progress</span>
                        <span><%= pct.round(1) %>%</span>
                      </div>

                      <div class="h-1.5 overflow-hidden rounded-full bg-gray-800">
                        <div class="h-full rounded-full bg-sky-400" style="width: <%= pct %>%"></div>
                      </div>
                    <% end %>

                    <% if jr[:progress_label].present? %>
                      <div class="mt-1 text-xs text-gray-500">
                        <%= jr[:progress_label] %>
                      </div>
                    <% end %>

                    <% if jr[:progress_meta].present? %>
                      <div class="mt-1 text-xs text-gray-600">
                        blocks=<%= jr[:progress_meta]["scanned_blocks"] || "—" %> ·
                        txs=<%= jr[:progress_meta]["scanned_txs"] || "—" %> ·
                        links=<%= jr[:progress_meta]["links_created"] || "—" %>
                      </div>
                    <% end %>
                  </div>
                <% else %>
                  <span class="text-gray-600">—</span>
                <% end %>
              </td>

              <td class="px-4 py-3 text-rose-300">
                <%= truncate((jr[:error_message] || jr[:error]).to_s, length: 120) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

  <% end %>
</div>