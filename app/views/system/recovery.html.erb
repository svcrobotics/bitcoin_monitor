<% snapshot = @recovery_snapshot || {} %>
<% state = @recovery_state || {} %>

<%
  def status_classes(status)
    case status.to_s
    when "ok", "healthy"
      "border-emerald-500/20 bg-emerald-500/10 text-emerald-300"
    when "critical", "stalled"
      "border-rose-500/20 bg-rose-500/10 text-rose-300"
    else
      "border-amber-500/20 bg-amber-500/10 text-amber-300"
    end
  end

  def progress_pct(pipe)
    best = pipe[:best_height].to_i
    last = pipe[:last_height].to_i
    return 100 if best <= 0
    [[(last.to_f / best * 100).round(2), 100].min, 0].max
  end

  def lag_label(lag)
    lag = lag.to_i
    return "À jour" if lag <= 0
    "#{lag} blocs de retard"
  end

  global_state = state[:state].to_s
  blocking_reason =
    if state[:cluster_lag].to_i > 20
      "Blocage principal : cluster scan en retard de #{state[:cluster_lag]} blocs."
    elsif state[:exchange_lag].to_i > 5
      "Blocage principal : exchange observed scan en retard de #{state[:exchange_lag]} blocs."
    elsif state[:realtime_lag].to_i > 0
      "Blocage principal : realtime processor en retard de #{state[:realtime_lag]} blocs."
    else
      "Aucun blocage critique détecté."
    end
%>

<div class="mx-auto max-w-7xl px-6 py-8 text-gray-100">

  <!-- Header -->
  <div class="mb-8 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
    <div>
      <p class="text-sm uppercase tracking-wide text-gray-400">System recovery</p>
      <h1 class="mt-2 text-3xl font-bold">Recovery control center</h1>
      <p class="mt-2 max-w-3xl text-gray-400">
        Suivi de la reprise après redémarrage, panne, backlog Sidekiq ou retard blockchain.
      </p>
    </div>

    <div class="rounded-2xl border <%= status_classes(global_state) %> px-5 py-4 text-right">
      <div class="text-sm opacity-80">État global</div>
      <div class="mt-1 text-2xl font-bold"><%= global_state.upcase %></div>
    </div>
  </div>

  <% if snapshot[:error].present? %>
    <div class="rounded-2xl border border-rose-500/30 bg-rose-500/10 p-4 text-rose-200">
      <%= snapshot[:error] %>
    </div>
  <% else %>

    <!-- Diagnostic -->
    <div class="mb-6 rounded-2xl border border-gray-800 bg-gray-900 p-5">
      <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
        <div>
          <div class="text-sm uppercase tracking-wide text-gray-500">Diagnostic</div>
          <div class="mt-1 text-lg font-semibold"><%= blocking_reason %></div>
          <p class="mt-1 text-sm text-gray-400">
            Best height <%= snapshot[:best_height] %> · Realtime lag <%= state[:realtime_lag] %> ·
            Exchange lag <%= state[:exchange_lag] %> · Cluster lag <%= state[:cluster_lag] %>
          </p>
        </div>

        <% if global_state == "stalled" %>
          <div class="rounded-xl border border-rose-500/20 bg-rose-500/10 px-4 py-3 text-sm text-rose-200">
            Action recommandée : relancer le pipeline critique avant de reconstruire les agrégats.
          </div>
        <% elsif global_state == "recovering" %>
          <div class="rounded-xl border border-amber-500/20 bg-amber-500/10 px-4 py-3 text-sm text-amber-200">
            Recovery en cours : surveiller la baisse progressive des lags.
          </div>
        <% else %>
          <div class="rounded-xl border border-emerald-500/20 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-200">
            Système synchronisé.
          </div>
        <% end %>
      </div>
    </div>

    <!-- KPIs -->
    <div class="grid grid-cols-1 gap-4 md:grid-cols-4">
      <% [
        ["Best height", snapshot[:best_height], "Hauteur blockchain actuelle"],
        ["Realtime lag", state[:realtime_lag], lag_label(state[:realtime_lag])],
        ["Exchange lag", state[:exchange_lag], lag_label(state[:exchange_lag])],
        ["Cluster lag", state[:cluster_lag], lag_label(state[:cluster_lag])]
      ].each do |label, value, sub| %>
        <div class="rounded-2xl border border-gray-800 bg-gray-900 p-4">
          <div class="text-sm text-gray-400"><%= label %></div>
          <div class="mt-1 text-2xl font-semibold"><%= value || "—" %></div>
          <div class="mt-1 text-xs text-gray-500"><%= sub %></div>
        </div>
      <% end %>
    </div>

    <!-- Pipelines -->
    <div class="mt-10 flex items-center justify-between">
      <h2 class="text-xl font-semibold">Pipelines de recovery</h2>
      <div class="text-sm text-gray-500">Progression par curseur</div>
    </div>

    <div class="mt-4 grid grid-cols-1 gap-4 lg:grid-cols-2">
      <% snapshot[:pipelines].each do |_key, pipe| %>
        <% pct = progress_pct(pipe) %>

        <div class="rounded-2xl border border-gray-800 bg-gray-900 p-5">
          <div class="flex items-center justify-between gap-4">
            <div>
              <div class="text-sm text-gray-400"><%= pipe[:priority] %></div>
              <div class="text-lg font-semibold"><%= pipe[:label] %></div>
              <% if pipe[:lag].present? %>
                <div class="mt-1 text-sm text-gray-500"><%= lag_label(pipe[:lag]) %></div>
              <% end %>
            </div>

            <span class="rounded-full border px-3 py-1 text-sm font-semibold <%= status_classes(pipe[:status]) %>">
              <%= pipe[:status].to_s.upcase %>
            </span>
          </div>

          <% if pipe[:lag].present? %>
            <div class="mt-5">
              <div class="mb-2 flex items-center justify-between text-xs text-gray-500">
                <span><%= pipe[:last_height] %></span>
                <span><%= pct %>%</span>
                <span><%= pipe[:best_height] %></span>
              </div>

              <div class="h-2 overflow-hidden rounded-full bg-gray-800">
                <div
                  class="h-full rounded-full <%= pipe[:status].to_s == "critical" ? "bg-rose-400" : pipe[:status].to_s == "ok" ? "bg-emerald-400" : "bg-amber-400" %>"
                  style="width: <%= pct %>%">
                </div>
              </div>

              <div class="mt-4 grid grid-cols-3 gap-3 text-sm">
                <div class="rounded-xl bg-gray-950 p-3">
                  <div class="text-gray-500">Last</div>
                  <div class="font-semibold"><%= pipe[:last_height] %></div>
                </div>
                <div class="rounded-xl bg-gray-950 p-3">
                  <div class="text-gray-500">Best</div>
                  <div class="font-semibold"><%= pipe[:best_height] %></div>
                </div>
                <div class="rounded-xl bg-gray-950 p-3">
                  <div class="text-gray-500">Lag</div>
                  <div class="font-semibold"><%= pipe[:lag] %></div>
                </div>
              </div>
            </div>
          <% end %>

          <% if pipe[:tables].present? %>
            <div class="mt-5 space-y-2">
              <% pipe[:tables].each do |t| %>
                <div class="flex items-center justify-between rounded-xl bg-gray-950 px-3 py-2 text-sm">
                  <span class="text-gray-300"><%= t[:name] %></span>
                  <span class="<%= t[:status] == "ok" ? "text-emerald-300" : t[:status] == "critical" ? "text-rose-300" : "text-amber-300" %>">
                    <%= t[:last_day] || "missing" %>
                  </span>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Queues -->
    <h2 class="mt-10 text-xl font-semibold">Queues Sidekiq</h2>

    <div class="mt-4 overflow-hidden rounded-2xl border border-gray-800">
      <table class="w-full text-left text-sm">
        <thead class="bg-gray-900 text-gray-400">
          <tr>
            <th class="px-4 py-3">Queue</th>
            <th class="px-4 py-3">Size</th>
            <th class="px-4 py-3">Latency</th>
            <th class="px-4 py-3">État</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800 bg-gray-950">
          <% snapshot[:queues].each do |q| %>
            <% busy = q[:size].to_i > 0 || q[:latency].to_f > 30 %>
            <tr>
              <td class="px-4 py-3 font-medium"><%= q[:name] %></td>
              <td class="px-4 py-3"><%= q[:size] %></td>
              <td class="px-4 py-3"><%= q[:latency] %>s</td>
              <td class="px-4 py-3">
                <span class="rounded-full border px-2 py-1 text-xs font-semibold <%= busy ? "border-amber-500/20 bg-amber-500/10 text-amber-300" : "border-emerald-500/20 bg-emerald-500/10 text-emerald-300" %>">
                  <%= busy ? "BACKLOG" : "CLEAR" %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- Workers + Locks -->
    <div class="mt-10 grid grid-cols-1 gap-6 lg:grid-cols-2">
      <div>
        <h2 class="text-xl font-semibold">Workers actifs</h2>

        <div class="mt-4 space-y-2">
          <% if snapshot[:workers].blank? %>
            <div class="rounded-2xl border border-gray-800 bg-gray-900 p-4 text-gray-400">
              Aucun worker actif.
            </div>
          <% else %>
            <% snapshot[:workers].each do |w| %>
              <div class="rounded-2xl border border-gray-800 bg-gray-900 p-4">
                <div class="font-semibold"><%= w[:job_class] %></div>
                <div class="mt-1 text-sm text-gray-400">
                  queue=<%= w[:queue] %> · run_at=<%= w[:run_at] %>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>

      <div>
        <h2 class="text-xl font-semibold">Locks</h2>

        <div class="mt-4 space-y-2">
          <% snapshot[:locks].each do |lock| %>
            <% stale = lock[:age_seconds].to_i > 600 %>
            <div class="rounded-2xl border border-gray-800 bg-gray-900 p-4">
              <div class="flex items-center justify-between">
                <div class="font-semibold"><%= lock[:name] %></div>
                <span class="rounded-full border px-2 py-1 text-xs font-semibold <%= stale ? "border-amber-500/20 bg-amber-500/10 text-amber-300" : "border-emerald-500/20 bg-emerald-500/10 text-emerald-300" %>">
                  <%= stale ? "OLD" : "FRESH" %>
                </span>
              </div>
              <div class="mt-2 text-sm text-gray-400">
                updated_at: <%= lock[:updated_at] || "missing" %><br>
                age: <%= lock[:age_seconds] || "—" %>s
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Recent jobs -->
    <h2 class="mt-10 text-xl font-semibold">Dernières exécutions recovery</h2>

    <div class="mt-4 overflow-hidden rounded-2xl border border-gray-800">
      <table class="w-full text-left text-sm">
        <thead class="bg-gray-900 text-gray-400">
          <tr>
            <th class="px-4 py-3">Job</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Start</th>
            <th class="px-4 py-3">Durée</th>
            <th class="px-4 py-3">Erreur</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800 bg-gray-950">
          <% snapshot[:recent_job_runs].each do |jr| %>
            <tr>
              <td class="px-4 py-3 font-medium"><%= jr[:name] %></td>
              <td class="px-4 py-3">
                <span class="rounded-full border px-2 py-1 text-xs font-semibold <%= status_classes(jr[:status]) %>">
                  <%= jr[:status].to_s.upcase %>
                </span>
              </td>
              <td class="px-4 py-3 text-gray-300"><%= jr[:started_at] %></td>
              <td class="px-4 py-3"><%= jr[:duration_seconds] || "—" %>s</td>
              <td class="px-4 py-3 text-rose-300">
                <%= truncate((jr[:error_message] || jr[:error]).to_s, length: 120) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

  <% end %>
</div>