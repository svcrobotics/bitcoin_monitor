<% snapshot = @recovery_snapshot || {} %>
<% state = @recovery_state || snapshot[:state] || {} %>
<% layer1 = snapshot[:layer1] || {} %>
<% redis_buffers = layer1[:redis_buffers] || {} %>
<% status_counts = layer1[:status_counts] || {} %>
<% pipelines = snapshot[:pipelines] || {} %>
<% cluster_refresh = snapshot[:cluster_refresh] || {} %>
<% queues = snapshot[:queues] || [] %>
<% workers = snapshot[:workers] || [] %>
<% recent_jobs = snapshot[:recent_job_runs] || [] %>

<% p0_realtime = pipelines[:p0_realtime] || {} %>
<% p3_realtime = pipelines[:p3_cluster_realtime] || {} %>
<% p3_batch = pipelines[:p3_cluster_batch] || {} %>

<% busy_queues = queues.select { |q| q[:size].to_i > 0 || q[:latency].to_f > 30 } %>
<% running_jobs = recent_jobs.select { |j| j[:status].to_s == "running" } %>

<%
  section_class = "rounded-2xl border border-white/10 bg-gray-950/70 p-5 shadow-sm"
  panel_class = "rounded-xl border border-white/10 bg-black/20 p-4"
  label_class = "text-xs font-semibold uppercase tracking-wide text-gray-500"
  muted_class = "text-sm text-gray-400"

  status_class_map = {
    "ok" => "border-emerald-500/20 bg-emerald-500/10 text-emerald-300",
    "healthy" => "border-emerald-500/20 bg-emerald-500/10 text-emerald-300",
    "processed" => "border-emerald-500/20 bg-emerald-500/10 text-emerald-300",
    "critical" => "border-rose-500/20 bg-rose-500/10 text-rose-300",
    "stalled" => "border-rose-500/20 bg-rose-500/10 text-rose-300",
    "fail" => "border-rose-500/20 bg-rose-500/10 text-rose-300",
    "failed" => "border-rose-500/20 bg-rose-500/10 text-rose-300"
  }

  status_classes = lambda do |status|
    status_class_map[status.to_s] || "border-amber-500/20 bg-amber-500/10 text-amber-300"
  end

  ms_to_label = lambda do |ms|
    value = ms.to_i

    if ms.nil?
      "—"
    elsif value <= 0
      "0 ms"
    elsif value < 1_000
      "#{value} ms"
    elsif value < 60_000
      "#{(value / 1_000.0).round(1)} s"
    else
      "#{(value / 60_000.0).round(1)} min"
    end
  end

  seconds_to_label = lambda do |seconds|
    value = seconds.to_i

    if value <= 0
      "—"
    elsif value < 60
      "#{value}s"
    elsif value < 3_600
      "#{(value / 60.0).round(1)} min"
    else
      "#{(value / 3_600.0).round(1)} h"
    end
  end

  lag_label = lambda do |lag_value|
    lag_value.to_i <= 0 ? "À jour" : "#{lag_value.to_i} blocs de retard"
  end

  job_titles = {
    "Blockchain::Jobs::BlockProcessJob" => "Layer 1 processing",
    "WhaleScanJob" => "Whale analytics",
    "Clusters::RefreshDirtyClustersJob" => "Cluster refresh",
    "ClusterScanJob" => "Cluster batch scanner",
    "Realtime::ProcessLatestBlockJob" => "Realtime block processing",
    "ExchangeObservedScanJob" => "Exchange observed scan",
    "SearchRefreshJob" => "Search indexing",
    "ClusterV3BuildMetricsJob" => "Cluster metrics builder",
    "ClusterV3DetectSignalsJob" => "Cluster signal detector",
    "SystemSnapshotsRefreshJob" => "System snapshots refresh",
    "Realtime::BlockStreamConsumerJob" => "Realtime stream consumer"
  }

  job_run_names = {
    "ClusterScanJob" => "cluster_scan",
    "ExchangeObservedScanJob" => "exchange_observed_scan",
    "Realtime::ProcessLatestBlockJob" => "realtime_process_latest_block",
    "Blockchain::Jobs::BlockProcessJob" => "block_process",
    "Clusters::RefreshDirtyClustersJob" => "cluster_refresh_dirty_clusters",
    "WhaleScanJob" => "whale_scan",
    "SearchRefreshJob" => "search_refresh",
    "ClusterV3BuildMetricsJob" => "cluster_v3_build_metrics",
    "ClusterV3DetectSignalsJob" => "cluster_v3_detect_signals",
    "SystemSnapshotsRefreshJob" => "system_snapshots_refresh",
    "Realtime::BlockStreamConsumerJob" => "realtime_block_stream_consumer"
  }

  lock_titles = {
    "realtime_processing_lock" => "Realtime processing",
    "exchange_observed_scan_lock" => "Exchange observed scan",
    "recovery_orchestrator_lock" => "Recovery orchestrator",
    "lock:cluster_scan" => "Cluster batch scanner",
    "cluster_scan_lock" => "Cluster batch scanner"
  }

  lock_descriptions = {
    "realtime_processing_lock" => "Empêche deux traitements realtime de tourner en même temps.",
    "exchange_observed_scan_lock" => "Protège le scan exchange-like contre les doubles exécutions.",
    "recovery_orchestrator_lock" => "Évite plusieurs orchestrations recovery simultanées.",
    "lock:cluster_scan" => "Protège le scanner cluster batch contre les doubles exécutions.",
    "cluster_scan_lock" => "Protège le scanner cluster batch contre les doubles exécutions."
  }

  lock_classes_map = {
    "active" => "border-emerald-500/20 bg-emerald-500/10 text-emerald-300",
    "stale" => "border-rose-500/20 bg-rose-500/10 text-rose-300",
    "error" => "border-rose-500/20 bg-rose-500/10 text-rose-300",
    "clear" => "border-sky-500/20 bg-sky-500/10 text-sky-300"
  }

  lag = layer1[:lag].to_i
  eta = layer1[:eta_minutes]
  speed = layer1[:recovery_speed]

  layer1_state =
    if status_counts["failed"].to_i > 0
      "critical"
    elsif lag > 0 || status_counts["processing"].to_i > 0 || status_counts["enqueued"].to_i > 0
      "recovering"
    else
      "healthy"
    end

  bottleneck =
    if layer1[:current_processing_blocks].present?
      "Traitement Layer 1 actif : #{layer1[:current_processing_blocks].size} bloc(s) en cours."
    elsif lag > 0
      "Recovery en attente : #{lag} blocs à rattraper."
    else
      "Layer 1 synchronisé."
    end
%>

<div class="mx-auto max-w-7xl px-6 py-8 text-gray-100">
  <div class="mb-8 rounded-3xl border border-gray-800 bg-gradient-to-br from-gray-900 to-gray-950 p-6">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <p class="text-sm uppercase tracking-wide text-gray-500">System recovery</p>
        <h1 class="mt-2 text-3xl font-bold">Recovery control center</h1>

        <p class="mt-2 max-w-3xl text-gray-400">
          Cockpit de reprise : Layer 1 canonique, consommateurs Layer 2, queues Sidekiq, locks et jobs en cours.
        </p>

        <div class="mt-5 grid grid-cols-1 gap-3 md:grid-cols-4">
          <div class="rounded-2xl border border-gray-800 bg-gray-950/70 p-4">
            <div class="text-sm uppercase tracking-wide text-gray-500">Layer 1</div>
            <div class="mt-1 text-2xl font-bold"><%= layer1_state.upcase %></div>
            <div class="mt-2 text-xs text-gray-500">
              lag=<%= lag %> · speed=<%= speed || "—" %> bloc/min
            </div>
          </div>

          <div class="rounded-2xl border border-gray-800 bg-gray-950/70 p-4">
            <div class="text-sm uppercase tracking-wide text-gray-500">Cluster realtime</div>
            <div class="mt-1 text-2xl font-bold"><%= p3_realtime[:lag] || "—" %></div>
            <div class="mt-2 text-xs text-gray-500">blocs de retard</div>
          </div>

          <div class="rounded-2xl border border-gray-800 bg-gray-950/70 p-4">
            <div class="text-sm uppercase tracking-wide text-gray-500">Cluster batch</div>
            <div class="mt-1 text-2xl font-bold"><%= p3_batch[:lag] || "—" %></div>
            <div class="mt-2 text-xs text-gray-500">blocs de retard</div>
          </div>

          <div class="rounded-2xl border border-gray-800 bg-gray-950/70 p-4">
            <div class="text-sm uppercase tracking-wide text-gray-500">Dirty clusters</div>
            <div class="mt-1 text-2xl font-bold"><%= cluster_refresh[:dirty_queue_size] || 0 %></div>
            <div class="mt-2 text-xs text-gray-500">
              <%= cluster_refresh[:estimated_batches_remaining] || "—" %> batches restants
            </div>
          </div>
        </div>

        <div class="mt-5 rounded-2xl border border-gray-800 bg-gray-950/70 p-4">
          <div class="text-sm uppercase tracking-wide text-gray-500">Diagnostic principal</div>
          <div class="mt-1 text-lg font-semibold"><%= bottleneck %></div>
          <div class="mt-2 text-sm text-gray-400">
            Queues en backlog : <%= busy_queues.size %> ·
            Jobs actifs : <%= running_jobs.size %> ·
            ETA Layer 1 : <%= eta ? "#{eta} min" : "—" %>
          </div>
        </div>
      </div>

      <div class="min-w-56 rounded-2xl border <%= status_classes.call(layer1_state) %> px-5 py-4 text-right">
        <div class="text-sm opacity-80">État recovery</div>
        <div class="mt-1 text-3xl font-bold"><%= layer1_state.upcase %></div>
        <div class="mt-2 text-xs opacity-70">
          generated_at: <%= snapshot[:generated_at] || "—" %>
        </div>
      </div>
    </div>
  </div>
  
  <% if snapshot[:error].present? %>
    <div class="rounded-2xl border border-rose-500/30 bg-rose-500/10 p-4 text-rose-200">
      <%= snapshot[:error] %>
    </div>
  <% else %>

    <!-- Layer 1 -->
    <section class="<%= section_class %>">
      <% processed_height = layer1[:last_processed_height].to_i %>
      <% spent_height = layer1[:spent_max_height].to_i %>
      <% flow_height = layer1[:exchange_flow_max_height].to_i %>

      <% spent_lag = processed_height.positive? && spent_height.positive? ? [processed_height - spent_height, 0].max : nil %>
      <% flow_lag = processed_height.positive? && flow_height.positive? ? [processed_height - flow_height, 0].max : nil %>
      <% async_lag = [spent_lag.to_i, flow_lag.to_i].max %>

      <% fast_path_enabled =
        if layer1.key?(:fast_path)
          layer1[:fast_path]
        else
          ENV.fetch("LAYER1_FAST_PATH", "true") == "true"
        end
      %>

      <% layer1_state =
        if status_counts["failed"].to_i > 0
          "failed"
        elsif layer1[:lag].to_i > 0 || status_counts["processing"].to_i > 0 || status_counts["enqueued"].to_i > 0 || async_lag > 5
          "recovering"
        else
          "ok"
        end
      %>

      <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
        <div>
          <div class="<%= label_class %>">Layer 1</div>
          <h2 class="mt-1 text-xl font-semibold">Blockchain recovery</h2>
          <p class="mt-2 <%= muted_class %>">
            État réel du rattrapage : blocs, processing, buffers Redis, spent resolver asynchrone et flows exchange-like.
          </p>
        </div>

        <span class="inline-flex items-center rounded-full border px-3 py-1 text-sm font-semibold <%= status_classes.call(layer1_state) %>">
          <%= layer1_state.upcase %>
        </span>
      </div>

      <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-6">
        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Best height</div>
          <div class="mt-3 text-3xl font-bold"><%= layer1[:best_height] || "—" %></div>
          <p class="mt-2 <%= muted_class %>">
            buffered <%= layer1[:highest_buffered_height] || "—" %>
          </p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Processed</div>
          <div class="mt-3 text-3xl font-bold"><%= layer1[:last_processed_height] || "—" %></div>
          <p class="mt-2 <%= muted_class %>">
            lag <%= layer1[:lag] || 0 %> blocs
          </p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Async state</div>
          <div class="mt-3 text-3xl font-bold <%= async_lag > 5 ? "text-amber-300" : "text-emerald-300" %>">
            <%= async_lag %>
          </div>
          <p class="mt-2 <%= muted_class %>">
            retard spent / flows
          </p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Spent max</div>
          <div class="mt-3 text-3xl font-bold <%= spent_lag.to_i > 5 ? "text-amber-300" : "text-gray-100" %>">
            <%= spent_height.positive? ? spent_height : "—" %>
          </div>
          <p class="mt-2 <%= muted_class %>">
            lag <%= spent_lag.nil? ? "—" : spent_lag %> blocs
          </p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Flow max</div>
          <div class="mt-3 text-3xl font-bold <%= flow_lag.to_i > 5 ? "text-amber-300" : "text-gray-100" %>">
            <%= flow_height.positive? ? flow_height : "—" %>
          </div>
          <p class="mt-2 <%= muted_class %>">
            lag <%= flow_lag.nil? ? "—" : flow_lag %> blocs
          </p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Runtime</div>
          <div class="mt-3 text-3xl font-bold <%= fast_path_enabled ? "text-cyan-300" : "text-amber-300" %>">
            <%= fast_path_enabled ? "ON" : "OFF" %>
          </div>
          <p class="mt-2 <%= muted_class %>">
            fast path <%= fast_path_enabled ? "enabled" : "disabled" %>
          </p>
        </div>
      </div>

      <div class="mt-5 rounded-2xl border border-slate-800 bg-slate-950/40 p-4">
        <div class="<%= label_class %>">Diagnostic Layer 1</div>

        <p class="mt-2 text-sm leading-relaxed text-slate-300">
          <% if layer1[:lag].to_i.zero? && async_lag.zero? && redis_buffers[:spent_outputs_buffer].to_i.zero? && redis_buffers[:outputs_buffer].to_i.zero? %>
            Layer 1 est synchronisé. Les blocs sont traités, les spent outputs sont flushés, et les flows exchange-like sont à jour.
          <% elsif layer1[:lag].to_i.positive? %>
            Layer 1 est en retard de <%= layer1[:lag].to_i %> bloc(s). Les blocs doivent encore être ingérés ou processés.
          <% elsif async_lag.positive? %>
            Layer 1 principal est synchronisé, mais le spent resolver / exchange flow a encore <%= async_lag %> bloc(s) de retard.
          <% elsif redis_buffers[:spent_outputs_buffer].to_i.positive? || redis_buffers[:outputs_buffer].to_i.positive? %>
            Les blocs sont traités, mais Redis contient encore des lignes à flusher vers PostgreSQL.
          <% else %>
            Layer 1 est stable.
          <% end %>
        </p>
      </div>

      <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-5">
        <% ["pending", "enqueued", "processing", "processed", "failed"].each do |status| %>
          <div class="<%= panel_class %>">
            <div class="<%= label_class %>"><%= status %></div>
            <div class="mt-3 text-2xl font-bold
              <%= status == "failed" && status_counts[status].to_i > 0 ? "text-rose-300" : "" %>
              <%= status == "processing" && status_counts[status].to_i > 0 ? "text-sky-300" : "" %>
              <%= status == "enqueued" && status_counts[status].to_i > 0 ? "text-amber-300" : "" %>">
              <%= status_counts[status].to_i %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-3">
        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Process queue</div>
          <div class="mt-3 text-3xl font-bold <%= layer1[:process_queue_size].to_i > 0 ? "text-amber-300" : "text-emerald-300" %>">
            <%= layer1[:process_queue_size] || 0 %>
          </div>
          <p class="mt-2 <%= muted_class %>">jobs BlockProcessJob en attente</p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Outputs Redis</div>
          <div class="mt-3 text-3xl font-bold <%= redis_buffers[:outputs_buffer].to_i > 0 ? "text-amber-300" : "text-emerald-300" %>">
            <%= redis_buffers[:outputs_buffer] || 0 %>
          </div>
          <p class="mt-2 <%= muted_class %>">blockchain:outputs:buffer</p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Spent outputs Redis</div>
          <div class="mt-3 text-3xl font-bold <%= redis_buffers[:spent_outputs_buffer].to_i > 0 ? "text-amber-300" : "text-emerald-300" %>">
            <%= redis_buffers[:spent_outputs_buffer] || 0 %>
          </div>
          <p class="mt-2 <%= muted_class %>">blockchain:spent_outputs:buffer</p>
        </div>
      </div>
    </section>

    <section class="<%= section_class %> mt-8">
      <div class="<%= label_class %>">Processing blocks</div>
      <h2 class="mt-1 text-xl font-semibold">Blocs en cours</h2>

      <div class="mt-4 overflow-x-auto rounded-2xl border border-gray-800">
        <table class="w-full text-left text-sm">
          <thead class="bg-gray-900 text-gray-400">
            <tr>
              <th class="px-4 py-3">Height</th>
              <th class="px-4 py-3">Age</th>
              <th class="px-4 py-3">Heartbeat</th>
              <th class="px-4 py-3">RPC</th>
              <th class="px-4 py-3">Parse</th>
              <th class="px-4 py-3">Flush</th>
              <th class="px-4 py-3">Attempts</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-gray-800 bg-gray-950">
            <% if layer1[:current_processing_blocks].blank? %>
              <tr>
                <td colspan="7" class="px-4 py-4 text-gray-500">Aucun bloc en processing.</td>
              </tr>
            <% else %>
              <% layer1[:current_processing_blocks].to_a.each do |b| %>
                <tr>
                  <td class="px-4 py-3 font-semibold"><%= b[:height] %></td>
                  <td class="px-4 py-3"><%= seconds_to_label.call(b[:age_seconds]) %></td>
                  <td class="px-4 py-3"><%= seconds_to_label.call(b[:heartbeat_age_seconds]) %></td>
                  <td class="px-4 py-3"><%= ms_to_label.call(b[:rpc_duration_ms]) %></td>
                  <td class="px-4 py-3 text-amber-300"><%= ms_to_label.call(b[:parse_duration_ms]) %></td>
                  <td class="px-4 py-3"><%= ms_to_label.call(b[:flush_duration_ms]) %></td>
                  <td class="px-4 py-3"><%= b[:attempts] || 0 %></td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="<%= section_class %> mt-8">
      <div class="<%= label_class %>">Recovery window</div>
      <h2 class="mt-1 text-xl font-semibold">Fenêtre actuelle du recovery Layer 1</h2>

      <p class="mt-2 <%= muted_class %>">
        Vue continue des blocs autour du rattrapage : processed, processing, enqueued, pending et failed.
      </p>

      <div class="mt-4 overflow-x-auto rounded-2xl border border-gray-800">
        <table class="w-full text-left text-sm">
          <thead class="bg-gray-900 text-gray-400">
            <tr>
              <th class="px-4 py-3">Height</th>
              <th class="px-4 py-3">Status</th>
              <th class="px-4 py-3">Total</th>
              <th class="px-4 py-3">RPC</th>
              <th class="px-4 py-3">Parse</th>
              <th class="px-4 py-3">Flush</th>
              <th class="px-4 py-3">Age</th>
              <th class="px-4 py-3">Heartbeat</th>
              <th class="px-4 py-3">Attempts</th>
              <th class="px-4 py-3">Updated / finished</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-gray-800 bg-gray-950">
            <% if layer1[:recovery_window].blank? %>
              <tr>
                <td colspan="10" class="px-4 py-4 text-gray-500">
                  Aucune fenêtre recovery disponible.
                </td>
              </tr>
            <% else %>
              <% layer1[:recovery_window].to_a.each do |b| %>
                <tr class="<%= b[:status].to_s == "processing" ? "bg-amber-500/5" : b[:status].to_s == "failed" ? "bg-rose-500/5" : "" %>">
                  <td class="px-4 py-3 font-semibold"><%= b[:height] %></td>

                  <td class="px-4 py-3">
                    <span class="rounded-full border px-2 py-1 text-xs font-semibold <%= status_classes.call(b[:status]) %>">
                      <%= b[:status].to_s.upcase %>
                    </span>
                  </td>

                  <td class="px-4 py-3"><%= ms_to_label.call(b[:duration_ms]) %></td>
                  <td class="px-4 py-3"><%= ms_to_label.call(b[:rpc_duration_ms]) %></td>
                  <td class="px-4 py-3 text-amber-300"><%= ms_to_label.call(b[:parse_duration_ms]) %></td>
                  <td class="px-4 py-3"><%= ms_to_label.call(b[:flush_duration_ms]) %></td>
                  <td class="px-4 py-3"><%= seconds_to_label.call(b[:age_seconds]) %></td>
                  <td class="px-4 py-3"><%= seconds_to_label.call(b[:heartbeat_age_seconds]) %></td>
                  <td class="px-4 py-3"><%= b[:attempts] || 0 %></td>

                  <td class="px-4 py-3 text-gray-400">
                    <%= b[:processed_at] || b[:failed_at] || b[:updated_at] || "—" %>
                  </td>
                </tr>

                <% if b[:status].to_s == "failed" && (b[:error_class].present? || b[:error_message].present?) %>
                  <tr>
                    <td colspan="10" class="bg-rose-950/20 px-4 py-3 text-xs text-rose-300">
                      <%= truncate("#{b[:error_class]} #{b[:error_message]}", length: 220) %>
                    </td>
                  </tr>
                <% end %>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <% if layer1[:recent_failed_blocks].present? %>
      <section class="<%= section_class %> mt-8">
        <div class="<%= label_class %>">Failed blocks</div>
        <h2 class="mt-1 text-xl font-semibold">Blocs Layer 1 en erreur</h2>

        <div class="mt-4 overflow-x-auto rounded-2xl border border-gray-800">
          <table class="w-full text-left text-sm">
            <thead class="bg-gray-900 text-gray-400">
              <tr>
                <th class="px-4 py-3">Height</th>
                <th class="px-4 py-3">Attempts</th>
                <th class="px-4 py-3">Failed at</th>
                <th class="px-4 py-3">Error</th>
              </tr>
            </thead>

            <tbody class="divide-y divide-gray-800 bg-gray-950">
              <% layer1[:recent_failed_blocks].to_a.each do |b| %>
                <tr>
                  <td class="px-4 py-3 font-semibold"><%= b[:height] %></td>
                  <td class="px-4 py-3"><%= b[:attempts] || 0 %></td>
                  <td class="px-4 py-3"><%= b[:failed_at] || "—" %></td>
                  <td class="px-4 py-3 text-rose-300">
                    <%= truncate("#{b[:error_class]} #{b[:error_message]}", length: 160) %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </section>
    <% end %>

    <% actor_labels_run = @actor_labels_last_run %>
    <% actor_meta = actor_labels_run&.progress_meta || {} %>
    <% actor_status = actor_labels_run&.status || "missing" %>

    <!-- Cluster / Actor Graph recovery -->
    <section class="<%= section_class %> mt-8">
      <% cluster_lag = [p3_realtime[:lag].to_i, p3_batch[:lag].to_i].max %>

      <% cluster_state =
        if cluster_lag > 50 || cluster_refresh[:dirty_queue_size].to_i > 5000
          "critical"
        elsif cluster_lag > 5 || cluster_refresh[:dirty_queue_size].to_i > 0
          "warning"
        else
          "ok"
        end
      %>

      <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
        <div>
          <div class="<%= label_class %>">Actor Graph</div>
          <h2 class="mt-1 text-xl font-semibold">Cluster recovery</h2>
          <p class="mt-2 <%= muted_class %>">
            État du graphe d’acteurs : cluster realtime, batch scanner, dirty refresh et dépendance au Layer 1.
          </p>
        </div>

        <span class="inline-flex items-center rounded-full border px-3 py-1 text-sm font-semibold <%= status_classes.call(cluster_state) %>">
          <%= cluster_state.upcase %>
        </span>
      </div>

      <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-5">
        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Realtime stream</div>
          <div class="mt-3 text-3xl font-bold"><%= p3_realtime[:last_height] || "—" %></div>
          <p class="mt-2 <%= muted_class %>">
            lag <%= p3_realtime[:lag] || "—" %> blocs
          </p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Batch scanner</div>
          <div class="mt-3 text-3xl font-bold"><%= p3_batch[:last_height] || "—" %></div>
          <p class="mt-2 <%= muted_class %>">
            lag <%= p3_batch[:lag] || "—" %> blocs
          </p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Cluster lag</div>
          <div class="mt-3 text-3xl font-bold <%= cluster_lag > 5 ? "text-amber-300" : "text-emerald-300" %>">
            <%= cluster_lag %>
          </div>
          <p class="mt-2 <%= muted_class %>">
            retard max realtime / batch
          </p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Dirty clusters</div>
          <div class="mt-3 text-3xl font-bold <%= cluster_refresh[:dirty_queue_size].to_i > 0 ? "text-amber-300" : "text-emerald-300" %>">
            <%= cluster_refresh[:dirty_queue_size] || 0 %>
          </div>
          <p class="mt-2 <%= muted_class %>">
            <%= cluster_refresh[:estimated_batches_remaining] || 0 %> batch(es) restantes
          </p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Last refresh</div>
          <div class="mt-3">
            <span class="inline-flex items-center rounded-full border px-3 py-1 text-sm font-semibold <%= status_classes.call(cluster_refresh[:last_run_status]) %>">
              <%= cluster_refresh[:last_run_status].to_s.upcase.presence || "UNKNOWN" %>
            </span>
          </div>
          <p class="mt-3 <%= muted_class %>">
            <%= cluster_refresh[:progress_label] || "—" %>
          </p>
        </div>
      </div>

      <div class="mt-5 rounded-2xl border border-slate-800 bg-slate-950/40 p-4">
        <div class="<%= label_class %>">Diagnostic Cluster</div>

        <p class="mt-2 text-sm leading-relaxed text-slate-300">
          <% if cluster_lag.zero? && cluster_refresh[:dirty_queue_size].to_i.zero? %>
            Cluster est synchronisé avec Layer 1. Le realtime, le batch scanner et le refresh des dirty clusters sont à jour.
          <% elsif cluster_lag.positive? %>
            Cluster a <%= cluster_lag %> bloc(s) de retard par rapport au Layer 1. Les modules qui dépendent du graphe peuvent avoir un léger décalage.
          <% elsif cluster_refresh[:dirty_queue_size].to_i.positive? %>
            Les cursors cluster sont à jour, mais il reste <%= cluster_refresh[:dirty_queue_size].to_i %> dirty cluster(s) à rafraîchir.
          <% else %>
            Cluster est stable.
          <% end %>
        </p>
      </div>
    </section>

    <!-- Actor Labels recovery -->
    <section class="<%= section_class %> mt-8">
      <%
        actor_labels_status = @actor_labels_status || {}

        total_labels = actor_labels_status[:total].to_i
        exchange_like_count = actor_labels_status[:exchange_like].to_i
        whale_like_count = actor_labels_status[:whale_like].to_i
        service_like_count = actor_labels_status[:service_like].to_i
        retail_like_count = actor_labels_status[:retail_like].to_i
        unknown_count = actor_labels_status[:unknown].to_i

        progress_pct = actor_labels_run&.progress_pct.to_f
        progress_label = actor_labels_run&.progress_label || "—"

        actor_state =
          if actor_status.to_s.in?(%w[fail failed critical])
            "critical"
          elsif actor_status.to_s == "running"
            "running"
          elsif total_labels.zero?
            "warning"
          else
            "ok"
          end
      %>

      <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
        <div>
          <div class="<%= label_class %>">Actor Graph</div>
          <h2 class="mt-1 text-xl font-semibold">Actor Labels recovery</h2>
          <p class="mt-2 <%= muted_class %>">
            État de la couche de classification économique : refresh des labels, couverture réelle et dépendance aux profils de clusters.
          </p>
        </div>

        <span class="inline-flex items-center rounded-full border px-3 py-1 text-sm font-semibold <%= status_classes.call(actor_state) %>">
          <%= actor_state.upcase %>
        </span>
      </div>

      <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-6">
        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Total labels</div>
          <div class="mt-3 text-3xl font-bold text-gray-100">
            <%= number_with_delimiter(total_labels) %>
          </div>
          <p class="mt-2 <%= muted_class %>">
            labels économiques en base
          </p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Exchange-like</div>
          <div class="mt-3 text-3xl font-bold text-blue-300">
            <%= number_with_delimiter(exchange_like_count) %>
          </div>
          <p class="mt-2 <%= muted_class %>">
            acteurs exchange probables
          </p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Whale-like</div>
          <div class="mt-3 text-3xl font-bold text-purple-300">
            <%= number_with_delimiter(whale_like_count) %>
          </div>
          <p class="mt-2 <%= muted_class %>">
            grands détenteurs probables
          </p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Service-like</div>
          <div class="mt-3 text-3xl font-bold text-emerald-300">
            <%= number_with_delimiter(service_like_count) %>
          </div>
          <p class="mt-2 <%= muted_class %>">
            services / infrastructures
          </p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Retail / Unknown</div>
          <div class="mt-3 text-3xl font-bold text-gray-100">
            <%= number_with_delimiter(retail_like_count + unknown_count) %>
          </div>
          <p class="mt-2 <%= muted_class %>">
            retail: <%= number_with_delimiter(retail_like_count) %> · unknown: <%= number_with_delimiter(unknown_count) %>
          </p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Refresh progress</div>
          <div class="mt-3 text-3xl font-bold <%= actor_status.to_s == "running" ? "text-sky-300" : "text-gray-100" %>">
            <%= progress_pct.round(1) %>%
          </div>
          <p class="mt-2 <%= muted_class %>">
            <%= progress_label %>
          </p>
        </div>
      </div>

      <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-3">
        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Created</div>
          <div class="mt-3 text-3xl font-bold text-emerald-300">
            <%= number_with_delimiter(actor_meta["created"].to_i) %>
          </div>
          <p class="mt-2 <%= muted_class %>">
            labels créés sur le dernier run
          </p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Updated</div>
          <div class="mt-3 text-3xl font-bold text-sky-300">
            <%= number_with_delimiter(actor_meta["updated"].to_i) %>
          </div>
          <p class="mt-2 <%= muted_class %>">
            labels rafraîchis
          </p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Skipped</div>
          <div class="mt-3 text-3xl font-bold <%= actor_meta["skipped"].to_i > 0 ? "text-amber-300" : "text-gray-100" %>">
            <%= number_with_delimiter(actor_meta["skipped"].to_i) %>
          </div>
          <p class="mt-2 <%= muted_class %>">
            profils ignorés
          </p>
        </div>
      </div>

      <div class="mt-5 rounded-2xl border border-slate-800 bg-slate-950/40 p-4">
        <div class="<%= label_class %>">Diagnostic Actor Labels</div>

        <p class="mt-2 text-sm leading-relaxed text-slate-300">
          <% if actor_status.to_s == "running" %>
            Actor Labels est en cours de refresh. Les modules Layer 2 peuvent consommer les labels existants, mais une partie des profils récents peut encore être en attente.
          <% elsif total_labels.zero? %>
            Aucun label économique n’est disponible. Les modules Layer 2 ne peuvent pas encore s’appuyer sur l’Actor Graph.
          <% elsif exchange_like_count.zero? %>
            Les labels existent, mais aucun acteur exchange-like n’est identifié. Les flows exchange peuvent être incomplets.
          <% elsif whale_like_count.zero? %>
            Les labels sont actifs. Les exchanges sont disponibles, mais la couverture whale-like doit encore progresser.
          <% else %>
            Actor Labels est opérationnel. Les modules Layer 2 peuvent consommer les classifications économiques issues du Cluster Engine.
          <% end %>
        </p>
      </div>

      <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-3">
        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Started</div>
          <div class="mt-2 text-sm text-gray-300">
            <%= actor_labels_run&.started_at || "—" %>
          </div>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Finished</div>
          <div class="mt-2 text-sm text-gray-300">
            <%= actor_labels_run&.finished_at || "—" %>
          </div>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Trigger</div>
          <div class="mt-2 text-sm text-gray-300">
            sidekiq_cron
          </div>
        </div>
      </div>
    </section>

    <!-- Exchange Core Flow recovery -->
    <section class="<%= section_class %> mt-8">
      <%
        flow_today = Dashboard::ExchangeCoreNetflowToday.call rescue {}

        inflow_btc = flow_today[:inflow_btc].to_d
        outflow_btc = flow_today[:outflow_btc].to_d
        netflow_btc = flow_today[:netflow_btc].to_d
        events_count = flow_today[:events_count].to_i

        exchange_like_count = (@actor_labels_status || {})[:exchange_like].to_i

        last_flow_height = ExchangeCoreFlowEvent.maximum(:block_height)
        processed_height = layer1[:last_processed_height].to_i

        flow_lag =
          if last_flow_height.present? && processed_height.positive?
            [processed_height - last_flow_height.to_i, 0].max
          else
            nil
          end

        flow_state =
          if exchange_like_count.zero?
            "warning"
          elsif flow_lag.to_i > 6
            "warning"
          else
            "ok"
          end
      %>

      <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
        <div>
          <div class="<%= label_class %>">Layer 2 consumer</div>
          <h2 class="mt-1 text-xl font-semibold">Exchange Core Flow recovery</h2>
          <p class="mt-2 <%= muted_class %>">
            Consomme les labels exchange_like produits par Actor Labels pour calculer les inflows, outflows et netflows.
          </p>
        </div>

        <span class="inline-flex items-center rounded-full border px-3 py-1 text-sm font-semibold <%= status_classes.call(flow_state) %>">
          <%= flow_state.upcase %>
        </span>
      </div>

      <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-6">
        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Exchange actors</div>
          <div class="mt-3 text-3xl font-bold text-blue-300">
            <%= number_with_delimiter(exchange_like_count) %>
          </div>
          <p class="mt-2 <%= muted_class %>">labels exchange_like</p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Inflow today</div>
          <div class="mt-3 text-3xl font-bold text-rose-300">
            <%= number_with_precision(inflow_btc, precision: 2, delimiter: " ") %> BTC
          </div>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Outflow today</div>
          <div class="mt-3 text-3xl font-bold text-emerald-300">
            <%= number_with_precision(outflow_btc, precision: 2, delimiter: " ") %> BTC
          </div>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Netflow</div>
          <div class="mt-3 text-3xl font-bold <%= netflow_btc.positive? ? "text-rose-300" : "text-emerald-300" %>">
            <%= number_with_precision(netflow_btc, precision: 2, delimiter: " ") %> BTC
          </div>
          <p class="mt-2 <%= muted_class %>"><%= flow_today[:signal] || "—" %></p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Last block</div>
          <div class="mt-3 text-3xl font-bold text-gray-100">
            <%= last_flow_height || "—" %>
          </div>
          <p class="mt-2 <%= muted_class %>">flow events</p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Flow lag</div>
          <div class="mt-3 text-3xl font-bold <%= flow_lag.to_i > 0 ? "text-amber-300" : "text-emerald-300" %>">
            <%= flow_lag || 0 %>
          </div>
          <p class="mt-2 <%= muted_class %>">retard vs Layer 1</p>
        </div>
      </div>

      <div class="mt-5 rounded-2xl border border-slate-800 bg-slate-950/40 p-4">
        <div class="<%= label_class %>">Diagnostic Exchange Core Flow</div>

        <p class="mt-2 text-sm leading-relaxed text-slate-300">
          <% if exchange_like_count.zero? %>
            Aucun acteur exchange_like disponible. Le module ne peut pas encore produire de flux fiables.
          <% elsif flow_lag.to_i > 6 %>
            Exchange Core Flow a <%= flow_lag %> bloc(s) de retard. Les données peuvent être temporairement incomplètes.
          <% elsif netflow_btc.positive? %>
            Les entrées vers exchanges dominent aujourd’hui. Le signal indique une pression vendeuse nette.
          <% else %>
            Les sorties des exchanges dominent aujourd’hui. Le signal indique une accumulation ou pression acheteuse probable.
          <% end %>
        </p>
      </div>
    </section>

    <!-- Whale Intelligence recovery -->
    <section class="<%= section_class %> mt-8">
      <%
        whale_today = WhaleCoreFlowDay.order(day: :desc).first rescue nil

        whale_inflow_btc = whale_today&.inflow_btc.to_d
        whale_outflow_btc = whale_today&.outflow_btc.to_d
        whale_netflow_btc = whale_today&.netflow_btc.to_d
        whale_events_count = whale_today&.events_count.to_i

        whale_like_count = (@actor_labels_status || {})[:whale_like].to_i

        whale_signal =
          if whale_netflow_btc&.positive?
            "Accumulation"
          elsif whale_netflow_btc&.negative?
            "Distribution"
          else
            "Neutral"
          end

        whale_state =
          if whale_like_count.zero?
            "warning"
          elsif whale_today.blank?
            "warning"
          else
            "ok"
          end
      %>

      <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
        <div>
          <div class="<%= label_class %>">Layer 2 consumer</div>

          <h2 class="mt-1 text-xl font-semibold">
            Whale Intelligence recovery
          </h2>

          <p class="mt-2 <%= muted_class %>">
            Consomme les labels whale_like produits par Actor Labels pour mesurer accumulation,
            distribution et netflow whale.
          </p>
        </div>

        <span class="inline-flex items-center rounded-full border px-3 py-1 text-sm font-semibold <%= status_classes.call(whale_state) %>">
          <%= whale_state.upcase %>
        </span>
      </div>

      <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-5">
        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Whale actors</div>
          <div class="mt-3 text-3xl font-bold text-purple-300">
            <%= number_with_delimiter(whale_like_count) %>
          </div>
          <p class="mt-2 <%= muted_class %>">labels whale_like</p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Inflow</div>
          <div class="mt-3 text-3xl font-bold text-emerald-300">
            <%= number_with_precision(whale_inflow_btc || 0, precision: 2, delimiter: " ") %> BTC
          </div>
          <p class="mt-2 <%= muted_class %>">BTC reçus par les whales</p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Outflow</div>
          <div class="mt-3 text-3xl font-bold text-rose-300">
            <%= number_with_precision(whale_outflow_btc || 0, precision: 2, delimiter: " ") %> BTC
          </div>
          <p class="mt-2 <%= muted_class %>">BTC envoyés par les whales</p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Netflow</div>
          <div class="mt-3 text-3xl font-bold <%= whale_netflow_btc&.positive? ? "text-emerald-300" : whale_netflow_btc&.negative? ? "text-rose-300" : "text-gray-100" %>">
            <%= number_with_precision(whale_netflow_btc || 0, precision: 2, delimiter: " ") %> BTC
          </div>
          <p class="mt-2 <%= muted_class %>"><%= whale_signal %></p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Events</div>
          <div class="mt-3 text-3xl font-bold text-gray-100">
            <%= number_with_delimiter(whale_events_count || 0) %>
          </div>
          <p class="mt-2 <%= muted_class %>">
            <%= whale_today&.day || "no data" %>
          </p>
        </div>
      </div>

      <div class="mt-5 rounded-2xl border border-slate-800 bg-slate-950/40 p-4">
        <div class="<%= label_class %>">Diagnostic Whale Intelligence</div>

        <p class="mt-2 text-sm leading-relaxed text-slate-300">
          <% if whale_like_count.zero? %>
            Aucun acteur whale_like disponible. Whale Intelligence ne peut pas encore produire de flux fiables.
          <% elsif whale_today.blank? %>
            Aucun WhaleCoreFlowDay n’est encore disponible. Il faut lancer ou vérifier le calcul whale flow.
          <% elsif whale_netflow_btc.positive? %>
            Les whales reçoivent actuellement plus de BTC qu’elles n’en envoient. Le module détecte une accumulation nette.
          <% elsif whale_netflow_btc.negative? %>
            Les whales envoient actuellement plus de BTC qu’elles n’en reçoivent. Le module détecte une distribution nette.
          <% else %>
            Les flux whales sont équilibrés. Le signal actuel est neutre.
          <% end %>
        </p>
      </div>
    </section>

    <div class="mt-10 flex items-center justify-between">
      <div>
        <h2 class="text-xl font-semibold">Pipelines secondaires</h2>
        <div class="mt-1 text-sm text-gray-500">
          Vue compacte des consommateurs restants : exchange observed, flows legacy, analytics et tables journalières.
        </div>
      </div>
    </div>

    <div class="mt-4 grid grid-cols-1 gap-4 lg:grid-cols-2">
      <% secondary_pipelines = snapshot[:pipelines].to_h.reject do |key, _pipe|
        key.to_s.in?(%w[
          p0_realtime
          p3_cluster_realtime
          p3_cluster_batch
        ])
      end %>

      <% secondary_pipelines.each do |_key, pipe| %>
        <%
          pipe_lag = pipe[:lag].to_i

          pipe_state =
            if pipe[:status].to_s == "critical"
              "critical"
            elsif pipe_lag > 50
              "critical"
            elsif pipe_lag > 5
              "warning"
            else
              pipe[:status] || "ok"
            end

          lag_state_label =
            pipe_lag <= 0 ? "À jour" : "#{pipe_lag} blocs de retard"
        %>

        <div class="<%= panel_class %>">
          <div class="flex items-start justify-between gap-4">
            <div>
              <div class="<%= label_class %>"><%= pipe[:priority] || "Pipeline" %></div>
              <div class="mt-1 text-lg font-semibold text-gray-100"><%= pipe[:label] %></div>
              <% if pipe[:description].present? %>
                <div class="mt-2 text-sm text-gray-500">
                  <%= pipe[:description] %>
                </div>
              <% end %>

              <% if pipe[:cursor_name].present? %>
                <div class="mt-1 text-xs font-mono text-gray-500">
                  cursor=<%= pipe[:cursor_name] %>
                </div>
              <% end %>
            </div>

            <span class="rounded-full border px-3 py-1 text-sm font-semibold <%= status_classes.call(pipe_state) %>">
              <%= pipe_state.to_s.upcase %>
            </span>
          </div>

          <% if pipe[:lag].present? %>
            <div class="mt-4 grid grid-cols-3 gap-3 text-sm">
              <div class="rounded-xl bg-gray-950 p-3">
                <div class="text-gray-500">Last</div>
                <div class="font-semibold"><%= pipe[:last_height] || "—" %></div>
              </div>

              <div class="rounded-xl bg-gray-950 p-3">
                <div class="text-gray-500">Best</div>
                <div class="font-semibold"><%= pipe[:best_height] || "—" %></div>
              </div>

              <div class="rounded-xl bg-gray-950 p-3">
                <div class="text-gray-500">Lag</div>
                <div class="font-semibold <%= pipe_lag > 50 ? "text-rose-300" : pipe_lag > 5 ? "text-amber-300" : "text-emerald-300" %>">
                  <%= pipe_lag %>
                </div>
              </div>
            </div>

            <p class="mt-3 text-sm <%= pipe_lag > 50 ? "text-rose-300" : pipe_lag > 5 ? "text-amber-300" : "text-emerald-300" %>">
              <%= lag_state_label %>
            </p>
          <% end %>

          <% if pipe[:tables].present? %>
            <div class="mt-4 space-y-2">
              <% pipe[:tables].to_a.each do |t| %>
                <div class="flex items-center justify-between rounded-xl bg-gray-950 px-3 py-2 text-sm">
                  <span class="text-gray-300"><%= t[:name] %></span>
                  <span class="<%= t[:status] == "ok" ? "text-emerald-300" : t[:status] == "critical" ? "text-rose-300" : "text-amber-300" %>">
                    <%= t[:last_day] || "missing" %>
                  </span>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="mt-10 flex items-center justify-between">
      <div>
        <h2 class="text-xl font-semibold">Dernières exécutions recovery</h2>
        <div class="mt-1 text-sm text-gray-500">
          Historique court des jobs utiles au recovery.
        </div>
      </div>

      <span class="rounded-full border px-3 py-1 text-sm font-semibold <%= running_jobs.any? ? status_classes.call("running") : status_classes.call("ok") %>">
        <%= running_jobs.any? ? "#{running_jobs.size} RUNNING" : "NO ACTIVE JOB" %>
      </span>
    </div>

    <div class="mt-4 overflow-x-auto rounded-2xl border border-gray-800">
      <table class="w-full text-left text-sm">
        <thead class="bg-gray-900 text-gray-400">
          <tr>
            <th class="px-4 py-3">Job</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Start</th>
            <th class="px-4 py-3">Durée</th>
            <th class="px-4 py-3">Progress</th>
            <th class="px-4 py-3">Erreur</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-gray-800 bg-gray-950">
          <% recent_jobs.to_a.each do |jr| %>
            <tr class="align-top">
              <td class="px-4 py-3 font-medium"><%= jr[:name] %></td>

              <td class="px-4 py-3">
                <span class="rounded-full border px-2 py-1 text-xs font-semibold <%= status_classes.call(jr[:status]) %>">
                  <%= jr[:status].to_s.upcase %>
                </span>
              </td>

              <td class="px-4 py-3 text-gray-300"><%= jr[:started_at] %></td>

              <td class="px-4 py-3">
                <%= jr[:duration_seconds].present? ? seconds_to_label.call(jr[:duration_seconds]) : "—" %>
              </td>

              <td class="px-4 py-3">
                <% if jr[:progress_pct].present? || jr[:progress_label].present? || jr[:progress_meta].present? %>
                  <% pct = [[jr[:progress_pct].to_f, 0].max, 100].min %>

                  <div class="min-w-44">
                    <% if jr[:progress_pct].present? %>
                      <div class="mb-1 flex justify-between text-xs text-gray-500">
                        <span>progress</span>
                        <span><%= pct.round(1) %>%</span>
                      </div>

                      <div class="h-1.5 overflow-hidden rounded-full bg-gray-800">
                        <div class="h-full rounded-full bg-sky-400" style="width: <%= pct %>%"></div>
                      </div>
                    <% end %>

                    <% if jr[:progress_label].present? %>
                      <div class="mt-1 text-xs text-gray-500">
                        <%= jr[:progress_label] %>
                      </div>
                    <% end %>

                    <% if jr[:progress_meta].present? %>
                      <div class="mt-1 text-xs text-gray-600">
                        <% meta = jr[:progress_meta] || {} %>

                        <% if meta["scanned_blocks"].present? || meta["scanned_txs"].present? || meta["links_created"].present? %>
                          blocks=<%= meta["scanned_blocks"] || "—" %> ·
                          txs=<%= meta["scanned_txs"] || "—" %> ·
                          links=<%= meta["links_created"] || "—" %>
                        <% elsif meta["refreshed"].present? || meta["dirty_queue_size_after"].present? %>
                          refreshed=<%= meta["refreshed"] || "—" %> ·
                          dirty_after=<%= meta["dirty_queue_size_after"] || "—" %> ·
                          removed=<%= meta["removed_from_queue"] || "—" %>
                        <% else %>
                          <%= meta.to_h.slice("layer1_lag", "batch_size", "removed_from_queue").map { |k, v| "#{k}=#{v}" }.join(" · ").presence || "—" %>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                <% else %>
                  <span class="text-gray-600">—</span>
                <% end %>
              </td>

              <td class="px-4 py-3 text-rose-300">
                <%= truncate((jr[:error_message] || jr[:error]).to_s, length: 120) %>
              </td>
            </tr>
          <% end %>
          <% if recent_jobs.blank? %>
            <tr>
              <td colspan="6" class="px-4 py-6 text-gray-500">
                Aucun job recovery récent sur les dernières 24 heures.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

  <% end %>
</div>