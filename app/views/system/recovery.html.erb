<% snapshot = @recovery_snapshot || {} %>
<% state = @recovery_state || snapshot[:state] || {} %>
<% layer1 = snapshot[:layer1] || {} %>
<% redis_buffers = layer1[:redis_buffers] || {} %>
<% status_counts = layer1[:status_counts] || {} %>
<% pipelines = snapshot[:pipelines] || {} %>
<% cluster_refresh = snapshot[:cluster_refresh] || {} %>
<% queues = snapshot[:queues] || [] %>
<% workers = snapshot[:workers] || [] %>
<% recent_jobs = snapshot[:recent_job_runs] || [] %>

<% p0_realtime = pipelines[:p0_realtime] || {} %>
<% p1_exchange = pipelines[:p1_exchange] || {} %>
<% p2_flows = pipelines[:p2_flows] || {} %>
<% p3_realtime = pipelines[:p3_cluster_realtime] || {} %>
<% p3_batch = pipelines[:p3_cluster_batch] || {} %>
<% p4_analytics = pipelines[:p4_analytics] || {} %>

<% busy_queues = queues.select { |q| q[:size].to_i > 0 || q[:latency].to_f > 30 } %>
<% running_jobs = recent_jobs.select { |j| j[:status].to_s == "running" } %>

<%
  section_class = "rounded-2xl border border-white/10 bg-gray-950/70 p-5 shadow-sm"
  panel_class = "rounded-xl border border-white/10 bg-black/20 p-4"
  label_class = "text-xs font-semibold uppercase tracking-wide text-gray-500"
  muted_class = "text-sm text-gray-400"

  status_classes = lambda do |status|
    case status.to_s
    when "ok", "healthy", "processed"
      "border-emerald-500/20 bg-emerald-500/10 text-emerald-300"
    when "critical", "stalled", "fail", "failed"
      "border-rose-500/20 bg-rose-500/10 text-rose-300"
    else
      "border-amber-500/20 bg-amber-500/10 text-amber-300"
    end
  end

  ms_to_label = lambda do |ms|
    value = ms.to_i

    if ms.nil?
      "—"
    elsif value <= 0
      "0 ms"
    elsif value < 1_000
      "#{value} ms"
    elsif value < 60_000
      "#{(value / 1_000.0).round(1)} s"
    else
      "#{(value / 60_000.0).round(1)} min"
    end
  end

  seconds_to_label = lambda do |seconds|
    value = seconds.to_i

    if value <= 0
      "—"
    elsif value < 60
      "#{value}s"
    elsif value < 3_600
      "#{(value / 60.0).round(1)} min"
    else
      "#{(value / 3_600.0).round(1)} h"
    end
  end

  progress_pct = lambda do |pipe|
    best = pipe[:best_height].to_i
    last = pipe[:last_height].to_i

    best <= 0 ? 100 : [[(last.to_f / best * 100).round(2), 100].min, 0].max
  end

  lag_label = lambda do |lag_value|
    lag_value.to_i <= 0 ? "À jour" : "#{lag_value.to_i} blocs de retard"
  end

  lag = layer1[:lag].to_i
  eta = layer1[:eta_minutes]
  speed = layer1[:recovery_speed]

  layer1_state =
    if status_counts["failed"].to_i > 0
      "critical"
    elsif lag > 0 || status_counts["processing"].to_i > 0 || status_counts["enqueued"].to_i > 0
      "recovering"
    else
      "healthy"
    end

  bottleneck =
    if layer1[:current_processing_blocks].present?
      "Traitement Layer 1 actif : #{layer1[:current_processing_blocks].size} bloc(s) en cours."
    elsif lag > 0
      "Recovery en attente : #{lag} blocs à rattraper."
    else
      "Layer 1 synchronisé."
    end
%>

<div class="mx-auto max-w-7xl px-6 py-8 text-gray-100">
  <div class="mb-8 rounded-3xl border border-gray-800 bg-gradient-to-br from-gray-900 to-gray-950 p-6">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <p class="text-sm uppercase tracking-wide text-gray-500">System recovery</p>
        <h1 class="mt-2 text-3xl font-bold">Recovery control center</h1>

        <p class="mt-2 max-w-3xl text-gray-400">
          Cockpit de reprise : Layer 1 canonique, consommateurs Layer 2, queues Sidekiq, locks et jobs en cours.
        </p>

        <div class="mt-5 grid grid-cols-1 gap-3 md:grid-cols-4">
          <div class="rounded-2xl border border-gray-800 bg-gray-950/70 p-4">
            <div class="text-sm uppercase tracking-wide text-gray-500">Layer 1</div>
            <div class="mt-1 text-2xl font-bold"><%= layer1_state.upcase %></div>
            <div class="mt-2 text-xs text-gray-500">
              lag=<%= lag %> · speed=<%= speed || "—" %> bloc/min
            </div>
          </div>

          <div class="rounded-2xl border border-gray-800 bg-gray-950/70 p-4">
            <div class="text-sm uppercase tracking-wide text-gray-500">Cluster realtime</div>
            <div class="mt-1 text-2xl font-bold"><%= p3_realtime[:lag] || "—" %></div>
            <div class="mt-2 text-xs text-gray-500">blocs de retard</div>
          </div>

          <div class="rounded-2xl border border-gray-800 bg-gray-950/70 p-4">
            <div class="text-sm uppercase tracking-wide text-gray-500">Cluster batch</div>
            <div class="mt-1 text-2xl font-bold"><%= p3_batch[:lag] || "—" %></div>
            <div class="mt-2 text-xs text-gray-500">blocs de retard</div>
          </div>

          <div class="rounded-2xl border border-gray-800 bg-gray-950/70 p-4">
            <div class="text-sm uppercase tracking-wide text-gray-500">Dirty clusters</div>
            <div class="mt-1 text-2xl font-bold"><%= cluster_refresh[:dirty_queue_size] || 0 %></div>
            <div class="mt-2 text-xs text-gray-500">
              <%= cluster_refresh[:estimated_batches_remaining] || "—" %> batches restants
            </div>
          </div>
        </div>

        <div class="mt-5 rounded-2xl border border-gray-800 bg-gray-950/70 p-4">
          <div class="text-sm uppercase tracking-wide text-gray-500">Diagnostic principal</div>
          <div class="mt-1 text-lg font-semibold"><%= bottleneck %></div>
          <div class="mt-2 text-sm text-gray-400">
            Queues en backlog : <%= busy_queues.size %> ·
            Jobs actifs : <%= running_jobs.size %> ·
            ETA Layer 1 : <%= eta ? "#{eta} min" : "—" %>
          </div>
        </div>
      </div>

      <div class="min-w-56 rounded-2xl border <%= status_classes.call(layer1_state) %> px-5 py-4 text-right">
        <div class="text-sm opacity-80">État recovery</div>
        <div class="mt-1 text-3xl font-bold"><%= layer1_state.upcase %></div>
        <div class="mt-2 text-xs opacity-70">
          generated_at: <%= snapshot[:generated_at] || "—" %>
        </div>
      </div>
    </div>
  </div>
  <section class="<%= section_class %> mb-8">
    <div class="flex items-center justify-between">
      <div>
        <div class="<%= label_class %>">Pipeline map</div>
        <h2 class="mt-1 text-xl font-semibold">Layer 1 → Layer 2</h2>
        <p class="mt-2 <%= muted_class %>">
          Vue réelle des dépendances : Layer 2 ne lit pas Bitcoin Core directement, il consomme l’état canonique Layer 1.
        </p>
      </div>
    </div>

    <div class="mt-5 grid grid-cols-1 gap-4 xl:grid-cols-6">
      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Source</div>
        <div class="mt-2 text-lg font-semibold">Bitcoin Core</div>
        <div class="mt-3 text-sm text-gray-400">
          best: <span class="font-mono text-gray-200"><%= snapshot[:best_height] || "—" %></span>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Canonical</div>
        <div class="mt-2 text-lg font-semibold">Layer 1 processed</div>
        <div class="mt-3 text-sm text-gray-400">
          height: <span class="font-mono text-gray-200"><%= layer1[:last_processed_height] || "—" %></span>
        </div>
        <div class="mt-1 text-sm text-gray-400">
          lag: <span class="font-mono"><%= layer1[:lag] || 0 %></span>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">P3A</div>
        <div class="mt-2 text-lg font-semibold">Cluster realtime</div>
        <div class="mt-3 text-sm text-gray-400">
          cursor: <span class="font-mono text-gray-200"><%= p3_realtime[:last_height] || "—" %></span>
        </div>
        <div class="mt-1 text-sm text-gray-400">
          lag: <span class="font-mono"><%= p3_realtime[:lag] || "—" %></span>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">P3B</div>
        <div class="mt-2 text-lg font-semibold">Cluster batch</div>
        <div class="mt-3 text-sm text-gray-400">
          cursor: <span class="font-mono text-gray-200"><%= p3_batch[:last_height] || "—" %></span>
        </div>
        <div class="mt-1 text-sm text-gray-400">
          lag: <span class="font-mono"><%= p3_batch[:lag] || "—" %></span>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Refresh</div>
        <div class="mt-2 text-lg font-semibold">Dirty clusters</div>
        <div class="mt-3 text-sm text-gray-400">
          queue: <span class="font-mono text-amber-300"><%= cluster_refresh[:dirty_queue_size] || 0 %></span>
        </div>
        <div class="mt-1 text-sm text-gray-400">
          batches: <span class="font-mono"><%= cluster_refresh[:estimated_batches_remaining] || "—" %></span>
        </div>
      </div>

      <div class="<%= panel_class %>">
        <div class="<%= label_class %>">Analytics</div>
        <div class="mt-2 text-lg font-semibold">Metrics / Signals</div>
        <div class="mt-3 text-sm text-gray-400">
          status:
          <span class="font-mono <%= p4_analytics[:status].to_s == "ok" ? "text-emerald-300" : "text-amber-300" %>">
            <%= p4_analytics[:status].to_s.upcase.presence || "—" %>
          </span>
        </div>
      </div>
    </div>
  </section>
  <% if snapshot[:error].present? %>
    <div class="rounded-2xl border border-rose-500/30 bg-rose-500/10 p-4 text-rose-200">
      <%= snapshot[:error] %>
    </div>
  <% else %>

    <section class="<%= section_class %>">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
        <div>
          <div class="<%= label_class %>">Layer 1</div>
          <h2 class="mt-1 text-xl font-semibold">Blockchain recovery</h2>
          <p class="mt-2 <%= muted_class %>">
            État réel du rattrapage : buffer, processing, métriques par bloc et backlog Redis.
          </p>
        </div>

        <span class="inline-flex items-center rounded-full border px-3 py-1 text-sm font-semibold <%= status_classes.call(layer1_state) %>">
          <%= layer1_state.upcase %>
        </span>
      </div>

      <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-4">
        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Best height</div>
          <div class="mt-3 text-3xl font-bold"><%= layer1[:best_height] || "—" %></div>
          <p class="mt-2 <%= muted_class %>">
            buffered <%= layer1[:highest_buffered_height] || "—" %>
          </p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Last processed</div>
          <div class="mt-3 text-3xl font-bold"><%= layer1[:last_processed_height] || "—" %></div>
          <p class="mt-2 <%= muted_class %>">
            lag <%= layer1[:lag] || "—" %> blocs
          </p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Recovery speed</div>
          <div class="mt-3 text-3xl font-bold"><%= layer1[:recovery_speed] || "—" %></div>
          <p class="mt-2 <%= muted_class %>">blocs/min sur 30 minutes</p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">ETA</div>
          <div class="mt-3 text-3xl font-bold"><%= layer1[:eta_minutes] ? "#{layer1[:eta_minutes]}m" : "—" %></div>
          <p class="mt-2 <%= muted_class %>">estimation recovery</p>
        </div>
      </div>

      <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-5">
        <% ["pending", "enqueued", "processing", "processed", "failed"].each do |status| %>
          <div class="<%= panel_class %>">
            <div class="<%= label_class %>"><%= status %></div>
            <div class="mt-3 text-2xl font-bold"><%= status_counts[status].to_i %></div>
          </div>
        <% end %>
      </div>

      <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-3">
        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Process queue</div>
          <div class="mt-3 text-3xl font-bold"><%= layer1[:process_queue_size] || 0 %></div>
          <p class="mt-2 <%= muted_class %>">jobs BlockProcessJob en attente</p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Outputs Redis</div>
          <div class="mt-3 text-3xl font-bold"><%= redis_buffers[:outputs_buffer] || 0 %></div>
          <p class="mt-2 <%= muted_class %>">blockchain:outputs:buffer</p>
        </div>

        <div class="<%= panel_class %>">
          <div class="<%= label_class %>">Spent outputs Redis</div>
          <div class="mt-3 text-3xl font-bold"><%= redis_buffers[:spent_outputs_buffer] || 0 %></div>
          <p class="mt-2 <%= muted_class %>">blockchain:spent_outputs:buffer</p>
        </div>
      </div>
    </section>

    <section class="<%= section_class %> mt-8">
      <div class="<%= label_class %>">Processing blocks</div>
      <h2 class="mt-1 text-xl font-semibold">Blocs en cours</h2>

      <div class="mt-4 overflow-x-auto rounded-2xl border border-gray-800">
        <table class="w-full text-left text-sm">
          <thead class="bg-gray-900 text-gray-400">
            <tr>
              <th class="px-4 py-3">Height</th>
              <th class="px-4 py-3">Age</th>
              <th class="px-4 py-3">Heartbeat</th>
              <th class="px-4 py-3">RPC</th>
              <th class="px-4 py-3">Parse</th>
              <th class="px-4 py-3">Flush</th>
              <th class="px-4 py-3">Attempts</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-gray-800 bg-gray-950">
            <% if layer1[:current_processing_blocks].blank? %>
              <tr>
                <td colspan="7" class="px-4 py-4 text-gray-500">Aucun bloc en processing.</td>
              </tr>
            <% else %>
              <% layer1[:current_processing_blocks].to_a.each do |b| %>
                <tr>
                  <td class="px-4 py-3 font-semibold"><%= b[:height] %></td>
                  <td class="px-4 py-3"><%= seconds_to_label.call(b[:age_seconds]) %></td>
                  <td class="px-4 py-3"><%= seconds_to_label.call(b[:heartbeat_age_seconds]) %></td>
                  <td class="px-4 py-3"><%= ms_to_label.call(b[:rpc_duration_ms]) %></td>
                  <td class="px-4 py-3 text-amber-300"><%= ms_to_label.call(b[:parse_duration_ms]) %></td>
                  <td class="px-4 py-3"><%= ms_to_label.call(b[:flush_duration_ms]) %></td>
                  <td class="px-4 py-3"><%= b[:attempts] || 0 %></td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="<%= section_class %> mt-8">
      <div class="<%= label_class %>">Recovery window</div>
      <h2 class="mt-1 text-xl font-semibold">Fenêtre actuelle du recovery Layer 1</h2>

      <p class="mt-2 <%= muted_class %>">
        Vue continue des blocs autour du rattrapage : processed, processing, enqueued, pending et failed.
      </p>

      <div class="mt-4 overflow-x-auto rounded-2xl border border-gray-800">
        <table class="w-full text-left text-sm">
          <thead class="bg-gray-900 text-gray-400">
            <tr>
              <th class="px-4 py-3">Height</th>
              <th class="px-4 py-3">Status</th>
              <th class="px-4 py-3">Total</th>
              <th class="px-4 py-3">RPC</th>
              <th class="px-4 py-3">Parse</th>
              <th class="px-4 py-3">Flush</th>
              <th class="px-4 py-3">Age</th>
              <th class="px-4 py-3">Heartbeat</th>
              <th class="px-4 py-3">Attempts</th>
              <th class="px-4 py-3">Updated / finished</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-gray-800 bg-gray-950">
            <% if layer1[:recovery_window].blank? %>
              <tr>
                <td colspan="10" class="px-4 py-4 text-gray-500">
                  Aucune fenêtre recovery disponible.
                </td>
              </tr>
            <% else %>
              <% layer1[:recovery_window].to_a.each do |b| %>
                <tr class="<%= b[:status].to_s == "processing" ? "bg-amber-500/5" : b[:status].to_s == "failed" ? "bg-rose-500/5" : "" %>">
                  <td class="px-4 py-3 font-semibold"><%= b[:height] %></td>

                  <td class="px-4 py-3">
                    <span class="rounded-full border px-2 py-1 text-xs font-semibold <%= status_classes.call(b[:status]) %>">
                      <%= b[:status].to_s.upcase %>
                    </span>
                  </td>

                  <td class="px-4 py-3"><%= ms_to_label.call(b[:duration_ms]) %></td>
                  <td class="px-4 py-3"><%= ms_to_label.call(b[:rpc_duration_ms]) %></td>
                  <td class="px-4 py-3 text-amber-300"><%= ms_to_label.call(b[:parse_duration_ms]) %></td>
                  <td class="px-4 py-3"><%= ms_to_label.call(b[:flush_duration_ms]) %></td>
                  <td class="px-4 py-3"><%= seconds_to_label.call(b[:age_seconds]) %></td>
                  <td class="px-4 py-3"><%= seconds_to_label.call(b[:heartbeat_age_seconds]) %></td>
                  <td class="px-4 py-3"><%= b[:attempts] || 0 %></td>

                  <td class="px-4 py-3 text-gray-400">
                    <%= b[:processed_at] || b[:failed_at] || b[:updated_at] || "—" %>
                  </td>
                </tr>

                <% if b[:status].to_s == "failed" && (b[:error_class].present? || b[:error_message].present?) %>
                  <tr>
                    <td colspan="10" class="bg-rose-950/20 px-4 py-3 text-xs text-rose-300">
                      <%= truncate("#{b[:error_class]} #{b[:error_message]}", length: 220) %>
                    </td>
                  </tr>
                <% end %>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <% if layer1[:recent_failed_blocks].present? %>
      <section class="<%= section_class %> mt-8">
        <div class="<%= label_class %>">Failed blocks</div>
        <h2 class="mt-1 text-xl font-semibold">Blocs Layer 1 en erreur</h2>

        <div class="mt-4 overflow-x-auto rounded-2xl border border-gray-800">
          <table class="w-full text-left text-sm">
            <thead class="bg-gray-900 text-gray-400">
              <tr>
                <th class="px-4 py-3">Height</th>
                <th class="px-4 py-3">Attempts</th>
                <th class="px-4 py-3">Failed at</th>
                <th class="px-4 py-3">Error</th>
              </tr>
            </thead>

            <tbody class="divide-y divide-gray-800 bg-gray-950">
              <% layer1[:recent_failed_blocks].to_a.each do |b| %>
                <tr>
                  <td class="px-4 py-3 font-semibold"><%= b[:height] %></td>
                  <td class="px-4 py-3"><%= b[:attempts] || 0 %></td>
                  <td class="px-4 py-3"><%= b[:failed_at] || "—" %></td>
                  <td class="px-4 py-3 text-rose-300">
                    <%= truncate("#{b[:error_class]} #{b[:error_message]}", length: 160) %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </section>
    <% end %>

    <% cluster_refresh = snapshot[:cluster_refresh] || {} %>

    <section class="mt-10">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-xl font-semibold">Cluster refresh</h2>
          <div class="mt-1 text-sm text-gray-500">
            État du refresh des dirty clusters
          </div>
        </div>

        <% refresh_status =
          if cluster_refresh[:dirty_queue_size].to_i > 5000
            "critical"
          elsif cluster_refresh[:dirty_queue_size].to_i > 0
            "warning"
          else
            "ok"
          end
        %>

        <span class="rounded-full border px-3 py-1 text-sm font-semibold <%= status_classes.call(refresh_status) %>">
          <%= refresh_status.upcase %>
        </span>
      </div>

      <div class="mt-4 grid grid-cols-1 gap-4 lg:grid-cols-5">
        <div class="rounded-2xl border border-gray-800 bg-gray-900 p-5">
          <div class="text-sm text-gray-500">Dirty queue</div>
          <div class="mt-2 text-3xl font-bold text-amber-300">
            <%= cluster_refresh[:dirty_queue_size] || 0 %>
          </div>
        </div>

        <div class="rounded-2xl border border-gray-800 bg-gray-900 p-5">
          <div class="text-sm text-gray-500">Batch size</div>
          <div class="mt-2 text-3xl font-bold">
            <%= cluster_refresh[:batch_size] || "—" %>
          </div>
        </div>

        <div class="rounded-2xl border border-gray-800 bg-gray-900 p-5">
          <div class="text-sm text-gray-500">Batches remaining</div>
          <div class="mt-2 text-3xl font-bold">
            <%= cluster_refresh[:estimated_batches_remaining] || "—" %>
          </div>
        </div>

        <div class="rounded-2xl border border-gray-800 bg-gray-900 p-5">
          <div class="text-sm text-gray-500">Last duration</div>
          <div class="mt-2 text-3xl font-bold">
            <%= cluster_refresh[:duration_ms].present? ? "#{(cluster_refresh[:duration_ms].to_f / 1000).round}s" : "—" %>
          </div>
        </div>

        <div class="rounded-2xl border border-gray-800 bg-gray-900 p-5">
          <div class="text-sm text-gray-500">Last refresh</div>

          <div class="mt-2">
            <span class="rounded-full border px-3 py-1 text-xs font-semibold <%= status_classes.call(cluster_refresh[:last_run_status]) %>">
              <%= cluster_refresh[:last_run_status].to_s.upcase.presence || "UNKNOWN" %>
            </span>
          </div>

          <div class="mt-3 text-xs text-gray-500">
            <%= cluster_refresh[:progress_label] || "—" %>
          </div>
        </div>
      </div>
    </section>

    <div class="mt-10 flex items-center justify-between">
      <h2 class="text-xl font-semibold">Détail des pipelines</h2>
      <div class="text-sm text-gray-500">État détaillé par curseur et table analytique</div>
    </div>

    <div class="mt-4 grid grid-cols-1 gap-4 lg:grid-cols-2">
      <% snapshot[:pipelines].to_h.each do |_key, pipe| %>
        <% pct = progress_pct.call(pipe) %>

        <div class="rounded-2xl border border-gray-800 bg-gray-900 p-5">
          <div class="flex items-center justify-between gap-4">
            <div>
              <div class="text-sm text-gray-400"><%= pipe[:priority] %></div>
              <div class="text-lg font-semibold"><%= pipe[:label] %></div>
              <% if pipe[:cursor_name].present? %>
                <div class="mt-1 text-xs font-mono text-gray-500">
                  cursor=<%= pipe[:cursor_name] %>
                </div>
              <% end %>
              <% if pipe[:lag].present? %>
                <div class="mt-1 text-sm text-gray-500"><%= lag_label.call(pipe[:lag]) %></div>
              <% end %>
            </div>

            <span class="rounded-full border px-3 py-1 text-sm font-semibold <%= status_classes.call(pipe[:status]) %>">
              <%= pipe[:status].to_s.upcase %>
            </span>
          </div>

          <% if pipe[:lag].present? %>
            <div class="mt-5">
              <div class="mb-2 flex items-center justify-between text-xs text-gray-500">
                <span><%= pipe[:last_height] %></span>
                <span><%= pct %>%</span>
                <span><%= pipe[:best_height] %></span>
              </div>

              <div class="h-2 overflow-hidden rounded-full bg-gray-800">
                <div
                  class="h-full rounded-full <%= pipe[:status].to_s == "critical" ? "bg-rose-400" : pipe[:status].to_s == "ok" ? "bg-emerald-400" : "bg-amber-400" %>"
                  style="width: <%= pct %>%">
                </div>
              </div>

              <div class="mt-4 grid grid-cols-3 gap-3 text-sm">
                <div class="rounded-xl bg-gray-950 p-3">
                  <div class="text-gray-500">Last</div>
                  <div class="font-semibold"><%= pipe[:last_height] %></div>
                </div>

                <div class="rounded-xl bg-gray-950 p-3">
                  <div class="text-gray-500">Best</div>
                  <div class="font-semibold"><%= pipe[:best_height] %></div>
                </div>

                <div class="rounded-xl bg-gray-950 p-3">
                  <div class="text-gray-500">Lag</div>
                  <div class="font-semibold <%= pipe[:lag].to_i > 24 ? "text-rose-300" : pipe[:lag].to_i > 5 ? "text-amber-300" : "text-emerald-300" %>">
                    <%= pipe[:lag] %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

          <% if pipe[:tables].present? %>
            <div class="mt-5 space-y-2">
              <% pipe[:tables].to_a.each do |t| %>
                <div class="flex items-center justify-between rounded-xl bg-gray-950 px-3 py-2 text-sm">
                  <span class="text-gray-300"><%= t[:name] %></span>
                  <span class="<%= t[:status] == "ok" ? "text-emerald-300" : t[:status] == "critical" ? "text-rose-300" : "text-amber-300" %>">
                    <%= t[:last_day] || "missing" %>
                  </span>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="mt-10 flex items-center justify-between">
      <div>
        <h2 class="text-xl font-semibold">Pression Sidekiq</h2>
        <div class="mt-1 text-sm text-gray-500">
          Backlogs, latence et queues qui ralentissent le recovery.
        </div>
      </div>

      <span class="rounded-full border px-3 py-1 text-sm font-semibold <%= busy_queues.any? ? status_classes.call("warning") : status_classes.call("ok") %>">
        <%= busy_queues.any? ? "#{busy_queues.size} BACKLOG" : "CLEAR" %>
      </span>
    </div>

    <div class="mt-4 overflow-hidden rounded-2xl border border-gray-800">
      <table class="w-full text-left text-sm">
        <thead class="bg-gray-900 text-gray-400">
          <tr>
            <th class="px-4 py-3">Queue</th>
            <th class="px-4 py-3">Size</th>
            <th class="px-4 py-3">Latency</th>
            <th class="px-4 py-3">État</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-gray-800 bg-gray-950">
          <% queues.to_a.each do |q| %>
            <%
              latency = q[:latency].to_f
              size = q[:size].to_i

              busy = size > 0 || latency > 30

              queue_state =
                if latency > 3600 || size > 50
                  "critical"
                elsif busy
                  "warning"
                else
                  "ok"
                end
            %>

            <tr>
              <td class="px-4 py-3 font-medium"><%= q[:name] %></td>
              <td class="px-4 py-3"><%= q[:size] %></td>
              <td class="px-4 py-3"><%= q[:latency] %>s</td>
              <td class="px-4 py-3">
                <span class="rounded-full border px-2 py-1 text-xs font-semibold <%= status_classes.call(queue_state) %>">
                  <%= queue_state == "ok" ? "CLEAR" : queue_state.upcase %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="mt-10 grid grid-cols-1 gap-6 lg:grid-cols-2">
      <div>
        <div class="flex items-center justify-between">
          <div>
            <h2 class="text-xl font-semibold">Workers actifs</h2>
            <div class="mt-1 text-sm text-gray-500">
              Jobs Sidekiq actuellement en cours d’exécution.
            </div>
          </div>

          <span class="rounded-full border px-3 py-1 text-sm font-semibold <%= workers.any? ? status_classes.call("warning") : status_classes.call("ok") %>">
            <%= workers.any? ? "#{workers.size} RUNNING" : "IDLE" %>
          </span>
        </div>

        <div class="mt-4 space-y-2">
          <% if workers.blank? %>
            <div class="rounded-2xl border border-gray-800 bg-gray-900 p-4 text-gray-400">
              Aucun worker actif.
            </div>
          <% else %>
            <% workers.to_a.each do |w| %>
              <%
                job_class = w[:job_class].to_s
                args = Array(w[:args])

                job_title =
                  if job_class == "Blockchain::Jobs::BlockProcessJob"
                    "Layer 1 processing"
                  elsif job_class == "WhaleScanJob"
                    "Whale analytics"
                  elsif job_class == "Clusters::RefreshDirtyClustersJob"
                    "Cluster refresh"
                  elsif job_class == "ClusterScanJob"
                    "Cluster batch scanner"
                  elsif job_class == "Realtime::ProcessLatestBlockJob"
                    "Realtime block processing"
                  elsif job_class == "InflowOutflowBuildJob"
                    "Exchange flows analytics"
                  else
                    job_class.presence || "Unknown job"
                  end

                job_description =
                  if job_class == "Blockchain::Jobs::BlockProcessJob"
                    block_height = args.first
                    "Traitement du bloc Bitcoin ##{block_height}"
                  elsif job_class == "WhaleScanJob"
                    "Détection des gros mouvements BTC"
                  elsif job_class == "Clusters::RefreshDirtyClustersJob"
                    "Recalcul des clusters modifiés après scan ou merge"
                  elsif job_class == "ClusterScanJob"
                    "Analyse batch du graphe cluster"
                  elsif job_class == "Realtime::ProcessLatestBlockJob"
                    "Traitement realtime du dernier bloc Bitcoin"
                  elsif job_class == "InflowOutflowBuildJob"
                    "Construction des flux entrants / sortants exchange-like"
                  else
                    "Job Sidekiq actif"
                  end
              %>

              <div class="rounded-2xl border border-gray-800 bg-gray-900 p-4">
                <div class="flex items-start justify-between gap-4">
                  <div class="min-w-0">
                    <div class="text-lg font-semibold text-gray-100">
                      <%= job_title %>
                    </div>

                    <div class="mt-1 text-sm text-gray-400 leading-relaxed">
                      <%= job_description %>
                    </div>

                    <div class="mt-2 flex flex-wrap items-center gap-2 text-xs text-gray-500">
                      <span>
                        queue=<span class="font-mono text-gray-300"><%= w[:queue] || "—" %></span>
                      </span>

                      <span>·</span>

                      <span>
                        job=<span class="font-mono text-gray-300"><%= w[:job_class] || "—" %></span>
                      </span>
                    </div>
                  </div>

                  <span class="rounded-full border px-2 py-1 text-xs font-semibold <%= status_classes.call("running") %>">
                    RUNNING
                  </span>
                </div>

                <details class="mt-4">
                  <summary class="cursor-pointer text-xs font-semibold text-gray-400 hover:text-gray-200">
                    Détails techniques
                  </summary>

                  <div class="mt-3 grid grid-cols-1 md:grid-cols-2 gap-3 text-xs text-gray-500">
                    <div>
                      <div>process</div>
                      <div class="mt-1 font-mono text-gray-300 truncate">
                        <%= w[:process_id] || "—" %>
                      </div>
                    </div>

                    <div>
                      <div>thread</div>
                      <div class="mt-1 font-mono text-gray-300 truncate">
                        <%= w[:thread_id] || "—" %>
                      </div>
                    </div>

                    <div>
                      <div>jid</div>
                      <div class="mt-1 font-mono text-gray-300 truncate">
                        <%= w[:jid] || "—" %>
                      </div>
                    </div>

                    <div>
                      <div>run_at</div>
                      <div class="mt-1 font-mono text-gray-300">
                        <%= w[:run_at] || "—" %>
                      </div>
                    </div>

                    <% if w[:args].present? %>
                      <div class="md:col-span-2">
                        <div>args</div>
                        <pre class="mt-1 overflow-x-auto rounded-xl border border-gray-800 bg-black/30 p-3 text-xs text-gray-400 whitespace-pre-wrap"><%= JSON.pretty_generate(w[:args]) rescue w[:args].inspect %></pre>
                      </div>
                    <% end %>
                  </div>
                </details>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>

      <div>
        <div class="flex items-center justify-between">
          <div>
            <h2 class="text-xl font-semibold">Locks</h2>
            <div class="mt-1 text-sm text-gray-500">
              Verrous de protection contre les doubles exécutions.
            </div>
          </div>
        </div>

        <div class="mt-4 space-y-2">
          <% snapshot[:locks].to_a.each do |lock| %>
            <%
              lock_name = lock[:name].to_s

              lock_title =
                if lock_name == "realtime_processing_lock"
                  "Realtime processing"
                elsif lock_name == "exchange_observed_scan_lock"
                  "Exchange observed scan"
                elsif lock_name == "recovery_orchestrator_lock"
                  "Recovery orchestrator"
                elsif lock_name == "lock:cluster_scan" || lock_name == "cluster_scan_lock"
                  "Cluster batch scanner"
                else
                  lock_name
                end

              lock_description =
                if lock_name == "realtime_processing_lock"
                  "Empêche deux traitements realtime de tourner en même temps."
                elsif lock_name == "exchange_observed_scan_lock"
                  "Protège le scan exchange-like contre les doubles exécutions."
                elsif lock_name == "recovery_orchestrator_lock"
                  "Évite plusieurs orchestrations recovery simultanées."
                elsif lock_name == "lock:cluster_scan" || lock_name == "cluster_scan_lock"
                  "Protège le scanner cluster batch contre les doubles exécutions."
                else
                  "Verrou technique Redis."
                end

              lock_status = lock[:status].to_s

              lock_classes =
                if lock_status == "active"
                  "border-emerald-500/20 bg-emerald-500/10 text-emerald-300"
                elsif lock_status == "stale" || lock_status == "error"
                  "border-rose-500/20 bg-rose-500/10 text-rose-300"
                elsif lock_status == "clear"
                  "border-sky-500/20 bg-sky-500/10 text-sky-300"
                else
                  "border-gray-500/20 bg-gray-500/10 text-gray-300"
                end
            %>

            <div class="rounded-2xl border border-gray-800 bg-gray-900 p-4">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <div class="text-sm font-semibold text-gray-100">
                    <%= lock_title %>
                  </div>

                  <div class="mt-1 text-sm text-gray-400 leading-relaxed">
                    <%= lock_description %>
                  </div>
                </div>

                <span class="rounded-full border px-2 py-1 text-xs font-semibold <%= lock_classes %>">
                  <%= lock_status.upcase.presence || "UNKNOWN" %>
                </span>
              </div>

              <details class="mt-3">
                <summary class="cursor-pointer text-xs font-semibold text-gray-400 hover:text-gray-200">
                  Détails techniques
                </summary>

                <div class="mt-3 text-sm text-gray-400">
                  key:
                  <span class="font-mono text-xs text-gray-300 break-all">
                    <%= lock[:name] %>
                  </span>
                  <br>

                  present:
                  <span class="font-mono text-xs text-gray-300">
                    <%= lock[:present] ? "yes" : "no" %>
                  </span>
                  <br>

                  ttl:
                  <span class="font-mono text-xs text-gray-300">
                    <%= lock[:ttl].to_i >= 0 ? "#{lock[:ttl]}s" : "—" %>
                  </span>
                  <br>

                  value:
                  <span class="font-mono text-xs text-gray-500 break-all">
                    <%= lock[:value].presence || "—" %>
                  </span>
                </div>

                <% if lock[:error].present? %>
                  <div class="mt-2 text-xs text-rose-300">
                    <%= lock[:error] %>
                  </div>
                <% end %>
              </details>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="mt-10 flex items-center justify-between">
      <div>
        <h2 class="text-xl font-semibold">Dernières exécutions recovery</h2>
        <div class="mt-1 text-sm text-gray-500">
          Historique court des jobs utiles au recovery.
        </div>
      </div>

      <span class="rounded-full border px-3 py-1 text-sm font-semibold <%= running_jobs.any? ? status_classes.call("running") : status_classes.call("ok") %>">
        <%= running_jobs.any? ? "#{running_jobs.size} RUNNING" : "NO ACTIVE JOB" %>
      </span>
    </div>

    <div class="mt-4 overflow-x-auto rounded-2xl border border-gray-800">
      <table class="w-full text-left text-sm">
        <thead class="bg-gray-900 text-gray-400">
          <tr>
            <th class="px-4 py-3">Job</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Start</th>
            <th class="px-4 py-3">Durée</th>
            <th class="px-4 py-3">Progress</th>
            <th class="px-4 py-3">Erreur</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-gray-800 bg-gray-950">
          <% recent_jobs.to_a.each do |jr| %>
            <tr class="align-top">
              <td class="px-4 py-3 font-medium"><%= jr[:name] %></td>

              <td class="px-4 py-3">
                <span class="rounded-full border px-2 py-1 text-xs font-semibold <%= status_classes.call(jr[:status]) %>">
                  <%= jr[:status].to_s.upcase %>
                </span>
              </td>

              <td class="px-4 py-3 text-gray-300"><%= jr[:started_at] %></td>

              <td class="px-4 py-3">
                <%= jr[:duration_seconds].present? ? seconds_to_label.call(jr[:duration_seconds]) : "—" %>
              </td>

              <td class="px-4 py-3">
                <% if jr[:progress_pct].present? || jr[:progress_label].present? || jr[:progress_meta].present? %>
                  <% pct = [[jr[:progress_pct].to_f, 0].max, 100].min %>

                  <div class="min-w-44">
                    <% if jr[:progress_pct].present? %>
                      <div class="mb-1 flex justify-between text-xs text-gray-500">
                        <span>progress</span>
                        <span><%= pct.round(1) %>%</span>
                      </div>

                      <div class="h-1.5 overflow-hidden rounded-full bg-gray-800">
                        <div class="h-full rounded-full bg-sky-400" style="width: <%= pct %>%"></div>
                      </div>
                    <% end %>

                    <% if jr[:progress_label].present? %>
                      <div class="mt-1 text-xs text-gray-500">
                        <%= jr[:progress_label] %>
                      </div>
                    <% end %>

                    <% if jr[:progress_meta].present? %>
                      <div class="mt-1 text-xs text-gray-600">
                        <% meta = jr[:progress_meta] || {} %>

                        <% if meta["scanned_blocks"].present? || meta["scanned_txs"].present? || meta["links_created"].present? %>
                          blocks=<%= meta["scanned_blocks"] || "—" %> ·
                          txs=<%= meta["scanned_txs"] || "—" %> ·
                          links=<%= meta["links_created"] || "—" %>
                        <% elsif meta["refreshed"].present? || meta["dirty_queue_size_after"].present? %>
                          refreshed=<%= meta["refreshed"] || "—" %> ·
                          dirty_after=<%= meta["dirty_queue_size_after"] || "—" %> ·
                          removed=<%= meta["removed_from_queue"] || "—" %>
                        <% else %>
                          <%= meta.to_h.slice("layer1_lag", "batch_size", "removed_from_queue").map { |k, v| "#{k}=#{v}" }.join(" · ").presence || "—" %>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                <% else %>
                  <span class="text-gray-600">—</span>
                <% end %>
              </td>

              <td class="px-4 py-3 text-rose-300">
                <%= truncate((jr[:error_message] || jr[:error]).to_s, length: 120) %>
              </td>
            </tr>
          <% end %>
          <% if recent_jobs.blank? %>
            <tr>
              <td colspan="6" class="px-4 py-6 text-gray-500">
                Aucun job recovery récent sur les dernières 24 heures.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

  <% end %>
</div>