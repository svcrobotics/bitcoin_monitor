<div
  id="btc-live-price"
  class="mt-6 rounded-2xl border border-orange-500/30 bg-orange-500/10 p-5">

  <div class="flex items-center justify-between">
    <div>
      <p class="text-xs uppercase tracking-[0.2em] text-orange-300">
        BTC/USD LIVE
      </p>

      <p class="mt-2 text-4xl font-bold tracking-tight text-white">
        <%= number_to_currency(price, unit: "$", precision: 0) %>
      </p>

      <p class="mt-2 text-sm text-gray-400">
        Dernière candle 5m · mise à jour automatique
      </p>
    </div>

    <div class="flex items-center gap-2">
      <span class="h-3 w-3 rounded-full bg-green-400 animate-pulse"></span>
      <span class="text-sm text-green-300 font-medium">LIVE</span>
    </div>
  </div>
</div>
