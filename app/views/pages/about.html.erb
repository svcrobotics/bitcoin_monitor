<% content_for :title, t("about.title") %>

<div class="max-w-4xl mx-auto px-6 py-16">

  <!-- HERO -->
  <section class="text-center space-y-6">
    <h1 class="text-4xl sm:text-5xl font-semibold text-gray-100">
      <%= t("about.hero.headline") %>
    </h1>

    <p class="text-lg text-gray-300 max-w-2xl mx-auto leading-relaxed">
      <%= t("about.hero.subtitle") %>
    </p>
  </section>

  <!-- MISSION -->
  <section class="mt-20 space-y-6 text-gray-300 leading-relaxed">
    <h2 class="text-xl font-semibold text-gray-100">
      <%= t("about.mission.title") %>
    </h2>

    <p><%= t("about.mission.p1") %></p>
    <p><%= t("about.mission.p2") %></p>
    <p class="text-gray-400"><%= t("about.mission.p3") %></p>
  </section>

  <!-- DATA -->
  <section class="mt-20 space-y-6 text-gray-300 leading-relaxed">
    <h2 class="text-xl font-semibold text-gray-100">
      <%= t("about.data.title") %>
    </h2>

    <p><%= t("about.data.p1") %></p>

    <ul class="list-disc pl-6 space-y-2">
      <li><%= t("about.data.bullets.b1") %></li>
      <li><%= t("about.data.bullets.b2") %></li>
      <li><%= t("about.data.bullets.b3") %></li>
      <li><%= t("about.data.bullets.b4") %></li>
    </ul>

    <p class="text-gray-400"><%= t("about.data.p2") %></p>
  </section>

  <!-- AI -->
  <section class="mt-20 space-y-6 text-gray-300 leading-relaxed">
    <h2 class="text-xl font-semibold text-gray-100">
      <%= t("about.technology.title") %>
    </h2>

    <p><%= t("about.technology.p1") %></p>
    <p><%= t("about.technology.p2") %></p>
    <p class="text-gray-400"><%= t("about.technology.p3") %></p>
  </section>

  <!-- VISION -->
  <section class="mt-20 space-y-6 text-gray-300 leading-relaxed">
    <h2 class="text-xl font-semibold text-gray-100">
      <%= t("about.vision.title") %>
    </h2>

    <p><%= t("about.vision.p1") %></p>
    <p><%= t("about.vision.p2") %></p>
  </section>

  <!-- DISCLAIMER -->
  <section class="mt-28 text-center space-y-4">
    <p class="text-sm text-gray-400 max-w-2xl mx-auto">
      <%= t("about.disclaimer") %>
    </p>
  </section>

</div>
