<%# dashboard/_ai_insight_help.html.erb %>

<div data-controller="toggle" class="bg-gray-900/60 border border-gray-800 rounded-xl p-4">
  <button type="button"
          data-action="toggle#toggle"
          data-toggle-show-value='<%= t("dashboard.ai_insight_help.show") %>'
          data-toggle-hide-value='<%= t("dashboard.ai_insight_help.hide") %>'
          class="w-full inline-flex items-center justify-between gap-3 text-sm text-gray-200 hover:text-gray-100 transition">
    <span class="inline-flex items-center gap-2">
      <span class="text-indigo-300">ℹ️</span>
      <span class="font-semibold"><%= t("dashboard.ai_insight_help.title") %></span>
    </span>

    <span class="inline-flex items-center gap-2">
      <span data-toggle-target="label" class="text-xs text-gray-400"><%= t("dashboard.ai_insight_help.hide") %></span>
      <span data-toggle-target="icon" class="text-gray-500">▾</span>
    </span>
  </button>

  <div data-toggle-target="content" class="hidden mt-4 text-sm text-gray-200 space-y-3 text-left">
    <p class="leading-relaxed">
      <%= t("dashboard.ai_insight_help.p1_html") %>
    </p>

    <ul class="list-disc list-inside text-gray-400 space-y-1">
      <li><strong class="text-gray-200"><%= t("dashboard.ai_insight_help.items.headline.k") %></strong> : <%= t("dashboard.ai_insight_help.items.headline.v") %></li>
      <li><strong class="text-gray-200"><%= t("dashboard.ai_insight_help.items.regime.k") %></strong> : <%= t("dashboard.ai_insight_help.items.regime.v") %></li>
      <li><strong class="text-gray-200"><%= t("dashboard.ai_insight_help.items.wm.k") %></strong> : <%= t("dashboard.ai_insight_help.items.wm.v") %></li>
      <li><strong class="text-gray-200"><%= t("dashboard.ai_insight_help.items.drivers.k") %></strong> : <%= t("dashboard.ai_insight_help.items.drivers.v") %></li>
      <li><strong class="text-gray-200"><%= t("dashboard.ai_insight_help.items.levels.k") %></strong> : <%= t("dashboard.ai_insight_help.items.levels.v") %></li>
      <li><strong class="text-gray-200"><%= t("dashboard.ai_insight_help.items.scenarios.k") %></strong> : <%= t("dashboard.ai_insight_help.items.scenarios.v") %></li>
      <li><strong class="text-gray-200"><%= t("dashboard.ai_insight_help.items.risk.k") %></strong> : <%= t("dashboard.ai_insight_help.items.risk.v") %></li>
    </ul>

    <p class="text-[11px] text-gray-500 leading-relaxed">
      <%= t("dashboard.ai_insight_help.footer") %>
    </p>
  </div>
</div>
