<%# --- Raccourcis dashboard (repliable, masqué par défaut) --- %>

<% shortcut_groups = [
  {
    title_key: "dashboard.shortcuts.groups.market",
    items: [
      { label_key: "dashboard.shortcuts.items.market_price", path: market_price_path(range: "30d", alerts_mode: "strict") },
      { label_key: "dashboard.shortcuts.items.btc_dashboard", path: btc_dashboard_path },
      { label_key: "dashboard.shortcuts.items.trade_simulator", path: trade_simulations_path }
    ]
  },
  {
    title_key: "dashboard.shortcuts.groups.onchain",
    items: [
      { label_key: "dashboard.shortcuts.items.whale_alerts", path: whale_alerts_path },
      { label_key: "dashboard.shortcuts.items.exchange_like", path: exchange_like_path },
      { label_key: "dashboard.shortcuts.items.inflow_outflow", path: inflow_outflow_path },
      { label_key: "dashboard.shortcuts.items.brc20", path: brc20_path },
      { label_key: "dashboard.shortcuts.items.runes", path: runes_path },
      { label_key: "dashboard.shortcuts.items.clusters", path: clusters_path },
      { label_key: "dashboard.shortcuts.items.cluster_signals", path: cluster_signals_path },
      { label_key: "dashboard.shortcuts.items.top_clusters", path: top_cluster_signals_path }
    ]
  },
  {
    title_key: "dashboard.shortcuts.groups.research",
    items: [
      { label_key: "dashboard.shortcuts.items.blocks", path: blocks_path },
      { label_key: "dashboard.shortcuts.items.p2wsh_wallets", path: vaults_path },
      { label_key: "dashboard.shortcuts.items.journal", path: journal_entries_path }
    ]
  },
  {
    title_key: "dashboard.shortcuts.groups.docs",
    items: [
      { label_key: "dashboard.shortcuts.items.guides", path: guides_path },
      { label_key: "dashboard.shortcuts.items.feature_requests", path: feature_requests_path },
      { label_key: "dashboard.shortcuts.items.about", path: about_path }
    ]
  },
  {
    title_key: "dashboard.shortcuts.groups.security",
    items: [
      { label_key: "dashboard.shortcuts.items.opsec", path: opsec_path }
    ]
  },
  {
    title_key: "dashboard.shortcuts.groups.system",
    items: [
      {
        label_key: "dashboard.shortcuts.items.system",
        path: system_path
      },
      {
        label_key: "dashboard.shortcuts.items.recovery",
        path: system_recovery_path
      }
    ]
  }
] %>

<section
  data-controller="toggle"
  class="mt-5 bg-gray-900/40 border border-gray-800 rounded-2xl p-4 sm:p-5"
>
  <!-- Header -->
  <div class="flex items-center justify-between gap-3">
    <div class="min-w-0">
      <p class="text-xs uppercase tracking-wide text-gray-500"><%= t("dashboard.shortcuts.header") %></p>
      <p class="text-xs text-gray-500"><%= t("dashboard.shortcuts.subheader") %></p>
    </div>

    <button
      type="button"
      data-action="toggle#toggle"
      data-toggle-show-value='<%= t("dashboard.shortcuts.show") %>'
      data-toggle-hide-value='<%= t("dashboard.shortcuts.hide") %>'
      class="inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs
             bg-black/20 border border-gray-800 text-gray-300
             hover:text-gray-100 hover:bg-white/5 transition"
    >
      <span data-toggle-target="icon" class="text-gray-500">▸</span>
      <span data-toggle-target="label"><%= t("dashboard.shortcuts.show") %></span>
    </button>
  </div>

  <!-- Contenu repliable -->
  <div
    data-toggle-target="content"
    class="hidden mt-4 space-y-5"
  >
    <% shortcut_groups.each do |group| %>
      <div>
        <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-gray-500">
          <%= t(group[:title_key]) %>
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          <% group[:items].each do |it| %>
            <%= link_to it[:path],
              class: "group w-full inline-flex items-center justify-between gap-3 rounded-xl
                      px-4 py-3 bg-black/20 border border-gray-800
                      text-gray-200 hover:bg-white/5 hover:border-gray-700 transition" do %>
              <span class="min-w-0 flex-1 font-semibold text-sm sm:text-[13px] leading-tight">
                <%= t(it[:label_key]) %>
              </span>
              <span class="text-gray-600 group-hover:text-gray-300 transition">›</span>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>