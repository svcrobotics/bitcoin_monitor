<div class="relative min-h-[calc(100vh-7rem)] overflow-hidden">
  <!-- Background -->
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute left-1/2 top-24 h-96 w-96 -translate-x-1/2 rounded-full bg-cyan-500/10 blur-3xl"></div>
    <div class="absolute right-20 top-40 h-72 w-72 rounded-full bg-blue-500/10 blur-3xl"></div>
    <div class="absolute left-20 bottom-20 h-72 w-72 rounded-full bg-emerald-500/10 blur-3xl"></div>
  </div>

  <div class="relative z-10 mx-auto flex min-h-[calc(100vh-7rem)] max-w-6xl flex-col px-4 py-10">

    <!-- Hero -->
    <div class="mx-auto max-w-4xl text-center">
      <div class="inline-flex items-center rounded-full border border-cyan-500/20 bg-cyan-500/10 px-4 py-2 text-xs font-semibold tracking-wider text-cyan-200 uppercase">
        探査 — Tansa
      </div>

      <h1 class="mt-6 text-4xl font-bold tracking-tight text-white md:text-6xl">
        Intelligence Bitcoin
      </h1>

      <p class="mx-auto mt-6 max-w-3xl text-lg leading-8 text-slate-400">
        Posez une question. Tansa analyse les données on-chain,
        les acteurs du marché et l'état de la plateforme afin de
        fournir une réponse claire, argumentée et traçable.
      </p>
    </div>

    <!-- Question box -->
    <div class="mx-auto mt-12 w-full max-w-5xl">
      <%= form_with url: ai_dashboard_answer_path,
                    method: :post,
                    data: { turbo_frame: "dashboard_answer" } do %>

        <div class="overflow-hidden rounded-3xl border border-white/10 bg-slate-950/80 backdrop-blur-xl">
          <div class="px-6 py-5">
            <textarea
              name="q"
              rows="2"
              autocomplete="off"
              placeholder="Pourquoi le Bitcoin baisse-t-il aujourd'hui ?"
              class="w-full resize-none bg-transparent text-lg text-white outline-none placeholder:text-slate-500"
            ></textarea>
          </div>

          <div class="flex items-center justify-between border-t border-white/5 px-6 py-4">
            <div class="flex flex-wrap gap-2">

              <button type="button"
                class="rounded-full border border-white/10 px-3 py-1 text-xs text-slate-400">
                Marché Bitcoin
              </button>

              <button type="button"
                class="rounded-full border border-white/10 px-3 py-1 text-xs text-slate-400">
                Whales
              </button>

              <button type="button"
                class="rounded-full border border-white/10 px-3 py-1 text-xs text-slate-400">
                Exchanges
              </button>

              <button type="button"
                class="rounded-full border border-white/10 px-3 py-1 text-xs text-slate-400">
                État du système
              </button>

            </div>

            <button
              type="submit"
              class="rounded-2xl bg-cyan-400 px-5 py-2 text-sm font-semibold text-slate-950 transition hover:bg-cyan-300">
              Demander à Tansa
            </button>
          </div>
        </div>

      <% end %>
    </div>

    <!-- Suggested questions -->
    <div class="mx-auto mt-8 flex max-w-5xl flex-wrap justify-center gap-3">

      <button class="rounded-full border border-white/10 bg-white/[0.03] px-4 py-2 text-sm text-slate-400">
        Pourquoi le Bitcoin baisse-t-il aujourd'hui ?
      </button>

      <button class="rounded-full border border-white/10 bg-white/[0.03] px-4 py-2 text-sm text-slate-400">
        Les whales accumulent-elles ?
      </button>

      <button class="rounded-full border border-white/10 bg-white/[0.03] px-4 py-2 text-sm text-slate-400">
        Les ETF soutiennent-ils encore le marché ?
      </button>

      <button class="rounded-full border border-white/10 bg-white/[0.03] px-4 py-2 text-sm text-slate-400">
        Le système fonctionne-t-il correctement ?
      </button>

    </div>

    <!-- Answer -->
    <div class="mx-auto mt-12 w-full max-w-6xl">
      <%= turbo_frame_tag "dashboard_answer" %>
    </div>

  </div>
</div>