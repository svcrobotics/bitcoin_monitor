<div class="relative min-h-screen overflow-hidden bg-[#050711] font-mono">
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <%= image_tag "tansa/background.png",
          class: "absolute inset-0 h-full w-full object-cover object-center" %>

    <div class="absolute inset-0 bg-[#050711]/20"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#050711]/88 via-[#050711]/35 to-transparent"></div>
  </div>

  <div class="relative z-10 mx-auto flex min-h-screen max-w-[1680px] flex-col px-8 py-10 lg:px-14">
    <header class="flex items-center gap-8 pb-10">
      <div class="text-2xl font-light tracking-[0.42em] text-white">
        TANSA
      </div>

      <div class="text-xs uppercase tracking-[0.28em] text-slate-400">
        Observatoire Bitcoin
      </div>
    </header>

    <section
      class="flex flex-1 flex-col pt-8"
      data-controller="dashboard-question"
    >
      <div class="w-full max-w-5xl">
        <%= turbo_stream_from System::AnomalyBroadcaster::STREAM %>

        <!-- Historique du terminal -->
        <div id="terminal_stream" class="space-y-10">
          <%= turbo_frame_tag "dashboard_answer",
                data: {
                  dashboard_question_target: "answer"
                } do %>
          <% end %>
        </div>

        <!-- Prompt actif -->
        <%= render "system/anomaly_notification", notification: nil %>

        <%= form_with url: ai_dashboard_answer_path,
                      method: :post,
                      data: {
                        turbo_frame: true,
                        dashboard_question_target: "form",
                        action: "turbo:submit-end->dashboard-question#showNewQuestion"
                      } do %>

          <div class="mt-10 flex items-center gap-3">
            <span class="shrink-0 text-xl text-violet-300">›</span>

            <textarea
              name="q"
              rows="1"
              autocomplete="off"
              autofocus
              data-dashboard-question-target="input"
              data-action="keydown->dashboard-question#submitOnEnter"
              class="h-10 w-full resize-none overflow-hidden bg-transparent text-xl leading-10 text-white outline-none placeholder:text-transparent"
            ></textarea>
          </div>

          <button type="submit" class="hidden">
            Envoyer
          </button>

        <% end %>
      </div>
    </section>
  </div>
</div>
