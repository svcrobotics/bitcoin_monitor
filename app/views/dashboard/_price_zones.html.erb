<%# app/views/dashboard/_price_zones.html.erb %>

<section class="mt-6 bg-gray-900/40 border border-gray-800 rounded-2xl p-5 sm:p-6">
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
    <div class="min-w-0">
      <div class="flex items-center gap-3">
        <h2 class="text-lg sm:text-xl font-semibold text-gray-100">
          <%= t("dashboard.price_zones.title") %>
        </h2>

        <span class="text-[11px] text-gray-500">
          <%= t("dashboard.price_zones.kicker") %>
        </span>
      </div>

      <p class="mt-1 text-sm text-gray-400">
        <%= t("dashboard.price_zones.desc") %>
      </p>

      <details class="group mt-3">
        <summary class="cursor-pointer select-none inline-flex items-center gap-2 text-xs text-gray-400 hover:text-gray-200">
          <span><%= t("dashboard.price_zones.help") %></span>
          <span class="text-gray-600 group-open:hidden">▸</span>
          <span class="text-gray-600 hidden group-open:inline">▾</span>
        </summary>

        <div class="mt-3 bg-black/20 border border-gray-800 rounded-xl p-4 text-sm text-gray-200 space-y-3">
          <p>
            <%= t("dashboard.price_zones.methodology.p1") %>
          </p>

          <ul class="list-disc list-inside text-gray-400">
            <li><%= t("dashboard.price_zones.methodology.li1_html").html_safe %></li>
            <li><%= t("dashboard.price_zones.methodology.li2_html").html_safe %></li>
            <li><%= t("dashboard.price_zones.methodology.li3") %></li>
          </ul>

          <p class="text-xs text-gray-500 pt-2 border-t border-gray-800">
            <%= t("dashboard.price_zones.methodology.params") %>
          </p>
        </div>
      </details>
    </div>

    <div class="shrink-0">
      <%= button_to price_zones_refresh_path,
                    method: :post,
                    class: "inline-flex items-center justify-center rounded-xl px-4 py-2.5 text-sm font-semibold
                            bg-black/20 border border-gray-700 text-gray-100 hover:bg-white/5 hover:border-gray-600 transition" do %>
        <%= t("dashboard.price_zones.recompute") %>
      <% end %>
    </div>
  </div>

  <% if @price_now.present? %>
    <div class="mt-4 flex flex-wrap items-center gap-2">
      <span class="text-[11px] uppercase tracking-wide text-gray-500">
        <%= t("dashboard.price_zones.price_now") %>
      </span>

      <span class="inline-flex items-center rounded-full px-3 py-1 bg-black/20 border border-gray-800 text-gray-100">
        <span class="font-mono font-semibold">
          <%= number_to_currency(@price_now.to_f, unit: "$", precision: 0, delimiter: " ") %>
        </span>
      </span>

      <span class="text-[11px] text-gray-500"><%= t("dashboard.price_zones.daily_close") %></span>
    </div>
  <% end %>

  <% if @price_now.present? && @price_zones.present? %>
    <% support = @price_zones[:support] %>
    <% resist  = @price_zones[:resistance] %>
    <% bonus   = Array(@price_zones[:bonus]) %>

    <%# Force badge sobre %>
    <% force_badge = lambda do |z|
         s = z&.strength.to_i
         if s >= 70
           [t("dashboard.price_zones.strength.strong"), "border-gray-600 text-gray-200 bg-white/5"]
         elsif s >= 60
           [t("dashboard.price_zones.strength.medium"), "border-gray-700 text-gray-300 bg-white/5"]
         else
           [t("dashboard.price_zones.strength.weak"), "border-gray-800 text-gray-400 bg-white/5"]
         end
       end
    %>

    <div class="mt-5 grid grid-cols-1 sm:grid-cols-2 gap-3">
      <!-- Support -->
      <div class="bg-black/20 border border-gray-800 rounded-2xl p-4">
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <p class="text-xs uppercase tracking-wide text-gray-500"><%= t("dashboard.price_zones.support") %></p>

            <% if support.present? %>
              <p class="mt-1 text-lg font-semibold text-gray-100">
                <span class="font-mono">
                  <%= number_to_currency(support.low_usd.to_f, unit: "$", precision: 0, delimiter: " ") %>
                  –
                  <%= number_to_currency(support.high_usd.to_f, unit: "$", precision: 0, delimiter: " ") %>
                </span>
              </p>
            <% else %>
              <p class="mt-2 text-sm text-gray-300"><%= t("dashboard.price_zones.no_support") %></p>
            <% end %>
          </div>

          <% if support.present? %>
            <% label, klass = force_badge.call(support) %>
            <span class="shrink-0 inline-flex items-center rounded-full px-2 py-0.5 text-[11px] border <%= klass %>">
              <%= label %> • <%= support.strength %>
            </span>
          <% end %>
        </div>

        <% if support.present? %>
          <% mid  = (support.low_usd.to_d + support.high_usd.to_d) / 2 %>
          <% dist = ((@price_now.to_d - mid) / @price_now.to_d * 100).abs.round(2) %>

          <div class="mt-2 flex flex-wrap items-center gap-2 text-xs text-gray-500">
            <span><%= t("dashboard.price_zones.distance") %></span>
            <span class="font-mono text-gray-300"><%= dist %>%</span>

            <span class="text-gray-700">•</span>
            <span><%= t("dashboard.price_zones.touches") %></span>
            <span class="font-mono text-gray-300"><%= support.touches_count %></span>
          </div>

          <p class="mt-2 text-xs text-gray-400">
            <%= t("dashboard.price_zones.support_hint") %>
          </p>
        <% end %>
      </div>

      <!-- Résistance -->
      <div class="bg-black/20 border border-gray-800 rounded-2xl p-4">
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <p class="text-xs uppercase tracking-wide text-gray-500"><%= t("dashboard.price_zones.resistance") %></p>

            <% if resist.present? %>
              <p class="mt-1 text-lg font-semibold text-gray-100">
                <span class="font-mono">
                  <%= number_to_currency(resist.low_usd.to_f, unit: "$", precision: 0, delimiter: " ") %>
                  –
                  <%= number_to_currency(resist.high_usd.to_f, unit: "$", precision: 0, delimiter: " ") %>
                </span>
              </p>
            <% else %>
              <p class="mt-2 text-sm text-gray-300"><%= t("dashboard.price_zones.no_resistance") %></p>
            <% end %>
          </div>

          <% if resist.present? %>
            <% label, klass = force_badge.call(resist) %>
            <span class="shrink-0 inline-flex items-center rounded-full px-2 py-0.5 text-[11px] border <%= klass %>">
              <%= label %> • <%= resist.strength %>
            </span>
          <% end %>
        </div>

        <% if resist.present? %>
          <% mid  = (resist.low_usd.to_d + resist.high_usd.to_d) / 2 %>
          <% dist = ((mid - @price_now.to_d) / @price_now.to_d * 100).abs.round(2) %>

          <div class="mt-2 flex flex-wrap items-center gap-2 text-xs text-gray-500">
            <span><%= t("dashboard.price_zones.distance") %></span>
            <span class="font-mono text-gray-300">+<%= dist %>%</span>

            <span class="text-gray-700">•</span>
            <span><%= t("dashboard.price_zones.touches") %></span>
            <span class="font-mono text-gray-300"><%= resist.touches_count %></span>
          </div>

          <p class="mt-2 text-xs text-gray-400">
            <%= t("dashboard.price_zones.resistance_hint") %>
          </p>
        <% end %>
      </div>
    </div>

    <% if bonus.any? %>
      <details class="group mt-4">
        <summary class="cursor-pointer select-none inline-flex items-center gap-2 text-xs text-gray-400 hover:text-gray-200">
          <span><%= t("dashboard.price_zones.bonus_title") %></span>
          <span class="text-gray-600 group-open:hidden">▸</span>
          <span class="text-gray-600 hidden group-open:inline">▾</span>
        </summary>

        <div class="mt-3 bg-black/20 border border-gray-800 rounded-2xl p-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <% bonus.each do |z| %>
              <% kind = z.kind.to_s %>
              <% label_kind =
                   if kind == "support"
                     t("dashboard.price_zones.support")
                   elsif kind == "resistance"
                     t("dashboard.price_zones.resistance")
                   else
                     t("dashboard.price_zones.level")
                   end
              %>
              <% mid  = (z.low_usd.to_d + z.high_usd.to_d) / 2 %>
              <% dist = ((mid - @price_now.to_d) / @price_now.to_d * 100).round(2) %>

              <div class="bg-black/20 border border-gray-800 rounded-xl p-4">
                <div class="flex items-center justify-between gap-3">
                  <p class="text-xs uppercase tracking-wide text-gray-500">
                    <%= label_kind %> <%= t("dashboard.price_zones.bonus_suffix") %>
                  </p>

                  <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[11px] border border-gray-800 bg-white/5 text-gray-300">
                    <%= z.strength %>
                  </span>
                </div>

                <p class="mt-1 text-lg font-semibold text-gray-100">
                  <span class="font-mono">
                    <%= number_to_currency(z.low_usd.to_f, unit: "$", precision: 0, delimiter: " ") %>
                    –
                    <%= number_to_currency(z.high_usd.to_f, unit: "$", precision: 0, delimiter: " ") %>
                  </span>
                </p>

                <div class="mt-2 text-xs text-gray-500">
                  <%= t("dashboard.price_zones.distance") %> :
                  <span class="font-mono text-gray-300"><%= dist >= 0 ? "+" : "" %><%= dist %>%</span>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </details>
    <% end %>

    <p class="mt-4 text-xs text-gray-500">
      <%= t("dashboard.price_zones.footer") %>
    </p>

  <% else %>
    <div class="mt-5 bg-black/20 border border-gray-800 rounded-2xl p-4">
      <p class="text-sm text-gray-200"><%= t("dashboard.price_zones.empty.title") %></p>
      <p class="mt-1 text-xs text-gray-400">
        <%= t("dashboard.price_zones.empty.hint_html", recompute: t("dashboard.price_zones.recompute")).html_safe %>
      </p>
    </div>
  <% end %>
</section>
