<%
  nav_item =
    "group flex min-h-10 items-center gap-3 rounded-xl px-3 py-1.5 text-[14px] font-medium text-slate-300 transition hover:bg-white/[0.055] hover:text-white"

  nav_item_active =
    "group flex min-h-10 items-center gap-3 rounded-xl bg-white/[0.06] px-3 py-1.5 text-[14px] font-semibold text-white ring-1 ring-white/[0.06]"

  nav_icon =
    "flex h-5 w-5 shrink-0 items-center justify-center text-slate-500 transition group-hover:text-cyan-300"

  nav_icon_active =
    "flex h-5 w-5 shrink-0 items-center justify-center text-cyan-300"

  nav_section =
    "mb-2 mt-5 px-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500"

  divider =
    "my-4 border-t border-white/[0.06]"
%>
<style>
  .tansa-scroll {
    overflow-y: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .tansa-scroll::-webkit-scrollbar {
    display: none;
  }
</style>

<div class="flex h-full flex-col bg-[#0f141d]">
  <div class="flex h-16 shrink-0 items-center border-b border-white/[0.06] px-4">
    <%= link_to root_path, class: "flex min-w-0 items-center gap-3" do %>
      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-cyan-400/10 text-lg font-black text-cyan-300 ring-1 ring-cyan-400/20">
        探査
      </div>

      <div class="min-w-0">
        <div class="truncate text-base font-semibold tracking-tight text-white">
          Tansa
        </div>
        <div class="truncate text-[11px] uppercase tracking-[0.16em] text-slate-500">
          On-chain intelligence
        </div>
      </div>
    <% end %>
  </div>

  <nav class="tansa-scroll min-h-0 flex-1 px-3 py-3">
    <div class="space-y-1">
      <%= link_to root_path, class: nav_item_active do %>
        <span class="<%= nav_icon_active %>">
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M10 2.5 3.5 8v8A1.5 1.5 0 0 0 5 17.5h3.25v-4.25h3.5v4.25H15A1.5 1.5 0 0 0 16.5 16V8L10 2.5Z" />
          </svg>
        </span>

        <div class="min-w-0">
          <div class="truncate">Dashboard</div>
          <div class="truncate text-[11px] font-normal text-slate-500">
            Questions · On-chain answers
          </div>
        </div>
      <% end %>

      <%= link_to about_path, class: nav_item do %>
        <span class="<%= nav_icon %>">
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M10 2a8 8 0 1 0 0 16 8 8 0 0 0 0-16Zm.75 11.25a.75.75 0 0 1-1.5 0V9.5a.75.75 0 0 1 1.5 0v3.75ZM10 7.75a1 1 0 1 1 0-2 1 1 0 0 1 0 2Z" />
          </svg>
        </span>

        <div class="min-w-0">
          <div class="truncate">About Tansa</div>
          <div class="truncate text-[11px] font-normal text-slate-500">
            Mission · Methodology
          </div>
        </div>
      <% end %>
    </div>

    <div class="<%= divider %>"></div>

    <div class="<%= nav_section %>">Market</div>

    <div class="space-y-1">
      <%= link_to btc_dashboard_path, class: nav_item do %>
        <span class="<%= nav_icon %>">
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M3 15.5A1.5 1.5 0 0 0 4.5 17h11a.75.75 0 0 0 0-1.5h-11V4.5a.75.75 0 0 0-1.5 0v11Z" />
            <path d="M6.25 12.75 9 10l2 1.5 3.75-4.25a.75.75 0 1 1 1.12 1L11.66 13a.75.75 0 0 1-1.01.1L9.1 11.94l-1.79 1.87a.75.75 0 0 1-1.06-1.06Z" />
          </svg>
        </span>

        <div class="min-w-0">
          <div class="truncate">BTC Market</div>
          <div class="truncate text-[11px] font-normal text-slate-500">
            Price · Momentum · Structure
          </div>
        </div>

        <!-- Live badge -->
        <div class="hidden md:flex items-center gap-1 rounded-md border border-cyan-500/20 bg-cyan-500/10 px-1.5 py-0.5">
          <span class="h-1.5 w-1.5 rounded-full bg-cyan-400 animate-pulse"></span>

          <span class="text-[10px] font-semibold uppercase tracking-[0.14em] text-cyan-300">
            Live
          </span>
        </div>
      <% end %>

      <%= link_to trade_simulations_path, class: nav_item do %>
        <span class="<%= nav_icon %>">
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M5 3.5A1.5 1.5 0 0 0 3.5 5v10A1.5 1.5 0 0 0 5 16.5h10a1.5 1.5 0 0 0 1.5-1.5V5A1.5 1.5 0 0 0 15 3.5H5Zm1.75 3h6.5a.75.75 0 0 1 0 1.5h-6.5a.75.75 0 0 1 0-1.5Zm0 3h3.5a.75.75 0 0 1 0 1.5h-3.5a.75.75 0 0 1 0-1.5Zm0 3h5.5a.75.75 0 0 1 0 1.5h-5.5a.75.75 0 0 1 0-1.5Z" />
          </svg>
        </span>

        <div class="min-w-0">
          <div class="truncate">Trade Simulator</div>
          <div class="truncate text-[11px] font-normal text-slate-500">
            DCA · Strategy · Risk
          </div>
        </div>
      <% end %>
    </div>

    <div class="<%= divider %>"></div>

    <div class="<%= nav_section %>">Intelligence</div>

    <div class="space-y-1">
      <%= link_to clusters_events_path, class: nav_item do %>
        <span class="<%= nav_icon %>">
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M10 2.5a7.5 7.5 0 0 0-7.5 7.5.75.75 0 0 0 1.5 0 6 6 0 1 1 6 6 .75.75 0 0 0 0 1.5 7.5 7.5 0 0 0 0-15Z" />
            <path d="M10 6a4 4 0 0 0-4 4 .75.75 0 0 0 1.5 0A2.5 2.5 0 1 1 10 12.5a.75.75 0 0 0 0 1.5 4 4 0 0 0 0-8Z" />
            <path d="M10 9a1 1 0 1 0 0 2 1 1 0 0 0 0-2Z" />
          </svg>
        </span>

        <div class="min-w-0 flex-1">
          <div class="truncate">Network Signals</div>
          <div class="truncate text-[11px] font-normal text-slate-500">
            Realtime anomalies · ClickHouse
          </div>
        </div>
      <% end %>

      <%= link_to actors_exchange_core_flows_path, class: nav_item do %>
        <span class="<%= nav_icon %>">
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M13.25 3.25a.75.75 0 0 0-1.06 1.06l1.44 1.44H5a.75.75 0 0 0 0 1.5h8.63l-1.44 1.44a.75.75 0 1 0 1.06 1.06l2.72-2.72a.75.75 0 0 0 0-1.06l-2.72-2.72ZM6.75 10.25a.75.75 0 0 0-1.06 0l-2.72 2.72a.75.75 0 0 0 0 1.06l2.72 2.72a.75.75 0 1 0 1.06-1.06l-1.44-1.44H15a.75.75 0 0 0 0-1.5H5.31l1.44-1.44a.75.75 0 0 0 0-1.06Z" />
          </svg>
        </span>

        <div class="min-w-0 flex-1">
          <div class="truncate">Exchange Flows</div>
          <div class="truncate text-[11px] font-normal text-slate-500">
            Netflow · Selling pressure
          </div>
        </div>

        <!-- Live badge -->
        <div class="hidden md:flex items-center gap-1 rounded-md border border-cyan-500/20 bg-cyan-500/10 px-1.5 py-0.5">
          <span class="h-1.5 w-1.5 rounded-full bg-cyan-400 animate-pulse"></span>

          <span class="text-[10px] font-semibold uppercase tracking-[0.14em] text-cyan-300">
            Live
          </span>
        </div>
      <% end %>

      <%= link_to actors_whale_core_flows_path, class: nav_item do %>
        <span class="<%= nav_icon %>">
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2.5 11.75c1.2 1.1 2.42 1.65 3.67 1.65 1.05 0 1.8-.25 2.57-.5.8-.26 1.63-.54 2.8-.54 1.52 0 2.86.48 4.05 1.44.38.31.96.04.96-.45V8.2c0-.43-.45-.72-.84-.53-.79.38-1.57.57-2.35.57-1.06 0-1.84-.25-2.66-.52-.86-.28-1.76-.57-3.05-.57-1.75 0-3.37.64-4.86 1.92a.85.85 0 0 0-.29.64v2.04Z" />
            <path d="M14.5 5.25a.75.75 0 0 0 0 1.5h.75V7.5a.75.75 0 0 0 1.5 0V6.75h.75a.75.75 0 0 0 0-1.5h-.75V4.5a.75.75 0 0 0-1.5 0v.75h-.75Z" />
          </svg>
        </span>

        <div class="min-w-0 flex-1">
          <div class="truncate">Whale Intelligence</div>
          <div class="truncate text-[11px] font-normal text-slate-500">
            Accumulation · Distribution
          </div>
        </div>

        <div class="hidden md:flex items-center gap-1 rounded-md border border-purple-500/20 bg-purple-500/10 px-1.5 py-0.5">
          <span class="h-1.5 w-1.5 rounded-full bg-purple-400 animate-pulse"></span>

          <span class="text-[10px] font-semibold uppercase tracking-[0.14em] text-purple-300">
            New
          </span>
        </div>
      <% end %>
    </div>

    <div class="<%= divider %>"></div>

    <div class="<%= nav_section %>">Security</div>

    <div class="space-y-1">
      <%= link_to opsec_path, class: nav_item do %>
        <span class="<%= nav_icon %>">
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M10 2.5 4 5v4.5c0 3.5 2.4 6.78 6 8 3.6-1.22 6-4.5 6-8V5l-6-2.5Zm2.78 5.72a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0L7.22 11.28a.75.75 0 1 1 1.06-1.06L9 10.94l2.72-2.72a.75.75 0 0 1 1.06 0Z" />
          </svg>
        </span>

        <div class="min-w-0">
          <div class="truncate">OP Sec</div>
          <div class="truncate text-[11px] font-normal text-slate-500">
            Operational security
          </div>
        </div>
      <% end %>

      <%= link_to vaults_path, class: nav_item do %>
        <span class="<%= nav_icon %>">
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M5 6.5V5a5 5 0 0 1 10 0v1.5h.25A1.75 1.75 0 0 1 17 8.25v7A1.75 1.75 0 0 1 15.25 17H4.75A1.75 1.75 0 0 1 3 15.25v-7A1.75 1.75 0 0 1 4.75 6.5H5Zm1.5 0h7V5a3.5 3.5 0 1 0-7 0v1.5Z" />
          </svg>
        </span>

        <div class="min-w-0">
          <div class="truncate">Vaults</div>
          <div class="truncate text-[11px] font-normal text-slate-500">
            Wallet protection
          </div>
        </div>
      <% end %>
    </div>

    <div class="<%= divider %>"></div>

    <div class="<%= nav_section %>">Documentation</div>

    <div class="space-y-1">
      <%= link_to guides_path, class: nav_item do %>
        <span class="<%= nav_icon %>">
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M5.5 3A2.5 2.5 0 0 0 3 5.5v10A1.5 1.5 0 0 0 4.5 17H15a2 2 0 0 0 2-2V4.5A1.5 1.5 0 0 0 15.5 3h-10ZM5 5.5A.5.5 0 0 1 5.5 5H15v10H4.5a.5.5 0 0 1 0-1H13a.75.75 0 0 0 0-1.5H5V5.5Z" />
          </svg>
        </span>

        <div class="min-w-0">
          <div class="truncate">Guides</div>
          <div class="truncate text-[11px] font-normal text-slate-500">
            Methodology · Book
          </div>
        </div>
      <% end %>

      <%= link_to feature_requests_path, class: nav_item do %>
        <span class="<%= nav_icon %>">
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M10 2.5a6.5 6.5 0 0 0-3.9 11.7v1.05A1.75 1.75 0 0 0 7.85 17h4.3a1.75 1.75 0 0 0 1.75-1.75V14.2A6.5 6.5 0 0 0 10 2.5Zm-1.5 12h3v.75a.25.25 0 0 1-.25.25h-2.5a.25.25 0 0 1-.25-.25v-.75Z" />
          </svg>
        </span>

        <div class="min-w-0">
          <div class="truncate">Feature Requests</div>
          <div class="truncate text-[11px] font-normal text-slate-500">
            Roadmap · Ideas
          </div>
        </div>
      <% end %>
    </div>

    <div class="<%= divider %>"></div>

    <div class="<%= nav_section %>">Operations</div>

    <div class="space-y-1">
      <%= link_to system_path, class: nav_item do %>
        <span class="<%= nav_icon %>">
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M3 13.5A1.5 1.5 0 0 1 4.5 12H6v5H4.5A1.5 1.5 0 0 1 3 15.5v-2ZM8 7h4v10H8V7ZM14 3h1.5A1.5 1.5 0 0 1 17 4.5v11a1.5 1.5 0 0 1-1.5 1.5H14V3Z" />
          </svg>
        </span>

        <div class="min-w-0">
          <div class="truncate">System</div>
          <div class="truncate text-[11px] font-normal text-slate-500">
            Health · Pipelines
          </div>
        </div>
      <% end %>

      <%= link_to system_recovery_path, class: nav_item do %>
        <span class="<%= nav_icon %>">
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M10 3a7 7 0 1 1-5.66 11.12.75.75 0 0 1 1.22-.88A5.5 5.5 0 1 0 4.5 10H6a.75.75 0 0 1 0 1.5H3.25A.75.75 0 0 1 2.5 10.75V8a.75.75 0 0 1 1.5 0v1.1A7 7 0 0 1 10 3Z" />
          </svg>
        </span>

        <div class="min-w-0">
          <div class="truncate">Recovery</div>
          <div class="truncate text-[11px] font-normal text-slate-500">
            Lag · Requeue · Backfill
          </div>
        </div>
      <% end %>

      <%= link_to system_sidekiq_path, class: nav_item do %>
        <span class="<%= nav_icon %>">
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M4 5.5A1.5 1.5 0 0 1 5.5 4h9A1.5 1.5 0 0 1 16 5.5v1A1.5 1.5 0 0 1 14.5 8h-9A1.5 1.5 0 0 1 4 6.5v-1ZM4 13.5A1.5 1.5 0 0 1 5.5 12h9a1.5 1.5 0 0 1 1.5 1.5v1a1.5 1.5 0 0 1-1.5 1.5h-9A1.5 1.5 0 0 1 4 14.5v-1ZM6 6h.01V6H6Zm0 8h.01v.01H6V14Z" />
          </svg>
        </span>

        <div class="min-w-0">
          <div class="truncate">Sidekiq</div>
          <div class="truncate text-[11px] font-normal text-slate-500">
            Jobs · Queues · Workers
          </div>
        </div>
      <% end %>
    </div>
  </nav>
</div>