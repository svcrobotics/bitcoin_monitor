<%# app/views/trade_simulations/new.html.erb %>
<% content_for :title, "Ouvrir une position" %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-6">
    <div class="min-w-0">
      <h1 class="text-2xl sm:text-3xl font-semibold text-gray-100">Ouvrir une position</h1>
      <p class="text-sm text-gray-400 mt-1">
        Tu saisis l’achat maintenant. La vente se fera plus tard via <span class="font-mono text-gray-200">Clôturer</span>.
      </p>
    </div>

    <div class="flex flex-wrap gap-2">
      <%= link_to "← Retour", trade_simulations_path,
        class: "inline-flex items-center justify-center rounded-xl px-4 py-2
                bg-gray-900/60 border border-gray-700/60 text-gray-200
                hover:bg-gray-800 hover:border-gray-600 hover:text-gray-100 transition
                text-sm font-semibold" %>
    </div>
  </div>

  <%= render "form", trade_simulation: @trade_simulation %>
</div>
