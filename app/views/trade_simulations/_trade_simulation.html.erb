<%# app/views/trade_simulations/_trade_simulation.html.erb %>

<div id="<%= dom_id trade_simulation %>"
     class="rounded-2xl border border-gray-800 bg-gray-900/50 p-5 space-y-4">

  <%# ---- Header ---- %>
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <p class="text-sm text-gray-400">Simulation</p>
      <p class="text-gray-100 font-semibold">
        <span class="font-mono"><%= trade_simulation.buy_day %></span>
        →
        <% if trade_simulation.respond_to?(:closed?) && trade_simulation.closed? %>
          <span class="font-mono"><%= trade_simulation.sell_day %></span>
        <% else %>
          <span class="text-amber-200 font-semibold">OUVERTE</span>
        <% end %>
      </p>
    </div>

    <% if trade_simulation.respond_to?(:open?) && trade_simulation.open? %>
      <span class="shrink-0 text-xs px-2 py-1 rounded-full
                   border border-amber-500/40 bg-amber-600/10 text-amber-200 font-semibold">
        Ouverte
      </span>
    <% else %>
      <span class="shrink-0 text-xs px-2 py-1 rounded-full
                   border border-emerald-500/40 bg-emerald-600/10 text-emerald-200 font-semibold">
        Clôturée
      </span>
    <% end %>
  </div>

  <%# ---- Metrics grid ---- %>
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 text-sm">

    <div class="rounded-xl border border-gray-800 bg-black/20 p-3">
      <p class="text-xs text-gray-500">Investi</p>
      <p class="font-mono text-gray-100">
        <% if trade_simulation.respond_to?(:buy_amount_eur) && trade_simulation.buy_amount_eur.present? %>
          <%= number_to_currency(trade_simulation.buy_amount_eur, unit: "€") %>
        <% else %>
          <span class="text-gray-500">—</span>
        <% end %>
      </p>
      <%# fallback legacy BTC si jamais une ancienne simu n'a pas buy_amount_eur %>
      <% if trade_simulation.buy_amount_eur.blank? && trade_simulation.btc_amount.present? %>
        <p class="text-[11px] text-gray-500 mt-1">
          (legacy: <span class="font-mono"><%= trade_simulation.btc_amount %> BTC</span>)
        </p>
      <% end %>
    </div>

    <div class="rounded-xl border border-gray-800 bg-black/20 p-3">
      <p class="text-xs text-gray-500">Slippage</p>
      <p class="font-mono text-gray-100"><%= trade_simulation.slippage_pct %>%</p>
    </div>

    <div class="rounded-xl border border-gray-800 bg-black/20 p-3">
      <p class="text-xs text-gray-500">Frais achat</p>
      <p class="font-mono text-gray-100">
        <%= trade_simulation.buy_fee_pct %>%
        <span class="text-gray-400">+</span>
        <%= number_to_currency(trade_simulation.buy_fee_fixed_eur, unit: "€") %>
      </p>
    </div>

    <div class="rounded-xl border border-gray-800 bg-black/20 p-3">
      <p class="text-xs text-gray-500">Frais vente</p>
      <p class="font-mono text-gray-100">
        <%= trade_simulation.sell_fee_pct %>%
        <span class="text-gray-400">+</span>
        <%= number_to_currency(trade_simulation.sell_fee_fixed_eur, unit: "€") %>
      </p>
    </div>

  </div>

  <%# ---- Notes ---- %>
  <% if trade_simulation.notes.present? %>
    <div class="rounded-xl border border-gray-800 bg-black/20 p-3">
      <p class="text-xs text-gray-500 mb-1">Notes</p>
      <p class="text-sm text-gray-100 whitespace-pre-wrap">
        <%= trade_simulation.notes %>
      </p>
    </div>
  <% end %>

</div>
