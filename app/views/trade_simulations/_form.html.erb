<%= form_with(model: trade_simulation, class: "space-y-6") do |f| %>
  <% if trade_simulation.errors.any? %>
    <div class="rounded-2xl border border-rose-500/30 bg-rose-500/10 p-4 text-rose-200">
      <p class="font-semibold mb-2">Erreurs</p>
      <ul class="list-disc list-inside text-sm text-rose-200/90">
        <% trade_simulation.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if trade_simulation.persisted? && trade_simulation.respond_to?(:closed?) && trade_simulation.closed? %>
    <div class="rounded-2xl border border-amber-500/30 bg-amber-500/10 p-4 text-amber-200 text-sm">
      Cette simulation est clôturée. Pour garder un historique fiable, la modification est désactivée.
    </div>
  <% end %>

  <div class="rounded-2xl border border-gray-800 bg-gray-900/50 p-5">
    <h2 class="text-lg font-semibold text-gray-100">Achat (position)</h2>
    <p class="text-sm text-gray-400 mt-1">Montant investi (€) + date d’achat + slippage.</p>

    <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= f.label :buy_day, "Date d’achat", class: "block text-sm text-gray-300 mb-1" %>
        <%= f.date_field :buy_day,
          class: "w-full rounded-xl bg-black/30 border border-gray-700 text-gray-100 px-3 py-2",
          disabled: (trade_simulation.respond_to?(:closed?) && trade_simulation.closed?) %>
      </div>

      <div>
        <%= f.label :buy_amount_eur, "Montant investi (EUR)", class: "block text-sm text-gray-300 mb-1" %>
        <%= f.number_field :buy_amount_eur, step: "0.01",
          placeholder: "ex: 100",
          class: "w-full rounded-xl bg-black/30 border border-gray-700 text-gray-100 px-3 py-2 font-mono",
          disabled: (trade_simulation.respond_to?(:closed?) && trade_simulation.closed?) %>

        <p class="text-xs text-gray-500 mt-1">
          BTC achetés = montant / prix du jour (<span class="font-mono">close_eur</span>).
        </p>
      </div>

      <div class="sm:col-span-2">
        <%= f.label :slippage_pct, "Slippage % (option)", class: "block text-sm text-gray-300 mb-1" %>
        <%= f.number_field :slippage_pct, step: "0.001",
          class: "w-full rounded-xl bg-black/30 border border-gray-700 text-gray-100 px-3 py-2 font-mono",
          disabled: (trade_simulation.respond_to?(:closed?) && trade_simulation.closed?) %>
      </div>
    </div>

    <p class="text-xs text-gray-500 mt-3">
      La date de vente se choisit plus tard via <span class="font-mono">Clôturer</span>.
    </p>
  </div>

  <div class="rounded-2xl border border-gray-800 bg-gray-900/50 p-5">
    <h2 class="text-lg font-semibold text-gray-100">Frais d’achat</h2>

    <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= f.label :buy_fee_pct, "Frais achat %", class: "block text-sm text-gray-300 mb-1" %>
        <%= f.number_field :buy_fee_pct, step: "0.001",
          class: "w-full rounded-xl bg-black/30 border border-gray-700 text-gray-100 px-3 py-2 font-mono",
          disabled: (trade_simulation.respond_to?(:closed?) && trade_simulation.closed?) %>
      </div>

      <div>
        <%= f.label :buy_fee_fixed_eur, "Frais achat fixe (EUR)", class: "block text-sm text-gray-300 mb-1" %>
        <%= f.number_field :buy_fee_fixed_eur, step: "0.01",
          class: "w-full rounded-xl bg-black/30 border border-gray-700 text-gray-100 px-3 py-2 font-mono",
          disabled: (trade_simulation.respond_to?(:closed?) && trade_simulation.closed?) %>
      </div>
    </div>

    <p class="text-xs text-gray-500 mt-3">
      Prix BTC utilisés : <span class="font-mono">btc_price_days.close_eur</span> (EUR).
    </p>
  </div>

  <div class="rounded-2xl border border-gray-800 bg-gray-900/50 p-5">
    <h2 class="text-lg font-semibold text-gray-100">Notes</h2>
    <p class="text-sm text-gray-400 mt-1">Contexte, raison du trade, plan…</p>

    <div class="mt-4">
      <%= f.text_area :notes, rows: 4,
        class: "w-full rounded-xl bg-black/30 border border-gray-700 text-gray-100 px-3 py-2",
        disabled: (trade_simulation.respond_to?(:closed?) && trade_simulation.closed?) %>
    </div>
  </div>

  <div class="flex flex-col sm:flex-row gap-2">
    <% if trade_simulation.respond_to?(:closed?) && trade_simulation.closed? %>
      <%= link_to "Retour", trade_simulation_path(trade_simulation),
        class: "rounded-xl px-4 py-2 bg-gray-900/60 border border-gray-700/60 text-gray-200 hover:bg-gray-800 hover:border-gray-600 transition font-semibold text-center" %>
    <% else %>
      <%= f.submit class: "rounded-xl px-4 py-2 bg-cyan-600/15 border border-cyan-500/50 text-cyan-200 hover:bg-cyan-600/25 hover:border-cyan-400 transition font-semibold" %>

      <%= link_to "Annuler", trade_simulations_path,
        class: "rounded-xl px-4 py-2 bg-gray-900/60 border border-gray-700/60 text-gray-200 hover:bg-gray-800 hover:border-gray-600 transition font-semibold text-center" %>
    <% end %>
  </div>
<% end %>
