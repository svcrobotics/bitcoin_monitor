<%# app/views/cluster_signals/top.html.erb %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <%
    signal_title = lambda do |signal_type|
      case signal_type.to_s
      when "volume_spike"
        "Volume élevé récent"
      when "sudden_activity"
        "Activité récente élevée"
      when "large_transfers"
        "Transferts massifs détectés"
      when "cluster_activation"
        "Activation récente du cluster"
      else
        signal_type.to_s.humanize
      end
    end

    severity_badge = lambda do |severity|
      case severity.to_s
      when "high"
        "text-amber-300 bg-amber-500/10 border-amber-500/20"
      when "medium"
        "text-violet-300 bg-violet-500/10 border-violet-500/20"
      else
        "text-gray-300 bg-gray-500/10 border-gray-500/20"
      end
    end

    classification_label = lambda do |value|
      case value.to_s
      when "exchange_like", "service"
        "Plateforme"
      when "whale"
        "Gros détenteur"
      when "retail"
        "Utilisateur"
      else
        "Inconnu"
      end
    end
  %>

  <div class="mb-8">
    <div class="mb-2 flex flex-wrap items-center gap-3">
      <%= link_to "← Retour au dashboard", root_path, class: "text-sm text-violet-400 hover:text-violet-300" %>
      <%= link_to "Voir tous les signaux", cluster_signals_path, class: "text-sm text-gray-400 hover:text-gray-200" %>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-100">
      Top clusters du jour
    </h1>

    <p class="mt-2 text-sm text-gray-400">
      Classement des clusters les plus marquants sur la dernière snapshot, selon les signaux détectés.
    </p>

    <% if @date.present? %>
      <div class="mt-3 text-xs text-gray-500">
        Snapshot analysée :
        <span class="font-semibold text-gray-300"><%= @date %></span>
      </div>
    <% end %>
  </div>

  <% if @top_clusters.blank? %>
    <div class="rounded-2xl border border-gray-800 bg-gray-900/60 p-6 text-gray-300">
      <div class="font-semibold text-gray-100">Aucun cluster à classer</div>
      <div class="mt-2 text-sm text-gray-500">
        Aucun signal cluster disponible pour la dernière snapshot.
      </div>
    </div>
  <% else %>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
      <div class="rounded-2xl border border-gray-800 bg-gray-900/60 p-5">
        <div class="text-xs uppercase tracking-wide text-gray-500">Clusters</div>
        <div class="mt-2 text-2xl font-bold text-gray-100">
          <%= number_with_delimiter(@top_clusters.size) %>
        </div>
      </div>

      <div class="rounded-2xl border border-gray-800 bg-gray-900/60 p-5">
        <div class="text-xs uppercase tracking-wide text-gray-500">High severity</div>
        <div class="mt-2 text-2xl font-bold text-amber-300">
          <%= number_with_delimiter(@top_clusters.sum { |row| row[:high_count].to_i }) %>
        </div>
      </div>

      <div class="rounded-2xl border border-gray-800 bg-gray-900/60 p-5">
        <div class="text-xs uppercase tracking-wide text-gray-500">Signals agrégés</div>
        <div class="mt-2 text-2xl font-bold text-gray-100">
          <%= number_with_delimiter(@top_clusters.sum { |row| row[:signal_count].to_i }) %>
        </div>
      </div>

      <div class="rounded-2xl border border-gray-800 bg-gray-900/60 p-5">
        <div class="text-xs uppercase tracking-wide text-gray-500">Top score agrégé</div>
        <div class="mt-2 text-2xl font-bold text-gray-100">
          <%= @top_clusters.first[:total_score] %>
        </div>
      </div>
    </div>

    <div class="space-y-4">
      <% @top_clusters.each_with_index do |row, idx| %>
        <% cluster = row[:cluster] %>
        <% profile = row[:cluster_profile] %>
        <% best_address = row[:best_address] %>

        <div class="rounded-2xl border border-gray-800 bg-gray-900/60 p-5">
          <div class="flex flex-col xl:flex-row xl:items-start xl:justify-between gap-5">
            <div class="min-w-0 flex-1">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex items-center px-2.5 py-1 rounded-full border text-xs font-semibold text-gray-200 bg-black/20 border-gray-700">
                  #<%= idx + 1 %>
                </span>

                <div class="text-lg font-bold text-gray-100">
                  Cluster #<%= cluster.id %>
                </div>

                <% if profile.present? %>
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full border text-xs font-semibold text-gray-300 bg-gray-500/10 border-gray-500/20">
                    <%= classification_label.call(profile.classification) %>
                  </span>
                <% end %>
              </div>

              <div class="text-sm text-gray-300">
                <span class="font-semibold text-gray-100"><%= number_with_delimiter(cluster.address_count) %></span>
                adresses
                <% if profile.present? && profile.score.present? %>
                  <span class="text-gray-500">• score profil <%= profile.score %>/100</span>
                <% end %>
                <% if profile.present? && profile.total_sent_sats.present? %>
                  <span class="text-gray-500">
                    • total envoyé <%= number_with_delimiter(sats_to_btc(profile.total_sent_sats)) %> BTC
                  </span>
                <% end %>
              </div>

              <% if best_address.present? %>
                <div class="mt-3">
                  <%= link_to address_lookup_path(address: best_address.address),
                    class: "inline-flex items-center gap-2 text-sm text-violet-400 hover:text-violet-300 break-all" do %>
                    <span class="font-mono"><%= best_address.address %></span>
                    <span>›</span>
                  <% end %>
                </div>
              <% end %>

              <div class="mt-4 flex flex-wrap gap-2">
                <% row[:signal_types].each do |signal_type| %>
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full border text-xs font-semibold text-gray-300 bg-gray-500/10 border-gray-500/20">
                    <%= signal_title.call(signal_type) %>
                  </span>
                <% end %>
              </div>
            </div>

            <div class="w-full xl:w-[24rem]">
              <div class="grid grid-cols-2 gap-3">
                <div class="rounded-xl border border-gray-800 bg-black/20 p-4">
                  <div class="text-xs uppercase tracking-wide text-gray-500">Score agrégé</div>
                  <div class="mt-2 text-2xl font-bold text-gray-100"><%= row[:total_score] %></div>
                </div>

                <div class="rounded-xl border border-gray-800 bg-black/20 p-4">
                  <div class="text-xs uppercase tracking-wide text-gray-500">Meilleur signal</div>
                  <div class="mt-2 text-2xl font-bold text-gray-100"><%= row[:max_score] %></div>
                </div>

                <div class="rounded-xl border border-gray-800 bg-black/20 p-4">
                  <div class="text-xs uppercase tracking-wide text-gray-500">High</div>
                  <div class="mt-2 text-2xl font-bold text-amber-300"><%= row[:high_count] %></div>
                </div>

                <div class="rounded-xl border border-gray-800 bg-black/20 p-4">
                  <div class="text-xs uppercase tracking-wide text-gray-500">Signals</div>
                  <div class="mt-2 text-2xl font-bold text-gray-100"><%= row[:signal_count] %></div>
                </div>
              </div>
            </div>
          </div>

          <div class="mt-5 space-y-2">
            <% row[:signals].first(3).each do |signal| %>
              <div class="rounded-xl border border-gray-800 bg-black/20 px-4 py-3">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
                  <div class="font-semibold text-gray-100">
                    <%= signal_title.call(signal.signal_type) %>
                  </div>

                  <span class="inline-flex items-center px-2.5 py-1 rounded-full border text-xs font-semibold <%= severity_badge.call(signal.severity) %>">
                    <%= signal.severity %> • score <%= signal.score %>
                  </span>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>