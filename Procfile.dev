web: TANSA_PIPELINE_MODE=development_backfill TANSA_BACKFILL_ALTERNATING_ENABLED=true TANSA_BACKFILL_LAYER1_START_LAG=10 TANSA_BACKFILL_LAYER1_STOP_LAG=2 bin/rails server -p 3000
css: bin/rails tailwindcss:build && sleep infinity

# Après toute modification de queue ou de variable d'environnement,
# arrêter proprement les anciennes générations Sidekiq avant de relancer.
# Un ancien processus conserve ses variables d'environnement jusqu'à son arrêt.
# Séquence opérationnelle: TSTP pour finir le travail courant, puis TERM.

scheduler: ACTOR_PROFILE_STRICT_BATCH_LIMIT=5 TANSA_PIPELINE_MODE=development_backfill TANSA_BACKFILL_ALTERNATING_ENABLED=true TANSA_BACKFILL_LAYER1_START_LAG=10 TANSA_BACKFILL_LAYER1_STOP_LAG=2 TANSA_BACKFILL_MAX_LAYER1_LAG=20 TANSA_BACKFILL_MAX_CLUSTER_GLOBAL_LAG=30 LAYER1_STRICT_ONLY=1 LAYER1_STRICT_SCHEDULER=1 STRICT_IO_LEASE_TTL_SECONDS=900 ADDRESS_SPEND_PROJECTION_JOB_LIMIT=25 ADDRESS_SPEND_PROJECTION_JOB_MAX_RUNTIME_SECONDS=15 ACTOR_BEHAVIOR_AUTO_ENABLED=true ACTOR_BEHAVIOR_MIN_INTERVAL_SECONDS=10 ACTOR_BEHAVIOR_HEAVY_AUTO_ENABLED=true ACTOR_BEHAVIOR_HEAVY_LABELS_ENABLED=true ACTOR_BEHAVIOR_HEAVY_AUTO_INTERVAL_SECONDS=1800 TX_OUTPUT_PROJECTION_ASYNC=0 TX_OUTPUTS_SPENT_ASYNC=1 nice -n 5 bundle exec sidekiq -c 1 -q scheduler
scheduler_fallback: ACTOR_PROFILE_STRICT_BATCH_LIMIT=5 TANSA_PIPELINE_MODE=development_backfill TANSA_BACKFILL_ALTERNATING_ENABLED=true TANSA_BACKFILL_LAYER1_START_LAG=10 TANSA_BACKFILL_LAYER1_STOP_LAG=2 TANSA_BACKFILL_MAX_LAYER1_LAG=20 TANSA_BACKFILL_MAX_CLUSTER_GLOBAL_LAG=30 LAYER1_STRICT_ONLY=1 LAYER1_STRICT_SCHEDULER=1 STRICT_IO_LEASE_TTL_SECONDS=900 ADDRESS_SPEND_PROJECTION_JOB_LIMIT=25 ADDRESS_SPEND_PROJECTION_JOB_MAX_RUNTIME_SECONDS=15 ACTOR_BEHAVIOR_AUTO_ENABLED=true ACTOR_BEHAVIOR_MIN_INTERVAL_SECONDS=10 ACTOR_BEHAVIOR_HEAVY_AUTO_ENABLED=true ACTOR_BEHAVIOR_HEAVY_LABELS_ENABLED=true ACTOR_BEHAVIOR_HEAVY_AUTO_INTERVAL_SECONDS=1800 TX_OUTPUT_PROJECTION_ASYNC=0 TX_OUTPUTS_SPENT_ASYNC=1 nice -n 5 bundle exec sidekiq -c 1 -q scheduler

sidekiq_layer1_strict: TANSA_PIPELINE_MODE=development_backfill TANSA_BACKFILL_ALTERNATING_ENABLED=true TANSA_BACKFILL_LAYER1_START_LAG=10 TANSA_BACKFILL_LAYER1_STOP_LAG=2 TANSA_BACKFILL_MAX_LAYER1_LAG=20 TANSA_BACKFILL_MAX_CLUSTER_GLOBAL_LAG=30 LAYER1_STRICT_ONLY=1 STRICT_IO_LEASE_TTL_SECONDS=900 SPENT_OUTPUT_FLUSHER_V2=1 TX_OUTPUTS_SPENT_ASYNC=1 SPENT_OUTPUT_FLUSH_BATCH_SIZE=20000 TX_OUTPUTS_SPENT_ASYNC_BATCH_SIZE=500 LAYER1_STRICT_TIP_SYNC_INTERVAL_SECONDS=10 LAYER1_STRICT_TIP_SYNC_MAX_BLOCKS=1 bundle exec sidekiq -c 2 -q layer1_strict

sidekiq_cluster_strict: TANSA_PIPELINE_MODE=development_backfill TANSA_BACKFILL_ALTERNATING_ENABLED=true TANSA_BACKFILL_LAYER1_START_LAG=10 TANSA_BACKFILL_LAYER1_STOP_LAG=2 TANSA_BACKFILL_MAX_LAYER1_LAG=20 TANSA_BACKFILL_MAX_CLUSTER_GLOBAL_LAG=30 LAYER1_STRICT_ONLY=1 STRICT_IO_LEASE_TTL_SECONDS=900 CLUSTER_TIMING_LOGS=false CLUSTER_STRICT_SYNC_LIMIT=2 bundle exec sidekiq -c 1 -q cluster_strict

sidekiq_address_spend_projection: TANSA_PIPELINE_MODE=development_backfill TANSA_BACKFILL_ALTERNATING_ENABLED=true TANSA_BACKFILL_LAYER1_START_LAG=10 TANSA_BACKFILL_LAYER1_STOP_LAG=2 TANSA_BACKFILL_MAX_LAYER1_LAG=20 TANSA_BACKFILL_MAX_CLUSTER_GLOBAL_LAG=30 LAYER1_STRICT_ONLY=1 nice -n 10 bundle exec sidekiq -c 1 -q address_spend_projection

sidekiq_actor_profile_strict: TANSA_PIPELINE_MODE=development_backfill TANSA_BACKFILL_ALTERNATING_ENABLED=true TANSA_BACKFILL_LAYER1_START_LAG=10 TANSA_BACKFILL_LAYER1_STOP_LAG=2 TANSA_BACKFILL_MAX_LAYER1_LAG=20 TANSA_BACKFILL_MAX_CLUSTER_GLOBAL_LAG=30 LAYER1_STRICT_ONLY=1 ACTOR_PROFILE_STRICT_BATCH_LIMIT=5 ACTOR_PROFILE_STRICT_PROFILE_TIMEOUT_SECONDS=120 ACTOR_PROFILE_STRICT_BATCH_MAX_RUNTIME_SECONDS=90 ACTOR_PROFILE_STRICT_SLOW_THRESHOLD_SECONDS=30 ACTOR_PROFILE_SLOW_RETRY_DELAYS_SECONDS=1800,3600,21600,86400 ACTOR_PROFILE_STRICT_WAIT_SECONDS=10 bundle exec sidekiq -c 1 -q actor_profile_strict

sidekiq_actor_behavior_strict: TANSA_PIPELINE_MODE=development_backfill TANSA_BACKFILL_ALTERNATING_ENABLED=true TANSA_BACKFILL_LAYER1_START_LAG=10 TANSA_BACKFILL_LAYER1_STOP_LAG=2 TANSA_BACKFILL_MAX_LAYER1_LAG=20 TANSA_BACKFILL_MAX_CLUSTER_GLOBAL_LAG=30 LAYER1_STRICT_ONLY=1 bundle exec sidekiq -c 1 -q actor_behavior_strict


sidekiq_actor_behavior_heavy: TANSA_PIPELINE_MODE=development_backfill TANSA_BACKFILL_ALTERNATING_ENABLED=true TANSA_BACKFILL_LAYER1_START_LAG=10 TANSA_BACKFILL_LAYER1_STOP_LAG=2 ACTOR_BEHAVIOR_HEAVY_LABELS_ENABLED=true nice -n 19 bundle exec sidekiq -c 1 -q actor_behavior_heavy

sidekiq_actor_labels_strict: TANSA_PIPELINE_MODE=development_backfill TANSA_BACKFILL_ALTERNATING_ENABLED=true TANSA_BACKFILL_LAYER1_START_LAG=10 TANSA_BACKFILL_LAYER1_STOP_LAG=2 TANSA_BACKFILL_MAX_LAYER1_LAG=20 TANSA_BACKFILL_MAX_CLUSTER_GLOBAL_LAG=30 LAYER1_STRICT_ONLY=1 ACTOR_LABEL_WRITE_ENABLED=true bundle exec sidekiq -c 1 -q actor_labels_strict

sidekiq_layer1_audit: TANSA_PIPELINE_MODE=development_backfill TANSA_BACKFILL_ALTERNATING_ENABLED=true TANSA_BACKFILL_LAYER1_START_LAG=10 TANSA_BACKFILL_LAYER1_STOP_LAG=2 LAYER1_STRICT_ONLY=1 nice -n 19 bundle exec sidekiq -c 1 -q layer1_audit

sidekiq_tx_outputs_async: TANSA_PIPELINE_MODE=development_backfill TANSA_BACKFILL_ALTERNATING_ENABLED=true TANSA_BACKFILL_LAYER1_START_LAG=10 TANSA_BACKFILL_LAYER1_STOP_LAG=2 LAYER1_STRICT_ONLY=1 TX_OUTPUTS_SPENT_ASYNC=1 TX_OUTPUTS_SPENT_ASYNC_BATCH_SIZE=500 nice -n 18 bundle exec sidekiq -c 1 -q tx_outputs_async
sidekiq_tx_output_projection: TANSA_PIPELINE_MODE=development_backfill TANSA_BACKFILL_ALTERNATING_ENABLED=true TANSA_BACKFILL_LAYER1_START_LAG=10 TANSA_BACKFILL_LAYER1_STOP_LAG=2 LAYER1_STRICT_ONLY=1 TX_OUTPUT_PROJECTION_ASYNC=0 nice -n 18 bundle exec sidekiq -c 1 -q tx_output_projection


sidekiq_cluster_coverage: TANSA_PIPELINE_MODE=development_backfill TANSA_BACKFILL_ALTERNATING_ENABLED=true TANSA_BACKFILL_LAYER1_START_LAG=10 TANSA_BACKFILL_LAYER1_STOP_LAG=2 LAYER1_STRICT_ONLY=1 CLUSTER_COVERAGE_WORKER=1 CLUSTER_COVERAGE_MAINTENANCE_ENABLED=true CLUSTER_COVERAGE_MAINTENANCE_WAIT_SECONDS=120 nice -n 18 bundle exec sidekiq -c 1 -q cluster_coverage
